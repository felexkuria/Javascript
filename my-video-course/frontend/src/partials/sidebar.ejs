<div class="sidebar">
    <!-- Progress Card -->
    <div class="sidebar-card">
        <div class="sidebar-title">📊 Progress</div>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 16px;">
            <div class="sidebar-stat">
                <div class="sidebar-stat-value user-level">1</div>
                <div class="sidebar-stat-label">Level</div>
            </div>
            <div class="sidebar-stat">
                <div class="sidebar-stat-value user-points">0</div>
                <div class="sidebar-stat-label">Pts</div>
            </div>
            <div class="sidebar-stat">
                <div class="sidebar-stat-value user-streak">0</div>
                <div class="sidebar-stat-label">Streak</div>
            </div>
        </div>
        <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
            <span style="font-size: 12px; color: var(--color-text-muted);"><%= watchedVideos || 0 %>/<%= totalVideos || 0 %> videos</span>
            <span style="font-size: 12px; color: var(--mdb-green); font-weight: 600;"><%= watchedPercent || 0 %>%</span>
        </div>
        <div class="progress-bar">
            <div class="progress-fill progress-fill-animated" style="width: 0%;" data-width="<%= watchedPercent || 0 %>"></div>
        </div>
    </div>

    <!-- AI Analysis Card -->
    <div class="sidebar-card">
        <div class="sidebar-title">🧠 AI Analysis</div>
        <div id="video-summary" style="font-size: 13px; line-height: 1.5; margin-bottom: 12px; color: var(--color-text-muted);">
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <div class="skeleton" style="height: 12px; border-radius: 4px;"></div>
                <div class="skeleton" style="height: 12px; width: 70%; border-radius: 4px;"></div>
            </div>
        </div>
        <div id="key-topics" style="display: none;">
            <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--mdb-green); margin-bottom: 8px;">Key Topics</div>
            <div id="topics-list" style="display: flex; flex-wrap: wrap; gap: 6px;"></div>
        </div>
    </div>

    <!-- AI Todos Card -->
    <div class="sidebar-card">
        <div class="sidebar-title">✅ AI Todos</div>
        <div id="todo-container" style="max-height: 200px; overflow-y: auto; margin-bottom: 12px;">
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <div class="skeleton" style="height: 32px; border-radius: 4px;"></div>
                <div class="skeleton" style="height: 32px; border-radius: 4px;"></div>
                <div class="skeleton" style="height: 32px; border-radius: 4px;"></div>
            </div>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 10px; border-top: 1px solid var(--color-border);">
            <span id="todo-progress" style="font-size: 12px; color: var(--color-text-muted);">0/0 completed</span>
            <button onclick="refreshTodos()" style="padding: 4px 10px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 4px; font-size: 11px; font-weight: 600; color: var(--color-text-muted); cursor: pointer;">
                ↺ Refresh
            </button>
        </div>
        <div class="progress-bar" style="margin-top: 8px;">
            <div id="todo-progress-bar" class="progress-fill" style="width: 0%; transition: width .3s ease;"></div>
        </div>
    </div>

    <!-- Chapters Card -->
    <% if (typeof chapters !== 'undefined' && chapters.length > 0) { %>
    <div class="sidebar-card">
        <div class="sidebar-title">📚 Chapters</div>
        <div style="display: flex; flex-direction: column; gap: 2px;">
            <% chapters.sort((a,b) => {
                const am = a.match(/(\d+)/); const bm = b.match(/(\d+)/);
                if (!am || !bm) return a.localeCompare(b);
                return parseInt(am[0]) - parseInt(bm[0]);
            }).forEach(chapter => {
                const chVids = videosByChapter[chapter];
            %>
            <div style="margin-bottom: 8px;">
                <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--color-text-muted); padding: 4px 10px; margin-bottom: 2px;">
                    <%= chapter %>
                </div>
                <% chVids.forEach((v, i) => { %>
                <a href="/videos/<%= encodeURIComponent(courseName) %>/<%= v._id %>"
                   class="chapter-link <%= v._id.toString() === video._id.toString() ? 'active' : '' %>">
                    <%= (i+1) %>. <%= v.title %>
                    <% if (v.watched) { %><span style="color: var(--mdb-green); float: right;">✓</span><% } %>
                </a>
                <% }); %>
            </div>
            <% }); %>
        </div>
    </div>
    <% } %>

    <!-- Shortcuts Card -->
    <div class="sidebar-card">
        <div class="sidebar-title">⌨ Shortcuts</div>
        <div style="display: flex; flex-direction: column; gap: 6px;">
            <div class="shortcut-item"><span class="shortcut-key">F</span><span class="shortcut-desc">Fullscreen</span></div>
            <div class="shortcut-item"><span class="shortcut-key">K</span><span class="shortcut-desc">Play / Pause</span></div>
            <div class="shortcut-item"><span class="shortcut-key">J</span><span class="shortcut-desc">Rewind 10s</span></div>
            <div class="shortcut-item"><span class="shortcut-key">L</span><span class="shortcut-desc">Forward 10s</span></div>
        </div>
    </div>
</div>