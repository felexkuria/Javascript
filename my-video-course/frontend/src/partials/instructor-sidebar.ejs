<!-- instructor-sidebar.ejs -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[45] hidden lg:hidden" onclick="toggleSidebar()"></div>
<aside id="main-sidebar" class="fixed lg:sticky top-0 left-0 w-72 bg-[#001E2B] border-r border-[#00ED64]/10 flex flex-col h-screen lg:min-h-screen shadow-2xl z-50 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
    <div class="px-8 py-12">
        <div class="flex items-center gap-4 group cursor-pointer" onclick="window.location.href='/teacher/dashboard'">
            <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center shadow-xl shadow-black/10 group-hover:rotate-6 transition-all duration-500">
                <img src="/images/logo-multitouch.png" alt="Logo" class="w-8 h-8 object-contain opacity-90 group-hover:opacity-100 transition-opacity" style="mix-blend-mode: screen; filter: brightness(1.2);">
            </div>
            <div class="flex flex-col">
                <span class="text-xl font-black tracking-tighter text-white leading-none">Multitouch</span>
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#00ED64] mt-1">Instructor</span>
            </div>
        </div>
    </div>

    <nav class="flex-1 px-4 space-y-1.5 overflow-y-auto">
        <div class="px-5 py-3 text-[10px] font-black text-gray-600 uppercase tracking-[0.3em] mb-2">Command Center</div>
        
        <a href="/admin/analytics" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all duration-300 group <%= typeof activePage !== 'undefined' && activePage === 'analytics' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20 shadow-lg shadow-[#00ED64]/5' : 'text-gray-400 hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-chart-pie w-5 group-hover:text-[#00ED64] transition-colors"></i> 
            <span class="tracking-tight">Platform Telemetry</span>
        </a>

        
        <a href="/admin/course-manager" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all duration-300 group <%= typeof activePage !== 'undefined' && activePage === 'courses' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20 shadow-lg shadow-[#00ED64]/5' : 'text-gray-400 hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-layer-group w-5 group-hover:text-[#00ED64] transition-colors"></i> 
            <span class="tracking-tight">Course Manager</span>
        </a>
        
        <a href="/teacher/upload-center" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all duration-300 group <%= typeof activePage !== 'undefined' && activePage === 'upload' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20 shadow-lg shadow-[#00ED64]/5' : 'text-gray-400 hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-cloud-upload-alt w-5 group-hover:text-[#00ED64] transition-colors"></i> 
            <span class="tracking-tight">Upload Center</span>
        </a>

        <div class="px-5 py-3 pt-10 text-[10px] font-black text-gray-600 uppercase tracking-[0.3em] mb-2">Governance</div>
        
        <a href="/admin/settings" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all duration-300 group <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20 shadow-lg shadow-[#00ED64]/5' : 'text-gray-400 hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-shield-halved w-5 group-hover:text-[#00ED64] transition-colors"></i> 
            <span class="tracking-tight">System Settings</span>
        </a>

        <a href="/dashboard" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold text-blue-400/70 hover:bg-blue-500/10 hover:text-blue-400 transition-all group mt-4">
            <i class="fas fa-desktop w-5 opacity-50 group-hover:opacity-100"></i> 
            <span class="tracking-tight">Student Console</span>
        </a>
    </nav>

    <div class="p-6 border-t border-white/5 mt-auto space-y-3">
        <div class="flex items-center justify-between px-4 py-3 bg-white/5 rounded-2xl border border-white/5 mb-4">
            <div class="flex items-center gap-3">
                <div class="w-2 h-2 bg-[#00ED64] rounded-full animate-pulse"></div>
                <span class="text-[9px] font-black uppercase tracking-widest text-gray-500">Admin Live</span>
            </div>
            <span class="text-[9px] font-black text-[#00ED64]">v2.4.9</span>
        </div>
        
        <a href="/logout" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold text-red-400/70 hover:bg-red-500/10 hover:text-red-400 transition-all group">
            <i class="fas fa-power-off w-5 opacity-50 group-hover:opacity-100"></i> 
            <span class="tracking-tight">Terminal Exit</span>
        </a>
    </div>

    <!-- Sidebar Toggle Script -->
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('main-sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            const isHidden = sidebar.classList.contains('-translate-x-full');
            
            if (isHidden) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
                document.body.style.overflow = '';
            }
        }
    </script>
</aside>
