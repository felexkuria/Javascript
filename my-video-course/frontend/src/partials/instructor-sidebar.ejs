<!-- instructor-sidebar.ejs -->
<aside class="instructor-sidebar">
    <div class="sidebar-brand">
        <span class="nav-leaf">🍃</span> Multitouch <span>Academy</span>
    </div>
    <nav class="sidebar-nav">
        <a href="/teacher/dashboard" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
            <i class="fas fa-chart-line"></i> Dashboard
        </a>
        <a href="/admin/course-manager" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'courses' ? 'active' : '' %>">
            <i class="fas fa-layer-group"></i> Course Manager
        </a>
        <a href="/teacher/upload-center" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'upload' ? 'active' : '' %>">
            <i class="fas fa-cloud-upload-alt"></i> Upload Center
        </a>
        
        <div style="margin: var(--space-6) 0 var(--space-2); font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; opacity: 0.4; font-weight: 700;">System Management</div>
        <a href="/admin/settings" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>">
            <i class="fas fa-cog"></i> Settings
        </a>
    </nav>
    <div style="margin-top: auto; padding-top: var(--space-6); border-top: 1px solid rgba(255,255,255,0.08);">
        <a href="/logout" class="nav-item" style="color: #ff3b30; margin-top: 8px;">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </div>

    <!-- Theme Toggle -->
    <div style="margin-top: var(--space-4); padding-top: var(--space-4); border-top: 1px solid rgba(120, 120, 120, 0.1);">
        <button id="sidebarThemeToggle" class="nav-item" style="width: 100%; background: transparent; border: none; cursor: pointer; color: inherit;">
            <i class="fas id-icon fa-moon" id="sidebarThemeIcon"></i> 
            <span id="sidebarThemeText">Dark Mode</span>
        </button>
    </div>

    <script>
        (function() {
            const toggleBtn = document.getElementById('sidebarThemeToggle');
            const icon = document.getElementById('sidebarThemeIcon');
            const text = document.getElementById('sidebarThemeText');

            function applyTheme(theme) {
                const isDark = theme === 'dark';
                document.documentElement.classList.toggle('dark', isDark);
                if (icon) {
                    icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
                }
                if (text) {
                    text.textContent = isDark ? 'Light Mode' : 'Dark Mode';
                }
            }

            function initTheme() {
                const savedTheme = localStorage.getItem('theme') || 'light';
                applyTheme(savedTheme);
            }

            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isCurrentlyDark = document.documentElement.classList.contains('dark');
                    const newTheme = isCurrentlyDark ? 'light' : 'dark';
                    localStorage.setItem('theme', newTheme);
                    applyTheme(newTheme);
                });
            }

            initTheme();
        })();
    </script>
</aside>
