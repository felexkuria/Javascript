<style>
/* MongoDB Atlas AI Assistant - Core Design System */
:root {
    --atlas-green: #00ED64;
    --atlas-midnight: #001E2B;
    --atlas-forest: #00684A;
    --atlas-slate: #023430;
    --atlas-blur: blur(40px);
}

/* Floating AI Assistant Widget */
.floating-chatbot {
    position: fixed;
    bottom: 100px;
    right: 30px;
    width: 420px;
    height: 600px;
    background: rgba(0, 30, 43, 0.7);
    backdrop-filter: var(--atlas-blur);
    -webkit-backdrop-filter: var(--atlas-blur);
    border: 1px solid rgba(0, 237, 100, 0.1);
    border-radius: 32px;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
    display: none;
    flex-direction: column;
    z-index: 10000;
    overflow: hidden;
    animation: atlas-pop 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: bottom right;
}

@keyframes atlas-pop {
    0% { transform: scale(0.9) translateY(20px); opacity: 0; }
    100% { transform: scale(1) translateY(0); opacity: 1; }
}

.chatbot-header {
    padding: 24px 32px;
    background: rgba(0, 237, 100, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.chatbot-title {
    display: flex;
    align-items: center;
    gap: 14px;
}

.chatbot-icon {
    font-size: 24px;
    color: var(--atlas-green);
    filter: drop-shadow(0 0 10px rgba(0, 237, 100, 0.3));
}

.chatbot-title span {
    font-weight: 800;
    letter-spacing: -0.02em;
    color: white;
}

.ai-model-badge {
    background: rgba(0, 237, 100, 0.1);
    color: var(--atlas-green);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 10px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid rgba(0, 237, 100, 0.2);
}

.chatbot-toggle {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    width: 32px;
    height: 32px;
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
}

.chatbot-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: rotate(90deg);
}

/* Chat Body & Messages */
.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
}

/* Scroll Customization */
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(0, 237, 100, 0.1); border-radius: 10px; }

.chat-message {
    max-width: 85%;
    display: flex;
    flex-direction: column;
    gap: 8px;
    animation: atlas-msg 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes atlas-msg {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
}

.chat-message.user { align-self: flex-end; }
.chat-message.bot { align-self: flex-start; }

.message-bubble {
    padding: 18px 24px;
    border-radius: 20px;
    font-size: 14px;
    line-height: 1.6;
    font-weight: 500;
}

.chat-message.user .message-bubble {
    background: rgba(0, 237, 100, 0.15);
    color: var(--atlas-green);
    border: 1px solid rgba(0, 237, 100, 0.2);
    border-radius: 24px 24px 4px 24px;
}

.chat-message.bot .message-bubble {
    background: rgba(255, 255, 255, 0.03);
    color: #9FB1AD;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px 24px 24px 4px;
}

.message-meta {
    font-family: 'SF Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
}

/* Input Area */
.chat-input-container {
    padding: 32px;
    background: rgba(0, 0, 0, 0.2);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    gap: 16px;
}

#chat-input {
    flex: 1;
    background: rgba(0, 30, 43, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 16px 20px;
    color: white;
    outline: none;
    font-size: 14px;
    transition: all 0.3s;
}

#chat-input:focus {
    border-color: var(--atlas-green);
    box-shadow: 0 0 20px rgba(0, 237, 100, 0.1);
}

.btn-send {
    width: 54px;
    height: 54px;
    background: var(--atlas-green);
    color: var(--atlas-midnight);
    border: none;
    border-radius: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    transition: all 0.3s;
}

.btn-send:hover {
    transform: scale(1.05) rotate(-5deg);
    box-shadow: 0 0 30px rgba(0, 237, 100, 0.4);
}

/* Trigger Button */
.chatbot-trigger {
    position: fixed;
    bottom: 30px;
    right: 30px;
    width: 72px;
    height: 72px;
    background: var(--atlas-midnight);
    color: var(--atlas-green);
    border: 1px solid rgba(0, 237, 100, 0.3);
    border-radius: 24px;
    cursor: pointer;
    font-size: 32px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
}

.chatbot-trigger:hover {
    background: var(--atlas-green);
    color: var(--atlas-midnight);
    transform: translateY(-8px) rotate(8deg);
    box-shadow: 0 30px 60px rgba(0, 237, 100, 0.2);
}

/* Standalone Page Enhancements */
.inquiry-node {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 24px;
    cursor: pointer;
    transition: all 0.3s;
    text-align: left;
}

.inquiry-node:hover {
    background: rgba(0, 237, 100, 0.05);
    border-color: var(--atlas-green);
    transform: translateY(-4px);
}

.node-label {
    font-family: 'SF Mono', monospace;
    font-size: 9px;
    font-weight: 800;
    color: var(--atlas-green);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 8px;
    display: block;
}

.node-text {
    font-size: 13px;
    font-weight: 600;
    color: white;
}
</style>