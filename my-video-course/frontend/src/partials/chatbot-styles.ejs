<style>
/* ── Atlas AI Assistant — Design System ─────────────────────────────────── */
:root {
    --atlas-green: #00ED64;
    --atlas-midnight: #001E2B;
    --atlas-forest: #00684A;
    --atlas-slate: #023430;
    --atlas-blur: blur(40px);
}

/* ── Floating Chatbot Widget ─────────────────────────────────────────────── */
.floating-chatbot {
    position: fixed;
    bottom: 110px;
    right: 30px;
    left: auto;
    width: 420px;
    height: 600px;
    max-height: calc(100vh - 140px);
    background: rgba(0, 30, 43, 0.88);
    backdrop-filter: var(--atlas-blur);
    -webkit-backdrop-filter: var(--atlas-blur);
    border: 1px solid rgba(0, 237, 100, 0.12);
    border-radius: 32px;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
    display: none;
    flex-direction: column;
    z-index: 10000;
    overflow: hidden;
    animation: atlas-pop 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: bottom right;
}

/* ── Mobile: Full-width bottom sheet ──────────────────────────────────────  */
@media (max-width: 768px) {
    .floating-chatbot {
        left: 0 !important;
        right: 0 !important;
        bottom: 0 !important;
        width: 100% !important;
        height: 78vh !important;
        max-height: 78vh !important;
        border-radius: 28px 28px 0 0 !important;
        transform-origin: bottom center !important;
        padding-bottom: env(safe-area-inset-bottom, 0px);
        animation: atlas-slide-up 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }
}

@keyframes atlas-pop {
    0%   { transform: scale(0.88) translateY(20px); opacity: 0; }
    100% { transform: scale(1) translateY(0);        opacity: 1; }
}

@keyframes atlas-slide-up {
    0%   { transform: translateY(60px); opacity: 0; }
    100% { transform: translateY(0);    opacity: 1; }
}

/* ── Header ─────────────────────────────────────────────────────────────── */
.chatbot-header {
    position: relative;
    flex-shrink: 0;
    padding: 20px 28px;
    background: rgba(0, 237, 100, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

@media (max-width: 768px) {
    .chatbot-header {
        padding: 20px 18px 14px;
    }
    /* iOS-style drag handle pill */
    .chatbot-header::before {
        content: '';
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        width: 40px;
        height: 4px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
    }
}

/* ── Body ────────────────────────────────────────────────────────────────── */
.chatbot-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 0; /* fix flex overflow on Safari */
}

.chatbot-title {
    display: flex;
    align-items: center;
    gap: 12px;
}

.chatbot-icon {
    font-size: 22px;
    color: var(--atlas-green);
    filter: drop-shadow(0 0 8px rgba(0, 237, 100, 0.3));
}

@media (max-width: 768px) {
    .chatbot-icon { font-size: 18px; }
}

.chatbot-title span {
    font-weight: 800;
    letter-spacing: -0.02em;
    font-size: 15px;
    color: #fff;
}

@media (max-width: 768px) {
    .chatbot-title span { font-size: 14px; }
}

.ai-model-badge {
    background: rgba(0, 237, 100, 0.1);
    color: var(--atlas-green);
    padding: 3px 9px;
    border-radius: 6px;
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid rgba(0, 237, 100, 0.2);
}

/* Larger tap target */
.chatbot-toggle {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    width: 44px;
    height: 44px;
    min-width: 44px;
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.2s;
}

.chatbot-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: rotate(90deg);
}

/* ── Chat Messages ───────────────────────────────────────────────────────── */
.chat-messages {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    min-height: 0;
}

@media (max-width: 768px) {
    .chat-messages { padding: 14px; gap: 14px; }
}

.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-thumb {
    background: rgba(0, 237, 100, 0.15);
    border-radius: 10px;
}

.chat-message {
    max-width: 85%;
    display: flex;
    flex-direction: column;
    gap: 6px;
    animation: atlas-msg 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@media (max-width: 768px) {
    .chat-message { max-width: 93%; }
}

@keyframes atlas-msg {
    0%   { opacity: 0; transform: translateY(8px); }
    100% { opacity: 1; transform: translateY(0);   }
}

.chat-message.user { align-self: flex-end; }
.chat-message.bot  { align-self: flex-start; }

.message-bubble {
    padding: 14px 20px;
    border-radius: 20px;
    font-size: 14px;
    line-height: 1.6;
    font-weight: 500;
}

@media (max-width: 768px) {
    .message-bubble { padding: 12px 15px; font-size: 13px; }
}

.chat-message.user .message-bubble {
    background: rgba(0, 237, 100, 0.12);
    color: var(--atlas-green);
    border: 1px solid rgba(0, 237, 100, 0.2);
    border-radius: 20px 20px 4px 20px;
}

.chat-message.bot .message-bubble {
    background: rgba(255, 255, 255, 0.03);
    color: #9FB1AD;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px 20px 20px 4px;
}

.message-bubble pre {
    background: #000a0f;
    padding: 14px;
    border-radius: 10px;
    overflow-x: auto;
    margin: 10px 0;
    border: 1px solid rgba(0, 237, 100, 0.1);
}

.message-bubble code {
    font-family: 'SF Mono', Consolas, Monaco, monospace;
    font-size: 12px;
}

.message-meta {
    font-family: 'SF Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
}

/* ── Input Area ──────────────────────────────────────────────────────────── */
.chat-input-container {
    flex-shrink: 0;
    padding: 18px 24px;
    /* Respect iPhone home bar */
    padding-bottom: max(18px, env(safe-area-inset-bottom, 18px));
    background: rgba(0, 0, 0, 0.22);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    gap: 12px;
    align-items: flex-end;
}

@media (max-width: 768px) {
    .chat-input-container {
        padding: 10px 12px;
        padding-bottom: max(12px, env(safe-area-inset-bottom, 12px));
        gap: 8px;
    }
}

#floating-chat-input,
#floating-chat-input-widget,
.chat-input-container input {
    flex: 1;
    background: rgba(0, 30, 43, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 13px 18px;
    color: #fff;
    outline: none;
    /* ≥16px prevents iOS auto-zoom on focus */
    font-size: 16px;
    line-height: 1.4;
    transition: border-color 0.2s, box-shadow 0.2s;
    min-height: 48px;
    resize: none;
}

@media (max-width: 768px) {
    #floating-chat-input,
    #floating-chat-input-widget,
    .chat-input-container input {
        padding: 11px 14px;
        border-radius: 12px;
    }
}

#floating-chat-input:focus,
#floating-chat-input-widget:focus,
.chat-input-container input:focus {
    border-color: var(--atlas-green);
    box-shadow: 0 0 16px rgba(0, 237, 100, 0.12);
    background: rgba(0, 20, 30, 0.95);
}

.btn-send {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    background: var(--atlas-green);
    color: var(--atlas-midnight);
    border: none;
    border-radius: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    transition: transform 0.2s, box-shadow 0.2s;
}

.btn-send:hover {
    transform: scale(1.06) rotate(-5deg);
    box-shadow: 0 0 24px rgba(0, 237, 100, 0.35);
}

/* Touch devices: use :active instead of :hover */
@media (hover: none) {
    .btn-send:hover { transform: none; box-shadow: none; }
    .btn-send:active { transform: scale(0.93); }
}

/* ── Trigger Button ──────────────────────────────────────────────────────── */
.chatbot-trigger {
    position: fixed;
    bottom: 30px;
    right: 24px;
    left: auto;
    width: 64px;
    height: 64px;
    background: var(--atlas-midnight);
    color: var(--atlas-green);
    border: 1px solid rgba(0, 237, 100, 0.3);
    border-radius: 20px;
    cursor: pointer;
    font-size: 28px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(0, 237, 100, 0.05);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
}

@media (max-width: 768px) {
    .chatbot-trigger {
        bottom: max(18px, env(safe-area-inset-bottom, 18px));
        right: 16px;
        width: 56px;
        height: 56px;
        border-radius: 18px;
        font-size: 22px;
    }
}

.chatbot-trigger:hover {
    background: var(--atlas-green);
    color: var(--atlas-midnight);
    transform: translateY(-6px) rotate(6deg);
    box-shadow: 0 24px 50px rgba(0, 237, 100, 0.2);
}

@media (hover: none) {
    .chatbot-trigger:hover  { transform: none; background: var(--atlas-midnight); color: var(--atlas-green); }
    .chatbot-trigger:active { transform: scale(0.9); }
}

/* ── Notification Dot ────────────────────────────────────────────────────── */
.notification-dot {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 12px;
    height: 12px;
    background: var(--atlas-green);
    border-radius: 50%;
    border: 2px solid var(--atlas-midnight);
    animation: pulse-dot 2s infinite;
}

@keyframes pulse-dot {
    0%, 100% { transform: scale(1);   opacity: 1; }
    50%       { transform: scale(1.3); opacity: 0.7; }
}

/* ── Inquiry nodes (standalone page) ────────────────────────────────────── */
.inquiry-node {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 20px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    text-align: left;
}

.inquiry-node:hover {
    background: rgba(0, 237, 100, 0.05);
    border-color: var(--atlas-green);
    transform: translateY(-3px);
}

.node-label {
    font-family: 'SF Mono', monospace;
    font-size: 9px;
    font-weight: 800;
    color: var(--atlas-green);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 6px;
    display: block;
}

.node-text {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
}
</style>