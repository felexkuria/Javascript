<div class="video-section animate-slide-up">
    <div class="video-container" id="videoContainer" style="position: relative; width: 100%; aspect-ratio: 16/9; background: #000; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <% if (isYouTube) { %>
        <iframe id="youtubePlayer" 
                src="<%= video.embedUrl %>" 
                style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; border: none; object-fit: cover;"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen>
        </iframe>
        <% } else if (video && video.videoUrl && (video.videoUrl.toLowerCase().includes('.pdf') || video.type === 'resource' || video.type === 'pdf')) { %>
        <div class="pdf-viewer-container" style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; background: #1e1e24; display: flex; flex-direction: column;">
            <iframe src="<%= video.fullVideoUrl || video.videoUrl || video.url %>" 
                    style="flex: 1; border: none; width: 100%; height: 100%;"
                    id="pdfViewer">
            </iframe>
            <div class="pdf-fallback" style="padding: 12px 20px; background: rgba(0,0,0,0.9); color: white; display: flex; justify-content: space-between; align-items: center; font-size: 14px; border-top: 1px solid #333;">
                <span>View document offline or bypass browser PDF viewer:</span>
                <a href="<%= video.fullVideoUrl || video.videoUrl || video.url %>" download="<%= video.title %>.pdf" target="_blank" style="color: #00ED64; text-decoration: none; font-weight: 600; padding: 4px 12px; background: rgba(0,237,100,0.1); border-radius: 6px;">Download PDF ↓</a>
            </div>
        </div>
        <% } else { %>
        <video id="videoPlayer" controls crossorigin="anonymous" class="interactive-video" preload="metadata" 
               poster="<%= video.thumbnailUrl || '/thumbnails/' + (video._id || video.videoId) + '.jpg' %>"
               onerror="window.handleVideoError(this)"
               style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; object-fit: contain; background: #000; border: none; outline: none;">
            <source src="<%= video.fullVideoUrl || video.videoUrl || video.url %>" type="video/mp4" id="videoSource" onerror="window.handleSourceError(this)">

            <% if (video.captionsUrl) { %>
            <track label="English" kind="subtitles" srclang="en" src="/captions/<%= courseName %>/<%= video._id %>" default />
            <% } %>
            <track id="autoCaption" label="Auto-Generated" kind="subtitles" srclang="en" 
                   src="/api/captions/vtt/<%= encodeURIComponent(courseName) %>/<%= video._id %>" />
        </video>
        <% } %>
        
        <!-- Interactive overlay (only shown when paused and not YouTube) -->
        <% if (!isYouTube) { %>
        <div class="video-overlay" id="videoOverlay" style="display: flex; opacity: 0; pointer-events: none;">
            <div class="play-button" id="playButton" style="pointer-events: all; cursor: pointer;">
                <span>▶</span>
            </div>
        </div>
        <% } %>
        
        <div id="mediaErrorOverlay" class="hidden hud-backdrop">
            <div class="hud-grid"></div>
            <div class="hud-scanner"></div>
            
            <div class="neural-core-container">
                <div class="neural-ring ring-1"></div>
                <div class="neural-ring ring-2"></div>
                <div class="neural-ring ring-3"></div>
                <div class="neural-nucleus"></div>
            </div>

            <h3 class="premium-title text-2xl tracking-[0.3em] uppercase mb-2">SYNC ENGINE</h3>
            <p class="sync-status-msg">Calibrating AI Learning Nodes...</p>

            <div class="hud-telemetry">
                <div class="telemetry-node">
                    <div class="node-label">Curriculum</div>
                    <div class="node-value"><%= courseName.replace(/[-_]/g, ' ') %></div>
                </div>
                <div class="telemetry-node">
                    <div class="node-label">Deployment Node</div>
                    <div class="node-value"><%= (video.title || 'ARCHITECT SECTOR').substring(0, 24) %></div>
                </div>
                <div class="telemetry-node">
                    <div class="node-label">Instructor</div>
                    <div class="node-value">Engineer Felex</div>
                </div>
                <div class="telemetry-node">
                    <div class="node-label">Asset Duration</div>
                    <div class="node-value"><%= video.duration || '24:00' %></div>
                </div>
            </div>

            <div class="mt-12 flex gap-6">
                <button onclick="window.repairAndReload('<%= courseName %>')" class="btn-hud-retry px-10 py-4 rounded-xl text-[10px] font-black tracking-[0.2em] uppercase">
                    REINITIATE HANDSHAKE
                </button>
            </div>
        </div>

        <script>
        (function() {
            window.handleVideoError = function(video) {
                console.error("Video element reported error:", video.error);
                showErrorOverlay();
            };

            window.handleSourceError = function(source) {
                console.error("Video source failed to load:", source.src);
                showErrorOverlay();
            };

            window.repairAndReload = async function(courseName) {
                const btn = event.currentTarget;
                const originalText = btn.innerText;
                btn.innerText = 'SYNCING...';
                btn.disabled = true;
                
                try {
                    const response = await fetch('/api/sync/repair-manifest', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ courseName })
                    });
                    const result = await response.json();
                    if (result.success) {
                        console.log('Manifest repaired:', result.repairedCount, 'items fixed');
                        window.location.reload();
                    } else {
                        throw new Error(result.error || 'Sync failed');
                    }
                } catch (error) {
                    console.error('Repair failed:', error);
                    alert('Sync error: ' + error.message);
                    btn.innerText = originalText;
                    btn.disabled = false;
                }
            };

            function showErrorOverlay() {
                const overlay = document.getElementById('mediaErrorOverlay');
                if (overlay) overlay.classList.remove('hidden');
                
                // Trigger global HUD orchestration mode
                document.body.classList.add('hud-active');

                // Also hide the poster and default controls
                const vp = document.getElementById('videoPlayer');
                if (vp) {
                    vp.style.display = 'none';
                }
            }

            document.addEventListener('DOMContentLoaded', function() {
                const videoPlayer = document.getElementById('videoPlayer');
                const overlay = document.getElementById('videoOverlay');
                const playButton = document.getElementById('playButton');
                
                // Auto-trigger error check for stalled streams
                if (videoPlayer) {
                    const timeout = setTimeout(() => {
                        if (videoPlayer.networkState === HTMLMediaElement.NETWORK_NO_SOURCE) {
                            showErrorOverlay();
                        }
                    }, 5000);
                    
                    videoPlayer.addEventListener('loadeddata', () => clearTimeout(timeout));
                }

                if (videoPlayer && overlay && playButton) {
                    playButton.addEventListener('click', function(e) {
                        e.stopPropagation();
                        videoPlayer.play().catch(err => {
                            console.error("Play blocked:", err);
                            // Some browsers trigger error on play failure if source is 404
                            showErrorOverlay();
                        });
                    });
                    
                    videoPlayer.addEventListener('play', function() {
                        overlay.style.opacity = '0';
                        overlay.style.pointerEvents = 'none';
                    });
                    
                    videoPlayer.addEventListener('pause', function() {
                        overlay.style.opacity = '1';
                    });

                    videoPlayer.addEventListener('click', function() {
                        if (videoPlayer.paused) videoPlayer.play();
                        else videoPlayer.pause();
                    });
                }
            });
        })();
        </script>
    </div>
</div>