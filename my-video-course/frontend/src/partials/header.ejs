<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Video Course Platform' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
      /* ── Nav ─────────────────────────────────────────────── */
      .mdb-nav {
        height: 56px;
        background: var(--mdb-midnight);
        display: flex;
        align-items: center;
        padding: 0 24px;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(0,237,100,.12);
        gap: 0;
      }
      .nav-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none !important;
        margin-right: 32px;
        flex-shrink: 0;
      }
      /* MongoDB leaf logo mark */
      .nav-leaf {
        width: 28px; height: 28px;
        background: var(--mdb-green);
        border-radius: 50% 50% 50% 0 / 60% 60% 40% 40%;
        flex-shrink: 0;
        position: relative;
      }
      .nav-leaf::after {
        content: '';
        position: absolute;
        width: 2px; height: 14px;
        background: var(--mdb-midnight);
        bottom: 3px; left: 50%;
        transform: translateX(-50%);
        border-radius: 1px;
      }
      .nav-brand-name {
        font-size: 15px;
        font-weight: 700;
        color: #fff;
        letter-spacing: -.01em;
      }
      .nav-brand-name span { color: var(--mdb-green); }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 4px;
        list-style: none;
        flex: 1;
      }
      .nav-link {
        padding: 6px 12px;
        border-radius: var(--radius-md);
        font-size: 13px;
        font-weight: 500;
        color: rgba(255,255,255,.7);
        text-decoration: none;
        transition: all var(--transition);
      }
      .nav-link:hover { color: #fff; background: rgba(255,255,255,.08); text-decoration: none; }
      .nav-link.active { color: var(--mdb-green); }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-left: auto;
      }
      .nav-theme-btn {
        width: 34px; height: 34px;
        display: flex; align-items: center; justify-content: center;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: var(--radius-md);
        background: transparent;
        color: rgba(255,255,255,.7);
        cursor: pointer;
        transition: all var(--transition);
        font-size: 15px;
      }
      .nav-theme-btn:hover { background: rgba(255,255,255,.1); color: #fff; }

      .nav-avatar {
        width: 30px; height: 30px;
        border-radius: 50%;
        background: var(--mdb-green);
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 700;
        color: var(--mdb-midnight);
        cursor: pointer;
        border: 2px solid rgba(0,237,100,.4);
      }
    </style>
</head>
<body>
    <nav class="mdb-nav" role="navigation" aria-label="Main navigation">
        <a href="/dashboard" class="nav-brand" aria-label="Home">
            <div class="nav-leaf" aria-hidden="true"></div>
            <span class="nav-brand-name">MongoDB <span>Academy</span></span>
        </a>

        <ul class="nav-links" role="list">
            <li><a href="/dashboard" class="nav-link">Dashboard</a></li>
            <li><a href="/courses" class="nav-link">Courses</a></li>
        </ul>

        <div class="nav-actions">
            <button id="themeToggle" class="nav-theme-btn" aria-label="Toggle theme" title="Toggle dark/light mode">
                <span id="themeIcon">☀️</span>
            </button>
            <div class="nav-avatar" id="navAvatar" title="Profile">U</div>
        </div>
    </nav>

    <script>
      // Sync navbar avatar with stored user
      (function() {
        try {
          const user = JSON.parse(localStorage.getItem('user') || '{}');
          const avatar = document.getElementById('navAvatar');
          if (user && user.name && avatar) {
            avatar.textContent = user.name.charAt(0).toUpperCase();
            avatar.setAttribute('title', user.name);
          }
        } catch(e) {}
      })();
    </script>
</body>
</html>