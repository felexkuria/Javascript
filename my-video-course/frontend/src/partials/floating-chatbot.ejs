<!-- Floating AI Assistant - MongoDB Atlas Edition -->
<div id="floating-chatbot" class="floating-chatbot glass">
    <div class="chatbot-header">
        <div class="chatbot-title">
            <i class="fas fa-brain chatbot-icon"></i>
            <span>AI Assistant</span>
            <span class="ai-model-badge">Nova Lite</span>
        </div>
        <button class="chatbot-toggle" onclick="toggleFloatingChatbot()">
            <i class="fas fa-minus"></i>
        </button>
    </div>
    
    <div class="chatbot-body flex flex-col h-[calc(100%-80px)]">
        <div class="chat-messages scroll-premium" id="floating-chat-messages">
            <div class="chat-message bot">
                <div class="message-bubble">
                    Hi! I'm your AI learning assistant. I can help explain concepts from this course using the David J. Malan pedagogy. What would you like to know?
                </div>
                <div class="message-meta">AI Assistant • Just now</div>
            </div>
        </div>
        
        <div class="chat-input-container">
            <input type="text" id="floating-chat-input" placeholder="Ask about the content..." maxlength="500">
            <button onclick="sendFloatingChatMessage()" id="send-btn" class="btn-send">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>
</div>

<!-- Premium Chatbot Trigger -->
<button id="chatbot-trigger" class="chatbot-trigger" onclick="toggleFloatingChatbot()">
    <i class="fas fa-comment-dots"></i>
    <span class="notification-dot" id="chat-notification" style="display: none;"></span>
</button>
<!-- Code Beauty Components -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/styles/atom-one-dark.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/highlight.min.js"></script>

<script>
    function toggleFloatingChatbot() {
        const bot = document.getElementById('floating-chatbot');
        const isVisible = bot.style.display === 'flex';
        bot.style.display = isVisible ? 'none' : 'flex';
        
        if (!isVisible) {
            document.getElementById('floating-chat-input').focus();
        }
    }

    async function sendFloatingChatMessage() {
        const input = document.getElementById('floating-chat-input');
        const messages = document.getElementById('floating-chat-messages');
        const message = input.value.trim();
        
        if (!message) return;

        // Add user message
        const userTime = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
        const userDiv = document.createElement('div');
        userDiv.className = 'chat-message user';
        userDiv.innerHTML = `
            <div class="message-bubble">${message}</div>
            <div class="message-meta">Student • ${userTime}</div>
        `;
        messages.appendChild(userDiv);
        input.value = '';
        messages.scrollTop = messages.scrollHeight;

        // Add typing indicator
        const typingId = 'typing-' + Date.now();
        const typingDiv = document.createElement('div');
        typingDiv.id = typingId;
        typingDiv.className = 'chat-message bot';
        typingDiv.innerHTML = `
            <div class="message-bubble technical-label animate-pulse">Synthesizing...</div>
        `;
        messages.appendChild(typingDiv);
        messages.scrollTop = messages.scrollHeight;

        try {
            const response = await fetch('/api/ai/chatbot', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            const data = await response.json();
            
            document.getElementById(typingId).remove();
            
            const htmlContent = window.marked ? marked.parse(data.response) : data.response.replace(/\n/g, '<br>');
            
            const botDiv = document.createElement('div');
            botDiv.className = 'chat-message bot';
            botDiv.innerHTML = `
                <div class="message-bubble w-full overflow-x-auto">${htmlContent}</div>
                <div class="message-meta">Nova Lite • Just now</div>
            `;
            messages.appendChild(botDiv);
            
            if (window.hljs) {
                botDiv.querySelectorAll('pre code').forEach((block) => {
                    hljs.highlightElement(block);
                });
            }
            messages.appendChild(botDiv);
            messages.scrollTop = messages.scrollHeight;
        } catch (error) {
            document.getElementById(typingId).remove();
            const errorDiv = document.createElement('div');
            errorDiv.className = 'chat-message bot';
            errorDiv.innerHTML = `<div class="message-bubble text-red-400">Connection error. Please try again.</div>`;
            messages.appendChild(errorDiv);
        }
    }

    // Handle Enter key
    document.getElementById('floating-chat-input').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendFloatingChatMessage();
    });
</script>