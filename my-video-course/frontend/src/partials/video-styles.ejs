<style>
:root { 
    --atlas-green: #00ED64; 
    --atlas-midnight: #001E2B; 
    --atlas-forest: #00684A; 
    --sidebar-width: 440px; 
} 

body { 
    background-color: var(--atlas-midnight); 
    color: #E7EEEB; 
    font-family: 'Euclid Circular A', 'Inter', system-ui, sans-serif; 
    overflow-x: hidden; 
    -webkit-font-smoothing: antialiased; 
} 

.atlas-nav { 
    border-bottom: 1px solid rgba(255, 255, 255, 0.05); 
    background: rgba(0, 30, 43, 0.95); 
    backdrop-filter: blur(20px); 
    z-index: 50; 
} 

.command-center { 
    display: grid; 
    grid-template-columns: 1fr var(--sidebar-width); 
    height: calc(100vh - 72px); 
    overflow: hidden; 
} 

.learning-canvas { 
    overflow-y: auto; 
    padding: 3rem; 
    background: radial-gradient(circle at 80% 20%, rgba(0, 237, 100, 0.04), transparent 50%); 
} 

.side-lab { 
    border-left: 1px solid rgba(255, 255, 255, 0.08); 
    background: rgba(0, 30, 43, 0.9); 
    backdrop-filter: blur(40px); 
    display: flex; 
    flex-direction: column; 
    z-index: 40; 
} 

.video-hero { 
    position: relative; 
    border-radius: 32px; 
    overflow: hidden; 
    background: #000; 
    box-shadow: 0 40px 120px rgba(0,0,0,0.8), 0 0 0 1px rgba(255,255,255,0.06); 
    aspect-ratio: 16/9; 
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); 
} 

.video-hero:hover { 
    box-shadow: 0 60px 160px rgba(0,0,0,0.9), 0 0 40px rgba(0, 237, 100, 0.05); 
    transform: translateY(-4px); 
} 

/* MongoDB Atlas UI Elements */ 
.atlas-badge { 
    background: rgba(0, 237, 100, 0.1); 
    color: var(--atlas-green); 
    padding: 4px 10px; 
    border-radius: 6px; 
    font-size: 10px; 
    font-weight: 800; 
    text-transform: uppercase; 
    letter-spacing: 0.1em; 
    border: 1px solid rgba(0, 237, 100, 0.2); 
} 

.lab-tabs { 
    padding: 1.5rem; 
    gap: 1rem; 
    border-bottom: 1px solid rgba(255, 255, 255, 0.08); 
} 

.lab-tab-btn { 
    padding: 0.85rem 1.25rem; 
    border-radius: 14px; 
    font-size: 11px; 
    font-weight: 800; 
    text-transform: uppercase; 
    letter-spacing: 0.12em; 
    color: #9FB1AD; 
    transition: all 0.4s ease; 
    background: rgba(255, 255, 255, 0.02); 
    border: 1px solid rgba(255, 255, 255, 0.05); 
} 

.lab-tab-btn.active { 
    background: var(--atlas-green); 
    color: var(--atlas-midnight); 
    border-color: var(--atlas-green); 
    box-shadow: 0 10px 30px rgba(0, 237, 100, 0.15); 
} 

.premium-meta-bay { 
    margin-top: 4rem; 
    padding: 3rem; 
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.02) 0%, transparent 100%); 
    border-radius: 40px; 
    border: 1px solid rgba(255, 255, 255, 0.05); 
} 

.technical-label { 
    font-family: 'SF Mono', 'Fira Code', monospace; 
    font-size: 10px; 
    color: #9FB1AD; 
    text-transform: uppercase; 
    letter-spacing: 0.2em; 
    opacity: 0.6; 
} 

/* Achievement Popup Atlas Style */ 
#achievement-popup { 
    background: #001E2B; 
    border: 1px solid var(--atlas-green); 
    box-shadow: 0 30px 60px rgba(0,0,0,0.5), 0 0 40px rgba(0, 237, 100, 0.1); 
} 

/* Syntax Highlighting IDE Theme Integration */
pre {
    background: #0d1117 !important;
    border-radius: 12px;
    padding: 1.5rem !important;
    margin: 1.5rem 0 !important;
    border: 1px solid rgba(255,255,255,0.05);
    overflow-x: auto;
}

code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace !important;
    font-size: 13px !important;
    line-height: 1.6 !important;
}

.copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.5rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    color: #8b949e;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    opacity: 0;
}

pre:hover .copy-btn {
    opacity: 1;
}

.copy-btn:hover {
    background: rgba(255,255,255,0.1);
    color: white;
}

@media (max-width: 1200px) { 
    .command-center { 
        grid-template-columns: 1fr; 
        height: auto; 
        overflow: visible; 
    } 
    .side-lab { 
        height: 600px; 
        border-left: none; 
        border-top: 1px solid rgba(255,255,255,0.05); 
    } 
}
</style>