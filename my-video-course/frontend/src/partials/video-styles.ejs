<style>
:root {
    --atlas-green: #00ED64;
    --atlas-midnight: #001E2B;
    --atlas-forest: #00684A;
    --atlas-slate: #023430;
    --atlas-gradient: linear-gradient(135deg, #001E2B 0%, #00684A 100%);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'Euclid Circular A', 'Inter', -apple-system, system-ui, sans-serif;
    background: var(--atlas-midnight);
    color: #E7EEEB;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

.container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 40px;
}

.video-header {
    margin-bottom: 40px;
}

.video-title {
    font-size: 48px;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: white;
    margin-bottom: 12px;
}

.video-subtitle {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--atlas-green);
    opacity: 0.8;
}

.main-content {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 48px;
}

@media (max-width: 1200px) {
    .main-content {
        grid-template-columns: 1fr;
    }
}

/* Atlas Card Style */
.atlas-card {
    background: rgba(2, 52, 48, 0.4);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 32px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.atlas-card:hover {
    border-color: rgba(0, 237, 100, 0.2);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}

.video-section {
    position: relative;
    border-radius: 40px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6);
}

.video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
}

.video-container iframe, 
.video-container video,
.video-container object {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
}

.video-controls-bar {
    padding: 24px 40px;
    background: rgba(2, 52, 48, 0.8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.05);
}

.btn-atlas {
    padding: 14px 28px;
    border-radius: 16px;
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.btn-atlas-primary {
    background: var(--atlas-green);
    color: var(--atlas-midnight);
}

.btn-atlas-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(0, 237, 100, 0.4);
}

.btn-atlas-secondary {
    background: rgba(255,255,255,0.05);
    color: white;
    border: 1px solid rgba(255,255,255,0.1);
}

.btn-atlas-secondary:hover {
    background: rgba(255,255,255,0.1);
}

/* Sidebar Styling */
.sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.curriculum-list {
    max-height: 70vh;
    overflow-y: auto;
    padding-right: 8px;
}

.curriculum-list::-webkit-scrollbar {
    width: 4px;
}

.curriculum-list::-webkit-scrollbar-thumb {
    background: rgba(0, 237, 100, 0.2);
    border-radius: 2px;
}

.lecture-item {
    padding: 16px 20px;
    border-radius: 16px;
    margin-bottom: 8px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 16px;
    background: rgba(255,255,255,0.02);
    border: 1px solid transparent;
}

.lecture-item:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.1);
}

.lecture-item.active {
    background: rgba(0, 237, 100, 0.1);
    border-color: rgba(0, 237, 100, 0.3);
}

.lecture-item.active .lecture-title {
    color: var(--atlas-green);
}

.lecture-icon {
    width: 32px;
    height: 32px;
    background: rgba(255,255,255,0.05);
    border-radius: 8px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: #9FB1AD;
}

.lecture-item.active .lecture-icon {
    background: var(--atlas-green);
    color: var(--atlas-midnight);
}

.lecture-title {
    font-size: 14px;
    font-weight: 600;
    color: #E7EEEB;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.lecture-meta {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    color: #9FB1AD;
    opacity: 0.5;
}

/* Gamification Widgets */
.gamification-card {
    background: linear-gradient(135deg, rgba(2, 52, 48, 0.8) 0%, rgba(0, 104, 74, 0.4) 100%);
}

.stat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

.stat-box {
    padding: 16px;
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
    text-align: center;
}

.stat-num {
    font-size: 20px;
    font-weight: 900;
    color: var(--atlas-green);
}

.stat-txt {
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    color: #9FB1AD;
    letter-spacing: 0.1em;
}

/* PDF Content */
.pdf-container {
    background: #001E2B;
    padding: 40px;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
}

.pdf-icon-hero {
    font-size: 64px;
    color: #FF3B30;
    filter: drop-shadow(0 0 20px rgba(255,59,48,0.3));
}

.progress-belt {
    height: 4px;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 12px;
}

.progress-fill {
    height: 100%;
    background: var(--atlas-green);
    box-shadow: 0 0 10px var(--atlas-green);
}
</style>