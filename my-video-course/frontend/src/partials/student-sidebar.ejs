<!-- student-sidebar.ejs -->
<aside class="w-72 bg-[#001E2B] border-r border-[#00ED64]/10 flex flex-col min-h-screen sticky top-0 self-start shadow-2xl">
    <div class="px-8 py-10">
        <div class="flex items-center space-x-4 group cursor-pointer">
            <div class="w-10 h-10 bg-gradient-to-br from-[#00ED64] to-[#00684A] rounded-xl flex items-center justify-center shadow-lg group-hover:rotate-6 transition-transform">
                <span class="text-[#001E2B] text-xl font-black">M</span>
            </div>
            <span class="text-xl font-black tracking-tighter text-white">Multitouch <span class="font-light text-gray-400">Academy</span></span>
        </div>
    </div>

    <nav class="flex-1 px-4 space-y-2">
        <div class="px-4 py-2 text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-2">Learning Mission</div>
        
        <a href="/dashboard" class="flex items-center gap-4 px-4 py-3.5 rounded-xl text-sm font-bold transition-all <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20' : 'text-[#9FB1AD] hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-home w-5"></i> Learning Path
        </a>
        
        <a href="/courses" class="flex items-center gap-4 px-4 py-3.5 rounded-xl text-sm font-bold transition-all <%= typeof activePage !== 'undefined' && activePage === 'courses' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20' : 'text-[#9FB1AD] hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-search w-5"></i> Explore Catalog
        </a>
        
        <a href="/profile" class="flex items-center gap-4 px-4 py-3.5 rounded-xl text-sm font-bold transition-all <%= typeof activePage !== 'undefined' && activePage === 'profile' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20' : 'text-[#9FB1AD] hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-user-graduate w-5"></i> Achievement Hub
        </a>

        <div class="px-4 py-2 pt-8 text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-2">Sectors</div>
        
        <a href="/settings" class="flex items-center gap-4 px-4 py-3.5 rounded-xl text-sm font-bold transition-all <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20' : 'text-[#9FB1AD] hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-user-cog w-5"></i> Account Settings
        </a>
    </nav>

    <div class="p-6 border-t border-white/5 mt-auto">
        <button id="sidebarThemeToggle" class="w-full flex items-center gap-4 px-4 py-3.5 rounded-xl text-sm font-bold text-[#9FB1AD] hover:bg-white/5 hover:text-white transition-all mb-4">
            <i class="fas fa-moon w-5" id="sidebarThemeIcon"></i>
            <span id="sidebarThemeText">Dark Mode</span>
        </button>
        
        <a href="/logout" class="flex items-center gap-4 px-4 py-3.5 rounded-xl text-sm font-bold text-red-400 hover:bg-red-500/10 transition-all">
            <i class="fas fa-sign-out-alt w-5"></i> Termination
        </a>
    </div>

    <script>
        (function() {
            const toggleBtn = document.getElementById('sidebarThemeToggle');
            const icon = document.getElementById('sidebarThemeIcon');
            const text = document.getElementById('sidebarThemeText');

            function applyTheme(theme) {
                const isDark = theme === 'dark';
                document.documentElement.classList.toggle('dark', isDark);
                if (icon) {
                    icon.className = isDark ? 'fas fa-sun w-5' : 'fas fa-moon w-5';
                }
                if (text) {
                    text.textContent = isDark ? 'Solar Mode' : 'Lunar Mode';
                }
            }

            function initTheme() {
                const savedTheme = localStorage.getItem('theme') || 'light';
                applyTheme(savedTheme);
            }

            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isCurrentlyDark = document.documentElement.classList.contains('dark');
                    const newTheme = isCurrentlyDark ? 'light' : 'dark';
                    localStorage.setItem('theme', newTheme);
                    applyTheme(newTheme);
                });
            }

            initTheme();
        })();
    </script>
</aside>
