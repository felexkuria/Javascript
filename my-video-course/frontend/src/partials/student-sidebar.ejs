<!-- student-sidebar.ejs -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[45] hidden lg:hidden" onclick="toggleSidebar()"></div>
<aside id="main-sidebar" class="fixed lg:sticky top-0 left-0 w-72 bg-[#001E2B] border-r border-[#00ED64]/10 flex flex-col h-screen lg:min-h-screen shadow-2xl z-50 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
    <div class="px-8 py-12">
        <div class="flex items-center gap-4 group cursor-pointer" onclick="window.location.href='/dashboard'">
            <div class="w-12 h-12 bg-[#001E2B] border border-[#00ED64]/20 rounded-2xl flex items-center justify-center shadow-xl shadow-[#00ED64]/10 group-hover:rotate-6 transition-all duration-500 overflow-hidden relative">
                <img src="/images/logo-multitouch.png" alt="Logo" class="w-full h-full object-contain p-1 relative z-10 mix-blend-mode-screen filter brightness-[1.2]" style="mix-blend-mode: screen;">
                <div class="absolute inset-0 bg-gradient-to-br from-[#00ED64]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <div class="flex flex-col">
                <span class="text-xl font-black tracking-tighter text-white leading-none">Multitouch</span>
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#00ED64] mt-1">Academy</span>
            </div>
        </div>
    </div>

    <!-- 🚀 Global XP Status (Google UI/UX Optimized) -->
    <div class="px-6 mb-8">
        <div class="bg-white/5 border border-white/10 rounded-[28px] p-5 shadow-2xl relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
                <i class="fas fa-bolt text-4xl text-[#00ED64]"></i>
            </div>
            <div class="relative z-10">
                <div class="flex items-center justify-between mb-4">
                    <div>
                        <div class="text-[9px] font-black uppercase tracking-[0.2em] text-gray-500 mb-1">Current Level</div>
                        <div class="text-2xl font-black text-white flex items-baseline gap-1">
                            <span class="text-[#00ED64]">LVL</span>
                            <span id="sidebar-level"><%= (typeof gamificationData !== 'undefined' && gamificationData.userStats) ? gamificationData.userStats.currentLevel : 1 %></span>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-[9px] font-black uppercase tracking-[0.2em] text-gray-500 mb-1">Total XP</div>
                        <div class="text-sm font-black text-white" id="sidebar-xp"><%= (typeof gamificationData !== 'undefined' && gamificationData.userStats) ? (gamificationData.userStats.experiencePoints || gamificationData.userStats.totalPoints || 0) : 0 %></div>
                    </div>
                </div>
                
                <% 
                    const currentXP = (typeof gamificationData !== 'undefined' && gamificationData.userStats) ? (gamificationData.userStats.experiencePoints || gamificationData.userStats.totalPoints || 0) : 0;
                    const currentLevel = Math.floor(Math.sqrt(currentXP / 100)) + 1;
                    const nextLevelXP = Math.pow(currentLevel, 2) * 100;
                    const prevLevelXP = Math.pow(currentLevel - 1, 2) * 100;
                    const progress = Math.min(100, Math.max(0, ((currentXP - prevLevelXP) / (nextLevelXP - prevLevelXP)) * 100));
                %>
                <div class="space-y-2">
                    <div class="flex justify-between items-center text-[10px] font-bold">
                        <span class="text-[#00ED64]">Progress</span>
                        <span class="text-gray-500"><%= Math.round(progress) %>%</span>
                    </div>
                    <div class="w-full h-1.5 bg-black/40 rounded-full overflow-hidden">
                        <div id="sidebar-progress-bar" class="h-full bg-gradient-to-r from-[#00ED64] to-[#00684A] shadow-[0_0_8px_rgba(0,237,100,0.4)] transition-all duration-1000" style="width: <%= progress %>%;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <nav class="flex-1 px-4 space-y-1.5 overflow-y-auto">
        <div class="px-5 py-3 text-[10px] font-black text-gray-600 uppercase tracking-[0.3em] mb-2">Command Center</div>
        
        <a href="/dashboard" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all duration-300 group <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20 shadow-lg shadow-[#00ED64]/5' : 'text-gray-400 hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-terminal w-5 group-hover:text-[#00ED64] transition-colors"></i> 
            <span class="tracking-tight">Learning Console</span>
        </a>
        
        <a href="/courses" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all duration-300 group <%= typeof activePage !== 'undefined' && activePage === 'courses' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20 shadow-lg shadow-[#00ED64]/5' : 'text-gray-400 hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-layer-group w-5 group-hover:text-[#00ED64] transition-colors"></i> 
            <span class="tracking-tight">Course Manifest</span>
        </a>
        
        <a href="/profile" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all duration-300 group <%= typeof activePage !== 'undefined' && activePage === 'profile' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20 shadow-lg shadow-[#00ED64]/5' : 'text-gray-400 hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-award w-5 group-hover:text-[#00ED64] transition-colors"></i> 
            <span class="tracking-tight">Achievement Hub</span>
        </a>

        <div class="px-5 py-3 pt-10 text-[10px] font-black text-gray-600 uppercase tracking-[0.3em] mb-2">System Ops</div>
        
        <a href="/settings" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all duration-300 group <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20 shadow-lg shadow-[#00ED64]/5' : 'text-gray-400 hover:bg-white/5 hover:text-white border border-transparent' %>">
            <i class="fas fa-sliders-h w-5 group-hover:text-[#00ED64] transition-colors"></i> 
            <span class="tracking-tight">Node Settings</span>
        </a>
    </nav>

    <div class="p-6 border-t border-white/5 mt-auto space-y-3">
        <div class="flex items-center justify-between px-4 py-3 bg-white/5 rounded-2xl border border-white/5 mb-4">
            <div class="flex items-center gap-3">
                <div class="w-2 h-2 bg-[#00ED64] rounded-full animate-pulse"></div>
                <span class="text-[9px] font-black uppercase tracking-widest text-gray-500">Live Sync</span>
            </div>
            <span class="text-[9px] font-black text-[#00ED64]">v2026.1</span>
        </div>
        
        <a href="/logout" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold text-red-400/70 hover:bg-red-500/10 hover:text-red-400 transition-all group">
            <i class="fas fa-power-off w-5 opacity-50 group-hover:opacity-100"></i> 
            <span class="tracking-tight">Terminate Session</span>
        </a>
    </div>

    <!-- Sidebar Toggle Script -->
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('main-sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            const isHidden = sidebar.classList.contains('-translate-x-full');
            
            if (isHidden) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
                document.body.style.overflow = '';
            }
        }
    </script>
</aside>
