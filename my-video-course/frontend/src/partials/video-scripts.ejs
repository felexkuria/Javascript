<script>
// ⚔️ Global Orchestration Context
window.courseName = '<%= courseName %>';
window.videoId = '<%= video ? (video.videoId || video._id || "") : "" %>';
window.chatKey = `chat_${window.courseName}_${window.videoId}`;

document.addEventListener('DOMContentLoaded', function() {
    const videoPlayer = document.getElementById('videoPlayer');
    const markWatchedButton = document.getElementById('markWatchedButton');
    const prevButton = document.getElementById('prevButton');
    const nextButton = document.getElementById('nextButton');
    const quizButton = document.getElementById('quizButton');
    const generateSRTButton = document.getElementById('generateSRTButton');
    const keyHint = document.getElementById('keyHint');
    
    let courseName = window.courseName;
    let videoId = window.videoId;
    let chatHistory = [];
    const chatKey = window.chatKey;
    
    function showKeyHint(text) {
        if (window.showAtlasHint) {
            window.showAtlasHint(text);
        } else if (keyHint) {
            keyHint.textContent = text;
            keyHint.classList.add('visible');
            setTimeout(() => keyHint.classList.remove('visible'), 1000);
        }
    }

    function markVideoAsWatched() {
        return fetch('/api/mark-watched', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ videoId, courseName })
        })
        .then(response => response.json())
        .then(data => {
            const markBtn = document.getElementById('markWatchedButton');
            if (markBtn) {
                markBtn.innerHTML = '<i class="fas fa-check-double text-[#00ED64]"></i> COMPLETED';
                markBtn.classList.add('opacity-50');
                
                // 🚀 Progress Score Pop & Confetti! (Synced with Backend)
                const points = data.pointsAwarded || 0;
                if (points > 0) {
                    window.updateProgressPoints(points);
                } else {
                    // Just show hint if already watched
                    window.showAtlasHint?.('VIDEO SYNCED TO CURRICULUM');
                }
            }
            
            if (window.gamificationSystem) {
                const isLastVideoVal = document.getElementById('isLastVideo')?.value === 'true';
                const isLastInChapterVal = document.getElementById('isLastInChapter')?.value === 'true';
                
                window.gamificationSystem.onVideoCompleted({
                    videoId, 
                    courseName,
                    isLastVideo: isLastVideoVal,
                    isLastInChapter: isLastInChapterVal
                });
            }

            // Check for certification eligibility
            try {
                const nodes = document.querySelectorAll('.curriculum-node');
                const watchedNodes = document.querySelectorAll('.curriculum-node .fa-check, .curriculum-node.active');
                if (watchedNodes.length >= nodes.length) {
                     document.getElementById('claimCertificateBanner')?.classList.remove('hidden');
                }
            } catch (e) {}
        })
        .catch(error => console.error('Error:', error));
    }

    // Event listeners
    const markBtn = document.getElementById('markWatchedButton');
    if (markBtn) {
        markBtn.addEventListener('click', markVideoAsWatched);
    }
    if (quizButton) quizButton.addEventListener('click', startVideoQuiz);
    
    // SRT Generation
    if (generateSRTButton) {
        generateSRTButton.addEventListener('click', async function() {
            this.disabled = true;
            this.innerHTML = '<span>🔄</span> Generating...';
            
            try {
                const response = await fetch('/api/generate-srt', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        videoTitle: '<%= video ? video.title : "" %>',
                        courseName: courseName,
                        videoId: videoId
                    })
                });
                
                const data = await response.json();
                if (data.status === 'processing') {
                    this.innerHTML = '<span>🔄</span> Processing...';
                    setTimeout(() => location.reload(), 3000);
                } else {
                    this.innerHTML = '<span>✅</span> Ready';
                    this.disabled = false;
                }
            } catch (error) {
                console.error('SRT generation failed:', error);
                this.innerHTML = '<span>❌</span> Failed';
                this.disabled = false;
            }
        });
    }
    
    const baseCourse = courseName;
    
    if (nextButton) {
        nextButton.addEventListener('click', async () => {
            try {
                const response = await fetch(`/api/next-video?currentVideoId=${videoId}&courseName=${encodeURIComponent(courseName)}&direction=next`);
                if (response.ok) {
                    const nextVideo = await response.json();
                    const targetId = nextVideo.videoId || nextVideo._id;
                    if (targetId) {
                        window.location.href = `/course/${encodeURIComponent(courseName)}/video/${encodeURIComponent(targetId)}?autoplay=true`;
                    }
                }
            } catch (error) {
                console.error('Error getting next video:', error);
            }
        });
    }

    if (prevButton) {
        prevButton.addEventListener('click', async () => {
            try {
                const response = await fetch(`/api/next-video?currentVideoId=${videoId}&courseName=${encodeURIComponent(courseName)}&direction=prev`);
                if (response.ok) {
                    const prevVideo = await response.json();
                    const targetId = prevVideo.videoId || prevVideo._id;
                    if (targetId) {
                        window.location.href = `/course/${encodeURIComponent(courseName)}/video/${encodeURIComponent(targetId)}`;
                    }
                }
            } catch (error) {
                console.error('Error getting previous video:', error);
            }
        });
    }

    // Keyboard shortcuts
    document.addEventListener('keydown', function(e) {
        if (!videoPlayer || document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA') return;

        const key = e.key.toLowerCase();
        switch(key) {
            case 'f':
                e.preventDefault();
                if (document.fullscreenElement) {
                    document.exitFullscreen();
                    showKeyHint('Exit Fullscreen');
                } else {
                    videoPlayer.requestFullscreen();
                    showKeyHint('Fullscreen');
                    awardShortcutPoints('fullscreen');
                }
                break;
            case 'j':
                e.preventDefault();
                videoPlayer.currentTime = Math.max(0, videoPlayer.currentTime - 10);
                showKeyHint('⏪ -10s');
                awardShortcutPoints('seek_backward');
                break;
            case 'k':
            case ' ':
                e.preventDefault();
                if (videoPlayer.paused) {
                    videoPlayer.play();
                    showKeyHint('▶️ Play');
                } else {
                    videoPlayer.pause();
                    showKeyHint('⏸️ Pause');
                }
                awardShortcutPoints('play_pause');
                break;
            case 'l':
                e.preventDefault();
                videoPlayer.currentTime = Math.min(videoPlayer.duration, videoPlayer.currentTime + 10);
                showKeyHint('⏩ +10s');
                awardShortcutPoints('seek_forward');
                break;
        }
    });

    async function awardShortcutPoints(action) {
        try {
            const response = await fetch('/api/gamification/keyboard-shortcut', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action })
            });
            const data = await response.json();
            if (data.success && data.awarded) {
                window.updateProgressPoints(data.awarded);
            }
        } catch (e) { /* silent fail for shortcuts */ }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // 🎬 AUTO-PLAY NEXT VIDEO + PROGRESS + FULL-SCREEN COMPLETION ENGINE
    // ─────────────────────────────────────────────────────────────────────────

    // ── Auto-Next Overlay injection ──────────────────────────────────────────
    const autoNextOverlay = document.createElement('div');
    autoNextOverlay.id = 'auto-next-overlay';
    autoNextOverlay.style.cssText = [
        'position:fixed', 'inset:0', 'z-index:9999',
        'display:none', 'align-items:center', 'justify-content:center',
        'background:rgba(0,30,43,0.92)', 'backdrop-filter:blur(16px)',
        '-webkit-backdrop-filter:blur(16px)'
    ].join(';');
    autoNextOverlay.innerHTML = `
        <div style="text-align:center;padding:48px;background:rgba(255,255,255,0.03);border:1px solid rgba(0,237,100,0.2);border-radius:32px;max-width:480px;width:90%;box-shadow:0 40px 80px rgba(0,0,0,0.5);">
            <div style="font-size:48px;margin-bottom:16px;">🎉</div>
            <p style="font-size:10px;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:#00ED64;margin-bottom:8px;">LECTURE COMPLETE</p>
            <h2 style="font-size:24px;font-weight:900;color:#fff;margin-bottom:6px;letter-spacing:-0.02em;" id="auto-next-title">Up Next</h2>
            <p style="font-size:11px;font-weight:700;color:#9FB1AD;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:32px;" id="auto-next-subtitle">Loading next lecture...</p>

            <!-- Circular countdown ring -->
            <div style="position:relative;width:88px;height:88px;margin:0 auto 32px;">
                <svg width="88" height="88" style="transform:rotate(-90deg);">
                    <circle cx="44" cy="44" r="38" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="6"/>
                    <circle id="auto-next-ring" cx="44" cy="44" r="38" fill="none" stroke="#00ED64" stroke-width="6"
                        stroke-dasharray="238.76" stroke-dashoffset="0"
                        style="transition:stroke-dashoffset 1s linear;filter:drop-shadow(0 0 6px #00ED64);"/>
                </svg>
                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
                    <span id="auto-next-count" style="font-size:26px;font-weight:900;color:#fff;">5</span>
                </div>
            </div>

            <div style="display:flex;gap:12px;justify-content:center;">
                <button id="auto-next-cancel" style="padding:14px 28px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:16px;color:#9FB1AD;font-size:11px;font-weight:900;letter-spacing:0.15em;text-transform:uppercase;cursor:pointer;transition:all 0.2s;"
                    onmouseover="this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.background='rgba(255,255,255,0.05)'">
                    ✕ Cancel
                </button>
                <button id="auto-next-now" style="padding:14px 28px;background:#00ED64;border:none;border-radius:16px;color:#001E2B;font-size:11px;font-weight:900;letter-spacing:0.15em;text-transform:uppercase;cursor:pointer;box-shadow:0 4px 20px rgba(0,237,100,0.25);transition:all 0.2s;"
                    onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                    ▶ Play Now
                </button>
            </div>
        </div>
    `;
    document.body.appendChild(autoNextOverlay);

    // ── Full-Screen Confetti Burst ────────────────────────────────────────────
    function fireCompletionConfetti() {
        if (!window.confetti) return;
        const MDB_GREEN = '#00ED64';
        const GOLD      = '#FFD700';
        const WHITE     = '#FFFFFF';
        const TEAL      = '#00A345';

        // 1. Central shower
        confetti({ particleCount: 180, spread: 90, origin: { y: 0.45 },
            colors: [MDB_GREEN, GOLD, WHITE, TEAL], scalar: 1.1 });

        // 2. Left cannon
        setTimeout(() => confetti({
            particleCount: 90, angle: 60, spread: 65,
            origin: { x: 0, y: 0.6 },
            colors: [MDB_GREEN, WHITE], scalar: 1.0
        }), 200);

        // 3. Right cannon
        setTimeout(() => confetti({
            particleCount: 90, angle: 120, spread: 65,
            origin: { x: 1, y: 0.6 },
            colors: [MDB_GREEN, GOLD], scalar: 1.0
        }), 200);

        // 4. Top-center starburst
        setTimeout(() => confetti({
            particleCount: 120, spread: 120, startVelocity: 55,
            origin: { x: 0.5, y: 0.1 },
            colors: [MDB_GREEN, WHITE, GOLD, TEAL], scalar: 0.9
        }), 450);

        // 5. Lingering sparkles
        setTimeout(() => confetti({
            particleCount: 60, spread: 60,
            origin: { x: 0.3, y: 0.7 },
            colors: [MDB_GREEN, WHITE], scalar: 0.7, gravity: 0.6
        }), 700);
        setTimeout(() => confetti({
            particleCount: 60, spread: 60,
            origin: { x: 0.7, y: 0.7 },
            colors: [GOLD, WHITE], scalar: 0.7, gravity: 0.6
        }), 750);
    }

    // ── Auto-next navigation ──────────────────────────────────────────────────
    let autoNextTimer  = null;
    let autoNextCancel = false;
    let nextVideoCache = null;

    async function fetchNextVideo() {
        try {
            const res = await fetch(
                `/api/next-video?currentVideoId=${encodeURIComponent(videoId)}&courseName=${encodeURIComponent(courseName)}&direction=next`
            );
            if (!res.ok) return null;
            const data = await res.json();
            return data.error ? null : data;
        } catch (e) { return null; }
    }

    function navigateToNext(nextVideo) {
        const targetId = nextVideo?.videoId || nextVideo?._id;
        if (targetId) {
            window.location.href = `/course/${encodeURIComponent(courseName)}/video/${encodeURIComponent(targetId)}?autoplay=true`;
        }
    }

    async function showAutoNextOverlay() {
        // Pre-fetch next video info
        nextVideoCache = await fetchNextVideo();
        if (!nextVideoCache) {
            // No next video — just do points + completion animation, no overlay
            return;
        }

        const titleEl    = document.getElementById('auto-next-title');
        const subtitleEl = document.getElementById('auto-next-subtitle');
        const countEl    = document.getElementById('auto-next-count');
        const ring       = document.getElementById('auto-next-ring');
        const circumference = 238.76;

        if (titleEl)    titleEl.textContent    = nextVideoCache.title || 'Next Lecture';
        if (subtitleEl) subtitleEl.textContent  = courseName;

        autoNextOverlay.style.display = 'flex';
        autoNextCancel = false;

        let secondsLeft = 5;
        if (countEl) countEl.textContent = secondsLeft;
        if (ring) ring.style.strokeDashoffset = '0';

        // Countdown tick
        autoNextTimer = setInterval(() => {
            if (autoNextCancel) { clearInterval(autoNextTimer); return; }
            secondsLeft--;
            if (countEl) countEl.textContent = secondsLeft;
            // Ring drains as time passes
            if (ring) ring.style.strokeDashoffset = String(circumference * (1 - secondsLeft / 5));

            if (secondsLeft <= 0) {
                clearInterval(autoNextTimer);
                if (!autoNextCancel) {
                    autoNextOverlay.style.display = 'none';
                    navigateToNext(nextVideoCache);
                }
            }
        }, 1000);
    }

    document.getElementById('auto-next-cancel')?.addEventListener('click', () => {
        autoNextCancel = true;
        clearInterval(autoNextTimer);
        autoNextOverlay.style.display = 'none';
        window.showAtlasHint?.('AUTO-PLAY CANCELLED');
    });

    document.getElementById('auto-next-now')?.addEventListener('click', () => {
        autoNextCancel = true;
        clearInterval(autoNextTimer);
        autoNextOverlay.style.display = 'none';
        if (nextVideoCache) navigateToNext(nextVideoCache);
    });

    // ── Video Player Event Hooks ──────────────────────────────────────────────
    if (videoPlayer) {
        let watchedMarked = false;

        // 🔥 VIDEO ENDED: Award Progress Score → Completion Animation → Auto-next overlay
        videoPlayer.addEventListener('ended', async function() {
            // 1. Mark complete & award Progress Score (100 base points)
            await markVideoAsWatched();

            // 2. Fire full-screen completion animation
            fireCompletionConfetti();

            // 3. Show auto-next countdown overlay (fires immediately after completion animation starts)
            setTimeout(() => showAutoNextOverlay(), 600);
        });

        const inputWidget = document.getElementById('floating-chat-input-widget');
        if (inputWidget) {
            inputWidget.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') sendFloatingChatMessage();
            });
        }

        // Expose save function to global scope
        window.saveAiResponseToNotes = function(btn) {
            const rawContent = decodeURIComponent(btn.getAttribute('data-content'));
            const notesBox = document.getElementById('studentNotes');
            if (!notesBox) return;

            const timestamp = new Date().toLocaleString([], { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
            const separator = notesBox.value.trim() ? '\n\n---\n\n' : '';
            const noteEntry = `${separator}📅 [${timestamp}] Tutor Assistant Insight:\n${rawContent}`;

            notesBox.value += noteEntry;
            if (typeof switchLabTab === 'function') switchLabTab('notes');
            if (typeof saveStudentNotes === 'function') saveStudentNotes();

            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check"></i> Saved';
            btn.classList.add('text-[#00ED64]', 'border-[#00ED64]/50');
            setTimeout(() => {
                btn.innerHTML = originalHtml;
                btn.classList.remove('text-[#00ED64]', 'border-[#00ED64]/50');
            }, 2000);
        };

        // Auto-mark at 90% progress (silent, no overlay/confetti)
        videoPlayer.addEventListener('timeupdate', function() {
            if (!videoPlayer.duration) return;
            const watchPercent = (videoPlayer.currentTime / videoPlayer.duration) * 100;
            if (watchPercent >= 90 && !watchedMarked) {
                markVideoAsWatched();
                watchedMarked = true;
            }
        });

        // Auto-play if page was navigated to with ?autoplay=true
        if (new URLSearchParams(window.location.search).get('autoplay') === 'true') {
            videoPlayer.play().catch(() => {/* Browser may block autoplay */});
        }
    }

    window.startVideoQuiz = async function() {
        try {
            const response = await fetch(`/api/quizzes/${videoId}`);
            const data = await response.json();
            if (data.success && data.quiz) {
                window.quizSystem.startQuiz('video-specific', data.quiz);
            } else {
                window.quizSystem.startQuiz('terraform');
            }
        } catch (error) {
            console.error('Error loading video quiz:', error);
            window.quizSystem.startQuiz('terraform');
        }
    };

    // --- Toggle Logic hardening ---
    window.toggleFloatingChatbot = function() {
        const chatbot = document.getElementById('floating-chatbot');
        if (chatbot) {
            const isVisible = chatbot.style.display === 'flex';
            chatbot.style.display = isVisible ? 'none' : 'flex';
            if (!isVisible) {
                // Initial focus for premium UX
                setTimeout(() => document.getElementById('floating-chat-input-widget')?.focus(), 300);
            }
        }
    };

    // Inline onclick is used in video.ejs for the trigger to prevent double execution.

    window.switchLabTab = function(tabId) {
        // Enforce strict !important isolation
        document.querySelectorAll('.lab-tab-btn').forEach(btn => btn.classList.remove('active'));
        document.getElementById('tab-' + tabId)?.classList.add('active');
        
        document.querySelectorAll('.lab-pane').forEach(pane => pane.classList.remove('active'));
        document.getElementById('content-' + tabId)?.classList.add('active');
        
        if (tabId === 'advisor') {
            setTimeout(() => {
                const messages = document.getElementById('floating-chat-messages');
                if (messages) messages.scrollTop = messages.scrollHeight;
                document.getElementById('floating-chat-input')?.focus();
            }, 100);
        }
        
        // Contextual AI Loads
        if (tabId === 'quiz' && typeof loadQuiz === 'function') loadQuiz();
        if (tabId === 'lab' && typeof loadLab === 'function') loadLab();
        if (tabId === 'notes') {
            if (typeof loadStudentNotes === 'function') loadStudentNotes();
            document.getElementById('studentNotes')?.focus();
        }
    };


    // --- Aesthetic AI Chat Logic (Aesthetic Magic Integrated) ---
    window.sendFloatingChatMessage = async function() {
        const inputSidebar = document.getElementById('floating-chat-input');
        const inputWidget = document.getElementById('floating-chat-input-widget');
        const message = (inputSidebar?.value || inputWidget?.value || '').trim();
        
        if (!message) return;
        
        const processMsg = async (targetInput, targetMessagesId) => {
            const messages = document.getElementById(targetMessagesId);
            if (!messages) return;
            
            const userTime = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            const userDiv = document.createElement('div');
            userDiv.className = 'flex flex-col items-end animate-message-in mb-6';
            userDiv.innerHTML = `
                <div class="max-w-[90%] bg-[#00ED64] text-[#001E2B] p-4 rounded-2xl rounded-tr-none text-[13px] font-bold">
                    ${message}
                </div>
                <div class="flex items-center gap-2 mt-2">
                    <div class="text-[9px] font-black text-[#9FB1AD] uppercase tracking-[0.2em] opacity-70">Student • ${userTime}</div>
                    <div class="w-4 h-4 rounded-full bg-white/10 flex items-center justify-center">
                        <i class="fas fa-user text-[8px] text-white/50"></i>
                    </div>
                </div>
            `;
            messages.appendChild(userDiv);
            messages.scrollTop = messages.scrollHeight;
        };

        await processMsg(inputSidebar, 'floating-chat-messages');
        await processMsg(inputWidget, 'floating-chat-messages-widget');

        if (inputSidebar) inputSidebar.value = '';
        if (inputWidget) inputWidget.value = '';
        
        const thinkingId = 'thinking-' + Date.now();
        const addThinking = (targetMessagesId) => {
            const messages = document.getElementById(targetMessagesId);
            if (!messages) return;
            const thinkingDiv = document.createElement('div');
            thinkingDiv.id = thinkingId + '-' + targetMessagesId;
            thinkingDiv.className = 'flex flex-col items-start animate-message-in mb-6';
            thinkingDiv.innerHTML = `
                <div class="bg-white/5 text-[#00ED64] p-3 rounded-2xl rounded-tl-none text-[10px] font-black uppercase tracking-widest flex items-center gap-3">
                    <div class="loader-pulse"></div> Thinking...
                </div>
            `;
            messages.appendChild(thinkingDiv);
            messages.scrollTop = messages.scrollHeight;
        };

        addThinking('floating-chat-messages');
        addThinking('floating-chat-messages-widget');
        
        try {
            const response = await fetch('/api/ai/chatbot', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message, context: { courseTitle: '<%= courseName %>', videoTitle: '<%= video ? video.title : "" %>' } })
            });
            
            const data = await response.json();
            document.getElementById(thinkingId + '-floating-chat-messages')?.remove();
            document.getElementById(thinkingId + '-floating-chat-messages-widget')?.remove();
            
            if (data.response) {
                const addBotMsg = (targetMessagesId) => {
                    const messages = document.getElementById(targetMessagesId);
                    if (!messages) return;
                    
                    const botTime = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                    const botDiv = document.createElement('div');
                    botDiv.className = 'flex flex-col items-start animate-message-in mb-6 group';
                    
                    const htmlContent = window.marked ? marked.parse(data.response) : data.response.replace(/\n text/g, '<br>');
                    
                    botDiv.innerHTML = `
                        <div class="relative max-w-[95%] bg-white/[0.03] border border-white/10 text-[#E7EEEB] p-5 rounded-2xl rounded-tl-none text-[13px] font-medium leading-[1.6] shadow-2xl overflow-x-auto">
                            ${htmlContent}
                        </div>
                        <div class="flex items-center w-full mt-3">
                            <div class="flex items-center gap-3">
                                <div class="w-4 h-4 rounded-full bg-gradient-to-br from-[#00ED64] to-[#00684A] flex items-center justify-center">
                                    <i class="fas fa-bolt text-[8px] text-[#001E2B]"></i>
                                </div>
                                <div class="text-[9px] font-black text-[#00ED64] uppercase tracking-[0.2em] opacity-70">Tutor Assistant • ${botTime}</div>
                            </div>
                            <button onclick="saveAiResponseToNotes(this)" data-content="${encodeURIComponent(data.response)}" class="ml-auto opacity-0 group-hover:opacity-100 transition-opacity text-[9px] font-bold uppercase tracking-wider text-[#9FB1AD] hover:text-[#00ED64] border border-white/10 hover:border-[#00ED64]/30 flex items-center gap-2 bg-white/5 py-1 px-3 rounded-full hover:bg-[#00ED64]/10">
                                <i class="fas fa-bookmark"></i> Save Note
                            </button>
                        </div>
                    `;
                    
                    messages.appendChild(botDiv);
                    
                    if (window.hljs) {
                        botDiv.querySelectorAll('pre code').forEach((block) => {
                            hljs.highlightElement(block);
                            block.parentElement.classList.add('relative', 'group');
                            const copyBtn = document.createElement('button');
                            copyBtn.className = 'absolute top-3 right-3 opacity-0 group-hover:opacity-100 p-2 bg-white/5 hover:bg-white/10 rounded-lg text-white/50 text-[10px] transition-all';
                            copyBtn.innerHTML = '<i class="far fa-copy"></i>';
                            block.parentElement.appendChild(copyBtn);
                            copyBtn.onclick = () => {
                                navigator.clipboard.writeText(block.innerText);
                                copyBtn.innerHTML = '<i class="fas fa-check text-green-400"></i>';
                                setTimeout(() => copyBtn.innerHTML = '<i class="far fa-copy"></i>', 2000);
                            };
                        });
                    }
                    messages.scrollTop = messages.scrollHeight;
                };

                addBotMsg('floating-chat-messages');
                addBotMsg('floating-chat-messages-widget');
            }
        } catch (error) {
            console.error('Chat error:', error);
            document.getElementById(thinkingId)?.remove();
            messages.innerHTML += `
                <div class="p-4 bg-red-500/10 border border-red-500/20 text-red-500 rounded-xl text-xs font-bold mt-4">
                     Error: Assistant Unresponsive.
                </div>
            `;
        }
    };

    // --- AI Learning Lab (To-Dos) Logic ---
    async function loadAITodos() {
        const container = document.getElementById('ai-todo-container');
        if (!container) return;
        
        try {
            const videoTitle = '<%= video ? video.title : "" %>';
            const response = await fetch(`/api/ai/video/todos/${encodeURIComponent(courseName)}/${encodeURIComponent(videoTitle)}`);
            const data = await response.json();
            
            const progResponse = await fetch(`/api/ai/video/todos/progress/${encodeURIComponent(courseName)}/${encodeURIComponent(videoTitle)}`);
            const progData = await progResponse.json();
            const progress = progData.progress || {};

            if (data.todos && data.todos.length > 0) {
                container.innerHTML = data.todos.map((group, gIdx) => `
                    <div class="col-span-2 mb-4">
                        <div class="flex items-center gap-2 mb-4">
                            <div class="w-1 h-4 bg-[#00ED64] rounded-full"></div>
                            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-[#00ED64]">${group.category}</span>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            ${group.items.map((todo, idx) => {
                                const todoId = `${gIdx}_${idx}`;
                                const isCompleted = progress[todoId] && progress[todoId].completed;
                                return `
                                    <div onclick="toggleTodo('${todoId}', ${!isCompleted})" 
                                         class="atlas-card glass p-5 flex items-start gap-4 cursor-pointer hover:bg-white/5 transition-all group ${isCompleted ? 'opacity-50' : ''}">
                                        <div class="w-5 h-5 mt-0.5 rounded-lg border-2 ${isCompleted ? 'bg-[#00ED64] border-[#00ED64]' : 'border-white/10 group-hover:border-[#00ED64]/50'} flex items-center justify-center transition-all shrink-0">
                                            ${isCompleted ? '<i class="fas fa-check text-[#001E2B] text-[8px]"></i>' : ''}
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-[11px] font-bold ${isCompleted ? 'line-through text-[#9FB1AD]' : 'text-white'} leading-relaxed">${todo.text || todo}</p>
                                        </div>
                                    </div>
                                `;
                            }).join('')}
                        </div>
                    </div>
                `).join('');
            }
        } catch (error) { console.error('Todo load error:', error); }
    }

    window.toggleTodo = async function(todoId, completed) {
        try {
            const videoTitle = '<%= video ? video.title : "" %>';
            await fetch('/api/ai/video/todos/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ courseName, videoTitle, todoId, completed })
            });
            loadAITodos();
        } catch (err) { console.error('Todo update failed:', err); }
    };

    if (document.getElementById('refreshTodos')) {
        document.getElementById('refreshTodos').addEventListener('click', async function() {
            const btn = this;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-sync-alt fa-spin mr-2"></i> Analyzing...';
            btn.disabled = true;
            try {
                const videoTitle = <%- JSON.stringify(video ? video.title : "") %>;
                const courseNameStr = <%- JSON.stringify(courseName) %>;
                
                // 1. Force Refresh Todos
                await fetch('/api/ai/video/todos/generate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ courseName: courseNameStr, videoTitle })
                });
                
                // 2. We don't have a "force generate quiz/lab" endpoint yet, 
                // but the active ingestion will trigger on next load.
                // Or we can add specific generation endpoints.
                
                console.log('🔄 Sync complete. Re-provisioning UI nodes...');
                await loadAITodos();
                await loadQuiz();
                await loadLab();
                
                window.showAtlasHint?.('TUTOR ENGINE SYNC COMPLETE');
            } catch (err) { 
                console.error('Tutor Refresh failed:', err); 
                window.showAtlasHint?.('SYNC ERROR');
            }
            finally { btn.innerHTML = originalText; btn.disabled = false; }
        });
    }

    setTimeout(() => { loadAITodos(); }, 500);

    // Achievement popup 
    window.showAchievement = function(icon, title, name, points) {
        const popup = document.getElementById('achievement-popup');
        const iconEl = document.getElementById('achievement-icon');
        const titleEl = document.getElementById('achievement-title');
        const nameEl = document.getElementById('achievement-name');
        const pointsEl = document.getElementById('achievement-points');
        if (popup && iconEl && titleEl && nameEl && pointsEl) {
            iconEl.textContent = icon; titleEl.textContent = title; nameEl.textContent = name; pointsEl.textContent = points;
            popup.classList.add('show');
            
            // Trigger celebration for achievements
            if (points) window.updateProgressPoints(parseInt(points));
            
            setTimeout(() => { popup.classList.remove('show'); }, 4000);
        }
    };

    // --- 🚀 Progress Score Celebration Engine (Enhanced) ---
    window.triggerProgressAnimation = function(points) {
        const pointsCounter = document.getElementById('userPoints');
        if (!pointsCounter) return;

        // 1. Inline celebration burst
        if (window.confetti && points > 50) {
            confetti({
                particleCount: Math.min(points * 1.5, 200),
                spread: 80,
                origin: { y: 0.55 },
                colors: ['#00ED64', '#00684A', '#FFFFFF', '#00A345', '#FFD700']
            });
            setTimeout(() => {
                confetti({ particleCount: 40, angle: 60, spread: 50, origin: { x: 0 }, colors: ['#00ED64'] });
                confetti({ particleCount: 40, angle: 120, spread: 50, origin: { x: 1 }, colors: ['#00ED64'] });
            }, 300);
        }

        // 2. Points Pop Animation
        pointsCounter.classList.remove('points-pop');
        void pointsCounter.offsetWidth;
        pointsCounter.classList.add('points-pop');

        // 3. Floating Increment Text
        const floatingInc = document.createElement('div');
        floatingInc.className = 'points-increment-float';
        floatingInc.innerText = `+${points} Score`;
        pointsCounter.parentElement.appendChild(floatingInc);
        setTimeout(() => floatingInc.remove(), 1200);

        // 4. Hint
        window.showAtlasHint?.(`PROGRESS INCREASE: +${points} Score`);
    };

    window.updateProgressPoints = function(points) {
        if (!points || points <= 0) return;
        
        // 1. Update Video Player Counter (Compatibility)
        const pointsCounter = document.getElementById('userPoints');
        if (pointsCounter) {
            const currentPoints = parseInt(pointsCounter.innerText) || 0;
            pointsCounter.innerText = currentPoints + points;
        }

        // 2. Update Global Sidebar Status
        const sidebarPoints = document.getElementById('sidebar-points');
        const sidebarLevel = document.getElementById('sidebar-level');
        const progressBar = document.getElementById('sidebar-progress-bar');
        
        if (sidebarPoints) {
            const currentTotalPoints = parseInt(sidebarPoints.innerText) || 0;
            const newTotalPoints = currentTotalPoints + points;
            sidebarPoints.innerText = newTotalPoints;
            
            // Recalculate Level & Progress (Neural Core Linear: 1000 XP/LVL)
            const newLevel = Math.floor(newTotalPoints / 1000) + 1;
            const progress = Math.min(100, Math.max(0, ((newTotalPoints % 1000) / 10) ));
            
            if (sidebarLevel) {
                const oldLevel = parseInt(sidebarLevel.innerText) || 1;
                if (newLevel > oldLevel) {
                    sidebarLevel.innerText = newLevel;
                    // Trigger "Level Up" Celebration via Universal Engine
                    if (window.gamificationSystem) {
                        window.gamificationSystem.triggerConfetti('high');
                        window.showAtlasHint?.(`LEVEL REACHED: LEVEL ${newLevel}!`);
                    } else if (window.confetti) {
                        confetti({ particleCount: 200, spread: 90, origin: { y: 0.5 }, colors: ['#00ED64', '#FFD700'] });
                    }
                }
            }
            
            if (progressBar) {
                progressBar.style.width = `${progress}%`;
            }
        }

        // 3. Trigger Visual Effects
        window.triggerProgressAnimation(points);
    };
    
    document.addEventListener('achievementUnlocked', (e) => {
        const { icon, title, name, points } = e.detail;
        showAchievement(icon || '🏆', title || 'Achievement Unlocked!', name, points);
    });

    // --- Notes Logic (High Performance Persistence) ---
    const notesKey = `notes_${courseName}_${videoId}`;
    const notesArea = document.getElementById('studentNotes');
    const saveBtn = document.getElementById('saveNotesBtn');
    const saveFeedback = document.getElementById('saveFeedback');

    window.saveStudentNotes = function() {
        if (!notesArea) return;
        
        const originalText = document.getElementById('saveText').innerText;
        document.getElementById('saveText').innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Persisting...';
        saveBtn.disabled = true;

        try {
            localStorage.setItem(notesKey, notesArea.value);
            
            setTimeout(() => {
                document.getElementById('saveText').innerText = 'PERSIST NOTES';
                saveBtn.disabled = false;
                saveFeedback.classList.remove('hidden');
                setTimeout(() => saveFeedback.classList.add('hidden'), 3000);
            }, 800);
        } catch (e) {
            console.error('Persistence failure:', e);
            document.getElementById('saveText').innerText = 'RETRY SAVE';
            saveBtn.disabled = false;
        }
    };

    window.loadStudentNotes = function() {
        if (!notesArea) return;
        const saved = localStorage.getItem(notesKey);
        if (saved) notesArea.value = saved;
    };

    // Auto-load on boot
    loadStudentNotes();

    // --- ASSESSMENT & LAB ORCHESTRATION ---
    window.loadQuiz = async function() {
        const container = document.getElementById('quiz-container');
        if (!container) return;
        
        container.innerHTML = `
            <div class="py-20 text-center">
                <div class="loader-pulse mx-auto mb-6"></div>
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#00ED64]">Calibrating Knowledge Check...</p>
                <p class="text-[8px] font-bold text-[#9FB1AD]/40 uppercase tracking-widest mt-2 px-10">Tutor Assistant is analyzing module content</p>
            </div>
        `;
        
        try {
            const response = await fetch(`/api/quizzes/${videoId}?courseName=${encodeURIComponent(courseName)}`);
            const data = await response.json();
            
            if (data.success && data.quiz && data.quiz.length > 0) {
                renderQuiz(data.quiz);
            } else {
                container.innerHTML = `
                    <div class="py-20 text-center opacity-40">
                        <i class="fas fa-satellite-dish text-2xl mb-4"></i>
                        <p class="text-[10px] font-black uppercase tracking-widest text-[#00ED64]">Calibrating Assessment Vectors...</p>
                        <p class="text-[8px] font-bold uppercase tracking-widest mt-2">Connecting to AI learning nodes</p>
                    </div>
                `;
            }
        } catch (error) {
            container.innerHTML = `<p class="text-[10px] text-red-500 font-bold uppercase tracking-widest text-center py-20">Engine Failure: Assessment Load Aborted</p>`;
        }
    };

    window.loadLab = async function() {
        const container = document.getElementById('lab-container');
        if (!container) return;

        container.innerHTML = `
            <div class="py-20 text-center">
                <i class="fas fa-terminal fa-spin text-2xl mb-6 text-[#00ED64] opacity-50"></i>
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#00ED64]">Provisioning Engineering Lab...</p>
                <p class="text-[8px] font-bold text-[#9FB1AD]/40 uppercase tracking-widest mt-2 px-10">Constructing technical objectives from module architecture</p>
            </div>
        `;
        
        try {
            const response = await fetch(`/api/ai/lab/${encodeURIComponent(courseName)}/${videoId}`);
            const data = await response.json();
            
            if (data.success && data.lab) {
                renderLab(data.lab);
            } else {
                container.innerHTML = `
                    <div class="py-20 text-center opacity-40">
                        <i class="fas fa-microchip text-2xl mb-4"></i>
                        <p class="text-[10px] font-black uppercase tracking-widest text-[#00ED64]">Provisioning Engineering Lab...</p>
                        <p class="text-[8px] font-bold uppercase tracking-widest mt-2">Establishing secure learning node connection</p>
                    </div>
                `;
            }
        } catch (error) {
            container.innerHTML = `<p class="text-[10px] text-red-500 font-bold uppercase tracking-widest text-center py-20">Engine Failure: Lab Provisioning Timeout</p>`;
        }
    };

    function renderQuiz(questions) {
        const container = document.getElementById('quiz-container');
        let score = 0;

        function showQuestion(idx) {
            const q = questions[idx];
            container.innerHTML = `
                <div class="px-2">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="text-[9px] font-black text-[#00ED64] uppercase tracking-[0.2em] bg-[#00ED64]/10 border border-[#00ED64]/20 px-3 py-1 rounded-md">Step ${idx + 1}/${questions.length}</div>
                        <div class="h-px flex-1 bg-white/5"></div>
                    </div>
                    <h3 class="text-lg font-black text-white leading-tight mb-8">${q.question}</h3>
                    <div class="space-y-4 mb-10">
                        ${q.options.map((opt, i) => `
                            <button onclick="handleQuizAnswer(${i}, ${idx})" class="quiz-option-btn w-full text-left p-5 glass border border-white/5 rounded-2xl hover:bg-white/5 hover:border-[#00ED64]/30 transition-all flex items-center gap-4 group">
                                <div class="w-6 h-6 rounded-lg bg-white/5 flex items-center justify-center text-[10px] font-black group-hover:bg-[#00ED64] group-hover:text-[#001E2B] transition-all">${String.fromCharCode(65 + i)}</div>
                                <span class="text-[13px] font-bold text-white/80 group-hover:text-white transition-all">${opt}</span>
                            </button>
                        `).join('')}
                    </div>
                </div>
            `;
            
            window.handleQuizAnswer = (selectedIdx, currentIdx) => {
                const q = questions[currentIdx];
                const isCorrect = selectedIdx === q.correct;
                if (isCorrect) score++;
                
                const optionBtns = document.querySelectorAll('.quiz-option-btn');
                optionBtns.forEach((btn, i) => {
                    btn.disabled = true;
                    if (i === q.correct) btn.classList.add('border-[#00ED64]/50', 'bg-[#00ED64]/10');
                    else if (i === selectedIdx && !isCorrect) btn.classList.add('border-red-500/50', 'bg-red-500/10');
                });

                const feedback = document.createElement('div');
                feedback.className = `mt-6 p-6 rounded-2xl text-[12px] leading-relaxed animate-in fade-in duration-300 ${isCorrect ? 'bg-[#00ED64]/5 border border-[#00ED64]/20 text-[#00ED64]' : 'bg-red-500/5 border border-red-500/20 text-red-500'}`;
                feedback.innerHTML = `<div class="font-black uppercase tracking-widest mb-2">${isCorrect ? '✅ Answer Confirmed' : '❌ Validation Failure'}</div>${q.explanation}`;
                container.querySelector('.px-2').appendChild(feedback);

                const nextBtn = document.createElement('button');
                nextBtn.className = 'btn-atlas btn-atlas-primary w-full mt-8 py-4';
                nextBtn.innerText = currentIdx + 1 < questions.length ? 'NEXT STEP' : 'EXECUTE FINAL GRADE';
                nextBtn.onclick = () => {
                    if (currentIdx + 1 < questions.length) showQuestion(currentIdx + 1);
                    else submitQuiz(score, questions.length);
                };
                container.querySelector('.px-2').appendChild(nextBtn);
            };
        }
        showQuestion(0);
    }

    async function submitQuiz(score, total) {
        const container = document.getElementById('quiz-container');
        const percentage = Math.round((score / total) * 100);
        
        container.innerHTML = `
            <div class="text-center py-20 animate-in zoom-in duration-500">
                <div class="w-24 h-24 rounded-full bg-[#00ED64]/10 border border-[#00ED64]/30 flex items-center justify-center mx-auto mb-8">
                    <span class="text-4xl font-black text-[#00ED64]">${percentage}%</span>
                </div>
                <h4 class="text-xl font-black text-white uppercase tracking-tight mb-2">${percentage >= 70 ? 'GOAL ACHIEVED' : 'SCORE SUB-OPTIMAL'}</h4>
                <p class="text-[10px] font-black text-[#9FB1AD] uppercase tracking-[0.2em] mb-12">Grade: ${score}/${total} Vectors Verified</p>
                <button onclick="loadQuiz()" class="btn-atlas border border-white/10 w-full py-4 text-[11px] font-black tracking-widest mb-4">RE-INITIALIZE ASSESSMENT</button>
            </div>
        `;

        try {
            const response = await fetch('/api/quizzes/complete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ videoId, score, totalQuestions: total })
            });
            const data = await response.json();
            if (data.success) {
                // Unified trigger
                window.updateProgressPoints(percentage * 2);
            }
        } catch (e) { console.error('Grade sync error:', e); }
    }

    function renderLab(lab) {
        const container = document.getElementById('lab-container');
        container.innerHTML = `
            <div class="px-2">
                <div class="flex items-center gap-3 mb-6">
                    <span class="technical-label text-[#00ED64]">Module Analysis</span>
                    <div class="h-px flex-1 bg-white/5"></div>
                    <span class="technical-label opacity-40">${lab.difficulty}</span>
                </div>
                <h3 class="text-2xl font-black text-white tracking-tight mb-4">${lab.title}</h3>
                <p class="text-[13px] text-[#9FB1AD] leading-relaxed mb-8">${lab.scenario}</p>
                
                <div class="atlas-card glass p-6 mb-8 border-l-4 border-[#00ED64]">
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-white mb-4">Tactical Objectives</h4>
                    <ul class="space-y-3">
                        ${lab.objectives.map(obj => `
                            <li class="flex items-start gap-3 text-[12px] font-bold text-white/70">
                                <i class="fas fa-dot-circle text-[#00ED64] mt-1 text-[8px]"></i>
                                <span>${obj}</span>
                            </li>
                        `).join('')}
                    </ul>
                </div>

                <div class="space-y-8 mb-12">
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-[#9FB1AD]">Execution Steps</h4>
                    <div class="space-y-6">
                        ${lab.steps.map((step, i) => `
                            <div class="flex gap-4">
                                <div class="w-5 h-5 rounded-full bg-white/5 border border-white/10 flex items-center justify-center shrink-0 text-[9px] font-black text-[#9FB1AD]">${i + 1}</div>
                                <p class="text-[12px] font-medium text-white/80">${step}</p>
                            </div>
                        `).join('')}
                    </div>
                </div>

                <button id="verifyLabBtn" onclick="completeLab('${lab.title}')" class="btn-atlas btn-atlas-primary w-full py-5 flex items-center justify-center gap-3 shadow-[0_4px_20px_rgba(0,237,100,0.15)]">
                    <i class="fas fa-satellite-dish"></i> VERIFY DEPLOYMENT
                </button>
            </div>
        `;
    }

    window.completeLab = async function(labId) {
        const btn = document.getElementById('verifyLabBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> PROBING SYSTEM...';
        
        try {
            const response = await fetch('/api/quizzes/lab/complete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ labId, points: 200 })
            });
            const data = await response.json();
            
            if (data.success) {
                btn.innerHTML = '<i class="fas fa-check-double"></i> COURSE VERIFIED';
                btn.className = 'btn-atlas w-full py-5 flex items-center justify-center gap-3 bg-gradient-to-r from-[#00ED64] to-[#00A345] text-[#001E2B] rounded-2xl';
                window.updateProgressPoints(200);
            }
        } catch (e) {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-satellite-dish"></i> RETRY VERIFICATION';
        }
    }

    // --- ARCHITECT CERTIFICATION SYSTEM ---
    window.generateArchitectCertificate = async function() {
        const btn = document.getElementById('claimCertBtn');
        const originalHtml = btn.innerHTML;
        
        btn.disabled = true;
        btn.innerHTML = `
            <i class="fas fa-circle-notch fa-spin"></i>
            <span>PROVISIONING CREDENTIALS...</span>
        `;
        
        try {
            const token = localStorage.getItem('accessToken');
            const response = await fetch('/api/certificates/generate', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ courseId: courseName })
            });
            
            const data = await response.json();
            
            if (data.success) {
                btn.innerHTML = `
                    <i class="fas fa-check-double"></i>
                    <span>CERTIFICATE ISSUED</span>
                `;
                btn.className = 'w-full py-4 bg-[#E7EEEB] text-[#00684A] rounded-xl text-[11px] font-black tracking-[0.2em] uppercase transition-all flex items-center justify-center gap-2';
                
                window.updateProgressPoints(500);
                
                // Redirect to certificates page after delay
                setTimeout(() => {
                    window.location.href = '/certificates';
                }, 2000);
            } else {
                throw new Error(data.message);
            }
        } catch (err) {
            console.error('Certification Error:', err);
            btn.disabled = false;
            btn.innerHTML = `
                <i class="fas fa-exclamation-triangle"></i>
                <span>VERIFICATION FAILED</span>
            `;
            setTimeout(() => {
                btn.innerHTML = originalHtml;
            }, 3000);
        }
    };

    // Sidebar and Accordion Global Controllers
    window.toggleSideLab = function() {
        const parent = document.querySelector('.command-center');
        const btnText = document.getElementById('sideLabBtnText');
        const btnIcon = document.getElementById('sideLabBtnIcon');
        
        if (parent.classList.contains('sidebar-collapsed')) {
            parent.classList.remove('sidebar-collapsed');
            if (btnText) btnText.innerText = 'Collapse Lab';
            if (btnIcon) btnIcon.className = 'fas fa-arrow-right';
        } else {
            parent.classList.add('sidebar-collapsed');
            if (btnText) btnText.innerText = 'Expand Lab';
            if (btnIcon) btnIcon.className = 'fas fa-arrow-left';
        }
    };

    window.toggleSectionGroup = function(headerEl) {
        const groupEl = headerEl.closest('.section-group');
        if (groupEl) groupEl.classList.toggle('expanded');
    };

    // Final Theme Sync and Ingestion
    document.documentElement.classList.add('dark');
    
    // ⚔️ Proactive Ingestion: Trigger assessment provisioning on load
    setTimeout(() => {
        if (typeof loadQuiz === 'function') loadQuiz();
        if (typeof loadLab === 'function') loadLab();
    }, 800);
});
</script>