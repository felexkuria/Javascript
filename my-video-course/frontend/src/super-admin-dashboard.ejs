<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super Admin — Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        /* ── Layout ──────────────────────────────────── */
        body { background: #F9FBFA; color: #001E2B; font-family: 'Inter', sans-serif; margin: 0; }
        .dark body { background: #001E2B; color: #E8EDEB; }

        .root { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }

        /* ── Sidebar ─────────────────────────────────── */
        .sidebar {
            background: #001E2B;
            color: #fff;
            display: flex;
            flex-direction: column;
            padding: 28px 20px;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            border-right: 1px solid rgba(0,237,100,0.1);
        }
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 17px;
            font-weight: 800;
            color: #00ED64;
            margin-bottom: 36px;
            letter-spacing: -0.02em;
        }
        .sidebar-brand .leaf { font-size: 22px; }
        .sb-group-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: rgba(255,255,255,0.3);
            margin: 20px 0 8px;
        }
        .sb-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.15s;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
            border-left: 3px solid transparent;
        }
        .sb-item:hover { background: rgba(255,255,255,0.06); color: #fff; }
        .sb-item.active { background: rgba(0,237,100,0.1); color: #00ED64; border-left-color: #00ED64; font-weight: 600; }
        .sb-item i { width: 16px; text-align: center; }
        .sb-badge {
            margin-left: auto;
            background: rgba(0,237,100,0.15);
            color: #00ED64;
            font-size: 10px;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 99px;
        }
        .sidebar-footer {
            margin-top: auto;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        /* ── Main ────────────────────────────────────── */
        .main { padding: 36px 40px; overflow-y: auto; }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 32px;
        }
        .page-title { font-size: 30px; font-weight: 800; letter-spacing: -0.03em; }
        .page-subtitle { color: #5C6B74; font-size: 14px; margin-top: 4px; }
        .shield-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(0,237,100,0.08);
            color: #00684A;
            border: 1px solid rgba(0,237,100,0.2);
            border-radius: 99px;
            padding: 6px 16px;
            font-size: 12px;
            font-weight: 700;
        }

        /* ── Panel ───────────────────────────────────── */
        .panel {
            background: #fff;
            border-radius: 16px;
            border: 1px solid #C8D5CE;
            margin-bottom: 28px;
            overflow: hidden;
        }
        .dark .panel { background: #0D2137; border-color: #1C3A52; }
        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 28px;
            border-bottom: 1px solid #C8D5CE;
        }
        .dark .panel-header { border-bottom-color: #1C3A52; }
        .panel-title {
            font-size: 15px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .panel-icon { font-size: 16px; color: #00684A; }

        /* ── Stats Grid ──────────────────────────────── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }
        .stat-card {
            background: #fff;
            border: 1px solid #C8D5CE;
            border-radius: 14px;
            padding: 22px 24px;
            position: relative;
            overflow: hidden;
        }
        .dark .stat-card { background: #0D2137; border-color: #1C3A52; }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
        }
        .stat-card.green::before  { background: #00ED64; }
        .stat-card.blue::before   { background: #016BF8; }
        .stat-card.orange::before { background: #FFA500; }
        .stat-card.red::before    { background: #C12A2A; }
        .stat-icon { font-size: 28px; margin-bottom: 10px; }
        .stat-val { font-size: 32px; font-weight: 800; letter-spacing: -0.03em; line-height: 1; }
        .stat-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #5C6B74; margin-top: 6px; }
        .stat-trend { position: absolute; top: 16px; right: 16px; font-size: 11px; background: rgba(0,237,100,0.1); color: #00684A; padding: 2px 8px; border-radius: 99px; font-weight: 700; }

        /* ── Table ───────────────────────────────────── */
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th {
            text-align: left;
            padding: 12px 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #5C6B74;
            background: #F9FBFA;
            border-bottom: 1px solid #C8D5CE;
        }
        .dark .data-table th { background: #0A1929; border-color: #1C3A52; }
        .data-table td {
            padding: 14px 20px;
            font-size: 13px;
            border-bottom: 1px solid #E8EDEB;
            vertical-align: middle;
        }
        .dark .data-table td { border-color: #1C3A52; }
        .data-table tr:last-child td { border-bottom: none; }
        .data-table tr:hover td { background: rgba(0,237,100,0.03); }

        /* ── Badges ──────────────────────────────────── */
        .badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 99px; font-size: 11px; font-weight: 700; }
        .badge-green  { background: rgba(0,237,100,0.12); color: #00684A; }
        .badge-blue   { background: rgba(1,107,248,0.1); color: #016BF8; }
        .badge-gray   { background: rgba(92,107,116,0.12); color: #3D4F58; }
        .badge-red    { background: rgba(193,42,42,0.1); color: #C12A2A; }
        .badge-orange { background: rgba(255,165,0,0.12); color: #944F01; }

        /* Active pulse */
        .pulse-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #00ED64;
            display: inline-block;
            position: relative;
            animation: pulse-ring 1.8s ease-out infinite;
        }
        @keyframes pulse-ring {
            0%   { box-shadow: 0 0 0 0 rgba(0,237,100,0.6); }
            70%  { box-shadow: 0 0 0 8px rgba(0,237,100,0); }
            100% { box-shadow: 0 0 0 0 rgba(0,237,100,0); }
        }

        /* ── Avatar ──────────────────────────────────── */
        .avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #00684A;
            color: #00ED64;
            font-size: 13px;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            text-transform: uppercase;
        }

        /* ── Search bar ──────────────────────────────── */
        .search-input {
            padding: 8px 14px;
            border: 1px solid #C8D5CE;
            border-radius: 8px;
            font-size: 13px;
            background: #F9FBFA;
            color: #001E2B;
            outline: none;
            width: 220px;
            transition: border-color 0.2s;
        }
        .search-input:focus { border-color: #00684A; }

        /* ── Progress bar ────────────────────────────── */
        .s3-track { height: 8px; background: #E8EDEB; border-radius: 99px; overflow: hidden; }
        .s3-fill  { height: 100%; border-radius: 99px; background: linear-gradient(90deg, #00684A, #00ED64); transition: width 0.5s; }

        /* ── Action btns ─────────────────────────────── */
        .btn-xs {
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            border: 1px solid;
            cursor: pointer;
            transition: all 0.15s;
            text-decoration: none;
        }
        .btn-danger-xs { border-color: #C12A2A; color: #C12A2A; background: rgba(193,42,42,0.06); }
        .btn-danger-xs:hover { background: #C12A2A; color: #fff; }
        .btn-green-xs { border-color: #00684A; color: #00684A; background: rgba(0,104,74,0.06); }
        .btn-green-xs:hover { background: #00684A; color: #fff; }
        .btn-warn-xs { border-color: #944F01; color: #944F01; background: rgba(148,79,1,0.06); }
        .btn-warn-xs:hover { background: #944F01; color: #fff; }

        /* ── Section nav ─────────────────────────────── */
        .section { display: none; }
        .section.active { display: block; }

        @media (max-width: 1100px) {
            .stats-row { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>
<div class="root">
    <!-- ────── SIDEBAR ────── -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <span class="leaf">🍃</span>
            <div>Multitouch <span style="opacity:.6;">Admin</span></div>
        </div>

        <div class="sb-group-label">Overview</div>
        <button class="sb-item active" onclick="showSection('stats', this)">
            <i class="fas fa-chart-bar"></i> Global Stats
        </button>

        <div class="sb-group-label">Management</div>
        <button class="sb-item" onclick="showSection('courses', this)">
            <i class="fas fa-database"></i> Courses
            <span class="sb-badge"><%= courses.length %></span>
        </button>
        <button class="sb-item" onclick="showSection('users', this)">
            <i class="fas fa-users"></i> Users
            <span class="sb-badge"><%= allUsers.length %></span>
        </button>

        <div class="sb-group-label">Infrastructure</div>
        <button class="sb-item" onclick="showSection('s3', this)">
            <i class="fas fa-hard-drive"></i> S3 Auditor
        </button>
        <button class="sb-item" onclick="showSection('sessions', this)">
            <i class="fas fa-shield-halved"></i> Live Sessions
            <% if (activeSessions.length > 0) { %>
                <span class="sb-badge" style="background:rgba(0,237,100,0.3);"><%= activeSessions.length %></span>
            <% } %>
        </button>

        <div class="sb-group-label">Quick Links</div>
        <a href="/admin/course-manager" class="sb-item">
            <i class="fas fa-layer-group"></i> Course Manager
        </a>
        <a href="/teacher/dashboard" class="sb-item">
            <i class="fas fa-chalkboard-teacher"></i> Teacher Dashboard
        </a>

        <div class="sidebar-footer">
            <a href="/logout" class="sb-item" style="color: #ff3b30;">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </aside>

    <!-- ────── MAIN ────── -->
    <main class="main">
        <div class="page-header">
            <div>
                <h1 class="page-title">Super Admin</h1>
                <p class="page-subtitle">Multitouch Academy — Full system control panel</p>
            </div>
            <div class="shield-badge">
                <i class="fas fa-shield-halved"></i>
                <%= user.email %>
            </div>
        </div>

        <!-- ═══════════════════════════════════════ -->
        <!-- SECTION: GLOBAL STATS                  -->
        <!-- ═══════════════════════════════════════ -->
        <div id="sec-stats" class="section active">
            <div class="stats-row">
                <div class="stat-card green">
                    <div class="stat-icon">🎓</div>
                    <div class="stat-val"><%= stats.totalStudents %></div>
                    <div class="stat-label">Total Students</div>
                    <span class="stat-trend">↑ Live</span>
                </div>
                <div class="stat-card blue">
                    <div class="stat-icon">👨‍🏫</div>
                    <div class="stat-val"><%= stats.totalTeachers %></div>
                    <div class="stat-label">Total Teachers</div>
                </div>
                <div class="stat-card orange">
                    <div class="stat-icon">📚</div>
                    <div class="stat-val"><%= stats.totalCourses %></div>
                    <div class="stat-label">Total Courses</div>
                </div>
                <div class="stat-card red">
                    <div class="stat-icon">💾</div>
                    <div class="stat-val"><%= stats.totalS3GB %></div>
                    <div class="stat-label">S3 Storage (GB)</div>
                </div>
            </div>

            <!-- Quick overview table -->
            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title"><i class="fas fa-bolt panel-icon"></i> Recent Courses</div>
                    <button class="btn-xs btn-green-xs" onclick="showSection('courses', document.querySelector('.sb-item:nth-child(4)'))">View All</button>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Instructor</th>
                            <th>Sections</th>
                            <th>Students Enrolled</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% (courses || []).slice(0, 5).forEach(c => { %>
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="avatar" style="background:#00684A;"><%= (c.title || '?')[0].toUpperCase() %></div>
                                    <div>
                                        <div style="font-weight:600;font-size:13px;"><%= c.title %></div>
                                        <div style="font-size:11px;color:#5C6B74;"><%= c.slug %></div>
                                    </div>
                                </div>
                            </td>
                            <td style="color:#5C6B74;"><%= c.instructorId || 'Unknown' %></td>
                            <td><span class="badge badge-blue"><%= (c.sections || []).length %> sections</span></td>
                            <td><strong><%= c.enrollmentCount || 0 %></strong></td>
                            <td>
                                <% if (c.isPublished) { %>
                                    <span class="badge badge-green"><i class="fas fa-circle" style="font-size:6px;"></i> Published</span>
                                <% } else { %>
                                    <span class="badge badge-gray">Draft</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ═══════════════════════════════════════ -->
        <!-- SECTION: COURSE MANAGEMENT             -->
        <!-- ═══════════════════════════════════════ -->
        <div id="sec-courses" class="section">
            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title"><i class="fas fa-database panel-icon"></i> Course Registry</div>
                    <a href="/admin/course-manager" class="btn-xs btn-green-xs"><i class="fas fa-plus"></i> New Course</a>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Course Title</th>
                            <th>Instructor</th>
                            <th>Sections / Lectures</th>
                            <th>Enrolled</th>
                            <th>Level</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% (courses || []).forEach(c => { %>
                        <tr id="course-row-<%= c._id %>">
                            <td>
                                <div style="font-weight:600;"><%= c.title %></div>
                                <div style="font-size:11px;color:#5C6B74;"><%= c.category || 'Uncategorised' %></div>
                            </td>
                            <td style="font-size:12px;color:#5C6B74;"><%= c.instructorId || '—' %></td>
                            <td>
                                <span class="badge badge-blue"><%= (c.sections || []).length %> §</span>
                                <span class="badge badge-gray" style="margin-left:4px;"><%= c.lectureCount %> lectures</span>
                            </td>
                            <td><strong><%= c.enrollmentCount %></strong></td>
                            <td>
                                <span class="badge <%= c.level === 'beginner' ? 'badge-green' : c.level === 'advanced' ? 'badge-red' : 'badge-orange' %>">
                                    <%= c.level || 'intermediate' %>
                                </span>
                            </td>
                            <td style="display:flex;gap:6px;">
                                <a href="/teacher/course-editor/<%= c._id %>" class="btn-xs btn-green-xs"><i class="fas fa-pen"></i> Edit</a>
                                <button class="btn-xs btn-danger-xs" onclick="deleteCourse('<%= c._id %>', this)"><i class="fas fa-trash"></i> Delete</button>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ═══════════════════════════════════════ -->
        <!-- SECTION: USER MANAGEMENT               -->
        <!-- ═══════════════════════════════════════ -->
        <div id="sec-users" class="section">
            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title"><i class="fas fa-users panel-icon"></i> User Directory</div>
                    <input class="search-input" type="text" id="userSearch" placeholder="🔍 Search by name or email…" oninput="filterUsers()">
                </div>
                <table class="data-table" id="userTable">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Points</th>
                            <th>Enrolled Courses</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% (allUsers || []).forEach(u => { %>
                        <tr id="user-row-<%= u._id %>" class="user-row" data-name="<%= (u.name || '').toLowerCase() %>" data-email="<%= (u.email || '').toLowerCase() %>">
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="avatar" style="background:<%= u.role==='teacher'?'#016BF8':'#00684A' %>;">
                                        <%= (u.name || u.email || '?')[0].toUpperCase() %>
                                    </div>
                                    <div>
                                        <div style="font-weight:600;"><%= u.name || 'Unnamed' %></div>
                                        <div style="font-size:11px;color:#5C6B74;">Joined <%= new Date(u.createdAt).toLocaleDateString('en-US',{month:'short',year:'numeric'}) %></div>
                                    </div>
                                </div>
                            </td>
                            <td style="font-size:12px;color:#5C6B74;"><%= u.email %></td>
                            <td>
                                <span class="badge <%= u.role==='admin'?'badge-red':u.role==='teacher'?'badge-blue':'badge-green' %>">
                                    <%= u.role || 'student' %>
                                </span>
                            </td>
                            <td><strong><%= u.points || 0 %></strong> XP</td>
                            <td><%= (u.enrolledCourses || []).length %></td>
                            <td>
                                <% if (u.isDeactivated) { %>
                                    <span class="badge badge-red">Deactivated</span>
                                <% } else { %>
                                    <span class="badge badge-green"><span class="pulse-dot" style="margin-right:4px;"></span> Active</span>
                                <% } %>
                            </td>
                            <td style="display:flex;gap:6px;">
                                <% if (u.email !== 'engineerfelex@gmail.com') { %>
                                    <% if (u.isDeactivated) { %>
                                        <button class="btn-xs btn-green-xs" onclick="toggleUser('<%= u._id %>', false, this)"><i class="fas fa-user-check"></i> Restore</button>
                                    <% } else { %>
                                        <button class="btn-xs btn-warn-xs" onclick="toggleUser('<%= u._id %>', true, this)"><i class="fas fa-user-slash"></i> Kick</button>
                                    <% } %>
                                <% } else { %>
                                    <span style="font-size:11px;color:#5C6B74;">Super Admin</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ═══════════════════════════════════════ -->
        <!-- SECTION: S3 STORAGE AUDITOR            -->
        <!-- ═══════════════════════════════════════ -->
        <div id="sec-s3" class="section">
            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title"><i class="fas fa-hard-drive panel-icon"></i> S3 Storage Auditor</div>
                    <div style="font-size:12px;color:#5C6B74;">Bucket: <strong>video-course-app-video-bucket-prod-6m5k2til</strong></div>
                </div>

                <% if ((s3Storage || []).length === 0) { %>
                    <div style="padding:48px;text-align:center;color:#5C6B74;">
                        <i class="fas fa-bucket" style="font-size:40px;margin-bottom:16px;opacity:.3;"></i>
                        <p>No S3 data available — bucket may be empty or credentials need review.</p>
                    </div>
                <% } else { %>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Teacher / Prefix</th>
                            <th>Storage Used</th>
                            <th style="width:40%;">Usage Bar</th>
                            <th>% of Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% (s3Storage || []).forEach(s => { %>
                        <% const pct = stats.totalS3Bytes > 0 ? Math.round((s.bytes / stats.totalS3Bytes) * 100) : 0; %>
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:8px;">
                                    <div class="avatar" style="background:#3D4F58;width:28px;height:28px;font-size:11px;"><%= s.name[0] %></div>
                                    <strong><%= s.name %></strong>
                                </div>
                            </td>
                            <td>
                                <strong><%= s.mb %> MB</strong>
                                <div style="font-size:11px;color:#5C6B74;"><%= (s.bytes / 1024 / 1024 / 1024).toFixed(3) %> GB</div>
                            </td>
                            <td>
                                <div class="s3-track">
                                    <div class="s3-fill" style="width:<%= pct %>%;"></div>
                                </div>
                            </td>
                            <td><strong><%= pct %>%</strong></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>

                <div style="padding:20px 28px;background:#F9FBFA;border-top:1px solid #C8D5CE;display:flex;gap:32px;">
                    <div><span style="font-size:11px;color:#5C6B74;text-transform:uppercase;letter-spacing:.06em;">Total Used</span><br><strong><%= stats.totalS3GB %> GB</strong></div>
                    <div><span style="font-size:11px;color:#5C6B74;text-transform:uppercase;letter-spacing:.06em;">Contributors</span><br><strong><%= (s3Storage || []).length %></strong></div>
                </div>
                <% } %>
            </div>
        </div>

        <!-- ═══════════════════════════════════════ -->
        <!-- SECTION: LIVE SESSION MONITOR          -->
        <!-- ═══════════════════════════════════════ -->
        <div id="sec-sessions" class="section">
            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title"><i class="fas fa-shield-halved panel-icon"></i> Live Session Monitor</div>
                    <div style="display:flex;align-items:center;gap:8px;font-size:12px;color:#5C6B74;">
                        <span class="pulse-dot"></span>
                        <%= activeSessions.length %> active in last 30 min
                    </div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Last Seen</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if ((activeSessions || []).length === 0) { %>
                        <tr>
                            <td colspan="4" style="text-align:center;padding:40px;color:#5C6B74;">No active sessions in the last 30 minutes.</td>
                        </tr>
                        <% } %>
                        <% (activeSessions || []).forEach(u => { %>
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="avatar"><%= (u.name||u.email||'?')[0].toUpperCase() %></div>
                                    <div>
                                        <div style="font-weight:600;"><%= u.name || 'Unnamed' %></div>
                                        <div style="font-size:11px;color:#5C6B74;"><%= u.email %></div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge <%= u.role==='teacher'?'badge-blue':'badge-green' %>"><%= u.role || 'student' %></span></td>
                            <td style="font-size:12px;color:#5C6B74;"><%= u.updatedAt ? new Date(u.updatedAt).toLocaleTimeString() : '—' %></td>
                            <td><span class="badge badge-green"><span class="pulse-dot" style="margin-right:5px;"></span> Active</span></td>
                        </tr>
                        <% }) %>
                        <!-- Show all users as a fallback roster -->
                        <% if ((activeSessions || []).length === 0) { %>
                        <% (allUsers || []).slice(0, 8).forEach(u => { %>
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="avatar" style="background:#3D4F58;"><%= (u.name||u.email||'?')[0].toUpperCase() %></div>
                                    <div>
                                        <div style="font-weight:600;"><%= u.name || 'Unnamed' %></div>
                                        <div style="font-size:11px;color:#5C6B74;"><%= u.email %></div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge badge-gray"><%= u.role || 'student' %></span></td>
                            <td style="font-size:12px;color:#5C6B74;">Recently</td>
                            <td><span class="badge badge-gray">Offline</span></td>
                        </tr>
                        <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>
</div>

<script>
    function initTheme() {
        const t = localStorage.getItem('theme') || 'light';
        document.documentElement.classList.toggle('dark', t === 'dark');
    }
    initTheme();

    // ── Section Navigation ─────────────────────────────────────────
    function showSection(id, btn) {
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        document.querySelectorAll('.sb-item').forEach(b => b.classList.remove('active'));
        document.getElementById('sec-' + id).classList.add('active');
        if (btn) btn.classList.add('active');
    }

    // ── User Search ────────────────────────────────────────────────
    function filterUsers() {
        const q = document.getElementById('userSearch').value.toLowerCase();
        document.querySelectorAll('.user-row').forEach(row => {
            const name  = row.dataset.name  || '';
            const email = row.dataset.email || '';
            row.style.display = (name.includes(q) || email.includes(q)) ? '' : 'none';
        });
    }

    // ── Toggle User (deactivate/reactivate) ───────────────────────
    async function toggleUser(userId, deactivate, btn) {
        const action = deactivate ? 'deactivate' : 'reactivate';
        if (!confirm(`${deactivate ? 'Kick/deactivate' : 'Restore'} this user?`)) return;
        try {
            const r = await fetch(`/api/admin/users/${userId}/${action}`, { method: 'POST' });
            const d = await r.json();
            if (d.success) {
                const row = document.getElementById('user-row-' + userId);
                if (deactivate) {
                    row.querySelector('td:nth-child(6)').innerHTML = '<span class="badge badge-red">Deactivated</span>';
                    btn.outerHTML = `<button class="btn-xs btn-green-xs" onclick="toggleUser('${userId}', false, this)"><i class="fas fa-user-check"></i> Restore</button>`;
                } else {
                    row.querySelector('td:nth-child(6)').innerHTML = '<span class="badge badge-green"><span class="pulse-dot" style="margin-right:4px;"></span> Active</span>';
                    btn.outerHTML = `<button class="btn-xs btn-warn-xs" onclick="toggleUser('${userId}', true, this)"><i class="fas fa-user-slash"></i> Kick</button>`;
                }
            }
        } catch (e) { alert('Action failed: ' + e.message); }
    }

    // ── Delete Course ──────────────────────────────────────────────
    async function deleteCourse(courseId, btn) {
        if (!confirm('Permanently delete this course? This cannot be undone.')) return;
        try {
            const r = await fetch(`/api/admin/courses/${courseId}`, { method: 'DELETE' });
            const d = await r.json();
            if (d.success) {
                document.getElementById('course-row-' + courseId)?.remove();
            } else {
                alert('Delete failed: ' + (d.message || 'Unknown error'));
            }
        } catch (e) { alert('Delete failed: ' + e.message); }
    }
</script>
</body>
</html>
