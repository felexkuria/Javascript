<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account - Multitouch Academy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mdb-green': '#00ED64',
              'mdb-forest': '#00684A',
              'mdb-midnight': '#001E2B',
              'mdb-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        body { 
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        .premium-glass {
            background: rgba(2, 52, 48, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 237, 100, 0.1);
        }
        .input-focus-green:focus {
            border-color: #00ED64 !important;
            box-shadow: 0 0 0 4px rgba(0, 237, 100, 0.1);
        }
        .btn-atlas-green {
            background: #00ED64;
            color: #001E2B;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-atlas-green:hover {
            box-shadow: 0 0 25px rgba(0, 237, 100, 0.3);
            transform: translateY(-2px);
        }
        .btn-atlas-green:active {
            transform: translateY(0);
        }
    </style>
</head>
<body class="dark bg-[#001E2B] text-white min-h-screen flex items-center justify-center p-4 overflow-hidden">
    <!-- Animated Background Architecture -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
        <!-- Technical Grid Overlay -->
        <div class="absolute inset-0 opacity-[0.03]" 
             style="background-image: linear-gradient(#00ED64 1px, transparent 1px), linear-gradient(90deg, #00ED64 1px, transparent 1px); background-size: 40px 40px;"></div>
        
        <!-- Radical Glows -->
        <div class="absolute -top-[10%] -right-[10%] w-[60%] h-[60%] bg-[#00ED64]/10 rounded-full blur-[160px] animate-pulse"></div>
        <div class="absolute top-[60%] -left-[10%] w-[50%] h-[50%] bg-[#00ED64]/5 rounded-full blur-[140px]"></div>
    </div>

    <div class="w-full max-w-[540px] relative z-10 animate-in fade-in zoom-in-95 duration-700">
        <!-- System Status Header -->
        <div class="flex justify-between items-center mb-8 px-2">
            <div class="flex items-center gap-3">
                <div class="flex gap-1">
                    <div class="w-1.5 h-1.5 rounded-full bg-[#00ED64] animate-pulse"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-[#00ED64]/40"></div>
                </div>
                <span class="text-[9px] font-black uppercase tracking-[0.3em] text-[#00ED64]/60">Member Registry Sync</span>
            </div>
            <div class="px-3 py-1 bg-white/5 border border-white/10 rounded-full backdrop-blur-md">
                <span class="text-[9px] font-black uppercase tracking-widest text-gray-500">Secure Protocol v3.2</span>
            </div>
        </div>

        <!-- Logo Area -->
        <div class="flex flex-col items-center mb-10">
            <div class="relative group cursor-pointer">
                <div class="absolute inset-0 bg-[#00ED64] blur-2xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                <div class="relative w-24 h-24 bg-gradient-to-br from-[#00ED64] to-[#00684A] rounded-[2rem] flex items-center justify-center shadow-2xl shadow-[#00ED64]/20 hover:-rotate-6 transition-transform duration-500">
                    <span class="text-[#001E2B] text-5xl font-black italic tracking-tighter">M</span>
                </div>
            </div>
            <h1 class="text-5xl font-black tracking-tighter text-white mt-8 mb-2">Multitouch<span class="text-[#00ED64]">_</span></h1>
            <p class="text-[#9FB1AD] font-medium tracking-widest uppercase text-[10px]">Initialize Your Professional Membership</p>
        </div>

        <!-- Auth Card Container -->
        <div class="relative">
            <!-- Decorative Border Accent -->
            <div class="absolute -inset-[1px] bg-gradient-to-b from-[#00ED64]/20 to-transparent rounded-[40px] opacity-50"></div>
            
            <div class="relative bg-[#001E2B]/80 backdrop-blur-3xl p-8 md:p-12 rounded-[40px] shadow-2xl border border-white/5">
                <div id="headerSection" class="mb-10 text-center md:text-left">
                    <h2 class="text-3xl font-black tracking-tight text-white mb-3">Register Account</h2>
                    <p class="text-[#9FB1AD] text-sm font-medium leading-relaxed">Join the global elite in cloud engineering architecture and infrastructure scaling.</p>
                </div>

                <!-- Signup Form -->
                <form id="signupForm" class="space-y-8">
                    <div class="group">
                        <label class="block text-[9px] font-black text-[#9FB1AD] uppercase tracking-[0.3em] mb-3 ml-1 group-focus-within:text-[#00ED64] transition-colors">Full Identity (Name)</label>
                        <div class="relative">
                            <i class="fas fa-id-badge absolute left-6 top-1/2 -translate-y-1/2 text-gray-500 text-[10px] group-focus-within:text-[#00ED64] transition-colors"></i>
                            <input type="text" id="name" name="name" required placeholder="John Architecture" 
                                   class="w-full bg-white/5 border border-white/10 rounded-2xl px-14 py-5 text-sm font-bold text-white outline-none focus:border-[#00ED64]/50 focus:bg-white/[0.08] transition-all placeholder:text-gray-700">
                        </div>
                    </div>

                    <div class="group">
                        <label class="block text-[9px] font-black text-[#9FB1AD] uppercase tracking-[0.3em] mb-3 ml-1 group-focus-within:text-[#00ED64] transition-colors">Transmission Target (Email)</label>
                        <div class="relative">
                            <i class="fas fa-terminal absolute left-6 top-1/2 -translate-y-1/2 text-gray-500 text-[10px] group-focus-within:text-[#00ED64] transition-colors"></i>
                            <input type="email" id="email" name="email" required placeholder="architect@infrastructure.io" 
                                   class="w-full bg-white/5 border border-white/10 rounded-2xl px-14 py-5 text-sm font-bold text-white outline-none focus:border-[#00ED64]/50 focus:bg-white/[0.08] transition-all placeholder:text-gray-700">
                        </div>
                    </div>

                    <div class="group">
                        <label class="block text-[9px] font-black text-[#9FB1AD] uppercase tracking-[0.3em] mb-3 ml-1 group-focus-within:text-[#00ED64] transition-colors">Secure Logic (Passkey)</label>
                        <div class="relative">
                            <i class="fas fa-shield-halved absolute left-6 top-1/2 -translate-y-1/2 text-gray-500 text-[10px] group-focus-within:text-[#00ED64] transition-colors"></i>
                            <input type="password" id="password" name="password" required placeholder="••••••••" minlength="8"
                                   class="w-full bg-white/5 border border-white/10 rounded-2xl px-14 py-5 text-sm font-bold text-white outline-none focus:border-[#00ED64]/50 focus:bg-white/[0.08] transition-all placeholder:text-gray-700">
                        </div>
                    </div>

                    <button type="submit" id="signupBtn" class="group relative w-full py-6 bg-[#00ED64] text-[#001E2B] rounded-2xl font-black uppercase tracking-[0.3em] text-[11px] transition-all hover:scale-[1.02] active:scale-[0.98] overflow-hidden shadow-xl shadow-[#00ED64]/20">
                        <div class="absolute inset-x-0 top-0 h-[1px] bg-white/40"></div>
                        <span id="signupText">Generate Member Access</span>
                    </button>

                    <div class="text-center pt-6">
                        <p class="text-[#9FB1AD] text-xs font-bold uppercase tracking-widest leading-relaxed">Existing Architect? <a href="/login" class="text-[#00ED64] ml-2 hover:brightness-125 transition-all">Authenticate Session_</a></p>
                    </div>
                </form>

                <!-- Verification Section -->
                <div id="verifyContainer" class="hidden animate-in fade-in slide-in-from-bottom-10 duration-700">
                    <div class="text-center mb-10">
                        <div class="w-16 h-16 bg-[#00ED64]/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-[#00ED64]/20">
                            <i class="fas fa-fingerprint text-[#00ED64] text-2xl"></i>
                        </div>
                        <h2 class="text-3xl font-black text-white mb-3 tracking-tight">Identity Validation</h2>
                        <p class="text-sm text-[#9FB1AD] font-medium leading-relaxed">
                            Transmission complete. Enter the 6-digit validation code sent to<br>
                            <span id="verifyEmailDisplay" class="text-[#00ED64] font-bold underline decoration-[#00ED64]/30 underline-offset-4"></span>
                        </p>
                    </div>
                    <form id="verifyForm" class="space-y-10 text-center">
                        <div class="px-2">
                            <input type="text" id="confirmationCode" placeholder="000000" required maxlength="6"
                                   class="w-full bg-white/5 border border-[#00ED64]/30 rounded-3xl py-7 text-5xl font-black text-white text-center tracking-[0.5em] outline-none focus:border-[#00ED64] focus:bg-[#00ED64]/5 transition-all placeholder:text-gray-800">
                        </div>
                        
                        <div class="space-y-4">
                            <button type="submit" id="verifyBtn" class="w-full py-6 bg-[#00ED64] text-[#001E2B] rounded-2xl font-black uppercase tracking-[0.3em] text-[11px] shadow-xl shadow-[#00ED64]/20 transition-all hover:scale-[1.02]">
                                Finalize Identity
                            </button>
                            <button type="button" id="backToSignup" class="text-[9px] font-black uppercase tracking-[0.3em] text-gray-500 hover:text-white transition-all w-full py-2">
                                <i class="fas fa-arrow-left mr-2"></i> Identity Error? Re-Register_
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        let userEmail = '';
        const signupForm = document.getElementById('signupForm');
        const verifyContainer = document.getElementById('verifyContainer');
        const headerSection = document.getElementById('headerSection');
        const verifyEmailDisplay = document.getElementById('verifyEmailDisplay');
        const signupText = document.getElementById('signupText');

        signupForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const signupBtn = document.getElementById('signupBtn');
            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            signupBtn.disabled = true;
            signupBtn.classList.add('opacity-50', 'cursor-not-allowed');
            signupText.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Transmitting...';
            
            try {
                const response = await fetch('/api/auth/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, email, password })
                });
                const data = await response.json();
                if (data.success) {
                    userEmail = email; 
                    verifyEmailDisplay.textContent = email;
                    signupForm.classList.add('hidden'); 
                    headerSection.classList.add('hidden'); 
                    verifyContainer.classList.remove('hidden');
                } else { alert(data.error); }
            } catch (error) { alert('Transmission failed: ' + error.message); }
            finally { 
                signupBtn.disabled = false;
                signupBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                signupText.textContent = 'Generate Access'; 
            }
        });

        document.getElementById('verifyForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const verifyBtn = document.getElementById('verifyBtn');
            const confirmationCode = document.getElementById('confirmationCode').value;
            
            verifyBtn.disabled = true;
            verifyBtn.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Validating...';
            
            try {
                const response = await fetch('/api/auth/confirm', {
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: userEmail, confirmationCode })
                });
                const data = await response.json();
                if (data.success) { 
                    alert('Success: Identity Validated'); 
                    window.location.href = '/login'; 
                } else { alert(data.error); }
            } catch (error) { alert('Validation error: ' + error.message); }
            finally { 
                verifyBtn.disabled = false; 
                verifyBtn.innerHTML = 'Validate Identity'; 
            }
        });

        document.getElementById('backToSignup').addEventListener('click', () => {
            verifyContainer.classList.add('hidden'); 
            signupForm.classList.remove('hidden'); 
            headerSection.classList.remove('hidden');
        });
    </script>
</body>
</html>