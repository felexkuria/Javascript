<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account — Multitouch Academy</title>
    <meta name="description" content="Create a free Multitouch Academy account to start learning.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        body {
            min-height: 100vh;
            display: grid;
            place-items: center;
            background: var(--mdb-midnight);
            padding: 24px;
        }
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 60% 50% at 80% 20%, rgba(0,237,100,.07) 0%, transparent 70%),
                radial-gradient(ellipse 45% 35% at 15% 80%, rgba(1,107,248,.05) 0%, transparent 70%);
            pointer-events: none;
        }
        .auth-card {
            width: 100%; max-width: 460px;
            background: #0D1B24;
            border: 1px solid rgba(0,237,100,.15);
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,.5), 0 0 0 1px rgba(0,237,100,.08);
            position: relative; z-index: 1;
        }
        .auth-brand {
            display: flex; align-items: center; gap: 10px; margin-bottom: 28px;
        }
        .auth-leaf {
            width: 32px; height: 32px;
            background: var(--mdb-green);
            border-radius: 50% 50% 50% 0 / 60% 60% 40% 40%;
            flex-shrink: 0; position: relative;
        }
        .auth-leaf::after {
            content: ''; position: absolute;
            width: 2px; height: 16px;
            background: var(--mdb-midnight);
            bottom: 4px; left: 50%;
            transform: translateX(-50%);
            border-radius: 1px;
        }
        .auth-brand-name { font-size: 18px; font-weight: 700; color: #fff; letter-spacing: -.01em; }
        .auth-brand-name span { color: var(--mdb-green); }
        .auth-heading { font-size: 22px; font-weight: 600; color: #E8EDEB; margin-bottom: 4px; }
        .auth-sub { font-size: 13px; color: #5C6B74; margin-bottom: 24px; }

        /* Steps indicator */
        .steps {
            display: flex; align-items: center; gap: 8px;
            margin-bottom: 24px;
        }
        .step-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: #1C3A52; transition: background .2s;
        }
        .step-dot.active { background: var(--mdb-green); }
        .step-dot.done   { background: var(--mdb-forest); }
        .step-line { flex: 1; height: 1px; background: #1C3A52; }

        /* Field */
        .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
        .field label { font-size: 13px; font-weight: 500; color: #89989E; }
        .field input, .field select {
            padding: 10px 14px;
            background: #0F2336; border: 1px solid #1C3A52;
            border-radius: 6px; font-size: 14px; color: #E8EDEB;
            outline: none; transition: border-color .15s, box-shadow .15s;
            -webkit-appearance: none;
        }
        .field input:focus, .field select:focus {
            border-color: var(--mdb-green);
            box-shadow: 0 0 0 3px rgba(0,237,100,.18);
        }
        .field input::placeholder { color: #3D4F58; }
        .field .hint { font-size: 11px; color: #3D4F58; margin-top: 3px; }

        /* Role cards */
        .role-cards {
            display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
            margin-bottom: 16px;
        }
        .role-card {
            padding: 12px;
            background: #0F2336;
            border: 2px solid #1C3A52;
            border-radius: 8px;
            cursor: pointer;
            transition: all .15s;
            text-align: center;
        }
        .role-card:hover { border-color: #3D4F58; }
        .role-card.selected { border-color: var(--mdb-green); background: rgba(0,237,100,.06); }
        .role-card-icon { font-size: 22px; margin-bottom: 6px; }
        .role-card-label { font-size: 13px; font-weight: 600; color: #E8EDEB; }
        .role-card-desc  { font-size: 11px; color: #5C6B74; margin-top: 2px; }

        .auth-submit {
            width: 100%; padding: 11px; margin-top: 8px;
            background: var(--mdb-green); color: var(--mdb-midnight);
            border: none; border-radius: 6px;
            font-size: 14px; font-weight: 600; cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: background .15s, box-shadow .15s;
        }
        .auth-submit:hover { background: var(--mdb-green-dark); box-shadow: 0 2px 8px rgba(0,237,100,.3); }
        .auth-submit:disabled { opacity: .5; cursor: not-allowed; }

        .auth-alert {
            display: flex; align-items: flex-start; gap: 8px;
            padding: 10px 14px; border-radius: 6px;
            font-size: 13px; font-weight: 500; margin-bottom: 16px; border-left: 3px solid;
        }
        .auth-alert-error   { background: rgba(193,42,42,.12); color: #F56262; border-color: #C12A2A; }
        .auth-alert-success { background: rgba(0,237,100,.1);  color: var(--mdb-green); border-color: var(--mdb-green); }
        .auth-alert.hidden  { display: none; }

        .auth-footer { text-align: center; font-size: 13px; color: #5C6B74; margin-top: 20px; }
        .auth-footer a { color: var(--mdb-green); font-weight: 500; }

        .confirm-form { display: none; }
        .confirm-form.active { display: block; }
        .signup-form.hidden { display: none; }

        .spinner {
            display: inline-block; width: 14px; height: 14px;
            border: 2px solid var(--mdb-midnight); border-top-color: transparent;
            border-radius: 50%; animation: spin .8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="auth-card" role="main">
        <div class="auth-brand">
            <div class="auth-leaf" aria-hidden="true"></div>
            <div class="auth-brand-name">Learn<span>DB</span></div>
        </div>

        <h1 class="auth-heading" id="formTitle">Create your free account</h1>
        <p class="auth-sub" id="formSub">Start learning in minutes — no credit card required</p>

        <!-- Progress dots -->
        <div class="steps" id="stepIndicator" aria-hidden="true">
            <div class="step-dot active" id="dot1"></div>
            <div class="step-line"></div>
            <div class="step-dot" id="dot2"></div>
        </div>

        <div id="alertBox" class="auth-alert hidden" role="alert" aria-live="assertive"></div>

        <!-- Step 1: Signup form -->
        <form id="signupForm" class="signup-form" novalidate>
            <div class="field">
                <label for="name">Full name</label>
                <input type="text" id="name" name="name" autocomplete="name" required placeholder="Alex Johnson">
            </div>
            <div class="field">
                <label for="email">Email address</label>
                <input type="email" id="email" name="email" autocomplete="email" required placeholder="you@example.com">
            </div>
            <div class="field">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" autocomplete="new-password" required placeholder="Min 8 chars with uppercase & number">
                <span class="hint">Minimum 8 characters with uppercase, lowercase, and a number</span>
            </div>

            <!-- Role selector -->
            <div style="margin-bottom: 16px;">
                <div style="font-size: 13px; font-weight: 500; color: #89989E; margin-bottom: 10px;">I want to…</div>
                <div class="role-cards">
                    <label class="role-card selected" for="role-student">
                        <input type="radio" id="role-student" name="role" value="student" style="display:none" checked>
                        <div class="role-card-icon">🎓</div>
                        <div class="role-card-label">Learn</div>
                        <div class="role-card-desc">Browse &amp; take courses</div>
                    </label>
                    <label class="role-card" for="role-teacher">
                        <input type="radio" id="role-teacher" name="role" value="teacher" style="display:none">
                        <div class="role-card-icon">📖</div>
                        <div class="role-card-label">Teach</div>
                        <div class="role-card-desc">Create &amp; publish courses</div>
                    </label>
                </div>
            </div>

            <button type="submit" id="signupBtn" class="auth-submit">Create Account</button>
        </form>

        <!-- Step 2: Confirm form -->
        <form id="confirmForm" class="confirm-form" novalidate>
            <div class="field">
                <label for="confirmCode">Confirmation code</label>
                <input type="text" id="confirmCode" autocomplete="one-time-code"
                       inputmode="numeric" pattern="[0-9]*" placeholder="6-digit code" required>
                <span class="hint">We sent a code to your email address</span>
            </div>
            <button type="submit" id="confirmBtn" class="auth-submit">Verify &amp; Continue</button>
        </form>

        <div class="auth-footer">
            Already have an account? <a href="/login">Sign in</a>
        </div>
    </div>

    <script>
        document.getElementById('html-root').classList.add('dark');

        let userEmail = '';

        function showAlert(msg, type) {
            const box = document.getElementById('alertBox');
            box.className = 'auth-alert auth-alert-' + type;
            box.textContent = (type === 'error' ? '⚠ ' : '✓ ') + msg;
        }
        function hideAlert() {
            const box = document.getElementById('alertBox');
            box.className = 'auth-alert hidden';
        }

        // Role card radio toggle
        document.querySelectorAll('.role-card').forEach(card => {
            card.addEventListener('click', () => {
                document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
                card.classList.add('selected');
            });
        });

        // Signup
        document.getElementById('signupForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            hideAlert();
            const name     = document.getElementById('name').value.trim();
            const email    = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const role     = document.querySelector('input[name="role"]:checked').value;
            const btn      = document.getElementById('signupBtn');

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span> Creating account…';

            try {
                const res  = await fetch('/api/auth/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, email, password, role })
                });
                const data = await res.json();
                if (data.success) {
                    userEmail = email;
                    // Transition to step 2
                    document.getElementById('signupForm').classList.add('hidden');
                    document.getElementById('confirmForm').classList.add('active');
                    document.getElementById('formTitle').textContent = 'Check your email';
                    document.getElementById('formSub').textContent = `We sent a code to ${email}`;
                    document.getElementById('dot1').className = 'step-dot done';
                    document.getElementById('dot2').className = 'step-dot active';
                    showAlert(data.message || 'Confirmation code sent!', 'success');
                } else {
                    throw new Error(data.error || 'Signup failed');
                }
            } catch (err) {
                showAlert(err.message, 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Create Account';
            }
        });

        // Confirm
        document.getElementById('confirmForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            hideAlert();
            const code = document.getElementById('confirmCode').value.trim();
            const btn  = document.getElementById('confirmBtn');

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span> Verifying…';

            try {
                const res  = await fetch('/api/auth/confirm', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: userEmail, confirmationCode: code })
                });
                const data = await res.json();
                if (data.success) {
                    showAlert('Account confirmed! Redirecting…', 'success');
                    setTimeout(() => window.location.href = '/login?confirmed=true', 1500);
                } else {
                    throw new Error(data.error || 'Invalid code');
                }
            } catch (err) {
                showAlert(err.message, 'error');
                btn.disabled = false;
                btn.textContent = 'Verify & Continue';
            }
        });
    </script>
</body>
</html>