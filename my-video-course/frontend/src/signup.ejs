<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account - Multitouch Academy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mdb-green': '#00ED64',
              'mdb-forest': '#00684A',
              'mdb-midnight': '#001E2B',
              'mdb-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        body { 
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        .premium-glass {
            background: rgba(2, 52, 48, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 237, 100, 0.1);
        }
        .input-focus-green:focus {
            border-color: #00ED64 !important;
            box-shadow: 0 0 0 4px rgba(0, 237, 100, 0.1);
        }
        .btn-atlas-green {
            background: #00ED64;
            color: #001E2B;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-atlas-green:hover {
            box-shadow: 0 0 25px rgba(0, 237, 100, 0.3);
            transform: translateY(-2px);
        }
        .btn-atlas-green:active {
            transform: translateY(0);
        }
    </style>
</head>
<body class="dark bg-[#001E2B] text-white min-h-screen flex items-center justify-center p-4">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] bg-[#00ED64]/5 rounded-full blur-[120px]"></div>
        <div class="absolute top-[60%] -left-[10%] w-[50%] h-[50%] bg-[#00ED64]/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="w-full max-w-[480px] relative z-10">
        <!-- Logo Area -->
        <div class="flex flex-col items-center mb-12">
            <div class="w-20 h-20 bg-gradient-to-br from-[#00ED64] to-[#00684A] rounded-3xl flex items-center justify-center shadow-2xl shadow-[#00ED64]/20 mb-6 group cursor-pointer hover:-rotate-6 transition-transform">
                <span class="text-[#001E2B] text-4xl font-black">M</span>
            </div>
            <h1 class="text-4xl font-black tracking-tighter text-white mb-2">Multitouch Academy</h1>
            <p class="text-gray-400 font-medium">Initialize Your Membership</p>
        </div>

        <!-- Auth Card -->
        <div class="premium-glass p-6 md:p-10 rounded-[30px] md:rounded-[40px] shadow-3xl">
            <div id="headerSection" class="mb-10 text-center md:text-left">
                <h2 class="text-2xl font-black tracking-tight text-white mb-2">Create New Account</h2>
                <p class="text-gray-400 text-sm">Join the global elite in cloud engineering architecture.</p>
            </div>

            <!-- Signup Form -->
            <form id="signupForm" class="space-y-6">
                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Full Identity (Name)</label>
                    <div class="relative">
                        <i class="fas fa-id-card absolute left-5 top-1/2 -translate-y-1/2 text-gray-400/30 text-[10px]"></i>
                        <input type="text" id="name" name="name" required placeholder="John Doe" 
                               class="w-full bg-[#001E2B]/40 border border-white/10 rounded-2xl px-12 py-4 text-sm font-medium outline-none input-focus-green transition-all placeholder:text-gray-600">
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Email Address</label>
                    <div class="relative">
                        <i class="fas fa-envelope absolute left-5 top-1/2 -translate-y-1/2 text-gray-400/30 text-[10px]"></i>
                        <input type="email" id="email" name="email" required placeholder="name@company.com" 
                               class="w-full bg-[#001E2B]/40 border border-white/10 rounded-2xl px-12 py-4 text-sm font-medium outline-none input-focus-green transition-all placeholder:text-gray-600">
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Secure Key (Password)</label>
                    <div class="relative">
                        <i class="fas fa-lock absolute left-5 top-1/2 -translate-y-1/2 text-gray-400/30 text-[10px]"></i>
                        <input type="password" id="password" name="password" required placeholder="••••••••" minlength="8"
                               class="w-full bg-[#001E2B]/40 border border-white/10 rounded-2xl px-12 py-4 text-sm font-medium outline-none input-focus-green transition-all placeholder:text-gray-600">
                    </div>
                </div>

                <button type="submit" id="signupBtn" class="w-full py-5 btn-atlas-green rounded-2xl font-black uppercase tracking-[0.2em] text-xs shadow-lg shadow-[#00ED64]/10">
                    <span id="signupText">Generate Access</span>
                </button>

                <div class="text-center pt-4">
                    <p class="text-gray-400 text-sm font-medium">Already have an account? <a href="/login" class="text-[#00ED64] font-bold hover:underline">Log in</a></p>
                </div>
            </form>

            <!-- Verification Section -->
            <div id="verifyContainer" class="hidden animate-in fade-in slide-in-from-bottom-10 duration-500">
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-black text-white mb-2 tracking-tight">Verify Identity</h2>
                    <p class="text-xs text-gray-400 font-medium leading-relaxed">
                        We've transmitted a 6-digit validation code to<br>
                        <span id="verifyEmailDisplay" class="text-[#00ED64] font-bold"></span>
                    </p>
                </div>
                <form id="verifyForm" class="space-y-6 text-center">
                    <div class="px-4">
                        <input type="text" id="confirmationCode" placeholder="000000" required maxlength="6"
                               class="w-full bg-[#001E2B]/40 border border-[#00ED64]/30 rounded-3xl py-6 text-4xl font-black text-center tracking-[0.4em] outline-none input-focus-green transition-all placeholder:text-gray-700">
                    </div>
                    
                    <div class="space-y-3">
                        <button type="submit" id="verifyBtn" class="w-full py-5 btn-atlas-green rounded-2xl font-black uppercase tracking-[0.2em] text-xs">
                            Validate Identity
                        </button>
                        <button type="button" id="backToSignup" class="text-[10px] font-black uppercase tracking-widest text-gray-500 hover:text-white transition-all w-full">
                            <i class="fas fa-arrow-left mr-2"></i> Incorrect Email?
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        let userEmail = '';
        const signupForm = document.getElementById('signupForm');
        const verifyContainer = document.getElementById('verifyContainer');
        const headerSection = document.getElementById('headerSection');
        const verifyEmailDisplay = document.getElementById('verifyEmailDisplay');
        const signupText = document.getElementById('signupText');

        signupForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const signupBtn = document.getElementById('signupBtn');
            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            signupBtn.disabled = true;
            signupBtn.classList.add('opacity-50', 'cursor-not-allowed');
            signupText.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Transmitting...';
            
            try {
                const response = await fetch('/api/auth/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, email, password })
                });
                const data = await response.json();
                if (data.success) {
                    userEmail = email; 
                    verifyEmailDisplay.textContent = email;
                    signupForm.classList.add('hidden'); 
                    headerSection.classList.add('hidden'); 
                    verifyContainer.classList.remove('hidden');
                } else { alert(data.error); }
            } catch (error) { alert('Transmission failed: ' + error.message); }
            finally { 
                signupBtn.disabled = false;
                signupBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                signupText.textContent = 'Generate Access'; 
            }
        });

        document.getElementById('verifyForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const verifyBtn = document.getElementById('verifyBtn');
            const confirmationCode = document.getElementById('confirmationCode').value;
            
            verifyBtn.disabled = true;
            verifyBtn.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Validating...';
            
            try {
                const response = await fetch('/api/auth/confirm', {
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: userEmail, confirmationCode })
                });
                const data = await response.json();
                if (data.success) { 
                    alert('Success: Identity Validated'); 
                    window.location.href = '/login'; 
                } else { alert(data.error); }
            } catch (error) { alert('Validation error: ' + error.message); }
            finally { 
                verifyBtn.disabled = false; 
                verifyBtn.innerHTML = 'Validate Identity'; 
            }
        });

        document.getElementById('backToSignup').addEventListener('click', () => {
            verifyContainer.classList.add('hidden'); 
            signupForm.classList.remove('hidden'); 
            headerSection.classList.remove('hidden');
        });
    </script>
</body>
</html>