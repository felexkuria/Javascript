<%- include('partials/header', { title: 'Settings' }) %>

<main class="flex-grow overflow-y-auto px-4 py-8 md:px-8 bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
  <div class="max-w-3xl mx-auto space-y-8">
    <!-- Header -->
    <div>
      <h1 class="text-3xl font-extrabold text-[#001E2B] dark:text-[#E7EEEB] tracking-tight">Settings</h1>
      <p class="text-gray-500 dark:text-gray-400">Manage your account preferences and security</p>
    </div>

    <!-- Profile Section -->
    <div class="bg-white dark:bg-[#023430] rounded-2xl shadow-sm border border-gray-100 dark:border-[#133A41] overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-[#133A41] bg-gray-50/50 dark:bg-[#001E2B]/50">
        <h2 class="text-lg font-bold text-[#001E2B] dark:text-[#00ED64]">Profile Information</h2>
      </div>
      <div class="p-6 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Display Name</label>
            <input type="text" value="<%= user.name %>" 
                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-[#001E2B] border border-gray-200 dark:border-[#133A41] text-[#001E2B] dark:text-[#E7EEEB] rounded-xl focus:ring-2 focus:ring-[#00ED64] outline-none transition-all">
          </div>
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Email Address</label>
            <input type="email" value="<%= user.email %>" disabled
                   class="w-full px-4 py-2.5 bg-gray-100 dark:bg-[#001E2B]/50 border border-gray-200 dark:border-[#133A41] text-gray-500 rounded-xl cursor-not-allowed">
          </div>
        </div>
        <div class="space-y-2">
          <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Bio</label>
          <textarea rows="3" placeholder="Tell students about yourself..."
                    class="w-full px-4 py-2.5 bg-gray-50 dark:bg-[#001E2B] border border-gray-200 dark:border-[#133A41] text-[#001E2B] dark:text-[#E7EEEB] rounded-xl focus:ring-2 focus:ring-[#00ED64] outline-none transition-all"></textarea>
        </div>
        <div class="flex justify-end">
          <button class="px-6 py-2.5 bg-[#00684A] hover:bg-[#00ED64] text-white hover:text-[#001E2B] font-bold rounded-xl transition-all">
            Save Changes
          </button>
        </div>
      </div>
    </div>

    <!-- Security Section -->
    <div class="bg-white dark:bg-[#023430] rounded-2xl shadow-sm border border-gray-100 dark:border-[#133A41] overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-[#133A41] bg-gray-50/50 dark:bg-[#001E2B]/50">
        <h2 class="text-lg font-bold text-[#001E2B] dark:text-[#00ED64]">Security</h2>
      </div>
      <div class="p-6 space-y-6">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-bold text-[#001E2B] dark:text-[#E7EEEB]">Password</h3>
            <p class="text-sm text-gray-500">Change your password to keep your account secure</p>
          </div>
          <button class="px-4 py-2 border border-[#00684A] text-[#00684A] dark:text-[#00ED64] dark:border-[#00ED64] font-bold rounded-xl hover:bg-[#00ED64] hover:text-[#001E2B] transition-all">
            Update
          </button>
        </div>
        <hr class="border-gray-100 dark:border-[#133A41]">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-bold text-[#001E2B] dark:text-[#E7EEEB]">Two-Factor Authentication</h3>
            <p class="text-sm text-gray-500">Add an extra layer of security (Coming Soon)</p>
          </div>
          <div class="w-12 h-6 bg-gray-200 dark:bg-gray-700 rounded-full relative cursor-not-allowed opacity-50">
            <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Danger Zone -->
    <div class="p-6 bg-red-50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/30 rounded-2xl">
      <h3 class="font-bold text-red-700 dark:text-red-400 mb-2">Danger Zone</h3>
      <p class="text-sm text-red-600 dark:text-red-400/80 mb-4">Once you delete your account, there is no going back. Please be certain.</p>
      <button class="text-red-700 dark:text-red-400 font-bold hover:underline">Delete Account</button>
    </div>
  </div>
</main>

<%- include('partials/footer') %>