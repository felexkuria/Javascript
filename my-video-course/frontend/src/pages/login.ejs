<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mongo-green': '#00ED64',
              'mongo-slate': '#001E2B',
              'mongo-forest': '#00684A'
            },
            fontFamily: {
              'sans': ['Inter', '-apple-system', 'BlinkMacSystemFont', 'system-ui', 'sans-serif']
            }
          }
        }
      }
    </script>
</head>
<body class="bg-apple-gray dark:bg-gray-900 font-sans antialiased transition-colors duration-200">
    <div class="min-h-screen flex items-center justify-center px-6">
        <!-- Dark Mode Toggle -->
        <button id="themeToggle" class="fixed top-4 right-4 p-3 bg-white dark:bg-[#023430] rounded-full shadow-lg border border-transparent dark:border-[#00ED64]/20 hover:shadow-xl transition-all duration-200 z-10">
            <span id="themeIcon" class="text-xl">🌙</span>
        </button>
        
        <div class="w-full max-w-sm">
            <div class="bg-white dark:bg-[#023430] rounded-2xl shadow-sm border border-gray-100 dark:border-[#133A41] p-8 transition-colors duration-200">
                <div class="text-center mb-8">
                    <div class="w-16 h-16 bg-[#00ED64] rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-sm">
                        <span class="text-[#001E2B] text-3xl font-bold">🍃</span>
                    </div>
                    <h1 class="text-2xl font-bold text-gray-900 dark:text-[#E7EEEB] mb-2 tracking-tight">MongoDB <span class="font-normal text-gray-500">Academy</span></h1>
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Sign in to your learning account</p>
                </div>
                
                <% if (typeof error !== 'undefined' && error) { %>
                <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 text-red-700 dark:text-red-400 rounded-xl text-sm">
                    <%= error %>
                </div>
                <% } %>
                
                <!-- Role Selection -->
                <div class="mb-6">
                    <div class="flex bg-gray-100 dark:bg-[#001E2B] rounded-xl p-1 border border-transparent dark:border-[#133A41]">
                        <button id="studentTab" class="flex-1 py-2 px-4 text-sm font-semibold rounded-lg transition-all bg-white dark:bg-[#00684A] text-[#001E2B] dark:text-white shadow-sm">
                            🎓 Student
                        </button>
                        <button id="teacherTab" class="flex-1 py-2 px-4 text-sm font-medium rounded-lg transition-all text-gray-500 dark:text-gray-400">
                            👨🏫 Teacher
                        </button>
                    </div>
                </div>
                
                <form id="loginForm" class="space-y-4">
                    <div>
                        <input type="email" id="email" name="email" placeholder="Email" required
                               class="w-full px-4 py-3 bg-gray-50 dark:bg-[#001E2B] border border-gray-200 dark:border-[#133A41] text-gray-900 dark:text-[#E7EEEB] placeholder-gray-500 dark:placeholder-gray-400 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#00ED64] focus:border-transparent transition-all">
                    </div>
                    
                    <div>
                        <input type="password" id="password" name="password" placeholder="Password" required
                               class="w-full px-4 py-3 bg-gray-50 dark:bg-[#001E2B] border border-gray-200 dark:border-[#133A41] text-gray-900 dark:text-[#E7EEEB] placeholder-gray-500 dark:placeholder-gray-400 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#00ED64] focus:border-transparent transition-all">
                    </div>
                    
                    <div id="teacherNote" class="hidden p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-xl">
                        <p class="text-sm text-amber-700 dark:text-amber-300">
                            📋 Teacher access requires approval from admin
                        </p>
                    </div>
                    
                    <button type="submit" id="loginBtn" class="w-full bg-gradient-to-r from-[#00ED64] to-[#00C152] text-[#001E2B] font-bold py-3 rounded-xl hover:shadow-[0_0_20px_rgba(0,237,100,0.3)] hover:scale-[1.02] transition-all">
                        <span id="loginText">Sign In as Student</span>
                    </button>
                    
                    <div class="flex justify-between items-center text-sm">
                        <a href="/forgot-password" class="text-[#00C152] hover:text-[#00ED64] hover:underline font-medium">Forgot Password?</a>
                        <a href="/signup" class="text-[#00C152] hover:text-[#00ED64] hover:underline font-medium">Create Account</a>
                    </div>
                </form>
                
                <div class="mt-6 p-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-xl cursor-pointer hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors" onclick="loginAsSuperAdmin()">
                    <p class="text-xs text-blue-700 dark:text-blue-300 text-center">
                        🔑 <strong>Super Admin:</strong> engineerfelex@gmail.com <span class="text-blue-500">(Click to login)</span>
                    </p>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // Dark theme toggle
        function initTheme() {
            const theme = localStorage.getItem("theme") || "light";
            document.documentElement.classList.toggle("dark", theme === "dark");
            document.getElementById('themeIcon').textContent = theme === "dark" ? '☀️' : '🌙';
        }
        
        function toggleTheme() {
            const newTheme = document.documentElement.classList.contains("dark") ? "light" : "dark";
            document.documentElement.classList.toggle("dark", newTheme === "dark");
            localStorage.setItem("theme", newTheme);
            document.getElementById('themeIcon').textContent = newTheme === "dark" ? '☀️' : '🌙';
        }
        
        initTheme();
        document.getElementById('themeToggle').addEventListener('click', toggleTheme);
        
        // Check for existing login on page load
        function checkExistingLogin() {
            // Prevent infinite loops
            if (window.location.pathname === '/login' && !sessionStorage.getItem('loginCheck')) {
                sessionStorage.setItem('loginCheck', 'true');
                
                const accessToken = localStorage.getItem('accessToken');
                const user = localStorage.getItem('user');
                
                if (accessToken && user) {
                    console.log('Found existing login, redirecting...');
                    window.location.href = '/dashboard';
                }
            }
        }
        
        // Only check on login page
        if (window.location.pathname === '/login') {
            checkExistingLogin();
        }
        
        let selectedRole = 'student';
        
        // Role tab switching
        document.getElementById('studentTab').addEventListener('click', () => {
            selectedRole = 'student';
            console.log('Selected role:', selectedRole);
            document.getElementById('studentTab').className = 'flex-1 py-2 px-4 text-sm font-medium rounded-lg transition-all bg-white dark:bg-gray-600 text-apple-blue shadow-sm';
            document.getElementById('teacherTab').className = 'flex-1 py-2 px-4 text-sm font-medium rounded-lg transition-all text-gray-500 dark:text-gray-400';
            document.getElementById('teacherNote').classList.add('hidden');
            document.getElementById('loginText').textContent = 'Sign In as Student';
        });
        
        document.getElementById('teacherTab').addEventListener('click', () => {
            selectedRole = 'teacher';
            console.log('Selected role:', selectedRole);
            document.getElementById('teacherTab').className = 'flex-1 py-2 px-4 text-sm font-medium rounded-lg transition-all bg-white dark:bg-gray-600 text-apple-blue shadow-sm';
            document.getElementById('studentTab').className = 'flex-1 py-2 px-4 text-sm font-medium rounded-lg transition-all text-gray-500 dark:text-gray-400';
            document.getElementById('teacherNote').classList.remove('hidden');
            document.getElementById('loginText').textContent = 'Sign In as Teacher';
        });
        
        // Super admin login function
        function loginAsSuperAdmin() {
            document.getElementById('email').value = 'engineerfelex@gmail.com';
            document.getElementById('password').focus();
            // Switch to teacher tab
            document.getElementById('teacherTab').click();
        }
        
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const loginBtn = document.getElementById('loginBtn');
            
            loginBtn.disabled = true;
            loginBtn.textContent = 'Signing in...';
            
            try {
                console.log('Login attempt:', { email, requestedRole: selectedRole });
                
                const response = await fetch('/api/auth/signin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password, requestedRole: selectedRole })
                });
                
                const data = await response.json();
                console.log('Login response:', data);
                
                if (data.success) {
                    localStorage.setItem('accessToken', data.accessToken);
                    localStorage.setItem('user', JSON.stringify(data.user));
                    localStorage.setItem('selectedRole', selectedRole);
                    
                    // Show success message based on role
                    if (selectedRole === 'teacher' && data.user.isTeacher) {
                        console.log('Redirecting to teacher dashboard');
                    } else if (selectedRole === 'teacher' && !data.user.isTeacher) {
                        alert('Teacher access requested. Admin approval required.');
                    } else {
                        console.log('Redirecting to student dashboard');
                    }
                    
                    // Always redirect to dashboard - backend will handle role-based rendering
                    window.location.href = '/dashboard';
                } else {
                    alert(data.error);
                }
            } catch (error) {
                console.error('Login error:', error);
                alert('Login failed: ' + error.message);
            } finally {
                loginBtn.disabled = false;
                document.getElementById('loginText').textContent = selectedRole === 'teacher' ? 'Sign In as Teacher' : 'Sign In as Student';
            }
        });
    </script>
</body>
</html>