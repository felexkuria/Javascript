<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - Multitouch Academy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mdb-green': '#00ED64',
              'mdb-forest': '#00684A',
              'mdb-midnight': '#001E2B',
              'mdb-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        body { 
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        .premium-glass {
            background: rgba(2, 52, 48, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 237, 100, 0.1);
        }
        .input-focus-green:focus {
            border-color: #00ED64 !important;
            box-shadow: 0 0 0 4px rgba(0, 237, 100, 0.1);
        }
        .btn-atlas-green {
            background: #00ED64;
            color: #001E2B;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-atlas-green:hover {
            box-shadow: 0 0 25px rgba(0, 237, 100, 0.3);
            transform: translateY(-2px);
        }
        .btn-atlas-green:active {
            transform: translateY(0);
        }
    </style>
</head>
<body class="dark bg-[#001E2B] text-white min-h-screen flex items-center justify-center p-4">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-[#00ED64]/5 rounded-full blur-[120px]"></div>
        <div class="absolute top-[60%] -right-[10%] w-[50%] h-[50%] bg-[#00ED64]/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="w-full max-w-[480px] relative z-10">
        <!-- Logo Area -->
        <div class="flex flex-col items-center mb-12">
            <div class="w-20 h-20 bg-gradient-to-br from-[#00ED64] to-[#00684A] rounded-3xl flex items-center justify-center shadow-2xl shadow-[#00ED64]/20 mb-6 group cursor-pointer hover:rotate-6 transition-transform">
                <span class="text-[#001E2B] text-4xl font-black">M</span>
            </div>
            <h1 class="text-4xl font-black tracking-tighter text-white mb-2">Multitouch Academy</h1>
            <p class="text-gray-400 font-medium">Cloud Infrastructure Engineering Lab</p>
        </div>

        <!-- Auth Card -->
        <div class="premium-glass p-10 rounded-[40px] shadow-3xl">
            <div class="mb-10">
                <h2 class="text-2xl font-black tracking-tight text-white mb-2">Sign in to Console</h2>
                <p class="text-gray-400 text-sm">Enter your credentials to access the deployment bay.</p>
            </div>

            <!-- Role Selector -->
            <div class="flex p-1 bg-[#001E2B]/60 rounded-2xl border border-white/5 mb-8">
                <button id="studentTab" class="flex-1 py-3 text-xs font-black uppercase tracking-widest rounded-xl transition-all bg-[#00ED64] text-[#001E2B]">Student</button>
                <button id="teacherTab" class="flex-1 py-3 text-xs font-black uppercase tracking-widest rounded-xl transition-all text-gray-400 hover:text-white">Instructor</button>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl text-xs font-bold flex items-center gap-3">
                    <i class="fas fa-exclamation-circle text-sm"></i> <%= error %>
                </div>
            <% } %>

            <form id="loginForm" class="space-y-6">
                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Identity (Email)</label>
                    <div class="relative">
                        <i class="fas fa-user absolute left-5 top-1/2 -translate-y-1/2 text-gray-400/30 text-[10px]"></i>
                        <input type="email" id="email" required placeholder="name@company.com" autocomplete="username"
                               class="w-full bg-[#001E2B]/40 border border-white/10 rounded-2xl px-12 py-4 text-sm font-medium outline-none input-focus-green transition-all placeholder:text-gray-600">
                    </div>
                </div>

                <div>
                    <div class="flex justify-between mb-2 ml-1">
                        <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Access Key (Password)</label>
                        <a href="/forgot-password" class="text-[10px] font-black text-[#00ED64] uppercase tracking-widest hover:opacity-75 transition-opacity">Key Loss?</a>
                    </div>
                    <div class="relative">
                        <i class="fas fa-lock absolute left-5 top-1/2 -translate-y-1/2 text-gray-400/30 text-[10px]"></i>
                        <input type="password" id="password" required placeholder="••••••••" autocomplete="current-password"
                               class="w-full bg-[#001E2B]/40 border border-white/10 rounded-2xl px-12 py-4 text-sm font-medium outline-none input-focus-green transition-all placeholder:text-gray-600">
                    </div>
                </div>

                <div id="teacherNote" class="hidden p-4 bg-amber-500/5 border border-amber-500/10 rounded-2xl">
                    <p class="text-[10px] font-black text-amber-500 uppercase tracking-widest leading-relaxed text-center">
                        <i class="fas fa-shield-halved mr-2"></i> Security: Instructor hardware-key required
                    </p>
                </div>

                <button type="submit" id="loginBtn" class="w-full py-5 btn-atlas-green rounded-2xl font-black uppercase tracking-[0.2em] text-xs shadow-lg shadow-[#00ED64]/10">
                    <span id="loginText">Initialize Access</span>
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-white/5 text-center">
                <p class="text-gray-400 text-sm font-medium">New to Academy? <a href="/signup" class="text-[#00ED64] font-bold hover:underline">Join Academy</a></p>
            </div>

            <!-- Developer Gate -->
            <div class="mt-8 flex gap-3">
                <button onclick="loginAsSuperAdmin()" class="flex-1 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-[9px] font-black uppercase tracking-widest text-gray-400 transition-all">Auto-Fill</button>
                <button onclick="setupSuperAdmin()" class="flex-1 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-[9px] font-black uppercase tracking-widest text-gray-400 transition-all">Sync Cognito</button>
            </div>
        </div>
    </div>

    <script>
        let selectedRole = 'student';
        const studentTab = document.getElementById('studentTab');
        const teacherTab = document.getElementById('teacherTab');
        const loginText = document.getElementById('loginText');
        const teacherNote = document.getElementById('teacherNote');

        function updateRole(role) {
            selectedRole = role;
            if (role === 'student') {
                studentTab.className = 'flex-1 py-3 text-xs font-black uppercase tracking-widest rounded-xl transition-all bg-[#00ED64] text-[#001E2B] shadow-lg';
                teacherTab.className = 'flex-1 py-3 text-xs font-black uppercase tracking-widest rounded-xl transition-all text-gray-400 hover:text-white';
                teacherNote.classList.add('hidden');
                loginText.textContent = 'Initialize Student Access';
            } else {
                teacherTab.className = 'flex-1 py-3 text-xs font-black uppercase tracking-widest rounded-xl transition-all bg-[#00ED64] text-[#001E2B] shadow-lg';
                studentTab.className = 'flex-1 py-3 text-xs font-black uppercase tracking-widest rounded-xl transition-all text-gray-400 hover:text-white';
                teacherNote.classList.remove('hidden');
                loginText.textContent = 'Initialize Instructor Access';
            }
        }

        studentTab.addEventListener('click', () => updateRole('student'));
        teacherTab.addEventListener('click', () => updateRole('teacher'));

        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            console.log(`[Diagnostic] Attempting login for: ${email} (${password.length} chars)`);
            loginBtn.disabled = true;
            loginBtn.classList.add('opacity-50', 'cursor-not-allowed');
            loginText.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Verifying Cluster...';
            
            try {
                const response = await fetch('/api/auth/signin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password, requestedRole: selectedRole })
                });
                const data = await response.json();
                if (data.success) {
                    localStorage.setItem('accessToken', data.token);
                    localStorage.setItem('user', JSON.stringify(data.user));
                    localStorage.setItem('selectedRole', selectedRole);
                    window.location.href = '/dashboard';
                } else { alert(data.error); }
            } catch (error) { alert('Runtime error: ' + error.message); }
            finally { 
                loginBtn.disabled = false;
                loginBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                loginText.textContent = selectedRole === 'teacher' ? 'Initialize Instructor Access' : 'Initialize Student Access';
            }
        });

        function loginAsSuperAdmin() {
            document.getElementById('email').value = 'engineerfelex@gmail.com';
            document.getElementById('password').value = 'hyjnij-honrun-2cEdju';
            updateRole('teacher');
        }

        async function setupSuperAdmin() {
            const adminKey = prompt("Enter ADMIN_KEY:");
            if (!adminKey) return;
            try {
                const response = await fetch('/api/auth/setup-admin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: 'engineerfelex@gmail.com', password: 'hyjnij-honrun-2cEdju', adminKey })
                });
                const data = await response.json();
                alert(data.success ? 'Success' : 'Error: ' + data.error);
            } catch (error) { alert('Error: ' + error.message); }
        }
    </script>
</body>
</html>