<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Security - Multitouch Academy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/images/logo-multitouch.png">
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mongo-green': '#00ED64',
              'mongo-dark': '#001E2B',
              'mongo-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@100;300;400;500;700;900&display=swap');
        body { font-family: 'Outfit', sans-serif; }
        .glass {
            background: rgba(2, 52, 48, 0.4);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 237, 100, 0.1);
        }
        .premium-title {
            background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .input-premium {
            background: rgba(0, 30, 43, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .input-premium:focus {
            border-color: #00ED64;
            box-shadow: 0 0 20px rgba(0, 237, 100, 0.1);
        }
    </style>
</head>
<body class="dark bg-[#001E2B] text-[#E7EEEB] min-h-screen flex items-center justify-center p-6 bg-[url('https://www.mongodb.com/ready-2022/static/background-blobs-c9d3b1b4d8d8d8d8d8d8d8d8d8d8d8d8.svg')] bg-cover">
    
    <!-- Dark Mode Toggle -->
    <button id="themeToggle" class="fixed top-8 right-8 w-12 h-12 glass rounded-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all z-50">
        <span id="themeIcon">🌙</span>
    </button>

    <div class="w-full max-w-md relative animate-in fade-in zoom-in duration-700">
        <!-- Decoration -->
        <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-emerald-500/10 rounded-full blur-[100px]"></div>

        <div class="glass p-10 rounded-[2.5rem] shadow-2xl relative overflow-hidden text-center">
            <!-- Header -->
            <div class="mb-10">
                <div class="w-16 h-16 bg-[#001E2B] border border-[#00ED64]/20 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl overflow-hidden relative">
                    <img src="/images/logo-multitouch.png" alt="Logo" class="w-full h-full object-contain p-2 relative z-10" style="mix-blend-mode: screen; filter: brightness(1.2);">
                </div>
                <h1 class="text-3xl font-black tracking-tighter text-white">Reset <span class="premium-title">Security</span></h1>
                <p class="text-[#9FB1AD] mt-2 font-medium text-sm">Finalize credential restoration protocol.</p>
            </div>

            <form id="resetForm" class="space-y-6">
                <input type="hidden" id="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
                
                <div class="relative text-left">
                    <i class="fas fa-key absolute left-4 top-1/2 -translate-y-1/2 text-[10px] text-[#9FB1AD] opacity-30"></i>
                    <input type="text" id="confirmationCode" placeholder="Recovery Code" required
                           class="w-full pl-10 pr-4 py-4 input-premium rounded-2xl text-sm font-bold outline-none uppercase tracking-widest">
                </div>

                <div class="relative text-left">
                    <i class="fas fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-[10px] text-[#9FB1AD] opacity-30"></i>
                    <input type="password" id="newPassword" placeholder="New Security Key (8+ chars)" required minlength="8"
                           class="w-full pl-10 pr-4 py-4 input-premium rounded-2xl text-sm font-bold outline-none">
                </div>

                <button type="submit" id="submitBtn" class="w-full py-4 bg-[#00ED64] text-[#001E2B] font-black rounded-2xl hover:shadow-xl hover:shadow-[#00ED64]/20 hover:scale-[1.02] active:scale-[0.98] transition-all uppercase tracking-[0.2em] text-xs">
                    Commit Changes
                </button>

                <div class="flex justify-center mt-6">
                    <a href="/login" class="text-[10px] font-black uppercase tracking-widest text-[#9FB1AD] hover:text-[#00ED64] transition-all">
                        ← Re-read Gateway
                    </a>
                </div>
            </form>
        </div>
        <p class="text-center mt-8 text-[9px] font-black text-[#9FB1AD] uppercase tracking-[0.5em] opacity-20">© 2026 Multitouch Systems</p>
    </div>

    <script>
        // Theme Management
        function initTheme() {
            const theme = localStorage.getItem("theme") || "dark";
            document.documentElement.classList.toggle("dark", theme === "dark");
            document.getElementById('themeIcon').textContent = theme === "dark" ? '☀️' : '🌙';
        }
        initTheme();

        const resetForm = document.getElementById('resetForm');

        resetForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const confirmationCode = document.getElementById('confirmationCode').value;
            const newPassword = document.getElementById('newPassword').value;
            const submitBtn = document.getElementById('submitBtn');

            submitBtn.disabled = true;
            submitBtn.textContent = 'COMMITTING...';

            try {
                const response = await fetch('/api/auth/confirm-forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, confirmationCode, newPassword })
                });
                const data = await response.json();
                if (data.success) {
                    alert('Success: Security Key Updated');
                    window.location.href = '/login';
                } else {
                    alert(data.error || 'Commit failed');
                }
            } catch (error) { alert('Runtime error: ' + error.message); }
            finally { 
                submitBtn.disabled = false;
                submitBtn.textContent = 'Commit Changes';
            }
        });
    </script>
</body>
</html>