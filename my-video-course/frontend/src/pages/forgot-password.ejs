<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Video Course Platform</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mongo-green': '#00ED64',
              'mongo-slate': '#001E2B',
              'mongo-forest': '#00684A'
            },
            fontFamily: {
              'sans': ['Inter', '-apple-system', 'BlinkMacSystemFont', 'system-ui', 'sans-serif']
            }
          }
        }
      }
    </script>
</head>
<body class="bg-gray-50 dark:bg-gray-900 font-sans text-sm transition-colors duration-200">
    <div class="min-h-screen flex items-center justify-center px-4">
        <!-- Dark Mode Toggle -->
        <button id="themeToggle" class="fixed top-4 right-4 p-3 bg-white dark:bg-[#023430] rounded-full shadow-lg border border-transparent dark:border-[#00ED64]/20 hover:shadow-xl transition-all duration-200 z-10">
            <span id="themeIcon" class="text-xl">🌙</span>
        </button>
        
        <div class="max-w-md w-full bg-white dark:bg-[#023430] rounded-2xl shadow-lg border border-gray-100 dark:border-[#133A41] p-8 transition-colors duration-200">
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-[#00ED64] rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-sm">
                    <span class="text-[#001E2B] text-3xl font-bold">🍃</span>
                </div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-[#E7EEEB] mb-2 tracking-tight">
                    MongoDB <span class="font-normal text-gray-500">Academy</span>
                </h1>
                <p class="text-gray-500 dark:text-gray-400 text-sm">Enter your email to receive recovery instructions</p>
            </div>
            
            <form id="forgotForm" class="space-y-4">
                <div>
                    <input type="email" id="email" name="email" placeholder="Email" required
                           class="w-full px-4 py-3 bg-gray-50 dark:bg-[#001E2B] border border-gray-200 dark:border-[#133A41] text-gray-900 dark:text-[#E7EEEB] placeholder-gray-500 dark:placeholder-gray-400 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#00ED64] focus:border-transparent transition-all">
                </div>
                
                <button type="submit" id="resetBtn" class="w-full bg-gradient-to-r from-[#00ED64] to-[#00C152] text-[#001E2B] font-bold py-3 px-4 rounded-xl hover:shadow-[0_0_20px_rgba(0,237,100,0.3)] transition-all">
                    Send Reset Link
                </button>
                
                <div class="flex justify-center mt-4">
                    <a href="/login" class="text-sm text-[#00ED64] hover:underline font-medium">
                        ← Back to Sign In
                    </a>
                </div>
            </form>
            
            <!-- Success Message -->
            <div id="successMessage" class="hidden text-center space-y-4">
                <div class="text-4xl mb-4">📧</div>
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Check Your Email</h2>
                <p class="text-gray-500 dark:text-gray-400 text-sm">
                    We've sent password reset instructions to <span id="sentEmail" class="font-medium"></span>
                </p>
                <div class="flex justify-center mt-6">
                    <a href="/login" class="text-sm text-apple-blue dark:text-blue-400 hover:underline">
                        ← Back to Sign In
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // Dark Theme Toggle
        function initTheme() {
            const theme = localStorage.getItem("theme") || "light";
            document.documentElement.classList.toggle("dark", theme === "dark");
            document.getElementById('themeIcon').textContent = theme === "dark" ? '☀️' : '🌙';
        }
        
        function toggleTheme() {
            const newTheme = document.documentElement.classList.contains("dark") ? "light" : "dark";
            document.documentElement.classList.toggle("dark", newTheme === "dark");
            localStorage.setItem("theme", newTheme);
            document.getElementById('themeIcon').textContent = newTheme === "dark" ? '☀️' : '🌙';
        }
        
        initTheme();
        document.getElementById('themeToggle').addEventListener('click', toggleTheme);
        
        // Forgot password form handler
        document.getElementById('forgotForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const resetBtn = document.getElementById('resetBtn');
            
            resetBtn.disabled = true;
            resetBtn.textContent = 'Sending...';
            
            try {
                const response = await fetch('/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Redirect to reset password page with email pre-filled
                    window.location.href = `/reset-password?email=${encodeURIComponent(email)}`;
                } else {
                    alert(data.error || 'Failed to send reset email');
                }
            } catch (error) {
                alert('Error: ' + error.message);
            } finally {
                resetBtn.disabled = false;
                resetBtn.textContent = 'Send Reset Link';
            }
        });
    </script>
</body>
</html>