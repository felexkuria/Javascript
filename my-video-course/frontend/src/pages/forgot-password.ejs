<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recover Access - Multitouch Academy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mongo-green': '#00ED64',
              'mongo-dark': '#001E2B',
              'mongo-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@100;300;400;500;700;900&display=swap');
        body { font-family: 'Outfit', sans-serif; }
        .glass {
            background: rgba(2, 52, 48, 0.4);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 237, 100, 0.1);
        }
        .premium-title {
            background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .input-premium {
            background: rgba(0, 30, 43, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .input-premium:focus {
            border-color: #00ED64;
            box-shadow: 0 0 20px rgba(0, 237, 100, 0.1);
        }
    </style>
</head>
<body class="dark bg-[#001E2B] text-[#E7EEEB] min-h-screen flex items-center justify-center p-6 bg-[url('https://www.mongodb.com/ready-2022/static/background-blobs-c9d3b1b4d8d8d8d8d8d8d8d8d8d8d8d8.svg')] bg-cover">
    
    <!-- Dark Mode Toggle -->
    <button id="themeToggle" class="fixed top-8 right-8 w-12 h-12 glass rounded-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all z-50">
        <span id="themeIcon">🌙</span>
    </button>

    <div class="w-full max-w-md relative animate-in fade-in zoom-in duration-700">
        <!-- Decoration -->
        <div class="absolute -top-24 -left-24 w-64 h-64 bg-amber-500/10 rounded-full blur-[100px]"></div>

        <div class="glass p-10 rounded-[2.5rem] shadow-2xl relative overflow-hidden text-center">
            <!-- Header -->
            <div class="mb-10">
                <div class="w-16 h-16 bg-amber-500/20 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl border border-amber-500/20">
                    <i class="fas fa-key text-2xl text-amber-500"></i>
                </div>
                <h1 class="text-3xl font-black tracking-tighter text-white">Recover <span class="premium-title">Path</span></h1>
                <p class="text-[#9FB1AD] mt-2 font-medium text-sm">Initiate credential restoration protocol.</p>
            </div>

            <form id="forgotForm" class="space-y-6">
                <div class="relative text-left">
                    <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-[10px] text-[#9FB1AD] opacity-30"></i>
                    <input type="email" id="email" name="email" placeholder="Verification Email" required
                           class="w-full pl-10 pr-4 py-4 input-premium rounded-2xl text-sm font-bold outline-none">
                </div>

                <button type="submit" id="resetBtn" class="w-full py-4 bg-[#00ED64] text-[#001E2B] font-black rounded-2xl hover:shadow-xl hover:shadow-[#00ED64]/20 hover:scale-[1.02] active:scale-[0.98] transition-all uppercase tracking-[0.2em] text-xs">
                    Authorize Reset
                </button>

                <div class="flex justify-center mt-6">
                    <a href="/login" class="text-[10px] font-black uppercase tracking-widest text-[#9FB1AD] hover:text-[#00ED64] transition-all">
                        ← Return to Portal
                    </a>
                </div>
            </form>

            <!-- Success Overlay (Hidden) -->
            <div id="successMessage" class="hidden animate-in fade-in duration-500">
                <div class="py-10">
                    <i class="fas fa-paper-plane text-5xl text-[#00ED64] mb-6 block opacity-50"></i>
                    <h2 class="text-2xl font-black text-white mb-2 tracking-tight">Transmission Successful</h2>
                    <p class="text-xs text-[#9FB1AD] font-bold uppercase tracking-widest opacity-70 leading-relaxed">
                        Recovery vector transmitted to<br><span id="sentEmail" class="text-[#00ED64]"></span>
                    </p>
                    <div class="mt-10">
                        <a href="/login" class="px-8 py-3 glass rounded-xl text-[10px] font-black uppercase tracking-widest text-white hover:bg-white/5 transition-all">Back to Gateway</a>
                    </div>
                </div>
            </div>
        </div>
        <p class="text-center mt-8 text-[9px] font-black text-[#9FB1AD] uppercase tracking-[0.5em] opacity-20">© 2026 Multitouch Systems</p>
    </div>

    <script>
        // Theme Management
        function initTheme() {
            const theme = localStorage.getItem("theme") || "dark";
            document.documentElement.classList.toggle("dark", theme === "dark");
            document.getElementById('themeIcon').textContent = theme === "dark" ? '☀️' : '🌙';
        }
        initTheme();

        const forgotForm = document.getElementById('forgotForm');
        const successMessage = document.getElementById('successMessage');
        const sentEmail = document.getElementById('sentEmail');

        forgotForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const resetBtn = document.getElementById('resetBtn');

            resetBtn.disabled = true;
            resetBtn.textContent = 'TRANSMITTING...';

            try {
                const response = await fetch('/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await response.json();
                if (data.success) {
                    window.location.href = `/reset-password?email=${encodeURIComponent(email)}`;
                } else {
                    alert(data.error || 'Vector transmission failed');
                }
            } catch (error) { alert('Runtime error: ' + error.message); }
            finally { 
                resetBtn.disabled = false;
                resetBtn.textContent = 'Authorize Reset';
            }
        });
    </script>
</body>
</html>