<%- include('partials/header', { title: 'All Courses', activePage: 'courses' }) %>

<!-- VERSION: ATLAS-REWRITE-V3 -->
<style>
  :root {
    --atlas-forest: #00684A;
    --atlas-spring: #00ED64;
    --atlas-evergreen: #023430;
    --atlas-slate: #495957;
    --atlas-mist: #E7EEEB;
    --atlas-white: #FFFFFF;
    --atlas-black: #001E2B;
    --atlas-border: #E8EDE9;
  }

  .atlas-main-wrapper {
    min-height: 100vh;
    background-color: #FFFFFF; /* FORCE WHITE BACKGOUND */
    color: var(--atlas-black);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    padding-bottom: 100px;
  }

  .dark .atlas-main-wrapper {
    background-color: var(--atlas-black);
    color: var(--atlas-mist);
  }

  .atlas-hero-section {
    padding: 80px 24px;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  @media (min-width: 1024px) {
    .atlas-hero-section {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }

  .search-container-atlas {
    width: 100%;
    max-width: 500px;
    position: relative;
  }

  .search-input-atlas {
    width: 100%;
    padding: 14px 16px 14px 48px;
    background: #FFFFFF;
    border: 1px solid var(--atlas-border);
    border-radius: 8px;
    font-size: 14px;
    transition: all 0.2s;
  }

  .dark .search-input-atlas {
    background: #023430;
    border-color: #133A41;
    color: white;
  }

  .search-input-atlas:focus {
    outline: none;
    border-color: var(--atlas-forest);
    box-shadow: 0 0 0 4px rgba(0, 104, 74, 0.05);
  }

  /* ── Grid System ── */
  .courses-grid-atlas {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Card Design ── */
  .atlas-card {
    background: white;
    border: 1px solid var(--atlas-border);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    height: 400px; /* FIXED HEIGHT FOR BALANCE */
    transition: all 0.2s cubic-bezier(0.2, 0, 0.4, 1);
    position: relative;
    overflow: hidden;
  }

  .dark .atlas-card {
    background: #001E2B;
    border-color: #133A41;
  }

  .atlas-card:hover {
    border-color: var(--atlas-forest);
    box-shadow: 0 8px 16px rgba(0, 30, 43, 0.05);
    background: #F9FBFA;
  }

  .dark .atlas-card:hover {
    border-color: var(--atlas-spring);
    background: #023430;
  }

  .monogram-atlas {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, var(--atlas-spring) 0%, #00C152 100%);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 18px;
    color: var(--atlas-black);
    margin-bottom: 20px;
  }

  .course-badge-atlas {
    position: absolute;
    top: 24px;
    right: 24px;
    background: var(--atlas-mist);
    color: var(--atlas-forest);
    padding: 4px 10px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dark .course-badge-atlas {
    background: rgba(0, 237, 100, 0.1);
    color: var(--atlas-spring);
  }

  .course-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--atlas-black);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .dark .course-title {
    color: white;
  }

  .course-desc {
    font-size: 14px;
    color: var(--atlas-slate);
    line-height: 1.5;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .dark .course-desc {
    color: #9FB1AD;
  }

  .meta-atlas {
    display: flex;
    gap: 16px;
    font-size: 11px;
    font-weight: 700;
    color: var(--atlas-slate);
    text-transform: uppercase;
    margin-bottom: auto;
  }

  .atlas-btn-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 24px;
  }

  .btn-atlas {
    padding: 10px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 700;
    text-align: center;
    transition: all 0.2s;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
  }

  .btn-atlas-fill {
    background: var(--atlas-forest);
    color: white;
  }

  .btn-atlas-fill:hover {
    background: #00593f;
  }

  .btn-atlas-ghost {
    background: transparent;
    border-color: var(--atlas-border);
    color: var(--atlas-black);
  }

  .dark .btn-atlas-ghost {
    border-color: #133A41;
    color: white;
  }

  .btn-atlas-ghost:hover {
    border-color: var(--atlas-forest);
  }

  /* ── Progress Bar ── */
  .atlas-p-bar {
    width: 100%;
    height: 4px;
    background: var(--atlas-mist);
    border-radius: 4px;
    margin-top: 16px;
    overflow: hidden;
  }

  .atlas-p-fill {
    height: 100%;
    background: var(--atlas-forest);
    transition: width 1s ease;
  }

  .dark .atlas-p-fill {
    background: var(--atlas-spring);
  }
</style>

<div class="atlas-main-wrapper">
  <div class="atlas-hero-section">
    <div>
      <h1 style="font-size: 44px; font-weight: 900; letter-spacing: -0.03em;">Academy Curriculum</h1>
      <p style="opacity: 0.7; font-weight: 500; margin-top: 8px;">Master modern engineering with our professional-grade modules.</p>
    </div>
    
    <div class="search-container-atlas">
      <i class="fas fa-search" style="position: absolute; left: 16px; top: 18px; color: var(--atlas-forest); opacity: 0.5;"></i>
      <input type="text" id="courseSearch" class="search-input-atlas" placeholder="Filter subjects...">
    </div>
  </div>

  <div class="courses-grid-atlas" id="coursesGrid">
    <% if (courses && courses.length > 0) { %>
      <% courses.forEach(course => { %>
        <% 
          const title = (course.title || course.name || '').replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
          const initial = title.match(/[A-Z]/)?.[0] || 'A';
        %>
        <div class="atlas-card">
          <div class="course-badge-atlas"><%= course.category || 'Core' %></div>
          
          <div class="monogram-atlas"><%= initial %></div>
          
          <h3 class="course-title"><%= title %></h3>
          
          <p class="course-desc">
            <%= course.description || 'Deep dive into this comprehensive engineering lab designed for modern infrastructure.' %>
          </p>

          <div class="meta-atlas">
            <span><i class="fas fa-layer-group"></i> <%= course.sections ? course.sections.length : 0 %></span>
            <span><i class="fas fa-play-circle"></i> <%= course.videoCount || 0 %></span>
          </div>

          <!-- Progress Injected by JS -->
          <div class="enrollment-status" data-course-id="<%= course._id || course.name %>"></div>

          <div class="atlas-btn-group">
            <button onclick="enrollInCourse('<%= course._id || course.name %>')" 
                    class="btn-atlas btn-atlas-fill" 
                    data-btn-course-id="<%= course._id || course.name %>">
              Enroll
            </button>
            <a href="/course/<%= course.name %>" class="btn-atlas btn-atlas-ghost">
              Details
            </a>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

<script>
// Search
document.getElementById('courseSearch')?.addEventListener('input', (e) => {
  const term = e.target.value.toLowerCase();
  document.querySelectorAll('.atlas-card').forEach(card => {
    const title = card.querySelector('.course-title').textContent.toLowerCase();
    card.style.display = title.includes(term) ? 'flex' : 'none';
  });
});

async function enrollInCourse(courseId) {
  try {
    const token = localStorage.getItem('accessToken');
    if (!token) { window.location.href = '/login'; return; }

    const button = document.querySelector(`[data-btn-course-id="${courseId}"]`);
    button.disabled = true;
    button.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>';

    const response = await fetch('/api/enrollments', {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ courseId })
    });

    const data = await response.json();
    if (data.success) {
      button.innerHTML = 'Enrolled';
      button.style.opacity = '0.5';
      setTimeout(() => window.location.reload(), 800);
    } else { throw new Error(data.error); }
  } catch (err) {
    alert('Error: ' + err.message);
    const button = document.querySelector(`[data-btn-course-id="${courseId}"]`);
    button.disabled = false;
    button.innerText = 'Enroll';
  }
}

// Progress
document.addEventListener('DOMContentLoaded', async () => {
  const token = localStorage.getItem('accessToken');
  if (!token) return;

  const containers = document.querySelectorAll('.enrollment-status');
  for (const container of containers) {
    const courseId = container.dataset.courseId;
    try {
      const response = await fetch(`/api/enrollments/check/${encodeURIComponent(courseId)}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.success && data.data.enrolled) {
        const btn = document.querySelector(`[data-btn-course-id="${courseId}"]`);
        if (btn) { btn.disabled = true; btn.innerText = 'Enrolled'; btn.style.opacity = '0.5'; }
        const progress = data.data.progress || 0;
        container.innerHTML = `
          <div class="atlas-p-bar"><div class="atlas-p-fill" style="width: ${progress}%"></div></div>
          <div style="font-size: 9px; font-weight: 800; opacity: 0.5; margin-top: 4px; text-transform: uppercase;">${progress}% Complete</div>
        `;
      }
    } catch (e) {}
  }
});
</script>
