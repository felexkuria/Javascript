<%- include('partials/header', { title: 'Engineering Manifest - Course Catalog', activePage: 'courses' }) %>

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --mdb-green: #00ED64;
        --mdb-midnight: #001E2B;
        --glass-bg: rgba(2, 52, 48, 0.4);
        --glass-border: rgba(0, 237, 100, 0.1);
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--mdb-midnight);
        color: #E7EEEB;
        -webkit-font-smoothing: antialiased;
        transition: all 0.3s ease;
    }

    .premium-glass {
        background: var(--glass-bg);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid var(--glass-border);
    }

    .catalog-card-atlas {
        border-radius: 24px;
        transition: all 0.4s cubic-bezier(0.2, 0, 0, 1);
        border: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(255, 255, 255, 0.02);
        height: 100%;
    }

    .catalog-card-atlas:hover {
        transform: translateY(-8px);
        border-color: var(--mdb-green);
        background: rgba(0, 237, 100, 0.03);
        box-shadow: 0 20px 40px rgba(0, 30, 43, 0.4);
    }

    .monogram-canvas {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 18px;
        color: var(--mdb-midnight);
    }

    .btn-atlas-action {
        background: #00ED64;
        color: #001E2B;
        font-weight: 800;
        padding: 12px 20px;
        border-radius: 14px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 10px;
    }

    .btn-atlas-action:hover {
        box-shadow: 0 0 30px rgba(0, 237, 100, 0.3);
        transform: scale(1.03);
    }

    .btn-atlas-outline {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
        font-weight: 800;
        padding: 12px 20px;
        border-radius: 14px;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 10px;
    }

    .btn-atlas-outline:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: var(--mdb-green);
    }

    .search-bay {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 16px 24px 16px 56px;
        width: 100%;
        color: white;
        font-weight: 500;
        outline: none;
        transition: all 0.3s;
    }

    .search-bay:focus {
        border-color: var(--mdb-green);
        background: rgba(0, 237, 100, 0.05);
        box-shadow: 0 0 0 4px rgba(0, 237, 100, 0.1);
    }

    .tag-premium {
        padding: 6px 14px;
        background: rgba(0, 237, 100, 0.08);
        color: #00ED64;
        border: 1px solid rgba(0, 237, 100, 0.15);
        border-radius: 12px;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .progress-conduit {
        width: 100%;
        height: 6px;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 99px;
        overflow: hidden;
    }

    .progress-flow {
        height: 100%;
        background: linear-gradient(90deg, #00ED64, #00684A);
        box-shadow: 0 0 10px rgba(0, 237, 100, 0.4);
        transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>

<div class="min-h-screen pt-24 lg:pt-32 pb-16 lg:pb-24 px-4 sm:px-8 lg:px-12">
    <div class="max-w-[1400px] mx-auto">
        <!-- Dashboard Navigation Integration -->
        <%- include('partials/student-sidebar', { activePage: 'courses' }) %>

        <div class="lg:ml-72 transition-all">
            <!-- Hero Section -->
            <header class="mb-12 lg:mb-20">
                <div class="flex items-center gap-4 mb-6">
                    <span class="px-4 py-1.5 bg-[#00ED64]/10 text-[#00ED64] text-[10px] font-black uppercase tracking-[0.3em] rounded-full border border-[#00ED64]/20">Core Manifest</span>
                    <div class="h-px flex-grow bg-white/5"></div>
                </div>
                
                <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8 lg:gap-12">
                    <div class="max-w-3xl">
                        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter mb-4 lg:mb-6 text-white leading-none">Engineering <span class="text-[#00ED64]">Atlas</span></h1>
                        <p class="text-gray-400 text-xl font-medium leading-relaxed max-w-2xl">
                            Deploy high-fidelity curriculum modules optimized for professional-grade architectural mastery. Synchronize your development path.
                        </p>
                    </div>
                    <div class="w-full lg:w-[480px] relative group">
                        <i class="fas fa-search absolute left-6 top-1/2 -translate-y-1/2 text-gray-500 text-sm group-focus-within:text-[#00ED64] transition-colors"></i>
                        <input type="text" id="courseSearch" class="search-bay" placeholder="SEARCH CORE MODULES BY TITLE OR TECH...">
                    </div>
                </div>
            </header>

            <!-- Grid Controller -->
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-6" id="coursesGrid">
                <% if (courses && courses.length > 0) { %>
                    <% courses.forEach(course => { %>
                        <% 
                            const title = (course.title || course.name || '').replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
                            const initial = title.match(/[A-Z]/)?.[0] || 'A';
                        %>
                        <div class="catalog-card-atlas premium-glass p-6 flex flex-col group">
                            <div class="flex justify-between items-start mb-6">
                                <div class="monogram-canvas group-hover:rotate-6 transition-transform"><%= initial %></div>
                                <div class="tag-premium"><%= course.category || 'PROD' %></div>
                            </div>
                            
                            <div class="mb-6 flex-grow">
                                <h3 class="text-lg font-black tracking-tight mb-3 group-hover:text-[#00ED64] transition-colors line-clamp-2"><%= title %></h3>
                                <p class="text-gray-400 text-[13px] font-medium leading-relaxed mb-6 line-clamp-3 opacity-80 group-hover:opacity-100 transition-opacity">
                                    <%= course.description || 'Access high-fidelity engineering labs designed for professional-grade architectural mastery.' %>
                                </p>
                            </div>

                            <div class="mt-auto">
                                <div class="flex items-center gap-4 mb-6 border-t border-white/5 pt-6">
                                    <div class="flex items-center gap-2 text-[9px] font-black tracking-widest uppercase text-gray-500">
                                        <i class="fas fa-cubes text-[#00ED64]/60"></i>
                                        <%= course.sections ? course.sections.length : 0 %> Sec
                                    </div>
                                    <div class="flex items-center gap-2 text-[9px] font-black tracking-widest uppercase text-gray-500">
                                        <i class="fas fa-bolt text-[#00ED64]/60"></i>
                                        <%= course.videoCount || course.videos?.length || 0 %> Les
                                    </div>
                                </div>

                                <!-- Dynamic Enrollment Interface -->
                                <div class="enrollment-status-bay" data-course-id="<%= course._id || course.name %>"></div>

                                <div class="flex gap-4 mt-8">
                                    <button onclick="enrollInCourse('<%= course._id || course.name %>')" 
                                            class="btn-atlas-action flex-grow" 
                                            id="btn-enroll-<%= course._id || course.name %>"
                                            data-course-name="<%= course.name %>">
                                        Initialize Access
                                    </button>
                                    <a href="/course/<%= course.name %>" class="btn-atlas-outline px-8 flex items-center justify-center">
                                        <i class="fas fa-cog"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full py-40 premium-glass rounded-[60px] border-dashed border-white/10 flex flex-col items-center justify-center text-center">
                        <div class="w-32 h-32 bg-[#00ED64]/5 rounded-full flex items-center justify-center mb-10 border border-[#00ED64]/10">
                            <i class="fas fa-network-wired text-[#00ED64] text-5xl"></i>
                        </div>
                        <h2 class="text-4xl font-black text-white mb-6">Database Offline</h2>
                        <p class="text-gray-400 text-lg font-medium max-w-md mx-auto mb-12">The curriculum manifest is currently empty or the synchronization pipe is obstructed.</p>
                        <button onclick="window.location.reload()" class="btn-atlas-action px-12">Retry Connection</button>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    // System Theme Force
    document.documentElement.classList.add('dark');

    // Live Manifest Search
    document.getElementById('courseSearch')?.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        document.querySelectorAll('.catalog-card-atlas').forEach(card => {
            const title = card.querySelector('h3').textContent.toLowerCase();
            const desc = card.querySelector('p').textContent.toLowerCase();
            card.style.display = (title.includes(term) || desc.includes(term)) ? 'flex' : 'none';
        });
    });

    async function enrollInCourse(courseId) {
        try {
            const token = localStorage.getItem('accessToken');
            if (!token) { window.location.href = '/login'; return; }

            const button = document.getElementById(`btn-enroll-${courseId}`);
            const originalText = button.innerText;
            button.disabled = true;
            button.innerHTML = '<i class="fas fa-circle-notch fa-spin mr-2"></i> Initializing...';

            const response = await fetch('/api/enrollments', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ courseId })
            });

            const data = await response.json();
            if (data.success) {
                button.innerHTML = '<i class="fas fa-check mr-2"></i> Synchronized';
                button.classList.add('opacity-50');
                setTimeout(() => window.location.reload(), 1200);
            } else { throw new Error(data.error); }
        } catch (err) {
            alert('PROTOCOL ERROR: ' + err.message);
            const button = document.getElementById(`btn-enroll-${courseId}`);
            button.disabled = false;
            button.innerText = 'RETRY INITIALIZATION';
        }
    }

    // Refresh Sync States
    document.addEventListener('DOMContentLoaded', async () => {
        const token = localStorage.getItem('accessToken');
        if (!token) return;

        const bincords = document.querySelectorAll('.enrollment-status-bay');
        for (const bin of bincords) {
            const courseId = bin.dataset.courseId;
            try {
                const response = await fetch(`/api/enrollments/check/${encodeURIComponent(courseId)}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await response.json();
                if (data.success && data.data.enrolled) {
                    const btn = document.getElementById(`btn-enroll-${courseId}`);
                    if (btn) {
                        btn.innerText = 'RESUME CONSOLE';
                        btn.onclick = () => window.location.href = `/course/${encodeURIComponent(btn.getAttribute('data-course-name'))}`;
                    }
                    const progress = data.data.progress || 0;
                    bin.innerHTML = `
                        <div class="flex justify-between items-center mb-3">
                            <span class="text-[9px] font-black text-[#00ED64] uppercase tracking-[0.2em]">Sync Intelligence</span>
                            <span class="text-[9px] font-black text-white/40 tracking-widest">${progress}% COMPLETE</span>
                        </div>
                        <div class="progress-conduit"><div class="progress-flow" style="width: ${progress}%"></div></div>
                    `;
                }
            } catch (e) {}
        }
    });
</script>
