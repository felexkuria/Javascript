<%- include('partials/header', { title: 'Engineering Manifest - Course Catalog', activePage: 'courses' }) %>

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;400;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --atlas-green: #00ED64;
        --atlas-forest: #00684A;
        --atlas-slate: #001E2B;
        --glass-bg: rgba(255, 255, 255, 0.7);
        --glass-border: rgba(0, 30, 43, 0.1);
    }

    .dark {
        --glass-bg: rgba(2, 52, 48, 0.4);
        --glass-border: rgba(0, 237, 100, 0.15);
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: #F9FBFA;
        color: var(--atlas-slate);
        transition: all 0.3s ease;
    }

    .dark body {
        background-color: var(--atlas-slate);
        color: white;
    }

    .premium-glass {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
    }

    .catalog-card {
        border-radius: 32px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        overflow: hidden;
    }

    .catalog-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 30, 43, 0.1);
        border-color: var(--atlas-green);
    }

    .monogram-box {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 24px;
        color: var(--atlas-slate);
        box-shadow: 0 8px 20px rgba(0, 237, 100, 0.2);
    }

    .btn-atlas {
        background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
        color: var(--atlas-slate);
        font-weight: 900;
        padding: 12px 24px;
        border-radius: 14px;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 11px;
    }

    .btn-atlas:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 25px rgba(0, 237, 100, 0.3);
    }

    .btn-details {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: inherit;
        font-weight: 700;
        padding: 12px 24px;
        border-radius: 14px;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 11px;
    }

    .btn-details:hover {
        background: rgba(0, 237, 100, 0.05);
        border-color: var(--atlas-green);
    }

    .search-input-premium {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 14px 20px 14px 48px;
        width: 100%;
        font-weight: 600;
        outline: none;
        transition: all 0.2s;
    }

    .search-input-premium:focus {
        border-color: var(--atlas-green);
        box-shadow: 0 0 0 4px rgba(0, 237, 100, 0.1);
    }

    .catalog-badge {
        position: absolute;
        top: 24px;
        right: 24px;
        padding: 4px 12px;
        background: rgba(0, 237, 100, 0.1);
        color: #00ED64;
        border: 1px solid rgba(0, 237, 100, 0.2);
        border-radius: 20px;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .p-bar-track {
        width: 100%;
        height: 6px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        overflow: hidden;
        margin-top: 16px;
    }

    .p-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #00ED64, #00684A);
        transition: width 1s ease;
    }
</style>

<div class="atlas-main-wrapper min-h-screen pt-32 pb-24 px-10">
    <div class="max-w-7xl mx-auto">
        <!-- Hero Header -->
        <header class="mb-20">
            <div class="flex items-center gap-3 mb-4">
                <span class="px-3 py-1 bg-[#00ED64]/10 text-[#00ED64] text-[10px] font-black uppercase tracking-widest rounded-full border border-[#00ED64]/20">Academy Registry</span>
                <div class="h-px w-12 bg-white/10"></div>
            </div>
            <div class="flex flex-col lg:flex-row justify-between items-end gap-10">
                <div class="max-w-2xl">
                    <h1 class="text-6xl font-black tracking-tighter mb-4">Engineering <span class="text-[#00ED64]">Manifest</span></h1>
                    <p class="text-gray-400 text-xl font-medium leading-relaxed">Systematic mastery of cloud architecture, neural networks, and distributed systems. Execute your curriculum.</p>
                </div>
                <div class="w-full lg:w-96 relative">
                    <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-gray-500 text-xs"></i>
                    <input type="text" id="courseSearch" class="search-input-premium" placeholder="SEARCH CORE MODULES...">
                </div>
            </div>
        </header>

        <!-- Courses Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10" id="coursesGrid">
            <% if (courses && courses.length > 0) { %>
                <% courses.forEach(course => { %>
                    <% 
                        const title = (course.title || course.name || '').replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
                        const initial = title.match(/[A-Z]/)?.[0] || 'A';
                    %>
                    <div class="catalog-card premium-glass p-10 flex flex-col justify-between">
                        <div class="catalog-badge"><%= course.category || 'CORE' %></div>
                        
                        <div>
                            <div class="monogram-box mb-8"><%= initial %></div>
                            <h3 class="text-2xl font-black tracking-tight mb-4 line-clamp-2"><%= title %></h3>
                            <p class="text-gray-400 text-sm font-medium leading-relaxed mb-10 line-clamp-3">
                                <%= course.description || 'Access high-fidelity engineering labs designed for professional-grade architectural mastery.' %>
                            </p>
                        </div>

                        <div>
                            <div class="flex items-center gap-6 mb-10 opacity-60">
                                <div class="flex items-center gap-2 text-[10px] font-black tracking-widest uppercase">
                                    <i class="fas fa-layer-group text-[#00ED64]"></i>
                                    <%= course.sections ? course.sections.length : 0 %> Sections
                                </div>
                                <div class="flex items-center gap-2 text-[10px] font-black tracking-widest uppercase">
                                    <i class="fas fa-play-circle text-[#00ED64]"></i>
                                    <%= course.videoCount || 0 %> Lessons
                                </div>
                            </div>

                            <!-- Progress Placeholder -->
                            <div class="enrollment-status" data-course-id="<%= course._id || course.name %>"></div>

                            <div class="flex gap-4 mt-8">
                                <button onclick="enrollInCourse('<%= course._id || course.name %>')" 
                                        class="btn-atlas flex-1" 
                                        data-btn-course-id="<%= course._id || course.name %>"
                                        data-course-name="<%= course.name %>">
                                    Initialize
                                </button>
                                <a href="/course/<%= course.name %>" class="btn-details">
                                    Specs
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    // Search Functionality
    document.getElementById('courseSearch')?.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        document.querySelectorAll('.catalog-card').forEach(card => {
            const title = card.querySelector('h3').textContent.toLowerCase();
            const desc = card.querySelector('p').textContent.toLowerCase();
            card.style.display = (title.includes(term) || desc.includes(term)) ? 'flex' : 'none';
        });
    });

    async function enrollInCourse(courseId) {
        try {
            const token = localStorage.getItem('accessToken');
            if (!token) { window.location.href = '/login'; return; }

            const button = document.querySelector(`[data-btn-course-id="${courseId}"]`);
            const originalText = button.innerText;
            button.disabled = true;
            button.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>';

            const response = await fetch('/api/enrollments', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ courseId })
            });

            const data = await response.json();
            if (data.success) {
                button.innerHTML = 'SYNCHRONIZED';
                button.classList.add('opacity-50');
                setTimeout(() => window.location.reload(), 1000);
            } else { throw new Error(data.error); }
        } catch (err) {
            alert('ORCHESTRATION FAILED: ' + err.message);
            const button = document.querySelector(`[data-btn-course-id="${courseId}"]`);
            button.disabled = false;
            button.innerText = 'INITIALIZE';
        }
    }

    // Sync Progress States
    document.addEventListener('DOMContentLoaded', async () => {
        const token = localStorage.getItem('accessToken');
        if (!token) return;

        const containers = document.querySelectorAll('.enrollment-status');
        for (const container of containers) {
            const courseId = container.dataset.courseId;
            try {
                const response = await fetch(`/api/enrollments/check/${encodeURIComponent(courseId)}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await response.json();
                if (data.success && data.data.enrolled) {
                    const btn = document.querySelector(`[data-btn-course-id="${courseId}"]`);
                    if (btn) {
                        btn.innerText = 'RESUME CONSOLE';
                        btn.onclick = () => window.location.href = `/course/${encodeURIComponent(btn.getAttribute('data-course-name'))}`;
                    }
                    const progress = data.data.progress || 0;
                    container.innerHTML = `
                        <div class="p-bar-track"><div class="p-bar-fill" style="width: ${progress}%"></div></div>
                        <div class="flex justify-between items-center mt-2">
                            <span class="text-[9px] font-black text-[#00ED64] uppercase tracking-widest">Synchronization State</span>
                            <span class="text-[9px] font-black text-white/50">${progress}%</span>
                        </div>
                    `;
                }
            } catch (e) {}
        }
    });
</script>
