<%- include('partials/header', { title: 'AI Assistant', extraStyles: `
<style>
  body {
    background-color: #001E2B;
    color: #E7EEEB;
    font-family: 'Inter', sans-serif;
  }
  .chat-container {
    height: calc(100vh - 250px);
    background-color: rgba(2, 52, 48, 0.5);
    backdrop-filter: blur(10px);
    border-radius: 0;
  }
  .message {
    animation: fadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .message .bg-mongo-green {
    background-color: #00ED64;
    color: #001E2B;
  }
  .message .bg-mongo-slate {
    background-color: #001E2B;
    border: 1px solid rgba(0, 237, 100, 0.2);
    color: #E7EEEB;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
` }) %>

<main class="flex-grow px-4 py-8 md:px-8">
  <div class="max-w-4xl mx-auto">
    <div class="bg-[#023430] border border-[#00ED64]/20 rounded-2xl shadow-2xl overflow-hidden mt-4">
      <div class="bg-gradient-to-r from-[#00ED64] to-[#00684A] p-8">
        <h1 class="text-3xl font-black text-[#001E2B] mb-2">🍃 AI Academy Assistant</h1>
        <p class="text-[#001E2B]/80 font-medium">
          Ask me anything about your course content. I'll explain complex concepts with modern clarity.
        </p>
      </div>

      <div
        id="chatContainer"
        class="chat-container overflow-y-auto p-6 space-y-6"
      >
        <div class="message mb-4">
          <div class="flex items-start">
            <div
              class="bg-[#00ED64] text-[#001E2B] rounded-xl w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0 shadow-lg"
            >
              🍃
            </div>
            <div class="bg-[#001E2B] border border-[#00ED64]/20 rounded-2xl p-6 shadow-xl max-w-3xl">
              <p class="text-[#E7EEEB]/90 font-medium leading-relaxed">
                Hello! I'm your course assistant. I have knowledge from all your
                video courses and can explain concepts in an engaging, David J.
                Malan style. Try asking me:
              </p>
              <ul class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-2 text-sm text-[#00ED64]/70 italic">
                <li>🍃 "Explain Git architecture"</li>
                <li>🍃 "What is a Cluster in MongoDB?"</li>
                <li>🍃 "How does the Event Loop work?"</li>
                <li>🍃 "Explain AWS IAM roles"</li>
              </ul>
              <p class="text-gray-300 mt-4">
                Additionally, I can help you manage your tasks. Here's a sample of what you can do:
              </p>
              <ul class="mt-2 text-sm text-gray-400">
                <li>• "Add 'Complete project report' to my todos"</li>
                <li>• "Show me my todos"</li>
                <li>• "Mark 'Complete project report' as done"</li>
                <li>• "Clear all completed todos"</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="border-t border-[#00ED64]/10 bg-[#001E2B] p-6">
        <div class="flex gap-4">
          <input
            type="text"
            id="messageInput"
            placeholder="Ask your technical questions here..."
            class="flex-1 bg-[#023430] border border-[#00ED64]/20 rounded-xl px-6 py-3 text-[#E7EEEB] placeholder-[#E7EEEB]/30 focus:outline-none focus:ring-2 focus:ring-[#00ED64]/50 transition-all font-medium"
          />
          <button
            id="sendButton"
            class="bg-gradient-to-r from-[#00ED64] to-[#00C152] text-[#001E2B] px-8 py-3 rounded-xl font-black hover:shadow-[0_0_20px_rgba(0,237,100,0.3)] transition-all flex items-center gap-2"
          >
            <span>Send</span>
            <i class="fas fa-paper-plane text-xs"></i>
          </button>
        </div>
        <div class="mt-4 flex justify-end">
          <button
            id="clearHistoryButton"
            class="text-xs font-bold uppercase tracking-widest text-[#E7EEEB]/20 hover:text-red-400 transition-colors"
          >
            Clear History
          </button>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const chatContainer = document.getElementById("chatContainer");
    const messageInput = document.getElementById("messageInput");
    const sendButton = document.getElementById("sendButton");

    // Load chat history from localStorage
    let chatHistory = JSON.parse(
      localStorage.getItem("chatbot_history") || "[]"
    );

    function addMessage(content, isUser = false, saveToHistory = true) {
      const messageDiv = document.createElement("div");
      // Format words enclosed in **<words>** as bold

      content = content.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");

      // Format words enclosed in *<word>* as italic
      content = content.replace(/\*(.*?)\*/g, "<em>$1</em>");
      messageDiv.className = "message mb-4";

      messageDiv.innerHTML = `
      <div class="flex items-start ${isUser ? "justify-end" : ""}">
        ${
          !isUser
            ? '<div class="bg-[#00ED64] text-[#001E2B] rounded-xl w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0 shadow-lg">🍃</div>'
            : ""
        }
        <div class="${
          isUser ? "bg-gradient-to-r from-[#00ED64] to-[#00C152] text-[#001E2B] ml-12 font-bold" : "bg-[#001E2B] text-[#E7EEEB] border border-[#00ED64]/20"
        } rounded-2xl p-4 shadow-xl max-w-3xl leading-relaxed">
          ${content}
        </div>
        ${
          isUser
            ? '<div class="bg-[#00684A] text-[#00ED64] border border-[#00ED64]/30 rounded-xl w-10 h-10 flex items-center justify-center ml-4 flex-shrink-0 shadow-lg">👤</div>'
            : ""
        }
      </div>
    `;

      chatContainer.appendChild(messageDiv);
      chatContainer.scrollTop = chatContainer.scrollHeight;

      // Save to history
      if (saveToHistory) {
        chatHistory.push({ content, isUser, timestamp: Date.now() });
        localStorage.setItem("chatbot_history", JSON.stringify(chatHistory));
      }
    }

    // Load existing chat history
    function loadChatHistory() {
      // Clear welcome message if history exists
      if (chatHistory.length > 0) {
        chatContainer.innerHTML = "";
        chatHistory.forEach((msg) => {
          addMessage(msg.content, msg.isUser, false);
        });
      }
    }

    function showTyping() {
      const typingDiv = document.createElement("div");
      typingDiv.id = "typing";
      typingDiv.className = "message mb-4";
      typingDiv.innerHTML = `
      <div class="flex items-start">
        <div class="bg-[#00ED64] text-[#001E2B] rounded-xl w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0 shadow-lg">🍃</div>
        <div class="bg-[#001E2B] border border-[#00ED64]/20 rounded-2xl p-6 shadow-xl">
          <div class="flex gap-2 items-center">
            <div class="w-2 h-2 bg-[#00ED64] rounded-full animate-bounce"></div>
            <div class="w-2 h-2 bg-[#00ED64] rounded-full animate-bounce [animation-delay:-0.15s]"></div>
            <div class="w-2 h-2 bg-[#00ED64] rounded-full animate-bounce [animation-delay:-0.3s]"></div>
            <span class="text-xs font-bold text-[#00ED64] ml-2 tracking-widest uppercase">Thinking...</span>
          </div>
        </div>
      </div>
    `;
      chatContainer.appendChild(typingDiv);
      chatContainer.scrollTop = chatContainer.scrollHeight;
    }

    function hideTyping() {
      const typing = document.getElementById("typing");
      if (typing) typing.remove();
    }

    async function sendMessage() {
      const message = messageInput.value.trim();
      if (!message) return;

      addMessage(message, true);
      messageInput.value = "";
      sendButton.disabled = true;

      showTyping();

      try {
        const response = await fetch("/api/chatbot", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ message }),
        });

        const data = await response.json();
        hideTyping();

        if (data.response) {
          addMessage(data.response.replace(/\n/g, "<br>"));
        } else {
          addMessage("Sorry, I encountered an error. Please try again.");
        }
      } catch (error) {
        hideTyping();
        addMessage("Sorry, I'm having trouble connecting. Please try again.");
      }

      sendButton.disabled = false;
    }

    // Load chat history on page load
    loadChatHistory();

    sendButton.addEventListener("click", sendMessage);
    messageInput.addEventListener("keypress", (e) => {
      if (e.key === "Enter") sendMessage();
    });
  });
</script>

<%- include('partials/footer') %>
