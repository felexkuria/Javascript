<%- include('partials/header', { title: 'Neural Support Hub', activePage: 'chatbot' }) %>

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<script src="/js/confetti.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<div class="flex min-h-screen pt-32 pb-24 px-8 lg:px-12 bg-[#001E2B] learning-canvas">
    <!-- Student Sidebar Integration -->
    <%- include('partials/student-sidebar', { activePage: 'chatbot' }) %>

    <main class="lg:ml-72 flex-grow">
        <div class="max-w-6xl mx-auto">
            <header class="mb-12">
                <div class="flex items-center gap-4 mb-4">
                    <span class="atlas-badge">Neural Interface v2.0</span>
                    <div class="h-px w-24 bg-white/5"></div>
                    <span class="technical-label">Nova Lite Active</span>
                </div>
                <h1 class="text-7xl font-black tracking-tighter text-white">Neural <span class="text-[#00ED64]">Support</span> Hub</h1>
                <p class="text-[#9FB1AD] text-xl font-medium mt-4">High-fidelity linguistic synthesis of architectural concepts for the Levi Academy.</p>
            </header>

            <div class="atlas-card glass rounded-[48px] overflow-hidden flex flex-col shadow-2xl">
                <!-- Chat Window -->
                <div id="chatContainer" class="h-[600px] overflow-y-auto p-12 space-y-8 scroll-premium">
                    <!-- Initial Welcome State -->
                    <div class="chat-message bot">
                        <div class="flex items-center gap-4 mb-2">
                            <div class="w-10 h-10 bg-[#00ED64] rounded-xl flex items-center justify-center text-[#001E2B]">
                                <i class="fas fa-brain"></i>
                            </div>
                            <span class="technical-label">Core Initialized</span>
                        </div>
                        <div class="message-bubble">
                            Greetings, Engineer. I am your integrated AI architecture assistant, modeled after the pedagogies of David J. Malan. My neural buffer is synced with the Academy's curriculum manifest.
                            <br><br>
                            How may I assist your technical ascent today?
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
                            <div onclick="fillInput('Explain MongoDB Sharding like David J. Malan')" class="inquiry-node">
                                <span class="node-label">Inquiry Node A</span>
                                <span class="node-text">"Explain MongoDB Sharding Architecture"</span>
                            </div>
                            <div onclick="fillInput('How do I handle authentication with Amazon Cognito?')" class="inquiry-node">
                                <span class="node-label">Inquiry Node B</span>
                                <span class="node-text">"Handle Global Auth with Amazon Cognito"</span>
                            </div>
                            <div onclick="fillInput('Show me my learning todos')" class="inquiry-node">
                                <span class="node-label">Task Command</span>
                                <span class="node-text">"Synchronize my project to-do list"</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Input Console -->
                <div class="p-10 bg-[#000000]/20 border-t border-white/5">
                    <div class="flex gap-6 items-center">
                        <div class="flex-grow">
                            <input type="text" id="messageInput" placeholder="Synthesize your technical query..." 
                                   class="w-full bg-[#001E2B]/60 border border-white/10 rounded-2xl px-8 py-5 text-white outline-none focus:border-[#00ED64] transition-all font-medium">
                        </div>
                        <button id="sendButton" class="bg-[#00ED64] text-[#001E2B] px-10 py-5 rounded-2xl font-black uppercase tracking-widest text-[11px] flex items-center gap-3 hover:scale-105 transition-all shadow-lg shadow-[#00ED64]/10">
                            <span>Execute</span>
                            <i class="fas fa-bolt"></i>
                        </button>
                    </div>
                    <div class="mt-8 flex justify-between items-center px-2">
                        <div class="flex items-center gap-3">
                            <div class="velocity-pulse"></div>
                            <span class="technical-label">Neural Continuity: Stable</span>
                        </div>
                        <button onclick="clearHistory()" class="technical-label hover:text-red-400 transition-colors cursor-pointer">
                            Purge Neural Buffer
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- XP Snackbar (Hidden by default) -->
        <div id="xp-snackbar" class="fixed bottom-12 right-12 z-[100] hidden transform translate-y-full opacity-0 px-8 py-5 bg-[#001E2B]/90 border border-[#00ED64]/30 rounded-[32px] shadow-2xl flex items-center gap-5 ring-1 ring-white/10">
            <div class="w-12 h-12 bg-[#00ED64]/10 rounded-2xl flex items-center justify-center border border-[#00ED64]/20 shadow-inner">
                <i class="fas fa-bolt text-[#00ED64] text-xl"></i>
            </div>
            <div class="flex flex-col pr-4">
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-[#9FB1AD] mb-1">Gamification Engine</span>
                <span id="snackbar-text" class="text-base font-black text-white tracking-tight"></span>
            </div>
        </div>
    </main>
</div>

<script>
    function fillInput(t) {
        const i = document.getElementById('messageInput');
        i.value = t; i.focus();
    }

    function clearHistory() {
        if(confirm('PURGE NEURAL BUFFER? All session context will be lost.')) {
            localStorage.removeItem("chatbot_history");
            location.reload();
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        const container = document.getElementById("chatContainer");
        const input = document.getElementById("messageInput");
        const btn = document.getElementById("sendButton");
        let history = JSON.parse(localStorage.getItem("chatbot_history") || "[]");

        function addMessage(c, user = false, save = true) {
            const rawContent = c; // Save raw text for memory before parsing
            
            // Premium Markdown Rendering using marked.js
            if (window.marked && !user) {
                c = marked.parse(c);
            } else if (!user) {
                // Fallback for simple formatting if marked fails
                c = c.replace(/\*\*(.*?)\*\*/g, "<span class='font-black text-[#00ED64]'>$1</span>")
                     .replace(/`(.*?)`/g, "<span class='font-mono bg-black/40 px-2 py-0.5 rounded border border-white/5 text-[#00ED64]'>$1</span>")
                     .replace(/\n/g, "<br>");
            }

            const div = document.createElement("div");
            div.className = `chat-message ${user ? "user" : "bot"}`;

            div.innerHTML = `
                ${!user ? `
                <div class="flex items-center gap-3 mb-1">
                     <span class="technical-label">AI Assistant</span>
                </div>` : ''}
                <div class="message-bubble overflow-x-auto">
                    ${c}
                </div>
                <span class="message-meta mt-1">${user ? 'Student' : 'Nova Lite'} • ${new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
            `;

            container.appendChild(div);
            
            // Trigger highlighting for the new block
            if (window.hljs) {
                div.querySelectorAll('pre code').forEach((block) => {
                    hljs.highlightElement(block);
                    // Add Copy Button
                    const copyBtn = document.createElement('button');
                    copyBtn.innerHTML = '<i class="far fa-copy"></i>';
                    copyBtn.className = 'absolute top-2 right-2 text-[#9FB1AD] hover:text-white transition-colors p-2 text-xs opacity-0 group-hover:opacity-100';
                    block.parentElement.classList.add('group', 'relative');
                    block.parentElement.appendChild(copyBtn);
                    copyBtn.onclick = () => {
                        navigator.clipboard.writeText(block.innerText);
                        copyBtn.innerHTML = '<i class="fas fa-check text-green-400"></i>';
                        setTimeout(() => copyBtn.innerHTML = '<i class="far fa-copy"></i>', 2000);
                    };
                });
            }
            container.scrollTop = container.scrollHeight;
            if (save) {
                history.push({ role: user ? 'user' : 'assistant', content: rawContent });
                localStorage.setItem("chatbot_history", JSON.stringify(history));
            }
        }

        if (history.length) {
            container.innerHTML = "";
            history.forEach(m => addMessage(m.content || m.c, (m.role === 'user' || m.user === true), false));
        }

        async function send() {
            const m = input.value.trim(); if (!m) return;
            addMessage(m, true); input.value = ""; btn.disabled = true;

            const tDiv = document.createElement("div");
            tDiv.id = "typing"; tDiv.className = "chat-message bot";
            tDiv.innerHTML = `<div class="message-bubble animate-pulse text-[#00ED64] font-black italic">Developing Analogy...</div>`;
            container.appendChild(tDiv); container.scrollTop = container.scrollHeight;

            try {
                // Diagnostic: Log history being sent to Neural Core
                console.log(`📡 Sending ${history.length} conversation turns to Neural Core...`);
                
                const r = await fetch("/api/ai/chatbot", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ 
                        message: m,
                        courseName: document.getElementById('courseName')?.value,
                        videoTitle: document.getElementById('videoTitle')?.value,
                        history: history.slice(-5)
                    })
                });
                const d = await r.json();
                document.getElementById("typing").remove();
                
                if (d.response) {
                    addMessage(d.response);
                    
                    // Award/Deduct XP Logic
                    if (d.xp_change && d.xp_change !== 0) {
                        const isPositive = d.xp_change > 0;
                        
                        showSnackbar(
                            isPositive ? `🎉 +10 XP: Correct Answer!` : `📉 -10 XP: Incorrect Answer. Keep trying!`,
                            isPositive ? 'success' : 'error'
                        );
                        
                        if (isPositive && window.confetti) {
                            confetti({
                                particleCount: 150,
                                spread: 70,
                                origin: { y: 0.6 },
                                colors: ['#00ED64', '#ffffff', '#0061FE']
                            });
                        }
                        
                        // Update global XP total if available in UI (DynamoDB is Source of Truth)
                        if (d.new_total !== undefined && d.new_total !== null) {
                            console.log('🎮 Gamification Sync (Live):', { 
                                xp_change: d.xp_change || 0, 
                                new_total: d.new_total 
                            });
                            
                            const xpDisplay = document.getElementById('sidebar-points');
                            if (xpDisplay) xpDisplay.innerText = d.new_total;
                            
                            const lvlDisplay = document.getElementById('sidebar-level');
                            if (lvlDisplay) {
                                const newLevel = Math.floor(d.new_total / 1000) + 1;
                                lvlDisplay.innerText = newLevel;
                            }
                            
                            const progressBar = document.getElementById('sidebar-progress-bar');
                            if (progressBar) {
                                const currentLevel = Math.floor(d.new_total / 1000) + 1;
                                const prevLevelPoints = (currentLevel - 1) * 1000;
                                const progress = Math.min(100, Math.max(0, ((d.new_total - prevLevelPoints) / 1000) * 100));
                                progressBar.style.width = `${progress}%`;
                            }
                        }
                    }
                }
            } catch (e) {
                document.getElementById("typing").remove();
                addMessage("COMMUNICATION ERROR: Neural pipe obstructed. Please verify AWS connectivity.");
            }
            btn.disabled = false;
        }

        btn.onclick = send;
        input.onkeypress = (e) => { if (e.key === "Enter") send(); };
    });
</script>

<script>
    function showSnackbar(message, type = 'success') {
        const snackbar = document.getElementById('xp-snackbar');
        const text = document.getElementById('snackbar-text');
        
        text.innerText = message;
        snackbar.classList.remove('hidden', 'translate-y-full', 'opacity-0');
        
        // Dynamic border based on type
        snackbar.style.borderColor = type === 'success' ? '#00ED64' : '#FF4B4B';
        
        setTimeout(() => {
            snackbar.classList.add('translate-y-full', 'opacity-0');
            setTimeout(() => snackbar.classList.add('hidden'), 500);
        }, 4000);
    }
</script>

<style>
    /* ── Premium XP Snackbar ─────────────────────────────── */
    #xp-snackbar {
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
    }
    
    /* ── Markdown & Typography Hardening ─────────────────── */
    .message-bubble {
        line-height: 1.6;
    }
    .message-bubble p { margin-bottom: 1rem; }
    .message-bubble p:last-child { margin-bottom: 0; }
    .message-bubble strong { color: #00ED64; font-weight: 800; }
    .message-bubble pre {
        background: rgba(0, 0, 0, 0.4) !important;
        padding: 1.25rem !important;
        border-radius: 1rem !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        margin: 1rem 0 !important;
        font-family: 'Fira Code', monospace !important;
    }
    .message-bubble code {
        color: #00ED64;
        background: rgba(0, 237, 100, 0.1);
        padding: 0.2rem 0.4rem;
        border-radius: 0.4rem;
        font-size: 0.9em;
    }
    .message-bubble ul, .message-bubble ol {
        margin-left: 1.5rem;
        margin-bottom: 1rem;
        list-style-type: disc;
    }
    
    @keyframes slide-up {
        from { transform: translateY(100%); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>
<%- include('partials/footer') %>
