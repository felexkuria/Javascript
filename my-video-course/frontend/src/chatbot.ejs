<%- include('partials/header', { title: 'Neural Support Hub', activePage: 'chatbot' }) %>

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<div class="flex min-h-screen pt-32 pb-24 px-8 lg:px-12 bg-[#001E2B] learning-canvas">
    <!-- Student Sidebar Integration -->
    <%- include('partials/student-sidebar', { activePage: 'chatbot' }) %>

    <main class="lg:ml-72 flex-grow">
        <div class="max-w-6xl mx-auto">
            <header class="mb-12">
                <div class="flex items-center gap-4 mb-4">
                    <span class="atlas-badge">Neural Interface v2.0</span>
                    <div class="h-px w-24 bg-white/5"></div>
                    <span class="technical-label">Nova Lite Active</span>
                </div>
                <h1 class="text-7xl font-black tracking-tighter text-white">Neural <span class="text-[#00ED64]">Support</span> Hub</h1>
                <p class="text-[#9FB1AD] text-xl font-medium mt-4">High-fidelity linguistic synthesis of architectural concepts for the Levi Academy.</p>
            </header>

            <div class="atlas-card glass rounded-[48px] overflow-hidden flex flex-col shadow-2xl">
                <!-- Chat Window -->
                <div id="chatContainer" class="h-[600px] overflow-y-auto p-12 space-y-8 scroll-premium">
                    <!-- Initial Welcome State -->
                    <div class="chat-message bot">
                        <div class="flex items-center gap-4 mb-2">
                            <div class="w-10 h-10 bg-[#00ED64] rounded-xl flex items-center justify-center text-[#001E2B]">
                                <i class="fas fa-brain"></i>
                            </div>
                            <span class="technical-label">Core Initialized</span>
                        </div>
                        <div class="message-bubble">
                            Greetings, Engineer. I am your integrated AI architecture assistant, modeled after the pedagogies of David J. Malan. My neural buffer is synced with the Academy's curriculum manifest.
                            <br><br>
                            How may I assist your technical ascent today?
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
                            <div onclick="fillInput('Explain MongoDB Sharding like David J. Malan')" class="inquiry-node">
                                <span class="node-label">Inquiry Node A</span>
                                <span class="node-text">"Explain MongoDB Sharding Architecture"</span>
                            </div>
                            <div onclick="fillInput('How do I handle authentication with Amazon Cognito?')" class="inquiry-node">
                                <span class="node-label">Inquiry Node B</span>
                                <span class="node-text">"Handle Global Auth with Amazon Cognito"</span>
                            </div>
                            <div onclick="fillInput('Show me my learning todos')" class="inquiry-node">
                                <span class="node-label">Task Command</span>
                                <span class="node-text">"Synchronize my project to-do list"</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Input Console -->
                <div class="p-10 bg-[#000000]/20 border-t border-white/5">
                    <div class="flex gap-6 items-center">
                        <div class="flex-grow">
                            <input type="text" id="messageInput" placeholder="Synthesize your technical query..." 
                                   class="w-full bg-[#001E2B]/60 border border-white/10 rounded-2xl px-8 py-5 text-white outline-none focus:border-[#00ED64] transition-all font-medium">
                        </div>
                        <button id="sendButton" class="bg-[#00ED64] text-[#001E2B] px-10 py-5 rounded-2xl font-black uppercase tracking-widest text-[11px] flex items-center gap-3 hover:scale-105 transition-all shadow-lg shadow-[#00ED64]/10">
                            <span>Execute</span>
                            <i class="fas fa-bolt"></i>
                        </button>
                    </div>
                    <div class="mt-8 flex justify-between items-center px-2">
                        <div class="flex items-center gap-3">
                            <div class="velocity-pulse"></div>
                            <span class="technical-label">Neural Continuity: Stable</span>
                        </div>
                        <button onclick="clearHistory()" class="technical-label hover:text-red-400 transition-colors cursor-pointer">
                            Purge Neural Buffer
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    function fillInput(t) {
        const i = document.getElementById('messageInput');
        i.value = t; i.focus();
    }

    function clearHistory() {
        if(confirm('PURGE NEURAL BUFFER? All session context will be lost.')) {
            localStorage.removeItem("chatbot_history");
            location.reload();
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        const container = document.getElementById("chatContainer");
        const input = document.getElementById("messageInput");
        const btn = document.getElementById("sendButton");
        let history = JSON.parse(localStorage.getItem("chatbot_history") || "[]");

        function addMessage(c, user = false, save = true) {
            // Premium Markdown & Syntax Highlighting
            if (window.marked && window.hljs) {
                c = marked.parse(c);
            } else {
                c = c.replace(/\*\*(.*?)\*\*/g, "<span class='font-black text-[#00ED64]'>$1</span>")
                     .replace(/`(.*?)`/g, "<span class='font-mono bg-black/40 px-2 py-0.5 rounded border border-white/5 text-[#00ED64]'>$1</span>")
                     .replace(/\n/g, "<br>");
            }

            const div = document.createElement("div");
            div.className = `chat-message ${user ? "user" : "bot"}`;

            div.innerHTML = `
                ${!user ? `
                <div class="flex items-center gap-3 mb-1">
                     <span class="technical-label">AI Assistant</span>
                </div>` : ''}
                <div class="message-bubble overflow-x-auto">
                    ${c}
                </div>
                <span class="message-meta mt-1">${user ? 'Student' : 'Nova Lite'} • ${new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
            `;

            container.appendChild(div);
            
            // Trigger highlighting for the new block
            if (window.hljs) {
                div.querySelectorAll('pre code').forEach((block) => {
                    hljs.highlightElement(block);
                    // Add Copy Button
                    const copyBtn = document.createElement('button');
                    copyBtn.innerHTML = '<i class="far fa-copy"></i>';
                    copyBtn.className = 'absolute top-2 right-2 text-[#9FB1AD] hover:text-white transition-colors p-2 text-xs opacity-0 group-hover:opacity-100';
                    block.parentElement.classList.add('group', 'relative');
                    block.parentElement.appendChild(copyBtn);
                    copyBtn.onclick = () => {
                        navigator.clipboard.writeText(block.innerText);
                        copyBtn.innerHTML = '<i class="fas fa-check text-green-400"></i>';
                        setTimeout(() => copyBtn.innerHTML = '<i class="far fa-copy"></i>', 2000);
                    };
                });
            }
            container.scrollTop = container.scrollHeight;
            if (save) {
                history.push({ c, user });
                localStorage.setItem("chatbot_history", JSON.stringify(history));
            }
        }

        if (history.length) {
            container.innerHTML = "";
            history.forEach(m => addMessage(m.c, m.user, false));
        }

        async function send() {
            const m = input.value.trim(); if (!m) return;
            addMessage(m, true); input.value = ""; btn.disabled = true;

            const tDiv = document.createElement("div");
            tDiv.id = "typing"; tDiv.className = "chat-message bot";
            tDiv.innerHTML = `<div class="message-bubble animate-pulse technical-label">Synthesizing Response...</div>`;
            container.appendChild(tDiv); container.scrollTop = container.scrollHeight;

            try {
                const r = await fetch("/api/ai/chatbot", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ message: m })
                });
                const d = await r.json();
                document.getElementById("typing").remove();
                if (d.response) addMessage(d.response);
            } catch (e) {
                document.getElementById("typing").remove();
                addMessage("COMMUNICATION ERROR: Neural pipe obstructed. Please verify AWS connectivity.");
            }
            btn.disabled = false;
        }

        btn.onclick = send;
        input.onkeypress = (e) => { if (e.key === "Enter") send(); };
    });
</script>

<%- include('partials/footer') %>
