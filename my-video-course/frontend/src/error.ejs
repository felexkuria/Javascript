<%- include('partials/header', { title: 'Error', extraStyles: `
<style>
  body { background: #001E2B; color: #E7EEEB; }
</style>
` }) %>

<main class="flex-1 flex items-center justify-center">
  <div class="text-center p-8">
    <div class="text-6xl mb-6">🍃</div>
    <h1 class="text-3xl font-extrabold text-[#00ED64] mb-4">Something went wrong</h1>
    <p class="text-lg text-gray-400 mb-8">
      <%= typeof message !== 'undefined' ? message : 'An unexpected error occurred' %>
    </p>
    <a href="/dashboard" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-[#00ED64] to-[#00C152] text-[#001E2B] font-bold rounded-xl hover:shadow-[0_0_20px_rgba(0,237,100,0.3)] transition-all">
      <i class="fas fa-home mr-2"></i>Back to Dashboard
    </a>
  </div>
</main>

<%- include('partials/footer') %>