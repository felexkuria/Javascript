<%- include('partials/header', { title: 'Error', extraStyles: `
<style>
  body { background: #001E2B; color: #E7EEEB; }
</style>
` }) %>

<main class="flex-1 flex items-center justify-center">
  <div class="text-center p-8">
    <div class="w-24 h-24 bg-[#001E2B] border border-[#00ED64]/20 rounded-3xl flex items-center justify-center mx-auto mb-8 shadow-2xl overflow-hidden relative">
      <img src="/images/logo-multitouch.png" alt="Logo" class="w-full h-full object-contain p-3 relative z-10" style="mix-blend-mode: screen; filter: brightness(1.2);">
    </div>
    <h1 class="text-3xl font-extrabold text-[#00ED64] mb-4 tracking-tight">Something went wrong</h1>
    <p class="text-lg text-gray-400 mb-8 max-w-md mx-auto">
      <%= typeof message !== 'undefined' ? message : 'An unexpected error occurred during your learning session.' %>
    </p>
    <a href="/dashboard" class="inline-flex items-center px-8 py-3.5 bg-gradient-to-r from-[#00ED64] to-[#00C152] text-[#001E2B] font-extrabold rounded-2xl hover:shadow-[0_0_30px_rgba(0,237,100,0.4)] hover:scale-105 transition-all duration-300">
      <i class="fas fa-home mr-2"></i>Return to Academy
    </a>
  </div>
</main>

<%- include('partials/footer') %>