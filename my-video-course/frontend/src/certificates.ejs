<%- include('partials/header', { title: 'My Certificates', activePage: 'certificates' }) %>

<main class="min-h-screen bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="mb-12">
      <h1 class="text-4xl font-black text-[#001E2B] dark:text-[#E7EEEB] tracking-tighter mb-2 brand-font">Technical <span class="text-[#00ED64]">Certifications</span></h1>
      <p class="text-gray-500 dark:text-[#9FB1AD] font-medium">Verify your database engineering expertise with professional certifications</p>
    </div>

    <!-- Certificates Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="certificatesGrid">
      <div class="animate-pulse bg-white dark:bg-[#023430] h-64 rounded-3xl border border-gray-100 dark:border-[#133A41]"></div>
      <div class="animate-pulse bg-white dark:bg-[#023430] h-64 rounded-3xl border border-gray-100 dark:border-[#133A41]"></div>
    </div>
    
    <div id="noCertificates" class="hidden text-center py-24 bg-white dark:bg-[#023430] rounded-[32px] border-2 border-dashed border-gray-100 dark:border-[#133A41]">
      <div class="text-8xl mb-8">🎓</div>
      <h3 class="text-2xl font-black text-[#001E2B] dark:text-[#E7EEEB] mb-3 brand-font">No Certifications Yet</h3>
      <p class="text-gray-500 dark:text-[#9FB1AD] max-w-xs mx-auto text-sm font-medium">Complete a course at 100% to generate your first professional certificate.</p>
      <a href="/courses" class="mt-8 inline-flex items-center px-8 py-3.5 bg-[#00ED64] text-[#001E2B] font-black rounded-2xl hover:bg-[#00C152] transition-all">
        Browse Courses
      </a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>

<script>
async function loadCertificates() {
  const grid = document.getElementById('certificatesGrid');
  const empty = document.getElementById('noCertificates');
  
  try {
    const token = localStorage.getItem('accessToken');
    if (!token) {
      window.location.href = '/login';
      return;
    }

    const response = await fetch('/api/certificates/my', {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    
    const data = await response.json();
    grid.innerHTML = '';
    
    if (data.success && data.certificates.length > 0) {
      data.certificates.forEach(cert => {
        const date = new Date(cert.issuedAt || cert.issuedDate).toLocaleDateString('en-US', { 
          month: 'long', day: 'numeric', year: 'numeric' 
        });
        
        grid.innerHTML += `
          <div class="bg-white dark:bg-[#023430] rounded-[32px] border border-gray-100 dark:border-[#133A41] overflow-hidden hover:shadow-[0_30px_60px_-12px_rgba(0,30,43,0.3)] transition-all duration-700 group relative">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-[#00ED64]/10 to-transparent rounded-full -mr-16 -mt-16 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
            
            <div class="p-10 relative z-10">
              <div class="flex justify-between items-start mb-10">
                <div class="w-16 h-16 bg-[#001E2B] rounded-2xl flex items-center justify-center text-[#00ED64] text-3xl shadow-xl border border-[#00ED64]/20 group-hover:scale-110 transition-transform duration-500">
                  <i class="fas fa-certificate"></i>
                </div>
                <div class="flex flex-col items-end gap-2">
                    <span class="inline-flex items-center px-4 py-1.5 bg-[#00ED64]/10 text-[#00ED64] text-[10px] font-black uppercase tracking-widest rounded-full border border-[#00ED64]/20">
                        <i class="fas fa-shield-alt mr-2"></i> ARCHITECT VERIFIED
                    </span>
                    <span class="text-[9px] font-mono text-gray-500 dark:text-[#9FB1AD] uppercase tracking-tighter opacity-70 group-hover:opacity-100 transition-opacity">AUTH: ${cert.certificateId.split('-')[0]}</span>
                </div>
              </div>
              
              <h3 class="text-2xl font-black text-[#001E2B] dark:text-[#E7EEEB] mb-2 leading-tight group-hover:text-[#00ED64] transition-colors duration-500">
                ${cert.courseName}
              </h3>
              <p class="text-xs text-gray-400 dark:text-[#9FB1AD] font-bold tracking-wide mb-10 uppercase">Ingested on ${date}</p>
              
              <div class="flex items-center justify-between pt-8 border-t border-gray-100 dark:border-white/5">
                <div class="flex -space-x-2">
                    <div class="w-6 h-6 rounded-full bg-[#00ED64] border-2 border-[#023430] flex items-center justify-center"><i class="fas fa-check text-[8px] text-[#001E2B]"></i></div>
                    <div class="w-6 h-6 rounded-full bg-[#00684A] border-2 border-[#023430]"></div>
                </div>
                <a href="${cert.s3Url}" target="_blank" class="flex items-center gap-3 text-[11px] font-black text-[#00684A] dark:text-[#00ED64] uppercase tracking-widest hover:gap-5 transition-all">
                  DOWNLOAD CREDENTIALS <i class="fas fa-arrow-right"></i>
                </a>
              </div>
            </div>
            <div class="h-1.5 w-0 group-hover:w-full bg-[#00ED64] transition-all duration-700"></div>
          </div>
        `;
      });
    } else {
      grid.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  } catch (error) {
    console.error('Failed to load certificates:', error);
    grid.innerHTML = '<p class="text-red-500">Failed to load certificates. Please try again later.</p>';
  }
}

document.addEventListener('DOMContentLoaded', loadCertificates);
</script>
