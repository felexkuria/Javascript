<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learning Progress - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .instructor-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            min-height: 100vh;
            background: var(--color-bg);
        }

        .instructor-main {
            padding: var(--space-8);
            background: var(--color-bg);
            overflow-y: auto;
        }

        .profile-card {
            background: var(--color-surface);
            border-radius: var(--radius-2xl);
            border: 1px solid var(--color-border);
            padding: var(--space-8);
            box-shadow: var(--shadow-sm);
            margin-bottom: var(--space-8);
        }

        .glass-stat-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: var(--radius-xl);
            padding: var(--space-6);
            text-align: center;
            transition: all 0.3s ease;
        }

        .dark .glass-stat-card {
            background: rgba(2, 52, 48, 0.4);
            border: 1px solid rgba(0, 237, 100, 0.1);
        }

        .glass-stat-card:hover {
            transform: translateY(-4px);
            border-color: var(--mdb-green);
        }

        .xp-progress-container {
            width: 100%;
            height: 12px;
            background: var(--color-bg-alt);
            border-radius: 980px;
            overflow: hidden;
            margin: 16px 0;
        }

        .xp-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--mdb-green), var(--mdb-green-dark));
            width: 0%;
            transition: width 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 0 15px rgba(0, 237, 100, 0.3);
        }

        .achievement-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 20px;
        }

        .achievement-card {
            background: var(--color-bg-alt);
            border-radius: var(--radius-lg);
            padding: 24px;
            text-align: center;
            opacity: 0.5;
            filter: grayscale(1);
            transition: all 0.4s ease;
            position: relative;
        }

        .achievement-card.earned {
            opacity: 1;
            filter: grayscale(0);
            background: var(--color-surface);
            border: 1px solid var(--mdb-green-light);
            box-shadow: var(--shadow-md);
        }

        .achievement-card.earned .achievement-icon {
            transform: scale(1.1);
            text-shadow: 0 0 10px rgba(0, 237, 100, 0.4);
        }

        /* Calendar Styling */
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 8px;
        }

        .calendar-day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            background: var(--color-bg-alt);
            color: var(--color-text-muted);
            cursor: default;
            position: relative;
        }

        .calendar-day.current-month { color: var(--color-text); }
        .calendar-day.has-activity {
            background: var(--mdb-green-light);
            color: var(--mdb-green-dark);
            border: 1px solid var(--mdb-green);
        }
        .calendar-day.today {
            box-shadow: 0 0 0 2px var(--mdb-midnight);
        }
        .dark .calendar-day.today {
            box-shadow: 0 0 0 2px var(--mdb-green);
        }

        .activity-indicator {
            position: absolute;
            top: -4px;
            right: -4px;
            background: var(--mdb-midnight);
            color: #fff;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            font-size: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
    <div class="instructor-layout">
        <%- include('partials/student-sidebar', { activePage: 'profile' }) %>

        <main class="instructor-main">
            <header style="margin-bottom: var(--space-10); display: flex; justify-content: space-between; align-items: flex-end;">
                <div>
                    <h1 style="font-size: 40px; font-weight: 800; letter-spacing: -0.04em;">Learning Progress</h1>
                    <p style="color: var(--color-text-muted); font-size: 18px;">Track your journey to engineering mastery.</p>
                </div>
                <button id="refresh-stats" class="btn btn-secondary" style="height: 44px; border-radius: 12px; font-weight: 700;">
                    <i class="fas fa-sync-alt"></i> Refresh Stats
                </button>
            </header>

            <!-- Quick Stats -->
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 48px;">
                <div class="glass-stat-card">
                    <div style="font-size: 24px; margin-bottom: 8px;">📺</div>
                    <div id="videos-watched" style="font-size: 28px; font-weight: 800;">0</div>
                    <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.6;">Lessons Watched</div>
                </div>
                <div class="glass-stat-card">
                    <div style="font-size: 24px; margin-bottom: 8px;">🎓</div>
                    <div id="courses-completed" style="font-size: 28px; font-weight: 800;">0</div>
                    <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.6;">Courses Finished</div>
                </div>
                <div class="glass-stat-card">
                    <div style="font-size: 24px; margin-bottom: 8px;">🏆</div>
                    <div id="achievements-earned" style="font-size: 28px; font-weight: 800;">0/0</div>
                    <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.6;">Achievements</div>
                </div>
                <div class="glass-stat-card">
                    <div style="font-size: 24px; margin-bottom: 8px;">🔥</div>
                    <div id="longest-streak" style="font-size: 28px; font-weight: 800;">0</div>
                    <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.6;">Day Streak</div>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
                <div class="profile-left">
                    <!-- Progress Card -->
                    <div class="profile-card">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                            <h2 style="font-size: 22px; font-weight: 700;">Current Level</h2>
                            <span style="padding: 4px 12px; background: var(--mdb-midnight); color: var(--mdb-green); border-radius: 8px; font-weight: 800; font-size: 14px;">LEVEL <span id="user-level">1</span></span>
                        </div>
                        <div class="xp-progress-container">
                            <div id="level-progress" class="xp-progress-fill"></div>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 13px; font-weight: 600; color: var(--color-text-muted);">
                            <span id="current-xp">0 XP</span>
                            <span id="next-level-xp">100 XP</span>
                        </div>
                    </div>

                    <!-- Achievements -->
                    <h3 style="font-size: 20px; font-weight: 700; margin-bottom: 24px;">Achievements</h3>
                    <div id="achievements-container" class="achievement-grid">
                        <!-- Populated by JS -->
                    </div>
                </div>

                <aside class="profile-right">
                    <!-- Streak Calendar -->
                    <div class="profile-card">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                            <h3 id="calendar-month" style="font-size: 16px; font-weight: 700;">March 2026</h3>
                            <div style="display: flex; gap: 8px;">
                                <button id="prev-month" style="background: none; border: none; cursor: pointer; opacity: 0.6;"><i class="fas fa-chevron-left"></i></button>
                                <button id="next-month" style="background: none; border: none; cursor: pointer; opacity: 0.6;"><i class="fas fa-chevron-right"></i></button>
                            </div>
                        </div>
                        <div class="calendar-grid" id="streak-calendar">
                            <!-- Populated by JS -->
                        </div>
                        <div style="margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--color-border);">
                            <div style="display: flex; align-items: center; gap: 12px; font-size: 13px; color: var(--color-text-muted);">
                                <div style="width: 12px; height: 12px; background: var(--mdb-green-light); border-radius: 2px;"></div>
                                <span>Study sessions completed</span>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </main>
    </div>

    <!-- Core Gamification Scripts -->
    <script src="/js/gamification.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            function initTheme() {
                const theme = localStorage.getItem('theme') || 'light';
                document.documentElement.classList.toggle('dark', theme === 'dark');
            }
            initTheme();

            let currentCalendarDate = new Date();
            let watchDatesData = [];

            const tryUpdateProfile = () => {
                if (window.gamificationSystem) {
                    updateProfileDisplay();
                } else {
                    setTimeout(tryUpdateProfile, 100);
                }
            };

            async function loadWatchDates() {
                try {
                    const response = await fetch('/api/videos/watch-dates');
                    if (response.ok) {
                        watchDatesData = await response.json();
                    }
                } catch (error) {
                    console.warn('Failed to load watch dates:', error);
                }
            }

            async function updateProfileDisplay() {
                if (!window.gamificationSystem) return;
                
                const progress = await window.gamificationSystem.getProgressSummary();
                
                document.getElementById('videos-watched').textContent = progress.videosWatched || 0;
                document.getElementById('courses-completed').textContent = progress.coursesCompleted || 0;
                document.getElementById('achievements-earned').textContent = `${progress.achievements || 0}/${progress.totalAchievements || 0}`;
                document.getElementById('longest-streak').textContent = progress.longestStreak || 0;
                document.getElementById('user-level').textContent = progress.level || 1;
                
                const xpForNextLevel = (progress.level || 1) * 100;
                const currentXP = window.gamificationSystem.userStats?.experiencePoints || 0;
                const progressPercent = Math.min((currentXP / xpForNextLevel) * 100, 100);
                
                document.getElementById('level-progress').style.width = `${progressPercent}%`;
                document.getElementById('current-xp').textContent = `${currentXP} XP`;
                document.getElementById('next-level-xp').textContent = `${xpForNextLevel} XP`;
                
                populateAchievements();
                populateStreakCalendar();
            }

            function populateAchievements() {
                const container = document.getElementById('achievements-container');
                if (!container || !window.gamificationSystem) return;
                
                const definitions = window.gamificationSystem.getAchievementDefinitions();
                const earned = window.gamificationSystem.achievements || [];
                
                container.innerHTML = '';
                
                Object.values(definitions).forEach(achievement => {
                    const isEarned = earned.includes(achievement.id);
                    const card = document.createElement('div');
                    card.className = `achievement-card ${isEarned ? 'earned' : ''}`;
                    
                    card.innerHTML = `
                        <div class="achievement-icon" style="font-size: 32px; margin-bottom: 12px;">${achievement.icon}</div>
                        <div style="font-size: 14px; font-weight: 700; margin-bottom: 4px;">${achievement.name}</div>
                        <div style="font-size: 11px; opacity: 0.7; line-height: 1.3;">${achievement.description}</div>
                        <div style="font-size: 10px; font-weight: 800; color: var(--mdb-green); margin-top: 12px;">+${achievement.points} XP</div>
                    `;
                    
                    container.appendChild(card);
                });
            }

            function populateStreakCalendar() {
                const calendar = document.getElementById('streak-calendar');
                const monthLabel = document.getElementById('calendar-month');
                if (!calendar || !monthLabel) return;
                
                monthLabel.textContent = currentCalendarDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
                
                const firstDay = new Date(currentCalendarDate.getFullYear(), currentCalendarDate.getMonth(), 1);
                const startDate = new Date(firstDay.getTime() - (firstDay.getDay() * 24 * 60 * 60 * 1000));
                
                calendar.innerHTML = '';
                
                for (let i = 0; i < 42; i++) {
                    const date = new Date(startDate.getTime() + (i * 24 * 60 * 60 * 1000));
                    const dateString = date.toISOString().split('T')[0];
                    
                    const dayWatchData = watchDatesData.filter(w => w.date === dateString);
                    const hasActivity = dayWatchData.length > 0;
                    const isCurrentMonth = date.getMonth() === currentCalendarDate.getMonth();
                    const isToday = dateString === new Date().toISOString().split('T')[0];
                    
                    const dayElement = document.createElement('div');
                    dayElement.className = `calendar-day ${isCurrentMonth ? 'current-month' : ''} ${hasActivity ? 'has-activity' : ''} ${isToday ? 'today' : ''}`;
                    dayElement.textContent = date.getDate();
                    
                    if (hasActivity && dayWatchData.length > 1) {
                        const indicator = document.createElement('div');
                        indicator.className = 'activity-indicator';
                        indicator.textContent = dayWatchData.length;
                        dayElement.appendChild(indicator);
                    }
                    
                    calendar.appendChild(dayElement);
                }
            }

            // Initialization
            loadWatchDates().then(() => {
                if (window.gamificationSystem) {
                    window.gamificationSystem.syncWithLocalStorageVideos().then(updateProfileDisplay);
                } else {
                    tryUpdateProfile();
                }
            });

            // Nav listeners
            document.getElementById('prev-month').addEventListener('click', () => {
                currentCalendarDate.setMonth(currentCalendarDate.getMonth() - 1);
                populateStreakCalendar();
            });
            document.getElementById('next-month').addEventListener('click', () => {
                currentCalendarDate.setMonth(currentCalendarDate.getMonth() + 1);
                populateStreakCalendar();
            });

            document.getElementById('refresh-stats').addEventListener('click', async function() {
                this.disabled = true;
                const originalText = this.innerHTML;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Syncing...';
                
                if (window.gamificationSystem) {
                    await window.gamificationSystem.syncWithLocalStorageVideos();
                    await loadWatchDates();
                    await updateProfileDisplay();
                }
                
                this.innerHTML = originalText;
                this.disabled = false;
            });
        });
    </script>
</body>
</html>