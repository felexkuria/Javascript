<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Progress Intelligence - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --atlas-green: #00ED64;
            --atlas-forest: #00684A;
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(0, 30, 43, 0.1);
        }

        .dark {
            --glass-bg: rgba(2, 52, 48, 0.3);
            --glass-border: rgba(0, 237, 100, 0.15);
        }

        body {
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            box-shadow: 0 8px 32px rgba(0, 30, 43, 0.05);
        }

        /* ── Profile Hero ── */
        .profile-hero {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-bottom: 48px;
        }

        .stat-node {
            padding: 32px 24px;
            border-radius: 24px;
            text-align: center;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .stat-node:hover {
            transform: translateY(-8px) scale(1.02);
            border-color: var(--atlas-green);
        }

        .stat-icon {
            font-size: 28px;
            margin-bottom: 16px;
            filter: drop-shadow(0 0 10px rgba(0, 237, 100, 0.2));
        }

        .stat-value-premium {
            font-size: 36px;
            font-weight: 900;
            color: #001E2B;
            letter-spacing: -0.04em;
            line-height: 1;
            margin-bottom: 4px;
        }

        .dark .stat-value-premium { color: white; text-shadow: 0 0 20px rgba(0, 237, 100, 0.2); }

        .stat-label-premium {
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--color-text-muted);
            opacity: 0.8;
        }

        /* ── XP Architecture ── */
        .xp-core {
            padding: 40px;
            border-radius: 32px;
            margin-bottom: 40px;
        }

        .xp-track {
            width: 100%;
            height: 16px;
            background: rgba(0, 30, 43, 0.05);
            border-radius: 100px;
            margin: 20px 0;
            overflow: hidden;
            position: relative;
        }

        .dark .xp-track { background: rgba(255, 255, 255, 0.05); }

        .xp-fill-glow {
            height: 100%;
            background: linear-gradient(90deg, #00ED64, #00684A);
            box-shadow: 0 0 20px rgba(0, 237, 100, 0.4);
            border-radius: 100px;
            transition: width 1.2s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        /* ── Achievement Grid ── */
        .achievement-cluster {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 24px;
        }

        .achievement-node {
            padding: 24px;
            border-radius: 24px;
            text-align: center;
            opacity: 0.4;
            filter: grayscale(1);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .achievement-node.earned {
            opacity: 1;
            filter: grayscale(0);
            border-color: var(--atlas-green);
        }

        .achievement-node.earned:hover {
            transform: scale(1.05) rotate(2deg);
            box-shadow: 0 20px 40px rgba(0, 237, 100, 0.1);
        }

        /* ── Calendar UI ── */
        .activity-calendar {
            padding: 32px;
            border-radius: 32px;
        }

        .cal-grid-premium {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 10px;
        }

        .cal-day-node {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 800;
            background: rgba(0, 30, 43, 0.03);
            color: var(--color-text-muted);
            transition: all 0.2s;
        }

        .dark .cal-day-node { background: rgba(255, 255, 255, 0.03); }

        .cal-day-active {
            background: rgba(0, 237, 100, 0.15);
            color: #00ED64;
            border: 1px solid rgba(0, 237, 100, 0.2);
        }

        .cal-day-today {
            box-shadow: 0 0 0 2.5px #001E2B;
        }

        .dark .cal-day-today {
            box-shadow: 0 0 0 2.5px #00ED64;
        }

        .btn-sync-premium {
            padding: 12px 24px;
            border-radius: 14px;
            font-weight: 800;
            font-size: 14px;
            transition: all 0.3s;
            border: 1px solid var(--glass-border);
            color: var(--color-text);
        }

        .btn-sync-premium:hover {
            border-color: var(--atlas-green);
            color: var(--atlas-green);
            background: rgba(0, 237, 100, 0.05);
        }
    </style>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
    <div class="instructor-layout">
        <%- include('partials/student-sidebar', { activePage: 'profile' }) %>

        <main class="instructor-main flex-grow p-10 overflow-auto">
            <header class="flex justify-between items-end mb-12">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <span class="px-3 py-1 bg-[#00ED64]/10 text-[#00684A] dark:text-[#00ED64] text-[10px] font-black uppercase tracking-widest rounded-full border border-[#00ED64]/20">Intelligence Dashboard</span>
                        <div class="h-px w-12 bg-gray-200 dark:bg-white/10"></div>
                    </div>
                    <h1 class="text-5xl font-black tracking-tighter text-[#001E2B] dark:text-white mb-2">Learning Progress</h1>
                    <p class="text-gray-500 dark:text-gray-400 font-medium text-lg">Quantum tracking for engineering skill acquisition.</p>
                </div>
                <button id="refresh-stats" class="btn-sync-premium group">
                    <i class="fas fa-satellite-dish mr-2 group-hover:animate-pulse"></i> Sync Intelligence
                </button>
            </header>

            <!-- Quick Intelligence Metrics -->
            <div class="profile-hero">
                <div class="stat-node premium-glass">
                    <div class="stat-icon">📈</div>
                    <div id="videos-watched" class="stat-value-premium">0</div>
                    <div class="stat-label-premium">Lessons Mastered</div>
                </div>
                <div class="stat-node premium-glass">
                    <div class="stat-icon">🎓</div>
                    <div id="courses-completed" class="stat-value-premium">0</div>
                    <div class="stat-label-premium">Curricula Mastered</div>
                </div>
                <div class="stat-node premium-glass">
                    <div class="stat-icon">🏆</div>
                    <div id="achievements-earned" class="stat-value-premium">0/0</div>
                    <div class="stat-label-premium">Merits Earned</div>
                </div>
                <div class="stat-node premium-glass">
                    <div class="stat-icon">🔥</div>
                    <div id="longest-streak" class="stat-value-premium">0</div>
                    <div class="stat-label-premium">Persistence Streak</div>
                </div>
            </div>

            <div class="grid grid-cols-[1fr,360px] gap-10">
                <div class="space-y-10">
                    <!-- XP Core Architecture -->
                    <div class="xp-core premium-glass">
                        <div class="flex justify-between items-center mb-4">
                            <div>
                                <h3 class="text-2xl font-black text-[#001E2B] dark:text-white tracking-tight">Engineering Level</h3>
                                <p class="text-gray-500 font-medium text-sm">Quantifying your technical expertise.</p>
                            </div>
                            <div class="px-6 py-2 bg-[#001E2B] dark:bg-[#00ED64] text-[#00ED64] dark:text-[#001E2B] rounded-2xl font-black text-lg shadow-xl">
                                LEVEL <span id="user-level">1</span>
                            </div>
                        </div>
                        <div class="xp-track">
                            <div id="level-progress" class="xp-fill-glow" style="width: 0%"></div>
                        </div>
                        <div class="flex justify-between text-xs font-black uppercase tracking-widest text-gray-500">
                            <span id="current-xp" class="text-[#00ED64]">0 XP</span>
                            <span id="next-level-xp">100 XP TO ASCEND</span>
                        </div>
                    </div>

                    <!-- Merit Constellation -->
                    <div>
                        <h3 class="text-2xl font-black text-[#001E2B] dark:text-white tracking-tight mb-8">Professional Merits</h3>
                        <div id="achievements-container" class="achievement-cluster">
                            <!-- Populated by JS -->
                        </div>
                    </div>
                </div>

                <aside class="space-y-10">
                    <!-- Persistence Calendar -->
                    <div class="activity-calendar premium-glass">
                        <div class="flex justify-between items-center mb-8">
                            <h3 id="calendar-month" class="text-lg font-black text-[#001E2B] dark:text-white tracking-tight">March 2026</h3>
                            <div class="flex gap-4">
                                <button id="prev-month" class="text-gray-400 hover:text-[#00ED64] transition-colors"><i class="fas fa-chevron-left"></i></button>
                                <button id="next-month" class="text-gray-400 hover:text-[#00ED64] transition-colors"><i class="fas fa-chevron-right"></i></button>
                            </div>
                        </div>
                        <div class="cal-grid-premium" id="streak-calendar">
                            <!-- Populated by JS -->
                        </div>
                        <div class="mt-8 pt-8 border-t border-gray-100 dark:border-white/5">
                            <div class="flex items-center gap-3 text-[11px] font-black uppercase tracking-widest text-gray-500">
                                <div class="w-3 h-3 bg-[#00ED64]/30 border border-[#00ED64]/50 rounded-sm"></div>
                                <span>High Activity Pulse Detected</span>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </main>
    </div>

    <!-- Core Gamification Scripts -->
    <script src="/js/gamification.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            let currentCalendarDate = new Date();
            let watchDatesData = [];

            const tryUpdateProfile = () => {
                if (window.gamificationSystem) updateProfileDisplay();
                else setTimeout(tryUpdateProfile, 100);
            };

            async function loadWatchDates() {
                try {
                    const response = await fetch('/api/videos/watch-dates');
                    if (response.ok) watchDatesData = await response.json();
                } catch (error) { console.warn(error); }
            }

            async function updateProfileDisplay() {
                if (!window.gamificationSystem) return;
                const progress = await window.gamificationSystem.getProgressSummary();
                
                document.getElementById('videos-watched').textContent = progress.videosWatched || 0;
                document.getElementById('courses-completed').textContent = progress.coursesCompleted || 0;
                document.getElementById('achievements-earned').textContent = `${progress.achievements || 0}/${progress.totalAchievements || 0}`;
                document.getElementById('longest-streak').textContent = progress.longestStreak || 0;
                document.getElementById('user-level').textContent = progress.level || 1;
                
                const xpForNextLevel = (progress.level || 1) * 100;
                const currentXP = window.gamificationSystem.userStats?.experiencePoints || 0;
                const progressPercent = Math.min((currentXP / xpForNextLevel) * 100, 100);
                
                document.getElementById('level-progress').style.width = `${progressPercent}%`;
                document.getElementById('current-xp').textContent = `${currentXP} XP`;
                document.getElementById('next-level-xp').textContent = `${xpForNextLevel} XP TO ASCEND`;
                
                populateAchievements();
                populateStreakCalendar();
            }

            function populateAchievements() {
                const container = document.getElementById('achievements-container');
                if (!container || !window.gamificationSystem) return;
                const definitions = window.gamificationSystem.getAchievementDefinitions();
                const earned = window.gamificationSystem.achievements || [];
                container.innerHTML = '';
                
                Object.values(definitions).forEach(achievement => {
                    const isEarned = earned.includes(achievement.id);
                    const card = document.createElement('div');
                    card.className = `achievement-node premium-glass ${isEarned ? 'earned' : ''}`;
                    card.innerHTML = `
                        <div class="text-4xl mb-4">${achievement.icon}</div>
                        <div class="text-sm font-black text-[#001E2B] dark:text-white mb-1 uppercase tracking-tighter">${achievement.name}</div>
                        <div class="text-[10px] text-gray-500 font-bold px-2 line-clamp-2">${achievement.description}</div>
                        <div class="text-[10px] font-black text-[#00ED64] mt-4 tracking-widest">+${achievement.points} XP</div>
                    `;
                    container.appendChild(card);
                });
            }

            function populateStreakCalendar() {
                const calendar = document.getElementById('streak-calendar');
                const monthLabel = document.getElementById('calendar-month');
                if (!calendar || !monthLabel) return;
                monthLabel.textContent = currentCalendarDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
                const firstDay = new Date(currentCalendarDate.getFullYear(), currentCalendarDate.getMonth(), 1);
                const startDate = new Date(firstDay.getTime() - (firstDay.getDay() * 24 * 60 * 60 * 1000));
                calendar.innerHTML = '';
                
                for (let i = 0; i < 42; i++) {
                    const date = new Date(startDate.getTime() + (i * 24 * 60 * 60 * 1000));
                    const dateString = date.toISOString().split('T')[0];
                    const dayWatchData = watchDatesData.filter(w => w.date === dateString);
                    const hasActivity = dayWatchData.length > 0;
                    const isCurrentMonth = date.getMonth() === currentCalendarDate.getMonth();
                    const isToday = dateString === new Date().toISOString().split('T')[0];
                    
                    const dayElement = document.createElement('div');
                    dayElement.className = `cal-day-node ${!isCurrentMonth ? 'opacity-20' : ''} ${hasActivity ? 'cal-day-active' : ''} ${isToday ? 'cal-day-today' : ''}`;
                    dayElement.textContent = date.getDate();
                    calendar.appendChild(dayElement);
                }
            }

            loadWatchDates().then(() => {
                if (window.gamificationSystem) window.gamificationSystem.syncWithLocalStorageVideos().then(updateProfileDisplay);
                else tryUpdateProfile();
            });

            document.getElementById('prev-month').addEventListener('click', () => { currentCalendarDate.setMonth(currentCalendarDate.getMonth() - 1); populateStreakCalendar(); });
            document.getElementById('next-month').addEventListener('click', () => { currentCalendarDate.setMonth(currentCalendarDate.getMonth() + 1); populateStreakCalendar(); });

            document.getElementById('refresh-stats').addEventListener('click', async function() {
                this.disabled = true;
                const originalText = this.innerHTML;
                this.innerHTML = '<i class="fas fa-satellite fa-spin mr-2"></i> Syncing Intelligence...';
                if (window.gamificationSystem) {
                    await window.gamificationSystem.syncWithLocalStorageVideos();
                    await loadWatchDates();
                    await updateProfileDisplay();
                }
                this.innerHTML = originalText;
                this.disabled = false;
            });
        });
    </script>
</body>
</html>