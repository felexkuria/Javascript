<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Progress Intelligence - Multitouch Academy</title>
    <link rel="icon" type="image/png" href="/images/logo-multitouch.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mdb-green': '#00ED64',
              'mdb-forest': '#00684A',
              'mdb-midnight': '#001E2B',
              'mdb-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        :root {
            --mdb-green: #00ED64;
            --mdb-midnight: #001E2B;
            --glass-bg: rgba(2, 52, 48, 0.4);
            --glass-border: rgba(0, 237, 100, 0.1);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--mdb-midnight);
            color: #E7EEEB;
            -webkit-font-smoothing: antialiased;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
        }

        .stat-card-atlas {
            border-radius: 32px;
            transition: all 0.4s cubic-bezier(0.2, 0, 0, 1);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .stat-card-atlas:hover {
            transform: translateY(-8px);
            border-color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.03);
        }

        .xp-conduit {
            height: 12px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 99px;
            overflow: hidden;
            position: relative;
        }

        .xp-flow-neon {
            height: 100%;
            background: linear-gradient(90deg, #00ED64, #00684A);
            box-shadow: 0 0 20px rgba(0, 237, 100, 0.4);
            transition: width 1.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .merit-badge-atlas {
            border-radius: 24px;
            transition: all 0.5s;
            filter: grayscale(1);
            opacity: 0.3;
        }

        .merit-badge-atlas.earned {
            filter: grayscale(0);
            opacity: 1;
            border-color: var(--mdb-green);
        }

        .btn-atlas-sync {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            border-radius: 14px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 10px;
            transition: all 0.3s;
        }

        .btn-atlas-sync:hover {
            border-color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.05);
            color: #00ED64;
        }

        .heatmap-container {
            display: grid;
            grid-auto-flow: column;
            grid-auto-columns: 12px;
            grid-template-rows: repeat(7, 12px);
            gap: 3px;
        }

        .heatmap-node {
            width: 12px;
            height: 12px;
            border-radius: 2px;
            background: rgba(255, 255, 255, 0.03);
            transition: all 0.3s;
        }

        .heatmap-node.level-0 { background: rgba(255, 255, 255, 0.03); }
        .heatmap-node.level-1 { background: rgba(0, 237, 100, 0.2); }
        .heatmap-node.level-2 { background: rgba(0, 237, 100, 0.4); }
        .heatmap-node.level-3 { background: rgba(0, 237, 100, 0.7); }
        .heatmap-node.level-4 { background: #00ED64; box-shadow: 0 0 10px rgba(0, 237, 100, 0.3); }

        .calendar-node {
            aspect-ratio: 1;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.02);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 900;
            color: #4B5563;
        }

        .calendar-node.active {
            background: rgba(0, 237, 100, 0.15);
            color: #00ED64;
            border: 1px solid rgba(0, 237, 100, 0.2);
        }
    </style>
</head>
<body class="dark overflow-x-hidden">
    <div class="flex">
        <!-- Sidebar -->
        <%- include('partials/student-sidebar', { activePage: 'profile' }) %>

        <main class="flex-grow p-10 lg:p-16">
            <header class="flex flex-col md:flex-row justify-between items-end gap-10 mb-16">
                <div>
                    <div class="flex items-center gap-4 mb-4">
                        <span class="px-4 py-1.5 bg-[#00ED64]/10 text-[#00ED64] text-[10px] font-black uppercase tracking-[0.3em] rounded-full border border-[#00ED64]/20">Cognitive Metrics</span>
                        <div class="h-px w-16 bg-white/5"></div>
                    </div>
                    <h1 class="text-6xl font-black tracking-tighter text-white">Progress <span class="text-[#00ED64]">Intelligence</span></h1>
                    <p class="text-gray-400 text-lg font-medium mt-2">Quantitative analysis of engineering mastery.</p>
                </div>
                <button id="refresh-stats" class="btn-atlas-sync px-8 py-4 flex items-center gap-3">
                    <i class="fas fa-satellite-dish"></i> Sync Intelligence
                </button>
            </header>

            <!-- Metric Mosaic -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-16">
                <% 
                    const stats = (typeof gamificationData !== 'undefined' && gamificationData.userStats) ? gamificationData.userStats : { totalPoints: 0, currentLevel: 1, experiencePoints: 0, videosWatched: {} };
                    const watchedCount = Object.keys(stats.videosWatched || {}).length;
                    const totalXP = stats.experiencePoints || stats.totalPoints || 0;
                    const level = stats.currentLevel || 1;
                    const nextLevelXP = Math.pow(level, 2) * 100;
                    const prevLevelXP = Math.pow(level - 1, 2) * 100;
                    const progressPercent = Math.min(100, Math.max(0, ((totalXP - prevLevelXP) / (nextLevelXP - prevLevelXP)) * 100));
                %>
                <div class="stat-card-atlas premium-glass p-8 flex flex-col items-center text-center">
                    <div class="w-16 h-16 bg-[#00ED64]/5 rounded-3xl flex items-center justify-center text-3xl mb-6">🛰️</div>
                    <div id="videos-watched" class="text-4xl font-black text-white mb-2 tracking-tighter"><%= watchedCount %></div>
                    <div class="text-[9px] font-black uppercase tracking-[0.2em] text-gray-500">Lessons Mastered</div>
                </div>
                <div class="stat-card-atlas premium-glass p-8 flex flex-col items-center text-center">
                    <div class="w-16 h-16 bg-blue-500/5 rounded-3xl flex items-center justify-center text-3xl mb-6">🏛️</div>
                    <div id="courses-completed" class="text-4xl font-black text-white mb-2 tracking-tighter"><%= stats.coursesCompleted || 0 %></div>
                    <div class="text-[9px] font-black uppercase tracking-[0.2em] text-gray-500">Curricula Completed</div>
                </div>
                <div class="stat-card-atlas premium-glass p-8 flex flex-col items-center text-center">
                    <div class="w-16 h-16 bg-purple-500/5 rounded-3xl flex items-center justify-center text-3xl mb-6">🎖️</div>
                    <div id="achievements-earned" class="text-4xl font-black text-white mb-2 tracking-tighter"><%= (typeof gamificationData !== 'undefined' && gamificationData.achievements) ? gamificationData.achievements.length : 0 %></div>
                    <div class="text-[9px] font-black uppercase tracking-[0.2em] text-gray-500">Merits Earned</div>
                </div>
                <div class="stat-card-atlas premium-glass p-8 flex flex-col items-center text-center">
                    <div class="w-16 h-16 bg-amber-500/5 rounded-3xl flex items-center justify-center text-3xl mb-6">🔥</div>
                    <div id="longest-streak" class="text-4xl font-black text-white mb-2 tracking-tighter"><%= (typeof gamificationData !== 'undefined' && gamificationData.streakData) ? gamificationData.streakData.longestStreak : 0 %></div>
                    <div class="text-[9px] font-black uppercase tracking-[0.2em] text-gray-500">Persistence Streak</div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                <!-- Level Architecture -->
                <div class="lg:col-span-2 space-y-12">
                    <div class="premium-glass p-12 rounded-[40px]">
                        <div class="flex justify-between items-center mb-10">
                            <div>
                                <h3 class="text-3xl font-black text-white tracking-tighter">Engineering Level</h3>
                                <p class="text-gray-400 font-medium text-sm mt-1">Quantifying technical ascent.</p>
                            </div>
                            <div class="w-24 h-24 bg-[#00ED64] rounded-[28px] flex flex-col items-center justify-center shadow-xl shadow-[#00ED64]/20">
                                <span class="text-[10px] font-black text-[#001E2B] uppercase tracking-widest">Rank</span>
                                <span id="user-level" class="text-4xl font-black text-[#001E2B]"><%= level %></span>
                            </div>
                        </div>
                        <div class="xp-conduit mb-6">
                            <div id="level-progress" class="xp-flow-neon" style="width: <%= (progressPercent || 0) + '%' %>"></div>
                        </div>
                        <div class="flex justify-between items-center">
                            <span id="current-xp" class="text-xs font-black text-[#00ED64] uppercase tracking-widest"><%= totalXP %> TOTAL ARCHIVED XP</span>
                            <span id="next-level-xp" class="text-[10px] font-black text-gray-500 uppercase tracking-widest"><%= nextLevelXP - totalXP %> XP TO ASCENSION</span>
                        </div>
                    </div>
<% 
    // Unify rank display on profile hub (Engineer, Lead, Architect tiering)
    const rankTier = (level >= 20) ? 'Principal Architect' : (level >= 10 ? 'Senior Engineer' : 'System Architect');
%>

                    <!-- Merit Constellation -->
                    <div>
                        <div class="flex items-center gap-4 mb-10">
                            <h3 class="text-2xl font-black text-white tracking-tighter">Professional Merits</h3>
                            <div class="h-px flex-grow bg-white/5"></div>
                        </div>
                        <div id="achievements-container" class="grid grid-cols-2 lg:grid-cols-3 gap-6">
                            <%
                            // ✅ Server-side render merits INSTANTLY (no JS delay)
                            const allMerits = [
                              {id:'first_video',      icon:'🎯', name:'First Step',        description:'Complete your first video lecture'},
                              {id:'video_5',          icon:'⚡', name:'Momentum',          description:'Watch 5 videos and build momentum'},
                              {id:'video_10',         icon:'🔥', name:'On Fire',           description:'Watch 10 videos in total'},
                              {id:'video_25',         icon:'🚀', name:'Committed',         description:'Watch 25 videos across courses'},
                              {id:'video_50',         icon:'💎', name:'Elite Student',     description:'Watch 50 videos total'},
                              {id:'streak_3',         icon:'📅', name:'Consistent',        description:'Maintain a 3-day learning streak'},
                              {id:'streak_7',         icon:'🏆', name:'Week Warrior',      description:'Maintain a 7-day learning streak'},
                              {id:'quiz_perfect',     icon:'🎓', name:'Perfect Score',     description:'Ace a quiz with 100% accuracy'},
                              {id:'keyboard_master',  icon:'⌨️', name:'Keyboard Master', description:'Use 10 keyboard shortcuts'},
                              {id:'level_5',          icon:'⭐', name:'Rising Star',      description:'Reach Engineering Level 5'},
                              {id:'night_owl',        icon:'🦉', name:'Night Owl',         description:'Study after midnight'},
                              {id:'course_complete',  icon:'🏅', name:'Graduate',          description:'Complete an entire course'},
                            ];
                            const earnedIds = (typeof gamificationData !== 'undefined' && gamificationData && gamificationData.achievements) ? gamificationData.achievements : [];
                            allMerits.forEach(a => {
                                const isEarned = earnedIds.includes(a.id);
                            %>
                            <div class="merit-badge-atlas premium-glass p-6 text-center border border-white/5 <%= isEarned ? 'earned' : '' %>">
                                <div class="text-3xl mb-4"><%= a.icon %></div>
                                <div class="text-[11px] font-black text-white uppercase tracking-tighter mb-1"><%= a.name %></div>
                                <div class="text-[9px] text-gray-500 font-bold px-2 leading-relaxed"><%= a.description %></div>
                                <% if (isEarned) { %>
                                <div class="mt-2 text-[8px] font-black text-[#00ED64] uppercase tracking-widest">✓ Earned</div>
                                <% } %>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

                <!-- Persistence Calendar -->
                <aside class="space-y-12">
                    <div class="premium-glass p-10 rounded-[40px]">
                        <div class="flex justify-between items-center mb-10">
                            <h3 id="calendar-month" class="text-xl font-black text-white tracking-tighter">March 2026</h3>
                            <div class="flex gap-3">
                                <button id="prev-month" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center hover:text-[#00ED64] transition-colors"><i class="fas fa-chevron-left text-[10px]"></i></button>
                                <button id="next-month" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center hover:text-[#00ED64] transition-colors"><i class="fas fa-chevron-right text-[10px]"></i></button>
                            </div>
                        </div>
                        <div class="calendar-node-container overflow-x-auto pb-4">
                            <div class="heatmap-container" id="streak-heatmap">
                                <!-- Populated by JS -->
                            </div>
                        </div>
                        <div class="grid grid-cols-7 gap-2 mt-8" id="streak-calendar">
                            <!-- Populated by JS -->
                        </div>
                        <div class="mt-10 pt-10 border-t border-white/5">
                            <div class="flex items-center gap-4">
                                <span class="w-2 h-2 rounded-full bg-[#00ED64] animate-pulse"></span>
                                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em]">Activity Detection Active</span>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </main>
    </div>

    <script src="/js/gamification.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            let currentCalendarDate = new Date();
            let watchDatesData = [];

            const tryUpdateProfile = () => {
                if (window.gamificationSystem) updateProfileDisplay();
                else setTimeout(tryUpdateProfile, 100);
            };

            async function loadWatchDates() {
                try {
                    const response = await fetch('/api/videos/watch-dates');
                    if (response.ok) watchDatesData = await response.json();
                } catch (error) { console.warn(error); }
            }

            async function updateProfileDisplay() {
                if (!window.gamificationSystem) return;
                const progress = await window.gamificationSystem.getProgressSummary();
                
                document.getElementById('videos-watched').textContent = progress.videosWatched || 0;
                document.getElementById('courses-completed').textContent = progress.coursesCompleted || 0;
                document.getElementById('achievements-earned').textContent = progress.achievements || 0;
                document.getElementById('longest-streak').textContent = progress.longestStreak || 0;
                document.getElementById('user-level').textContent = progress.level || 1;
                
                const currentXP = progress.points || 0;
                const currentLevel = Math.floor(Math.sqrt(currentXP / 100)) + 1;
                const nextLevelXP = Math.pow(currentLevel, 2) * 100;
                const prevLevelXP = Math.pow(currentLevel - 1, 2) * 100;
                const progressPercent = Math.min(100, Math.max(0, ((currentXP - prevLevelXP) / (nextLevelXP - prevLevelXP)) * 100));
                
                document.getElementById('level-progress').style.width = `${progressPercent}%`;
                document.getElementById('current-xp').textContent = `${currentXP} XP ARCHIVED`;
                document.getElementById('next-level-xp').textContent = `${nextLevelXP - currentXP} XP TO ASCENSION`;
                
                populateAchievements();
                populateStreakCalendar();
            }

            function populateAchievements() {
                const container = document.getElementById('achievements-container');
                if (!container || !window.gamificationSystem) return;
                const definitions = window.gamificationSystem.getAchievementDefinitions();
                const earned = window.gamificationSystem.achievements || [];
                // Only re-render if JS system has MORE achievements than server already showed
                if (Object.keys(definitions).length === 0) return;
                container.innerHTML = '';
                Object.values(definitions).forEach(achievement => {
                    const isEarned = earned.includes(achievement.id);
                    const card = document.createElement('div');
                    card.className = `merit-badge-atlas premium-glass p-6 text-center border border-white/5 ${isEarned ? 'earned' : ''}`;
                    card.innerHTML = `
                        <div class="text-3xl mb-4">${achievement.icon}</div>
                        <div class="text-[11px] font-black text-white uppercase tracking-tighter mb-1">${achievement.name}</div>
                        <div class="text-[9px] text-gray-500 font-bold px-2 line-clamp-2 leading-relaxed">${achievement.description}</div>
                        ${isEarned ? '<div class="mt-2 text-[8px] font-black text-[#00ED64] uppercase tracking-widest">✓ Earned</div>' : ''}
                    `;
                    container.appendChild(card);
                });
            }

            function populateStreakCalendar() {
                const heatmap = document.getElementById('streak-heatmap');
                const calendar = document.getElementById('streak-calendar');
                const monthLabel = document.getElementById('calendar-month');
                if (!calendar || !monthLabel || !heatmap) return;

                monthLabel.textContent = currentCalendarDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
                
                // --- 1. Populate Monthly Calendar ---
                const firstDay = new Date(currentCalendarDate.getFullYear(), currentCalendarDate.getMonth(), 1);
                const startDate = new Date(firstDay.getTime() - (firstDay.getDay() * 24 * 60 * 60 * 1000));
                calendar.innerHTML = '';
                
                for (let i = 0; i < 35; i++) {
                    const date = new Date(startDate.getTime() + (i * 24 * 60 * 60 * 1000));
                    const dateString = date.toISOString().split('T')[0];
                    const activity = watchDatesData.find(w => w.date === dateString);
                    const hasActivity = !!activity;
                    const isCurrentMonth = date.getMonth() === currentCalendarDate.getMonth();
                    
                    const dayElement = document.createElement('div');
                    dayElement.className = `calendar-node ${!isCurrentMonth ? 'opacity-10' : ''} ${hasActivity ? 'active' : ''}`;
                    dayElement.textContent = date.getDate();
                    calendar.appendChild(dayElement);
                }

                // --- 2. Populate Yearly Heatmap ---
                heatmap.innerHTML = '';
                const today = new Date();
                const yearStart = new Date(today.getFullYear(), 0, 1);
                const yearStartDate = new Date(yearStart.getTime() - (yearStart.getDay() * 24 * 60 * 60 * 1000));

                for (let i = 0; i < 371; i++) { // 53 weeks * 7 days
                    const date = new Date(yearStartDate.getTime() + (i * 24 * 60 * 60 * 1000));
                    const dateString = date.toISOString().split('T')[0];
                    const activity = watchDatesData.find(w => w.date === dateString);
                    const count = activity ? activity.count : 0;
                    
                    let level = 0;
                    if (count > 0) level = 1;
                    if (count > 2) level = 2;
                    if (count > 5) level = 3;
                    if (count > 10) level = 4;

                    const heatNode = document.createElement('div');
                    heatNode.className = `heatmap-node level-${level}`;
                    heatNode.title = `${dateString}: ${count} Activities`;
                    heatmap.appendChild(heatNode);
                }
            }

            // --- LocalStorage Caching for Performance ---
            function loadFromCache() {
                const cache = localStorage.getItem('profile_stats_cache');
                if (cache) {
                    const data = JSON.parse(cache);
                    applyStatsToUI(data);
                }
            }

            function applyStatsToUI(progress) {
                document.getElementById('videos-watched').textContent = progress.videosWatched || 0;
                document.getElementById('courses-completed').textContent = progress.coursesCompleted || 0;
                document.getElementById('achievements-earned').textContent = progress.achievements || 0;
                document.getElementById('longest-streak').textContent = progress.longestStreak || 0;
                document.getElementById('user-level').textContent = progress.level || 1;
                
                const currentXP = progress.experiencePoints || progress.points || 0;
                const currentLevel = GamificationSystem.calculateLevel(currentXP);
                const progressPercent = GamificationSystem.calculateProgress(currentXP, currentLevel);
                
                document.getElementById('level-progress').style.width = `${progressPercent}%`;
                document.getElementById('current-xp').textContent = `${currentXP} XP ARCHIVED`;
                const nextLVL = Math.pow(currentLevel, 2) * 100;
                document.getElementById('next-level-xp').textContent = `${Math.max(0, nextLVL - currentXP)} XP TO ASCENSION`;
            }

            loadFromCache();

            loadWatchDates().then(() => {
                if (window.gamificationSystem) {
                    window.gamificationSystem.syncWithLocalStorageVideos().then(() => {
                        window.gamificationSystem.getProgressSummary().then(progress => {
                            localStorage.setItem('profile_stats_cache', JSON.stringify(progress));
                            applyStatsToUI(progress);
                            populateAchievements();
                            populateStreakCalendar();
                        });
                    });
                }
                else tryUpdateProfile();
            });

            document.getElementById('prev-month').addEventListener('click', () => { currentCalendarDate.setMonth(currentCalendarDate.getMonth() - 1); populateStreakCalendar(); });
            document.getElementById('next-month').addEventListener('click', () => { currentCalendarDate.setMonth(currentCalendarDate.getMonth() + 1); populateStreakCalendar(); });

            document.getElementById('refresh-stats').addEventListener('click', async function() {
                this.classList.add('animate-pulse');
                if (window.gamificationSystem) {
                    await window.gamificationSystem.syncWithLocalStorageVideos();
                    await loadWatchDates();
                    await updateProfileDisplay();
                }
                setTimeout(() => this.classList.remove('animate-pulse'), 1000);
            });
        });
    </script>
</body>
</html>