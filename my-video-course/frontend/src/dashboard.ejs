<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .instructor-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            min-height: 100vh;
            background: var(--color-bg);
        }

        .instructor-main {
            padding: var(--space-8);
            background: var(--color-bg);
            overflow-y: auto;
        }

        .dashboard-hero {
            background: var(--mdb-midnight);
            color: #fff;
            padding: var(--space-10);
            border-radius: var(--radius-2xl);
            margin-bottom: var(--space-8);
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(0, 237, 100, 0.2);
        }

        .dashboard-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, var(--mdb-green) 0%, transparent 70%);
            opacity: 0.15;
            filter: blur(40px);
        }

        .stat-badge {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(8px);
            padding: 8px 16px;
            border-radius: 980px;
            display: flex;
            align-items: center;
            gap: 12px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .learning-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 24px;
        }

        .learning-card {
            background: var(--color-surface);
            border-radius: var(--radius-xl);
            border: 1px solid var(--color-border);
            overflow: hidden;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .learning-card:hover {
            transform: translateY(-4px);
            border-color: var(--mdb-green);
            box-shadow: var(--shadow-lg);
        }

        .card-thumbnail {
            width: 100%;
            aspect-ratio: 16/9;
            background: var(--mdb-midnight);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            position: relative;
        }

        .card-progress-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 4px;
            background: var(--mdb-green);
            transition: width 0.3s ease;
        }

        .section-tab {
            font-size: 14px;
            font-weight: 700;
            color: var(--color-text-muted);
            text-decoration: none;
            padding-bottom: 8px;
            border-bottom: 3px solid transparent;
            transition: all 0.2s;
        }

        .section-tab.active {
            color: var(--mdb-green);
            border-bottom-color: var(--mdb-green);
        }
    </style>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
    <div class="instructor-layout">
        <%- include('partials/student-sidebar', { activePage: 'dashboard' }) %>

        <main class="instructor-main">
            <div class="dashboard-hero">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h1 style="font-size: 32px; font-weight: 800; margin-bottom: 8px; letter-spacing: -0.02em;">Welcome Back, Scholar!</h1>
                        <p style="opacity: 0.7; font-size: 16px;">Pick up right where you left off in your engineering journey.</p>
                    </div>
                    <div style="display: flex; gap: 16px;">
                        <div class="stat-badge">
                            <span style="font-size: 20px;">⚡</span>
                            <div>
                                <div style="font-size: 18px; font-weight: 800; color: var(--mdb-green);"><%= (gamificationData && gamificationData.experiencePoints) || 0 %></div>
                                <div style="font-size: 10px; font-weight: 700; text-transform: uppercase; opacity: 0.6;">XP Points</div>
                            </div>
                        </div>
                        <div class="stat-badge">
                            <span style="font-size: 20px;">🔥</span>
                            <div>
                                <div style="font-size: 18px; font-weight: 800; color: #ff3b30;"><%= (gamificationData && gamificationData.streakData && gamificationData.streakData.currentStreak) || 0 %></div>
                                <div style="font-size: 10px; font-weight: 700; text-transform: uppercase; opacity: 0.6;">Day Streak</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <nav style="display: flex; gap: 32px; margin-bottom: 32px; border-bottom: 1px solid var(--color-border);">
                <a href="#" class="section-tab active">My Courses</a>
                <a href="#" class="section-tab">In Progress</a>
                <a href="#" class="section-tab">Completed</a>
                <a href="#" class="section-tab">Wishlist</a>
            </nav>

            <div class="learning-grid">
                <% if (courses && courses.length > 0) { %>
                    <% courses.forEach(course => { %>
                        <% 
                            const total = course.videos ? course.videos.length : 0;
                            const watched = course.videos ? course.videos.filter(v => v.watched).length : 0;
                            const progress = total > 0 ? Math.round((watched / total) * 100) : 0;
                        %>
                        <div class="learning-card">
                            <div class="card-thumbnail">
                                🎞️
                                <div class="card-progress-overlay" style="width: <%- progress %>%;"></div>
                            </div>
                            <div style="padding: 20px; flex: 1; display: flex; flex-direction: column;">
                                <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 8px;"><%= course.title || course.name %></h3>
                                <p style="font-size: 13px; color: var(--color-text-muted); margin-bottom: 24px;">Instructor: <%= course.instructor || 'Engineer Felex' %></p>
                                
                                <div style="margin-top: auto; display: flex; justify-content: space-between; align-items: center;">
                                    <div style="font-size: 12px; font-weight: 700; color: var(--mdb-green);"><%= progress %>% Complete</div>
                                    <a href="/course/<%= encodeURIComponent(course.name) %>" class="btn btn-primary" style="font-size: 12px; padding: 6px 16px; border-radius: 8px;">
                                        <%= progress > 0 ? 'Continue' : 'Start' %>
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div style="grid-column: 1/-1; text-align: center; padding: 80px 0; background: var(--color-surface); border: 2px dashed var(--color-border); border-radius: 24px;">
                        <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 8px;">Start your learning journey</h2>
                        <p style="color: var(--color-text-muted); margin-bottom: 32px;">You haven't enrolled in any courses yet.</p>
                        <a href="/courses" class="btn btn-primary" style="padding: 12px 32px;">Explore Courses</a>
                    </div>
            <div style="margin-top: 48px; margin-bottom: 24px;">
                <h2 style="font-size: 24px; font-weight: 800; letter-spacing: -0.01em;">Discover More</h2>
                <p style="color: var(--color-text-muted);">Explore our library of engineering courses.</p>
            </div>

            <div class="learning-grid">
                <% if (typeof allCourses !== 'undefined' && allCourses.length > 0) { %>
                    <% 
                        const enrolledIds = new Set(courses.map(c => (c.id || c._id)?.toString()));
                        const discoverableCourses = allCourses.filter(c => !enrolledIds.has(c._id?.toString()));
                    %>
                    <% if (discoverableCourses.length > 0) { %>
                        <% discoverableCourses.forEach(course => { %>
                            <div class="learning-card">
                                <div class="card-thumbnail" style="background: linear-gradient(135deg, #023430 0%, #001E2B 100%);">
                                    🎓
                                </div>
                                <div style="padding: 20px; flex: 1; display: flex; flex-direction: column;">
                                    <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 8px;"><%= course.title %></h3>
                                    <p style="font-size: 13px; color: var(--color-text-muted); margin-bottom: 24px;"><%= course.instructor || 'Engineer Felex' %></p>
                                    
                                    <div style="margin-top: auto; display: flex; justify-content: space-between; align-items: center;">
                                        <div style="font-size: 12px; font-weight: 700; color: var(--mdb-green);">Available</div>
                                        <a href="/course/<%= encodeURIComponent(course.title) %>" class="btn btn-secondary" style="font-size: 12px; padding: 6px 16px; border-radius: 8px;">
                                            Learn More
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-muted">You have enrolled in all available courses! ✨</p>
                    <% } %>
                <% } else { %>
                    <p class="text-muted">No other courses available at the moment.</p>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        initTheme();
    </script>
</body>
</html>