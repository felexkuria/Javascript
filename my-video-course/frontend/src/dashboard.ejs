<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — LearnDB</title>
    <meta name="description" content="Your learning dashboard.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .dashboard-hero {
            background: var(--mdb-midnight);
            color: #fff;
            padding: var(--space-10) 0;
            margin-bottom: var(--space-8);
            border-bottom: 1px solid var(--mdb-green);
        }

        .dashboard-container {
            max-width: var(--container-width);
            margin: 0 auto;
            padding: 0 var(--space-6);
        }

        .hero-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stats-row {
            display: flex;
            gap: var(--space-10);
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: 32px;
            font-weight: 800;
            color: var(--mdb-green);
            display: block;
        }

        .stat-label {
            font-size: 13px;
            opacity: 0.7;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .section-nav {
            display: flex;
            gap: var(--space-6);
            border-bottom: 1px solid var(--color-border);
            margin-bottom: var(--space-8);
        }

        .section-tab {
            padding: var(--space-4) 0;
            font-size: 16px;
            font-weight: 700;
            color: var(--color-text-muted);
            text-decoration: none;
            border-bottom: 3px solid transparent;
            transition: all var(--transition);
        }

        .section-tab.active {
            color: var(--mdb-green);
            border-bottom-color: var(--mdb-green);
        }

        .learning-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: var(--space-6);
            margin-bottom: var(--space-10);
        }

        .learning-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: all var(--transition);
            display: flex;
            flex-direction: column;
        }

        .learning-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
            border-color: var(--mdb-green);
        }

        .card-thumbnail {
            width: 100%;
            aspect-ratio: 16/9;
            background: var(--mdb-midnight);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            position: relative;
        }

        .card-progress-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 4px;
            background: var(--mdb-green);
            transition: width 0.3s ease;
        }

        .card-content {
            padding: var(--space-5);
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .card-title {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: var(--space-2);
            line-height: 1.4;
        }

        .card-instructor {
            font-size: 13px;
            color: var(--color-text-muted);
            margin-bottom: var(--space-4);
        }

        .card-footer {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .progress-text {
            font-size: 12px;
            font-weight: 600;
            color: var(--color-text-muted);
        }

        @media (max-width: 768px) {
            .hero-content { flex-direction: column; text-align: center; gap: var(--space-6); }
            .stats-row { gap: var(--space-6); }
        }
    </style>

</head>
<body>
    <!-- ── Navigation ──────────────────────────────────────── -->
    <nav class="page-nav" role="navigation">
        <div class="dashboard-container hero-content" style="padding: 0; min-height: 64px;">
            <a href="/dashboard" class="nav-brand">
                <div class="nav-leaf" aria-hidden="true"></div>
                <span class="nav-brand-name">MongoDB <em>Academy</em></span>
            </a>
            <ul class="nav-links-list" role="list">
                <li><a href="/dashboard" class="nav-link active">My Learning</a></li>
                <li><a href="/courses" class="nav-link">Browse</a></li>
                <% if (user && user.isTeacher) { %>
                <li><a href="/teacher/dashboard" class="nav-link">Instructor</a></li>
                <% } %>
            </ul>
            <div class="nav-right">
                <button id="themeToggle" class="theme-btn" aria-label="Toggle dark mode">
                    <span id="themeIcon">🌙</span>
                </button>
                <a href="/profile" class="user-avatar" title="Your profile">
                    <%= (user && user.name) ? user.name.charAt(0).toUpperCase() : 'U' %>
                </a>
            </div>
        </div>
    </nav>

    <!-- ── Dashboard Hero ──────────────────────────────────── -->
    <header class="dashboard-hero">
        <div class="dashboard-container">
            <div class="hero-content">
                <div>
                    <h1 style="font-size: 36px; font-weight: 800; margin-bottom: var(--space-2);">My Learning</h1>
                    <p style="opacity: 0.8; font-size: 16px;">Welcome back, <%= (user && user.name) ? user.name.split(' ')[0] : 'Learner' %>! Continue where you left off.</p>
                </div>
                <div class="stats-row">
                    <div class="stat-item">
                        <span class="stat-number"><%= (gamificationData && gamificationData.userStats && gamificationData.userStats.currentLevel) || 1 %></span>
                        <span class="stat-label">Level</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number"><%= (gamificationData && gamificationData.userStats && gamificationData.userStats.totalPoints) || 0 %></span>
                        <span class="stat-label">Points</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number"><%= (gamificationData && gamificationData.streakData && gamificationData.streakData.currentStreak) || 0 %></span>
                        <span class="stat-label">Streak</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- ── Main Content ────────────────────────────────────── -->
    <main class="dashboard-container">
        <nav class="section-nav">
            <a href="#" class="section-tab active">All Courses</a>
            <a href="#" class="section-tab">In Progress</a>
            <a href="#" class="section-tab">Completed</a>
            <a href="#" class="section-tab">Wishlist</a>
        </nav>

        <div class="learning-grid">
            <% if (courses && courses.length > 0) { %>
                <% courses.forEach(course => { %>
                    <% 
                        const total = course.videos ? course.videos.length : 0;
                        const watched = course.videos ? course.videos.filter(v => v.watched).length : 0;
                        const progress = total > 0 ? Math.round((watched / total) * 100) : 0;
                    %>
                    <div class="learning-card">
                        <div class="card-thumbnail">
                            🎞️
                            <div class="card-progress-overlay" style="width: <%= progress %>%"></div>
                        </div>
                        <div class="card-content">
                            <h3 class="card-title"><%= course.name %></h3>
                            <p class="card-instructor">Instructor: <%= course.instructor || 'David Malan' %></p>
                            
                            <div class="card-footer">
                                <div class="progress-text"><%= progress %>% Complete</div>
                                <a href="/course/<%= course.name %>" class="btn btn-primary btn-sm">
                                    <%= progress > 0 ? 'Continue' : 'Start' %>
                                </a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="grid-column: 1/-1; text-align: center; padding: var(--space-20); background: var(--color-surface); border-radius: var(--radius-lg); border: 2px dashed var(--color-border);">
                    <div style="font-size: 64px; margin-bottom: var(--space-4);">🎓</div>
                    <h2 style="font-size: 24px; font-weight: 700; margin-bottom: var(--space-2);">Start your learning journey</h2>
                    <p style="color: var(--color-text-muted); margin-bottom: var(--space-6);">You haven't enrolled in any courses yet.</p>
                    <a href="/courses" class="btn btn-primary">Browse Courses</a>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        // Theme management
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'dark';
            document.documentElement.classList.toggle('dark', theme === 'dark');
            document.getElementById('themeIcon').textContent = theme === 'dark' ? '☀️' : '🌙';
        }
        
        function toggleTheme() {
            const isDark = document.documentElement.classList.contains('dark');
            const newTheme = isDark ? 'light' : 'dark';
            document.documentElement.classList.toggle('dark', newTheme === 'dark');
            localStorage.setItem('theme', newTheme);
            document.getElementById('themeIcon').textContent = newTheme === 'dark' ? '☀️' : '🌙';
        }

        initTheme();
        document.getElementById('themeToggle').addEventListener('click', toggleTheme);
    </script>
    <script src="/js/auth-persistence.js"></script>
</body>
</html>