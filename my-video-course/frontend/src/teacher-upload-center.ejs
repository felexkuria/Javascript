<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Center - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .upload-zone {
            border: 2px dashed var(--mdb-green);
            border-radius: 16px;
            padding: 48px 24px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            background: rgba(0, 237, 100, 0.02);
        }
        .upload-zone:hover, .upload-zone.dragging {
            background: rgba(0, 237, 100, 0.06);
            border-style: solid;
        }
        .upload-zone input[type="file"] { display: none; }

        .progress-item {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .progress-bar-wrap {
            flex: 1;
        }
        .progress-track {
            height: 6px;
            background: var(--color-border);
            border-radius: 99px;
            overflow: hidden;
            margin-top: 6px;
        }
        .progress-fill {
            height: 100%;
            background: var(--mdb-green);
            border-radius: 99px;
            transition: width 0.3s;
        }
        .form-select {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid var(--color-border);
            background: var(--color-surface);
            color: var(--color-text);
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }
        .form-select:focus { border-color: var(--mdb-green); }
        .form-label {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--color-text-muted);
            margin-bottom: 6px;
            display: block;
        }
        .badge-success { background: rgba(0,237,100,0.12); color: var(--mdb-green); padding: 3px 10px; border-radius: 99px; font-size: 11px; font-weight: 700; }
        .badge-error   { background: rgba(193,42,42,0.1); color: #C12A2A;        padding: 3px 10px; border-radius: 99px; font-size: 11px; font-weight: 700; }
        .badge-pending { background: rgba(92,107,116,0.15); color: var(--color-text-muted); padding: 3px 10px; border-radius: 99px; font-size: 11px; font-weight: 700; }

        .section-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(0,237,100,0.08);
            color: var(--mdb-green);
            border: 1px solid rgba(0,237,100,0.2);
            border-radius: 8px;
            padding: 5px 12px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
        }
        .section-pill:hover, .section-pill.selected {
            background: var(--mdb-green);
            color: var(--mdb-midnight);
        }
    </style>
</head>
<body>
    <div class="instructor-layout">
        <%- include('partials/instructor-sidebar', { activePage: 'upload' }) %>

        <main class="instructor-main">
            <header style="margin-bottom: 40px;">
                <h1 style="font-size: 32px; font-weight: 800; letter-spacing: -0.03em;">Video Upload Center</h1>
                <p style="color: var(--color-text-muted); font-size: 15px; margin-top: 6px;">Upload lectures directly to S3 and assign them to a course section.</p>
            </header>

            <!-- ── Step 1: Select Course & Section ─────────────────── -->
            <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 20px; padding: 32px; margin-bottom: 28px;">
                <h2 style="font-size: 18px; font-weight: 700; margin-bottom: 20px;"><span style="color: var(--mdb-green);">Step 1</span> — Choose Course & Section</h2>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
                    <div>
                        <label class="form-label">Course</label>
                        <select id="courseSelect" class="form-select" onchange="onCourseChange()">
                            <option value="">— Select a course —</option>
                            <% if (typeof courses !== 'undefined' && courses.length > 0) { %>
                                <% courses.forEach(c => { %>
                                    <option value="<%= c._id %>" data-sections='<%= JSON.stringify(c.sections || []) %>'>
                                        <%= c.title %>
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Lecture Title (optional override)</label>
                        <input type="text" id="lectureTitle" class="form-select" placeholder="Auto-derived from file name">
                    </div>
                </div>

                <div>
                    <label class="form-label">Section</label>
                    <div id="sectionPills" style="display: flex; flex-wrap: wrap; gap: 8px; min-height: 36px;">
                        <span style="color: var(--color-text-muted); font-size: 13px; align-self: center;">Select a course first…</span>
                    </div>
                    <input type="hidden" id="selectedSectionId">
                    <input type="hidden" id="selectedSectionTitle">
                </div>
            </div>

            <!-- ── Step 2: Drop / Pick File ────────────────────────── -->
            <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 20px; padding: 32px; margin-bottom: 28px;">
                <h2 style="font-size: 18px; font-weight: 700; margin-bottom: 20px;"><span style="color: var(--mdb-green);">Step 2</span> — Upload Video</h2>

                <div class="upload-zone" id="dropZone" onclick="document.getElementById('videoFile').click()">
                    <input type="file" id="videoFile" accept="video/*" onchange="onFileSelected(this.files)">
                    <i class="fas fa-cloud-upload-alt" style="font-size: 40px; color: var(--mdb-green); margin-bottom: 16px;"></i>
                    <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 8px;">Drop video here or click to browse</h3>
                    <p style="color: var(--color-text-muted); font-size: 13px;">Supports .mp4, .mov, .webm — any size</p>
                </div>

                <!-- Upload queue -->
                <div id="uploadQueue" style="margin-top: 24px;"></div>

                <div style="margin-top: 20px; display: flex; justify-content: flex-end; gap: 12px;">
                    <button class="btn btn-secondary" onclick="clearQueue()">Clear</button>
                    <button id="uploadBtn" class="btn btn-primary" onclick="startUpload()" disabled style="min-width: 160px;">
                        <i class="fas fa-rocket"></i> Upload to S3
                    </button>
                </div>
            </div>

            <!-- ── Activity Log ─────────────────────── -->
            <div style="background: var(--color-surface); border: 1px dashed var(--color-border); border-radius: 20px; padding: 32px;">
                <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 16px;">Activity Log</h3>
                <div id="activityLog" style="font-family: monospace; font-size: 12px; color: var(--color-text-muted); min-height: 60px;">
                    Waiting for uploads…
                </div>
            </div>
        </main>
    </div>

    <script>
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        initTheme();

        // ── State ──────────────────────────────────────────────────
        let selectedFiles = [];
        let selectedSectionId = null;
        let selectedSectionTitle = null;

        // ── Course → Section pills ─────────────────────────────────
        function onCourseChange() {
            const sel = document.getElementById('courseSelect');
            const opt = sel.options[sel.selectedIndex];
            const pills = document.getElementById('sectionPills');
            document.getElementById('selectedSectionId').value = '';
            document.getElementById('selectedSectionTitle').value = '';
            selectedSectionId = null;
            selectedSectionTitle = null;

            if (!opt.value) {
                pills.innerHTML = '<span style="color:var(--color-text-muted);font-size:13px;">Select a course first…</span>';
                return;
            }

            const sections = JSON.parse(opt.dataset.sections || '[]');
            if (!sections.length) {
                pills.innerHTML = '<span style="color:var(--color-text-muted);font-size:13px;">No sections yet — add them in the Course Editor.</span>';
                return;
            }

            pills.innerHTML = sections.map((s, i) =>
                `<span class="section-pill" data-id="${s._id}" data-title="${s.title}" onclick="selectSection(this)">
                    <i class="fas fa-layer-group"></i> §${i+1}: ${s.title}
                </span>`
            ).join('');
        }

        function selectSection(el) {
            document.querySelectorAll('.section-pill').forEach(p => p.classList.remove('selected'));
            el.classList.add('selected');
            selectedSectionId = el.dataset.id;
            selectedSectionTitle = el.dataset.title;
            document.getElementById('selectedSectionId').value = selectedSectionId;
            document.getElementById('selectedSectionTitle').value = selectedSectionTitle;
            checkReadyToUpload();
        }

        // ── File handling ──────────────────────────────────────────
        const dropZone = document.getElementById('dropZone');
        dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragging'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragging'));
        dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('dragging'); onFileSelected(e.dataTransfer.files); });

        function onFileSelected(files) {
            for (const f of files) {
                if (!f.type.startsWith('video/')) continue;
                selectedFiles.push(f);
                renderQueueItem(f);
            }
            checkReadyToUpload();
        }

        function renderQueueItem(file) {
            const id = 'file_' + Date.now() + '_' + Math.random().toString(36).slice(2);
            file.__queueId = id;
            const div = document.createElement('div');
            div.className = 'progress-item';
            div.id = id;
            div.innerHTML = `
                <i class="fas fa-film" style="color:var(--mdb-green);font-size:20px;"></i>
                <div class="progress-bar-wrap">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span style="font-size:13px;font-weight:600;">${file.name}</span>
                        <span class="badge-pending" id="${id}_badge">Queued</span>
                    </div>
                    <div class="progress-track"><div class="progress-fill" id="${id}_fill" style="width:0%"></div></div>
                    <div style="font-size:11px;color:var(--color-text-muted);margin-top:4px;" id="${id}_meta">${(file.size / 1024 / 1024).toFixed(1)} MB</div>
                </div>
            `;
            document.getElementById('uploadQueue').appendChild(div);
        }

        function clearQueue() {
            selectedFiles = [];
            document.getElementById('uploadQueue').innerHTML = '';
            document.getElementById('videoFile').value = '';
            checkReadyToUpload();
        }

        function checkReadyToUpload() {
            const ready = selectedFiles.length > 0 && selectedSectionId && document.getElementById('courseSelect').value;
            document.getElementById('uploadBtn').disabled = !ready;
        }

        // ── Upload ─────────────────────────────────────────────────
        async function startUpload() {
            const courseId = document.getElementById('courseSelect').value;
            const lectureTitle = document.getElementById('lectureTitle').value.trim();
            const btn = document.getElementById('uploadBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Uploading…';

            log(`Starting upload of ${selectedFiles.length} file(s) to section: ${selectedSectionTitle}`);

            for (const file of selectedFiles) {
                const id = file.__queueId;
                setBadge(id, 'pending', 'Uploading…');
                setFill(id, 5);

                try {
                    const title = lectureTitle || file.name.replace(/\.[^.]+$/, '');
                    const formData = new FormData();
                    formData.append('video', file);
                    formData.append('courseId', courseId);
                    formData.append('sectionId', selectedSectionId);
                    formData.append('title', title);

                    // Simulate chunked progress (XHR gives real progress)
                    const xhr = new XMLHttpRequest();
                    xhr.open('POST', `/api/courses/${encodeURIComponent(courseId)}/upload-video`);

                    // Set auth headers
                    const token = localStorage.getItem('accessToken');
                    if (token) xhr.setRequestHeader('Authorization', `Bearer ${token}`);

                    xhr.upload.onprogress = e => {
                        if (e.lengthComputable) {
                            const pct = Math.round((e.loaded / e.total) * 100);
                            setFill(id, pct);
                            document.getElementById(id + '_meta').textContent = `${(e.loaded / 1024 / 1024).toFixed(1)} / ${(e.total / 1024 / 1024).toFixed(1)} MB`;
                        }
                    };

                    await new Promise((resolve, reject) => {
                        xhr.onload = () => {
                            try {
                                const data = JSON.parse(xhr.responseText);
                                if (xhr.status >= 200 && xhr.status < 300 && data.success !== false) {
                                    setFill(id, 100);
                                    setBadge(id, 'success', 'Done ✓');
                                    log(`✅ ${file.name} → uploaded. S3 key: ${data.data?.s3Key || data.s3Key || 'saved'}`);

                                    // If server returns updated course, patch the section
                                    if (data.sectionId || selectedSectionId) {
                                        log(`📌 Linked to section: ${selectedSectionTitle}`);
                                    }
                                    resolve();
                                } else {
                                    throw new Error(data.message || data.error || 'Upload failed');
                                }
                            } catch (e) { reject(e); }
                        };
                        xhr.onerror = () => reject(new Error('Network error'));
                        xhr.send(formData);
                    });
                } catch (err) {
                    setBadge(id, 'error', 'Failed ✗');
                    setFill(id, 0);
                    log(`❌ ${file.name}: ${err.message}`);
                }
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-rocket"></i> Upload to S3';
        }

        function setBadge(id, type, text) {
            const el = document.getElementById(id + '_badge');
            if (!el) return;
            el.className = type === 'success' ? 'badge-success' : type === 'error' ? 'badge-error' : 'badge-pending';
            el.textContent = text;
        }
        function setFill(id, pct) {
            const el = document.getElementById(id + '_fill');
            if (el) el.style.width = pct + '%';
        }

        function log(msg) {
            const el = document.getElementById('activityLog');
            const ts = new Date().toLocaleTimeString();
            el.innerHTML = `[${ts}] ${msg}<br>` + el.innerHTML;
        }
    </script>
</body>
</html>