<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Center - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .instructor-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            min-height: 100vh;
            background: var(--color-bg);
        }

        .instructor-main {
            padding: var(--space-8);
            background: var(--color-bg);
            overflow-y: auto;
        }

        .upload-card {
            background: var(--color-surface);
            border-radius: var(--radius-2xl);
            border: 1px solid var(--color-border);
            padding: var(--space-8);
            box-shadow: var(--shadow-lg);
            margin-bottom: var(--space-8);
            transition: all 0.3s ease;
        }

        .upload-card:hover {
            border-color: var(--mdb-green);
        }

        .method-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            background: rgba(0, 237, 100, 0.1);
            color: var(--mdb-green);
            border-radius: 980px;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: var(--space-4);
        }

        .code-block {
            background: #001E2B;
            color: #E7EEEB;
            padding: var(--space-6);
            border-radius: var(--radius-lg);
            font-family: 'JetBrains Mono', 'Fira Code', monospace;
            font-size: 13px;
            position: relative;
            margin: var(--space-4) 0;
            overflow-x: auto;
        }

        .copy-trigger {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(255,255,255,0.1);
            border: none;
            color: #fff;
            padding: 6px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 11px;
            transition: all 0.2s;
        }

        .copy-trigger:hover {
            background: var(--mdb-green);
            color: var(--mdb-midnight);
        }

        .step-list {
            list-style: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .step-item {
            display: flex;
            gap: 12px;
            font-size: 14px;
            color: var(--color-text-muted);
        }

        .step-number {
            width: 24px;
            height: 24px;
            background: var(--mdb-midnight);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .dark .step-number {
            background: var(--mdb-green);
            color: var(--mdb-midnight);
        }
    </style>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
    <div class="instructor-layout">
        <%- include('partials/instructor-sidebar', { activePage: 'upload' }) %>

        <main class="instructor-main">
            <header style="margin-bottom: var(--space-10);">
                <h1 style="font-size: 36px; font-weight: 800; letter-spacing: -0.03em;">Upload Center</h1>
                <p style="color: var(--color-text-muted); font-size: 17px;">Choose your preferred deployment method for course assets.</p>
            </header>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8);">
                <!-- Bulk Deployment Card -->
                <div class="upload-card">
                    <span class="method-badge"><i class="fas fa-rocket"></i> RECOMMENDED</span>
                    <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 12px;">Bulk CLI Sync</h2>
                    <p style="color: var(--color-text-muted); font-size: 14px; margin-bottom: 24px;">Synchronize entire folders of high-definition video assets directly from your local terminal.</p>
                    
                    <div style="margin-bottom: 32px;">
                        <h4 style="font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin-bottom: 12px;">Quick Start Guide</h4>
                        <div class="step-list">
                            <div class="step-item"><span class="step-number">1</span> <div>Install AWS CLI and run <code>aws configure</code></div></div>
                            <div class="step-item"><span class="step-number">2</span> <div>Navigate to your course video directory</div></div>
                            <div class="step-item"><span class="step-number">3</span> <div>Execute the generated sync script below</div></div>
                        </div>
                    </div>

                    <button class="btn btn-primary" onclick="showScriptModal()" style="width: 100%; justify-content: center; height: 48px;">
                        Generate Sync Script
                    </button>
                </div>

                <!-- Direct Upload Card -->
                <div class="upload-card">
                    <span class="method-badge" style="background: rgba(1, 107, 248, 0.1); color: #016bf8;"><i class="fas fa-cloud-upload-alt"></i> WEB INTERFACE</span>
                    <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 12px;">Direct Browser Upload</h2>
                    <p style="color: var(--color-text-muted); font-size: 14px; margin-bottom: 24px;">Perfect for quick updates or adding single lessons to an existing curriculum.</p>
                    
                    <div style="margin-bottom: 32px;">
                        <ul class="step-list">
                            <li class="step-item"><i class="fas fa-check-circle" style="color: var(--mdb-green);"></i> Supports drag & drop</li>
                            <li class="step-item"><i class="fas fa-check-circle" style="color: var(--mdb-green);"></i> Real-time progress tracking</li>
                            <li class="step-item"><i class="fas fa-check-circle" style="color: var(--mdb-green);"></i> Automatic S3 optimization</li>
                        </ul>
                    </div>

                    <a href="/upload" class="btn btn-secondary" style="width: 100%; justify-content: center; height: 48px; border-radius: 12px;">
                        Open Web Uploader
                    </a>
                </div>
            </div>

            <!-- Monitoring Section -->
            <div class="upload-card" style="margin-top: var(--space-8); border-style: dashed;">
                <h3 style="font-size: 18px; font-weight: 700; margin-bottom: var(--space-4);">Real-time Activity Stream</h3>
                <div id="activityLog" style="min-height: 100px; display: flex; flex-direction: column; items-center; justify-content: center; color: var(--color-text-muted);">
                    <div style="font-size: 32px; margin-bottom: 12px; opacity: 0.5;">📊</div>
                    <p style="font-size: 13px;">No active deployments detected. Use CLI or Web Uploader to start.</p>
                </div>
            </div>
        </main>
    </div>

    <!-- Script Modal (Simplified for beauty) -->
    <div id="scriptModal" class="modal-overlay" style="position: fixed; inset: 0; background: rgba(0,30,43,0.8); backdrop-filter: blur(8px); display: none; place-items: center; z-index: 1000;">
        <div class="modal-content" style="background: var(--color-surface); width: 100%; max-width: 600px; padding: 32px; border-radius: 24px; position: relative;">
            <button onclick="hideScriptModal()" style="position: absolute; top: 20px; right: 20px; background: none; border: none; font-size: 20px; cursor: pointer;">×</button>
            <h2 style="font-size: 24px; font-weight: 800; margin-bottom: 8px;">Sync Script Generator</h2>
            <p style="color: var(--color-text-muted); font-size: 14px; margin-bottom: 24px;">Detected Platform: <strong id="detectedOS">Checking...</strong></p>
            
            <div class="code-block">
                <button class="copy-trigger" onclick="copyScript()">Copy Code</button>
                <code id="scriptOutput">
                    # Loading deployment script...
                </code>
            </div>

            <p style="font-size: 12px; color: var(--color-text-muted); margin-top: var(--space-4);">
                <i class="fas fa-info-circle"></i> This script will synchronize <code>.mp4</code> files from your current directory to the production bucket.
            </p>
        </div>
    </div>

    <script>
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        initTheme();

        function showScriptModal() {
            const modal = document.getElementById('scriptModal');
            modal.style.display = 'grid';
            
            const os = navigator.platform.toLowerCase().includes('mac') ? 'macOS' : 'Windows';
            document.getElementById('detectedOS').textContent = os;
            
            const script = os === 'macOS' ? 
                `#!/bin/bash\naws s3 sync . s3://video-course-bucket-047ad47c/videos/ --include "*.mp4"` :
                `# PowerShell\naws s3 sync . s3://video-course-bucket-047ad47c/videos/ --include "*.mp4"`;
            
            document.getElementById('scriptOutput').textContent = script;
        }

        function hideScriptModal() {
            document.getElementById('scriptModal').style.display = 'none';
        }

        function copyScript() {
            const text = document.getElementById('scriptOutput').textContent;
            navigator.clipboard.writeText(text).then(() => {
                const btn = document.querySelector('.copy-trigger');
                btn.textContent = 'Copied!';
                setTimeout(() => btn.textContent = 'Copy Code', 2000);
            });
        }
    </script>
</body>
</html>