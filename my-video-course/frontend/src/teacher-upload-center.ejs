<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Video Ingestion & Sync - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --atlas-green: #00ED64;
            --atlas-forest: #00684A;
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(0, 30, 43, 0.1);
        }

        .dark {
            --glass-bg: rgba(2, 52, 48, 0.3);
            --glass-border: rgba(0, 237, 100, 0.15);
        }

        body {
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            box-shadow: 0 8px 32px rgba(0, 30, 43, 0.05);
        }

        /* ── Upload Zone UI ── */
        .upload-portal {
            border: 2px dashed var(--atlas-green);
            border-radius: 32px;
            padding: 60px 40px;
            text-align: center;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: rgba(0, 237, 100, 0.02);
            position: relative;
            overflow: hidden;
        }

        .upload-portal:hover, .upload-portal.dragging {
            background: rgba(0, 237, 100, 0.08);
            border-style: solid;
            transform: scale(1.01);
            box-shadow: 0 0 40px rgba(0, 237, 100, 0.1);
        }

        .upload-portal .icon-box {
            width: 80px;
            height: 80px;
            background: rgba(0, 237, 100, 0.1);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            color: var(--atlas-green);
            font-size: 32px;
            transition: all 0.3s;
        }

        .upload-portal:hover .icon-box {
            transform: translateY(-5px) rotate(5deg);
            background: var(--atlas-green);
            color: #001E2B;
        }

        /* ── Progress & Queue ── */
        .sync-item {
            padding: 20px 24px;
            border-radius: 20px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .progress-track-premium {
            height: 6px;
            background: rgba(0, 30, 43, 0.05);
            border-radius: 99px;
            overflow: hidden;
            margin-top: 8px;
            position: relative;
        }

        .dark .progress-track-premium { background: rgba(255, 255, 255, 0.05); }

        .progress-fill-neon {
            height: 100%;
            background: linear-gradient(90deg, #00ED64, #00684A);
            box-shadow: 0 0 15px rgba(0, 237, 100, 0.4);
            border-radius: 99px;
            transition: width 0.4s ease;
        }

        /* ── Section Selection ── */
        .strategic-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: transparent;
            color: var(--color-text-muted);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            padding: 8px 16px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }

        .strategic-pill:hover {
            border-color: var(--atlas-green);
            color: var(--atlas-green);
        }

        .strategic-pill.selected {
            background: var(--atlas-green);
            color: #001E2B;
            border-color: var(--atlas-green);
            box-shadow: 0 4px 12px rgba(0, 237, 100, 0.3);
        }

        .form-input-premium {
            width: 100%;
            padding: 14px 20px;
            border-radius: 16px;
            border: 1px solid var(--glass-border);
            background: rgba(255, 255, 255, 0.5);
            color: #001E2B;
            font-weight: 600;
            outline: none;
            transition: all 0.2s;
        }

        .dark .form-input-premium {
            background: rgba(0, 30, 43, 0.4);
            color: white;
        }

        .form-input-premium:focus {
            border-color: var(--atlas-green);
            box-shadow: 0 0 0 4px rgba(0, 237, 100, 0.1);
        }

        /* ── Milestones ── */
        .milestone-marker {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 14px;
            flex-shrink: 0;
        }

        .milestone-active { background: var(--atlas-green); color: #001E2B; }
        .milestone-inactive { background: rgba(0, 30, 43, 0.05); color: var(--color-text-muted); }
        .dark .milestone-inactive { background: rgba(255, 255, 255, 0.05); }
    </style>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
    <div class="instructor-layout">
        <%- include('partials/instructor-sidebar', { activePage: 'upload' }) %>

        <main class="instructor-main flex-grow p-10 overflow-auto">
            <header class="mb-12">
                <div class="flex items-center gap-3 mb-4">
                    <span class="px-3 py-1 bg-[#00ED64]/10 text-[#00684A] dark:text-[#00ED64] text-[10px] font-black uppercase tracking-widest rounded-full border border-[#00ED64]/20">Ingestion Hub</span>
                    <div class="h-px w-12 bg-gray-200 dark:bg-white/10"></div>
                </div>
                <h1 class="text-5xl font-black tracking-tighter text-[#001E2B] dark:text-white mb-2">Video Ingestion</h1>
                <p class="text-gray-500 dark:text-gray-400 font-medium text-lg">Synchronize high-definition lectures with the cloud infrastructure.</p>
            </header>

            <!-- Step 1: Destination -->
            <div class="premium-glass rounded-[40px] p-10 mb-8">
                <div class="flex items-center gap-4 mb-8">
                    <div class="milestone-marker milestone-active">1</div>
                    <h2 class="text-2xl font-black text-[#001E2B] dark:text-white tracking-tight">Destination Parameters</h2>
                </div>

                <div class="grid grid-cols-2 gap-8 mb-8">
                    <div>
                        <label class="block text-xs font-black uppercase tracking-widest text-gray-500 mb-2">Target Curriculum</label>
                        <select id="courseSelect" class="form-input-premium" onchange="onCourseChange()">
                            <option value="">— Select Environment —</option>
                            <% if (typeof courses !== 'undefined' && courses.length > 0) { %>
                                <% courses.forEach(c => { %>
                                    <option value="<%= c._id %>" data-sections='<%= JSON.stringify(c.sections || []) %>'>
                                        <%= c.title %>
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-black uppercase tracking-widest text-gray-500 mb-2">Logic Designation (Optional)</label>
                        <input type="text" id="lectureTitle" class="form-input-premium" placeholder="Auto-detect from metadata">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-widest text-gray-500 mb-2">Strategic Module Mapping</label>
                    <div id="sectionPills" class="flex flex-wrap gap-3 p-6 border-2 border-dashed border-gray-100 dark:border-white/5 rounded-2xl min-h-[80px]">
                        <span class="text-gray-400 font-medium self-center text-sm">Awaiting curriculum selection...</span>
                    </div>
                    <input type="hidden" id="selectedSectionId">
                    <input type="hidden" id="selectedSectionTitle">
                </div>
            </div>

            <!-- Step 2: Payload -->
            <div class="premium-glass rounded-[40px] p-10 mb-8">
                <div class="flex items-center gap-4 mb-8">
                    <div class="milestone-marker milestone-active">2</div>
                    <h2 class="text-2xl font-black text-[#001E2B] dark:text-white tracking-tight">Payload Selection</h2>
                </div>

                <div class="upload-portal" id="dropZone" onclick="document.getElementById('videoFile').click()">
                    <input type="file" id="videoFile" accept="video/*" onchange="onFileSelected(this.files)" style="display:none">
                    <div class="icon-box">
                        <i class="fas fa-satellite-dish"></i>
                    </div>
                    <h3 class="text-2xl font-black text-[#001E2B] dark:text-white mb-2">Transfer Payload</h3>
                    <p class="text-gray-500 dark:text-gray-400 font-medium">Drop MP4/MOV aggregates here or double-click to browse.</p>
                </div>

                <!-- Sync Queue -->
                <div id="uploadQueue" class="mt-8 space-y-4"></div>

                <div class="flex justify-end gap-4 mt-10">
                    <button class="px-8 py-4 rounded-xl font-bold text-gray-500 hover:text-red-500 transition-colors" onclick="clearQueue()">Purge Queue</button>
                    <button id="uploadBtn" class="bg-gradient-to-br from-[#00ED64] to-[#00684A] text-[#001E2B] font-black px-10 py-4 rounded-2xl shadow-xl shadow-[#00ED64]/20 disabled:opacity-30 disabled:grayscale transition-all" onclick="startUpload()" disabled>
                        <i class="fas fa-bolt mr-2"></i> Execute Transfer
                    </button>
                </div>
            </div>

            <!-- Log -->
            <div class="premium-glass rounded-[40px] p-8 opacity-60">
                <h3 class="text-sm font-black uppercase tracking-widest text-[#00ED64] mb-4 flex items-center gap-2">
                    <span class="w-2 h-2 bg-[#00ED64] rounded-full animate-pulse"></span> Terminal Log
                </h3>
                <div id="activityLog" class="font-mono text-[11px] text-gray-500 leading-relaxed overflow-y-auto max-h-[150px]">
                    [SYS] Ready for data ingestion...
                </div>
            </div>
        </main>
    </div>

    <script>
        let selectedFiles = [];
        let selectedSectionId = null;
        let selectedSectionTitle = null;

        function onCourseChange() {
            const sel = document.getElementById('courseSelect');
            const opt = sel.options[sel.selectedIndex];
            const pills = document.getElementById('sectionPills');
            selectedSectionId = null;
            selectedSectionTitle = null;

            if (!opt.value) {
                pills.innerHTML = '<span class="text-gray-400 font-medium self-center text-sm">Awaiting curriculum selection...</span>';
                return;
            }

            const sections = JSON.parse(opt.dataset.sections || '[]');
            if (!sections.length) {
                pills.innerHTML = '<span class="text-red-400 font-medium self-center text-sm">Zero modules detected in target curriculum.</span>';
                return;
            }

            pills.innerHTML = sections.map((s, i) =>
                `<button class="strategic-pill" data-id="${s._id}" data-title="${s.title}" onclick="selectSection(this)">
                    <i class="fas fa-layer-group text-[10px] opacity-40"></i> ${s.title}
                </button>`
            ).join('');
        }

        function selectSection(el) {
            document.querySelectorAll('.strategic-pill').forEach(p => p.classList.remove('selected'));
            el.classList.add('selected');
            selectedSectionId = el.dataset.id;
            selectedSectionTitle = el.dataset.title;
            checkReady();
        }

        function onFileSelected(files) {
            for (const f of files) {
                if (!f.type.startsWith('video/')) continue;
                selectedFiles.push(f);
                renderQueueItem(f);
            }
            checkReady();
        }

        function renderQueueItem(file) {
            const id = 'f_' + Math.random().toString(36).slice(2);
            file.__queueId = id;
            const div = document.createElement('div');
            div.className = 'sync-item premium-glass';
            div.id = id;
            div.innerHTML = `
                <div class="w-12 h-12 rounded-xl bg-[#00ED64]/10 flex items-center justify-center text-[#00ED64]">
                    <i class="fas fa-file-video text-xl"></i>
                </div>
                <div class="flex-grow">
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-sm font-bold text-[#001E2B] dark:text-white">${file.name}</span>
                        <span class="text-[10px] font-black uppercase tracking-widest text-gray-400" id="${id}_status">Awaiting Protocol</span>
                    </div>
                    <div class="progress-track-premium"><div class="progress-fill-neon" id="${id}_fill" style="width:0%"></div></div>
                    <div class="text-[10px] font-medium text-gray-400 mt-2" id="${id}_meta">${(file.size / 1024 / 1024).toFixed(1)} MB aggregates discovered</div>
                </div>
            `;
            document.getElementById('uploadQueue').appendChild(div);
        }

        function clearQueue() {
            selectedFiles = [];
            document.getElementById('uploadQueue').innerHTML = '';
            document.getElementById('videoFile').value = '';
            checkReady();
        }

        function checkReady() {
            const ready = selectedFiles.length > 0 && selectedSectionId && document.getElementById('courseSelect').value;
            document.getElementById('uploadBtn').disabled = !ready;
        }

        async function startUpload() {
            const courseId = document.getElementById('courseSelect').value;
            const lectureTitle = document.getElementById('lectureTitle').value.trim();
            const btn = document.getElementById('uploadBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-satellite fa-spin mr-3"></i> Synchronizing...';

            for (const file of selectedFiles) {
                const id = file.__queueId;
                document.getElementById(id + '_status').textContent = 'Synchronizing';
                
                try {
                    const title = lectureTitle || file.name.replace(/\.[^.]+$/, '');
                    const formData = new FormData();
                    formData.append('video', file);
                    formData.append('courseId', courseId);
                    formData.append('sectionId', selectedSectionId);
                    formData.append('title', title);

                    const xhr = new XMLHttpRequest();
                    xhr.open('POST', `/api/courses/${encodeURIComponent(courseId)}/upload-video`);
                    const token = localStorage.getItem('accessToken');
                    if (token) xhr.setRequestHeader('Authorization', `Bearer ${token}`);

                    xhr.upload.onprogress = e => {
                        if (e.lengthComputable) {
                            const pct = Math.round((e.loaded / e.total) * 100);
                            document.getElementById(id + '_fill').style.width = pct + '%';
                            document.getElementById(id + '_meta').textContent = `${(e.loaded / 1024 / 1024).toFixed(1)} / ${(e.total / 1024 / 1024).toFixed(1)} MB transferred`;
                        }
                    };

                    await new Promise((resolve, reject) => {
                        xhr.onload = () => {
                            const data = JSON.parse(xhr.responseText);
                            if (xhr.status >= 200 && xhr.status < 300) {
                                document.getElementById(id + '_status').textContent = 'Synced';
                                document.getElementById(id + '_status').style.color = '#00ED64';
                                log(`SUCCESS: [${file.name}] synced to strategic module.`);
                                resolve();
                            } else { reject(new Error(data.message || 'Transmission break')); }
                        };
                        xhr.onerror = () => reject(new Error('Infrastructure failure'));
                        xhr.send(formData);
                    });
                } catch (err) {
                    document.getElementById(id + '_status').textContent = 'Error';
                    document.getElementById(id + '_status').style.color = '#ff3b30';
                    log(`ERRO: ${err.message}`);
                }
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-bolt mr-2"></i> Execute Transfer';
        }

        function log(msg) {
            const el = document.getElementById('activityLog');
            el.innerHTML = `[${new Date().toLocaleTimeString()}] ${msg}<br>` + el.innerHTML;
        }

        // Drag Drop Styling
        const dropZone = document.getElementById('dropZone');
        ['dragenter', 'dragover'].forEach(e => dropZone.addEventListener(e, () => dropZone.classList.add('dragging'), false));
        ['dragleave', 'drop'].forEach(e => dropZone.addEventListener(e, () => dropZone.classList.remove('dragging'), false));
    </script>
</body>
</html>