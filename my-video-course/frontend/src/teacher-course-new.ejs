<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deploy New Curriculum - Multitouch Academy</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mdb-green': '#00ED64',
              'mdb-forest': '#00684A',
              'mdb-midnight': '#001E2B',
              'mdb-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        :root {
            --mdb-green: #00ED64;
            --mdb-midnight: #001E2B;
            --glass-bg: rgba(2, 52, 48, 0.4);
            --glass-border: rgba(0, 237, 100, 0.1);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--mdb-midnight);
            color: #E7EEEB;
            -webkit-font-smoothing: antialiased;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
        }

        .atlas-input {
            background: rgba(0, 30, 43, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 16px 24px;
            color: white;
            outline: none;
            transition: all 0.3s;
            width: 100%;
            font-weight: 500;
        }

        .atlas-input:focus {
            border-color: var(--mdb-green);
            background: rgba(0, 30, 43, 0.8);
            box-shadow: 0 0 0 4px rgba(0, 237, 100, 0.1);
        }

        .btn-atlas-rocket {
            background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
            color: #001E2B;
            font-weight: 900;
            border-radius: 20px;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 11px;
            box-shadow: 0 10px 30px rgba(0, 237, 100, 0.2);
        }

        .btn-atlas-rocket:hover {
            box-shadow: 0 15px 40px rgba(0, 237, 100, 0.4);
            transform: translateY(-4px);
        }

        .category-grid-atlas {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 16px;
        }

        .category-node {
            padding: 16px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: rgba(255, 255, 255, 0.02);
            color: #9FB1AD;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .category-node:hover {
            border-color: var(--mdb-green);
            color: var(--mdb-green);
        }

        .category-node.selected {
            background: var(--mdb-green);
            color: var(--mdb-midnight);
            border-color: var(--mdb-green);
        }
    </style>
</head>
<body class="dark overflow-x-hidden">
    <div class="flex">
        <!-- Sidebar -->
        <%- include('partials/instructor-sidebar', { activePage: 'dashboard' }) %>

        <main class="flex-grow p-10 lg:p-16">
            <header class="flex flex-col md:flex-row justify-between items-end gap-10 mb-20 md:max-w-4xl">
                <div>
                    <div class="flex items-center gap-4 mb-4">
                        <span class="px-4 py-1.5 bg-[#00ED64]/10 text-[#00ED64] text-[10px] font-black uppercase tracking-[0.3em] rounded-full border border-[#00ED64]/20">Infrastructure Deployment</span>
                        <div class="h-px w-16 bg-white/5"></div>
                    </div>
                    <h1 class="text-6xl font-black tracking-tighter text-white">Deploy <span class="text-[#00ED64]">Curriculum</span></h1>
                    <p class="text-gray-400 text-lg font-medium mt-2">Initialize a new learning node within the academy architecture.</p>
                </div>
            </header>

            <div class="md:max-w-4xl">
                <form action="/teacher/course-new" method="POST" class="premium-glass p-12 md:p-16 rounded-[48px] space-y-12">
                    <div class="space-y-6">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 ml-1">Blueprint Designation (Course Title)</label>
                        <input type="text" name="title" class="atlas-input" placeholder="e.g. Distributed Systems & Microservices" required>
                    </div>

                    <div class="space-y-6">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 ml-1">Curriculum Category</label>
                        <div class="category-grid-atlas" id="categoryGroup">
                            <% ['Engineering', 'Database', 'Cloud', 'Frontend', 'Backend', 'AI & ML'].forEach(cat => { %>
                                <div class="category-node" onclick="setCategory('<%= cat %>')"><%= cat %></div>
                            <% }) %>
                        </div>
                        <input type="hidden" name="category" id="categoryInput" value="Engineering">
                    </div>

                    <div class="space-y-6">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-gray-500 ml-1">Architectural Summary (Description)</label>
                        <textarea name="description" class="atlas-input resize-none" rows="5" placeholder="Define the core learning objectives and technical outcomes..."></textarea>
                    </div>

                    <div class="pt-8 flex flex-col md:flex-row items-center gap-8">
                        <button type="submit" class="btn-atlas-rocket px-12 py-6 flex items-center gap-4 w-full md:w-auto">
                            <i class="fas fa-rocket"></i> Deploy Architecture
                        </button>
                        <p class="text-[10px] font-black text-gray-600 uppercase tracking-widest leading-relaxed">
                            Deploying will initialize a new DynamoDB manifest and S3 bucket allocation for media assets.
                        </p>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <script>
        function setCategory(cat) {
            document.querySelectorAll('.category-node').forEach(node => {
                node.classList.toggle('selected', node.innerText.trim() === cat);
            });
            document.getElementById('categoryInput').value = cat;
        }
        // Initialize first category
        setCategory('Engineering');
    </script>
</body>
</html>
