<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .instructor-layout {
            display: grid;
            grid-template-columns: 260px 1fr;
            min-height: 100vh;
            background: var(--color-bg);
        }

        .instructor-sidebar {
            background: var(--mdb-midnight);
            color: #fff;
            padding: var(--space-6);
            display: flex;
            flex-direction: column;
            gap: var(--space-4);
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .sidebar-brand {
            font-size: 20px;
            font-weight: 800;
            color: var(--mdb-green);
            margin-bottom: var(--space-8);
            letter-spacing: -0.02em;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: var(--space-2);
        }

        .nav-item {
            padding: var(--space-3) var(--space-4);
            border-radius: var(--radius-md);
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            font-weight: 500;
            transition: all var(--transition);
        }

        .nav-item:hover, .nav-item.active {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }

        .nav-item.active {
            color: var(--mdb-green);
            border-left: 3px solid var(--mdb-green);
        }

        .instructor-main {
            padding: var(--space-8);
            overflow-y: auto;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: var(--space-6);
            margin-bottom: var(--space-8);
        }

        .stat-card {
            background: var(--color-surface);
            padding: var(--space-6);
            border-radius: var(--radius-lg);
            border: 1px solid var(--color-border);
            box-shadow: var(--shadow-sm);
        }

        .stat-label {
            font-size: 13px;
            color: var(--color-text-muted);
            margin-bottom: var(--space-2);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--color-text);
        }

        .course-manager {
            background: var(--color-surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--color-border);
            overflow: hidden;
        }

        .manager-header {
            padding: var(--space-6);
            border-bottom: 1px solid var(--color-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .course-table {
            width: 100%;
            border-collapse: collapse;
        }

        .course-table th {
            text-align: left;
            padding: var(--space-4) var(--space-6);
            background: var(--mdb-cloud-light);
            font-size: 13px;
            color: var(--color-text-muted);
            font-weight: 600;
        }

        .course-table td {
            padding: var(--space-4) var(--space-6);
            border-bottom: 1px solid var(--color-border);
        }

        .course-meta {
            display: flex;
            align-items: center;
            gap: var(--space-4);
        }

        .course-img {
            width: 80px;
            aspect-ratio: 16/9;
            background: var(--mdb-midnight);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .status-pill {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-published { background: var(--mdb-green-light); color: var(--mdb-green-dark); }
        .status-draft { background: var(--mdb-cloud); color: var(--color-text-muted); }

        @media (max-width: 1024px) {
            .instructor-layout { grid-template-columns: 1fr; }
            .instructor-sidebar { display: none; }
        }
    </style>

</head>
<body>
    <div class="instructor-layout">
        <%- include('partials/instructor-sidebar', { activePage: 'dashboard' }) %>
        <main class="instructor-main">
            <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-8);">
                <div>
                    <h1 style="font-size: 32px; font-weight: 700;">Performance</h1>
                    <p style="color: var(--color-text-muted);">Manage your courses and track student engagement.</p>
                </div>
                <div style="display: flex; gap: var(--space-4);">
                    <a href="/admin/course-manager" class="btn btn-primary">New Course</a>
                </div>
            </header>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Total Revenue</div>
                    <div class="stat-value">$0.00</div>
                    <div style="font-size: 12px; color: var(--mdb-green); margin-top: 4px;">+$0.00 this month</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Total Enrollments</div>
                    <div class="stat-value"><%= totalStudents %></div>
                    <div style="font-size: 12px; color: var(--mdb-green); margin-top: 4px;">+0 this month</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Instructor Rating</div>
                    <div class="stat-value">4.8 ★</div>
                    <div style="font-size: 12px; color: var(--mdb-green); margin-top: 4px;">0 ratings this month</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Total Courses</div>
                    <div class="stat-value"><%= totalCourses %></div>
                    <div style="font-size: 12px; color: var(--color-text-muted); margin-top: 4px;"><%= courses.filter(c => c.isPublished).length %> Published</div>
                </div>
            </div>

            <section class="course-manager">
                <div class="manager-header">
                    <h3 style="font-size: 18px; font-weight: 700;">Your Courses</h3>
                    <div style="display: flex; gap: var(--space-4);">
                        <input type="text" placeholder="Search courses..." class="form-input" style="width: 240px; margin-bottom: 0;">
                        <select class="form-input" style="width: 140px; margin-bottom: 0;">
                            <option>Newest</option>
                            <option>Oldest</option>
                            <option>A-Z</option>
                        </select>
                    </div>
                </div>
                <table class="course-table">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Enrollment</th>
                            <th>Status</th>
                            <th>Analytics</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (courses && courses.length > 0) { %>
                            <% courses.forEach(course => { %>
                                <tr>
                                    <td>
                                        <div class="course-meta">
                                            <div class="course-img">📽️</div>
                                            <div>
                                                <div style="font-weight: 600;"><%= course.title || course.name %></div>
                                                <div style="font-size: 12px; color: var(--color-text-muted);">Last updated <%= new Date().toLocaleDateString() %></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div style="font-weight: 600;">0</div>
                                        <div style="font-size: 11px; opacity: 0.6;">Students</div>
                                    </td>
                                    <td>
                                        <span class="status-pill <%= course.isPublished ? 'status-published' : 'status-draft' %>">
                                            <%= course.isPublished ? 'Published' : 'Draft' %>
                                        </span>
                                    </td>
                                    <td>
                                        <a href="/teacher/course-editor/<%= course.id %>" style="color: var(--mdb-green); font-size: 13px; font-weight: 600; text-decoration: none;">Manage Curriculum →</a>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" style="text-align: center; padding: var(--space-10); color: var(--color-text-muted);">
                                    You haven't created any courses yet.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </section>
        </main>
    </div>

    <script>
        // Theme management (minimal for instructor dashboard)
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        initTheme();
    </script>
</body>
</html>

</html>