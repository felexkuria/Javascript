<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instructor Console - Multitouch Academy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mongo-green': '#00ED64',
              'mongo-dark': '#001E2B',
              'mongo-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@100;300;400;500;700;900&display=swap');
        
        body { font-family: 'Outfit', sans-serif; }

        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .dark .glass {
            background: rgba(2, 52, 48, 0.4);
            border: 1px solid rgba(0, 237, 100, 0.1);
        }

        .atlas-card {
            border-radius: 1.5rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .premium-title {
            background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(0, 237, 100, 0.1); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(0, 237, 100, 0.2); }
    </style>
</head>
<body class="dark bg-[#001E2B] text-[#E7EEEB] min-h-screen">
    <div class="flex">
        <!-- Sidebar -->
        <%- include('partials/instructor-sidebar', { activePage: 'dashboard' }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8 md:p-12">
            <!-- Header -->
            <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-16">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <span class="px-2 py-1 bg-[#00ED64] text-[#001E2B] text-[9px] font-black uppercase tracking-widest rounded shadow-lg shadow-[#00ED64]/20">Console v4.0</span>
                        <span class="text-xs font-bold text-[#9FB1AD]">INSTRUCTOR ANALYTICS</span>
                    </div>
                    <h1 class="text-4xl font-black tracking-tighter text-white">Academy <span class="premium-title">Performance</span></h1>
                    <p class="text-[#9FB1AD] mt-2 font-medium">Monitor engagement, track revenue, and scale your influence.</p>
                </div>
                <a href="/teacher/course-new" class="px-8 py-4 bg-[#00ED64] text-[#001E2B] font-black rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-[#00ED64]/20 flex items-center gap-3">
                    <i class="fas fa-plus"></i> DEPLOY NEW COURSE
                </a>
            </header>

            <!-- Stats Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
                <!-- Revenue Card -->
                <div class="atlas-card glass p-8 group hover:border-[#00ED64]/30 transition-all border-dashed">
                    <div class="flex justify-between items-start mb-6">
                        <div class="w-12 h-12 rounded-xl bg-[#00ED64]/10 flex items-center justify-center text-[#00ED64] border border-[#00ED64]/20 group-hover:scale-110 transition-transform">
                            <i class="fas fa-dollar-sign"></i>
                        </div>
                        <span class="text-[10px] font-black text-[#00ED64]">+0.0% ↑</span>
                    </div>
                    <p class="text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest mb-1">TOTAL REVENUE</p>
                    <h3 class="text-3xl font-black text-white">$0.00</h3>
                </div>

                <!-- Enrollments Card -->
                <div class="atlas-card glass p-8 group hover:border-[#00ED64]/30 transition-all">
                    <div class="flex justify-between items-start mb-6">
                        <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 border border-blue-500/20 group-hover:scale-110 transition-transform">
                            <i class="fas fa-users"></i>
                        </div>
                        <span class="text-[10px] font-black text-blue-400">Total Enrolled</span>
                    </div>
                    <p class="text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest mb-1">STUDENTS</p>
                    <h3 class="text-3xl font-black text-white"><%= totalStudents %></h3>
                </div>

                <!-- Rating Card -->
                <div class="atlas-card glass p-8 group hover:border-[#00ED64]/30 transition-all">
                    <div class="flex justify-between items-start mb-6">
                        <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-500 border border-amber-500/20 group-hover:scale-110 transition-transform">
                            <i class="fas fa-star"></i>
                        </div>
                        <span class="text-[10px] font-black text-amber-400">Academy Rank</span>
                    </div>
                    <p class="text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest mb-1">INSTRUCTOR RATING</p>
                    <h3 class="text-3xl font-black text-white">4.8 <span class="text-lg opacity-30">/ 5</span></h3>
                </div>

                <!-- Courses Card -->
                <div class="atlas-card glass p-8 group hover:border-[#00ED64]/30 transition-all">
                    <div class="flex justify-between items-start mb-6">
                        <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 border border-purple-500/20 group-hover:scale-110 transition-transform">
                            <i class="fas fa-layer-group"></i>
                        </div>
                        <span class="text-[10px] font-black text-purple-400">Active Nodes</span>
                    </div>
                    <p class="text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest mb-1">LIVE COURSES</p>
                    <h3 class="text-3xl font-black text-white"><%= totalCourses %></h3>
                </div>
            </div>

            <!-- Course Management Table -->
            <section class="glass rounded-[2rem] overflow-hidden border-white/5 shadow-2xl">
                <div class="p-8 border-b border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
                    <div>
                        <h3 class="text-xl font-black text-white tracking-tight">Curriculum Architecture</h3>
                        <p class="text-xs text-[#9FB1AD] font-bold uppercase tracking-widest mt-1">Manage your deployed modules</p>
                    </div>
                    <div class="flex items-center gap-4 w-full md:w-auto">
                        <div class="relative flex-1 md:flex-none">
                            <input type="text" placeholder="Filter courses..." class="pl-10 pr-4 py-3 glass rounded-xl text-xs font-bold w-full md:w-64 focus:ring-1 focus:ring-[#00ED64] outline-none">
                            <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-[10px] opacity-30"></i>
                        </div>
                        <select class="px-4 py-3 glass rounded-xl text-xs font-bold outline-none border-r-8 border-transparent">
                            <option>Latest Deployed</option>
                            <option>Highest Enrollment</option>
                            <option>A-Z Alphabetical</option>
                        </select>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-white/5">
                                <th class="px-8 py-4 text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest">Blueprint Definition</th>
                                <th class="px-8 py-4 text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest">Enrollment Status</th>
                                <th class="px-8 py-4 text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest">Deployment</th>
                                <th class="px-8 py-4 text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest">Governance</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            <% if (courses && courses.length > 0) { %>
                                <% courses.forEach(course => { %>
                                    <tr class="group hover:bg-white/5 transition-colors cursor-pointer">
                                        <td class="px-8 py-6">
                                            <div class="flex items-center gap-6">
                                                <div class="w-20 h-12 bg-[#001E2B] rounded-lg flex items-center justify-center border border-white/10 group-hover:border-[#00ED64]/30 transition-all">
                                                    <i class="fas fa-video text-[#00ED64]/30 group-hover:text-[#00ED64] transition-colors"></i>
                                                </div>
                                                <div>
                                                    <p class="font-black text-white group-hover:text-[#00ED64] transition-colors"><%= course.title || course.name %></p>
                                                    <p class="text-[10px] text-[#9FB1AD] font-bold uppercase tracking-widest mt-1 opacity-50">Last Refactor: <%= new Date().toLocaleDateString() %></p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-8 py-6">
                                            <div class="flex flex-col">
                                                <span class="text-lg font-black text-white"><%= course.enrollments %></span>
                                                <span class="text-[10px] font-bold text-[#9FB1AD] uppercase tracking-widest opacity-50">Active Students</span>
                                            </div>
                                        </td>
                                        <td class="px-8 py-6">
                                            <span class="px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-widest <%= course.isPublished ? 'bg-[#00ED64]/10 text-[#00ED64] border border-[#00ED64]/20' : 'bg-gray-500/10 text-gray-500 border border-gray-500/20' %>">
                                                <%= course.isPublished ? 'PUBLISHED' : 'STAGING' %>
                                            </span>
                                        </td>
                                        <td class="px-8 py-6">
                                            <a href="/teacher/course-editor/<%= course.id %>" class="px-4 py-2 bg-white/5 text-[10px] font-black uppercase tracking-widest rounded-lg hover:bg-[#00ED64]/10 hover:text-[#00ED64] transition-all border border-transparent hover:border-[#00ED64]/20">
                                                MANAGE ARCHITECTURE →
                                            </a>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="px-8 py-20 text-center">
                                        <div class="flex flex-col items-center gap-4 opacity-30">
                                            <i class="fas fa-folder-open text-4xl"></i>
                                            <p class="text-[10px] font-black uppercase tracking-[0.4em]">No Curriculum Nodes Deployed</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <script>
        // Minimal script for immediate UI responsiveness
        document.addEventListener('DOMContentLoaded', function() {
            const path = window.location.pathname;
            document.querySelectorAll('.nav-item').forEach(item => {
                if (item.getAttribute('href') === path) {
                    item.classList.add('bg-[#00ED64]/10', 'text-[#00ED64]', 'border-[#00ED64]/20');
                }
            });
        });
    </script>
</body>
</html>