<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instructor Console - Multitouch Academy</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mdb-green': '#00ED64',
              'mdb-forest': '#00684A',
              'mdb-midnight': '#001E2B',
              'mdb-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        :root {
            --mdb-green: #00ED64;
            --mdb-midnight: #001E2B;
            --glass-bg: rgba(2, 52, 48, 0.4);
            --glass-border: rgba(0, 237, 100, 0.1);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--mdb-midnight);
            color: #E7EEEB;
            -webkit-font-smoothing: antialiased;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
        }

        .atlas-card-premium {
            border-radius: 32px;
            transition: all 0.4s cubic-bezier(0.2, 0, 0, 1);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .atlas-card-premium:hover {
            transform: translateY(-8px);
            border-color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.03);
        }

        .btn-atlas-primary {
            background: #00ED64;
            color: #001E2B;
            font-weight: 800;
            border-radius: 16px;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 11px;
        }

        .btn-atlas-primary:hover {
            box-shadow: 0 0 30px rgba(0, 237, 100, 0.3);
            transform: scale(1.05);
        }

        .row-atlas {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s;
        }

        .row-atlas:hover {
            background: rgba(0, 237, 100, 0.03);
            padding-left: 8px;
        }
    </style>
</head>
<body class="dark overflow-x-hidden">
    <div class="flex">
        <!-- Sidebar -->
        <%- include('partials/instructor-sidebar', { activePage: 'dashboard' }) %>

        <main class="flex-grow p-10 lg:p-16">
            <header class="flex flex-col md:flex-row justify-between items-end gap-10 mb-20">
                <div>
                    <div class="flex items-center gap-4 mb-4">
                        <span class="px-4 py-1.5 bg-[#00ED64]/10 text-[#00ED64] text-[10px] font-black uppercase tracking-[0.3em] rounded-full border border-[#00ED64]/20">Instructor Insight</span>
                        <div class="h-px w-16 bg-white/5"></div>
                    </div>
                    <h1 class="text-6xl font-black tracking-tighter text-white">Academy <span class="text-[#00ED64]">Performance</span></h1>
                    <p class="text-gray-400 text-lg font-medium mt-2">Monitor global engagement and curriculum resonance.</p>
                </div>
                <button onclick="window.location.href='/admin/course-manager'" class="btn-atlas-primary px-10 py-5 flex items-center gap-3">
                    <i class="fas fa-layer-group"></i> Manage Orchestration
                </button>
            </header>

            <!-- Metric Grid -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-20">
                <div class="atlas-card-premium premium-glass p-10">
                    <div class="flex justify-between items-start mb-8">
                        <div class="w-14 h-14 bg-green-500/10 rounded-2xl flex items-center justify-center text-[#00ED64] border border-[#00ED64]/20">
                            <i class="fas fa-chart-line text-xl"></i>
                        </div>
                        <span class="text-[10px] font-black text-[#00ED64] tracking-widest">+12%</span>
                    </div>
                    <div class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-500 mb-2">Total Impressions</div>
                    <div class="text-4xl font-black text-white">$0.00</div>
                </div>

                <div class="atlas-card-premium premium-glass p-10">
                    <div class="flex justify-between items-start mb-8">
                        <div class="w-14 h-14 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-400 border border-blue-500/20">
                            <i class="fas fa-users-viewfinder text-xl"></i>
                        </div>
                        <span class="text-[10px] font-black text-blue-400 tracking-widest">Active Pool</span>
                    </div>
                    <div class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-500 mb-2">Total Students</div>
                    <div class="text-4xl font-black text-white"><%= totalStudents %></div>
                </div>

                <div class="atlas-card-premium premium-glass p-10">
                    <div class="flex justify-between items-start mb-8">
                        <div class="w-14 h-14 bg-purple-500/10 rounded-2xl flex items-center justify-center text-purple-400 border border-purple-500/20">
                            <i class="fas fa-cube text-xl"></i>
                        </div>
                        <span class="text-[10px] font-black text-purple-400 tracking-widest">Deployed</span>
                    </div>
                    <div class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-500 mb-2">Active Sections</div>
                    <div class="text-4xl font-black text-white"><%= totalCourses %></div>
                </div>

                <div class="atlas-card-premium premium-glass p-10">
                    <div class="flex justify-between items-start mb-8">
                        <div class="w-14 h-14 bg-amber-500/10 rounded-2xl flex items-center justify-center text-amber-500 border border-amber-500/20">
                            <i class="fas fa-star text-xl"></i>
                        </div>
                        <span class="text-[10px] font-black text-amber-400 tracking-widest">Elite Rank</span>
                    </div>
                    <div class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-500 mb-2">Instructor Rating</div>
                    <div class="text-4xl font-black text-white">4.8 <span class="text-lg opacity-20">/ 5</span></div>
                </div>
            </div>

            <!-- Curriculum Intelligence -->
            <section class="premium-glass rounded-[40px] overflow-hidden shadow-3xl">
                <div class="p-10 border-b border-white/5 flex flex-col md:flex-row justify-between items-center bg-white/5">
                    <div>
                        <h3 class="text-2xl font-black text-white tracking-tighter">Curriculum Architecture</h3>
                        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#00ED64]/60 mt-2">Active Learning Nodes</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="relative">
                            <input type="text" placeholder="Search manifest..." class="pl-12 pr-6 py-4 bg-[#001E2B]/60 border border-white/10 rounded-2xl text-xs font-bold w-72 focus:ring-1 focus:ring-[#00ED64] outline-none transition-all">
                            <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-[10px] text-gray-500"></i>
                        </div>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="bg-white/2 overflow-hidden">
                                <th class="px-10 py-6 text-[9px] font-black text-gray-500 uppercase tracking-widest">Blueprint Designation</th>
                                <th class="px-10 py-6 text-[9px] font-black text-gray-500 uppercase tracking-widest">Enrollment Delta</th>
                                <th class="px-10 py-6 text-[9px] font-black text-gray-500 uppercase tracking-widest">Health Status</th>
                                <th class="px-10 py-6 text-right text-[9px] font-black text-gray-500 uppercase tracking-widest">Control</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            <% if (courses && courses.length > 0) { %>
                                <% courses.forEach(course => { %>
                                    <tr class="row-atlas group cursor-pointer" onclick="window.location.href='/teacher/course-editor/<%= course.id %>'">
                                        <td class="px-10 py-8">
                                            <div class="flex items-center gap-6">
                                                <div class="w-14 h-14 bg-gradient-to-br from-[#00ED64] to-[#00684A] rounded-2xl flex items-center justify-center text-[#001E2B] font-black text-xl shadow-lg">
                                                    <%= (course.title || course.name || 'C').charAt(0).toUpperCase() %>
                                                </div>
                                                <div>
                                                    <p class="text-xl font-black text-white tracking-tight group-hover:text-[#00ED64] transition-colors"><%= course.title || course.name %></p>
                                                    <p class="text-[10px] text-gray-500 font-black uppercase tracking-widest mt-1 opacity-60">ID: <%= (course.id || '').substring(0,8).toUpperCase() %></p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-10 py-8">
                                            <div class="flex flex-col">
                                                <span class="text-xl font-black text-white tracking-tight"><%= course.enrollments %></span>
                                                <span class="text-[9px] font-black text-gray-500 uppercase tracking-[0.2em] mt-1">Active Syncs</span>
                                            </div>
                                        </td>
                                        <td class="px-10 py-8">
                                            <div class="flex items-center gap-3">
                                                <span class="w-2 h-2 rounded-full <%= course.isPublished ? 'bg-[#00ED64] animate-pulse' : 'bg-gray-600' %>"></span>
                                                <span class="text-[10px] font-black uppercase tracking-widest <%= course.isPublished ? 'text-[#00ED64]' : 'text-gray-500' %>">
                                                    <%= course.isPublished ? 'PRODUCTION' : 'STAGING' %>
                                                </span>
                                            </div>
                                        </td>
                                        <td class="px-10 py-8 text-right">
                                            <button class="px-6 py-3 bg-white/5 border border-white/5 rounded-xl text-[9px] font-black uppercase tracking-widest hover:border-[#00ED64]/30 hover:text-[#00ED64] transition-all">
                                                Modify Node →
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="px-10 py-32 text-center">
                                        <div class="flex flex-col items-center gap-6 opacity-20">
                                            <i class="fas fa-layer-group text-5xl"></i>
                                            <p class="text-[10px] font-black uppercase tracking-[0.4em]">No Curriculum Nodes Deployed</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>
</body>
</html>