<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= courseName %> - Multitouch Academy</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Euclid Circular A', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #fbfbfd;
            color: #1d1d1f;
            line-height: 1.5;
            font-weight: 400;
            letter-spacing: -0.01em;
        }
        
        .dark body {
            background: #001E2B;
            color: #E7EEEB;
        }
        
        .container {
            max-width: 1080px;
            margin: 0 auto;
            padding: 60px 24px;
        }
        
        .course-header {
            text-align: center;
            margin-bottom: 24px;
        }
        
        .course-title {
            font-size: 32px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #1d1d1f;
            letter-spacing: -0.03em;
            line-height: 1.1;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }
        
        .dark .course-title {
            color: #E7EEEB;
        }
        
        .course-subtitle {
            font-size: 19px;
            color: #6e6e73;
            margin-bottom: 20px;
            font-weight: 500;
        }
        
        .course-actions {
            display: flex;
            justify-content: center;
            margin-bottom: 24px;
        }
        
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 980px;
            font-size: 17px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.15s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            min-height: 44px;
        }
        
        .btn-primary {
            background: linear-gradient(to right, #00ED64, #00C152);
            color: #001E2B;
            font-weight: 700;
        }
        
        .btn-primary:hover {
            box-shadow: 0 0 20px rgba(0, 237, 100, 0.3);
            transform: scale(1.02);
        }
        
        .progress-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-radius: 12px;
            padding: 16px 20px;
            border: 0.5px solid rgba(0, 0, 0, 0.04);
            margin-bottom: 32px;
        }
        
        .dark .progress-card {
            background: rgba(2, 52, 48, 0.8);
            border: 0.5px solid rgba(0, 237, 100, 0.2);
        }
        
        .progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }
        
        .progress-title {
            font-size: 15px;
            font-weight: 600;
            color: #1d1d1f;
        }
        
        .dark .progress-title {
            color: #00ED64;
        }
        
        .progress-stats {
            font-size: 13px;
            font-weight: 500;
            color: #6e6e73;
        }
        
        .progress-bar {
            width: 100%;
            height: 4px;
            background: #f2f2f7;
            border-radius: 2px;
            overflow: hidden;
        }
        
        .dark .progress-bar {
            background: #2c2c2e;
        }
        
        .progress-fill {
            height: 100%;
            background: #00ED64;
            border-radius: 2px;
            transition: width 0.4s ease;
        }
        
        .section-title {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 32px;
            color: #1d1d1f;
            letter-spacing: -0.02em;
        }
        
        .dark .section-title {
            color: #f5f5f7;
        }
        
        .chapter-section {
            margin-bottom: 48px;
        }
        
        .chapter-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 20px;
            color: #1d1d1f;
            letter-spacing: -0.01em;
        }
        
        .dark .chapter-title {
            color: #f5f5f7;
        }
        
        .videos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        
        .video-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            border-radius: 16px;
            overflow: hidden;
            border: 0.5px solid rgba(0, 0, 0, 0.04);
            transition: all 0.2s ease;
        }
        
        .dark .video-card {
            background: rgba(28, 28, 30, 0.7);
            border: 0.5px solid rgba(255, 255, 255, 0.1);
        }
        
        .video-card:hover {
            transform: translateY(-4px);
            border-color: rgba(0, 237, 100, 0.3);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }
        
        .video-thumbnail {
            position: relative;
            width: 100%;
            height: 160px;
            background: linear-gradient(135deg, #001E2B 0%, #00684A 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }
        
        .video-thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .video-placeholder {
            text-align: center;
        }
        
        .video-placeholder-icon {
            font-size: 32px;
            margin-bottom: 4px;
            opacity: 0.9;
        }
        
        .video-placeholder-text {
            font-size: 13px;
            font-weight: 500;
            opacity: 0.8;
        }
        
        .video-badges {
            position: absolute;
            top: 12px;
            left: 12px;
            right: 12px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        
        .lesson-badge {
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(10px);
            color: white;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 500;
        }
        
        .watched-badge {
            background: #00ED64;
            color: #001E2B;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
        }
        
        .video-content {
            padding: 20px;
        }
        
        .video-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 16px;
            color: #1d1d1f;
            display: flex;
            align-items: center;
            gap: 6px;
            line-height: 1.3;
        }
        
        .dark .video-title {
            color: #f5f5f7;
        }
        
        .btn-watch {
            width: 100%;
            background: linear-gradient(to right, #00ED64, #00C152);
            color: #001E2B;
            font-weight: 700;
            justify-content: center;
        }
        
        .btn-watch:hover {
            box-shadow: 0 0 15px rgba(0, 237, 100, 0.2);
        }
        
        .btn-locked {
            width: 100%;
            background: #8e8e93;
            color: white;
            justify-content: center;
            cursor: not-allowed;
            opacity: 0.6;
        }
        
        .btn-locked:hover {
            transform: none;
        }
        
        .btn-pdf {
            width: 100%;
            background: #ff3b30;
            color: white;
            justify-content: center;
        }
        
        .btn-pdf:hover {
            background: #d70015;
        }
        
        .error-state {
            text-align: center;
            padding: 60px 20px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            border: 0.5px solid rgba(0, 0, 0, 0.04);
        }
        
        .dark .error-state {
            background: rgba(28, 28, 30, 0.8);
            border: 0.5px solid rgba(255, 255, 255, 0.1);
        }
        
        .error-icon {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.8;
        }
        
        .error-title {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #1d1d1f;
        }
        
        .dark .error-title {
            color: #00ED64;
        }
        
        .error-message {
            color: #6e6e73;
            font-size: 15px;
        }
        
        .theme-toggle {
            position: fixed;
            top: 20px;
            right: 20px;
            width: 40px;
            height: 40px;
            border: none;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border: 0.5px solid rgba(0, 0, 0, 0.04);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            transition: all 0.15s ease;
            z-index: 1000;
        }
        
        .dark .theme-toggle {
            background: rgba(28, 28, 30, 0.8);
            border: 0.5px solid rgba(255, 255, 255, 0.1);
        }
        
        .theme-toggle:hover {
            transform: scale(1.05);
        }
        
        @media (max-width: 768px) {
            .container {
                padding: 40px 20px;
            }
            
            .course-title {
                font-size: 36px;
            }
            
            .videos-grid {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            
            .video-content {
                padding: 16px;
            }
        }
    </style>
</head>
<body class="dark:bg-[#001E2B]">
    <%- include('partials/header', { title: courseName + ' - Multitouch Academy', activePage: 'courses' }) %>
    
    <div class="container" style="margin-top: 40px;">
        <div class="course-header animate-slide-up" style="text-align: left; max-width: 800px;">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 20px;">
                <span class="badge badge-green">Premium Course</span>
                <span class="badge badge-blue">Verified Content</span>
            </div>
            <h1 class="course-title dark:text-[#E7EEEB]" style="font-size: 48px; letter-spacing: -0.03em;"><%= courseName %></h1>
            <p class="course-subtitle dark:text-[#9FB1AD]" style="font-size: 20px; line-height: 1.4; margin-top: 16px;">Master state-of-the-art engineering patterns with the Multitouch Academy curriculum.</p>
            
            <div style="display: flex; gap: 24px; margin: 32px 0; font-size: 14px; opacity: 0.8;" class="dark:text-[#9FB1AD]">
                <span class="flex items-center gap-2">👤 <strong>Engineer Felex</strong></span>
                <span class="flex items-center gap-2">📅 Updated March 2026</span>
                <span class="flex items-center gap-2">🌐 Global Access</span>
            </div>

            <div class="course-actions" style="justify-content: flex-start;">
                <% if (typeof isEnrolled !== 'undefined' && isEnrolled) { %>
                <a href="/course/<%= courseName %>/video/start" class="btn btn-primary" style="padding: 14px 40px; font-size: 16px; border-radius: 12px; background: #00684A; color: #fff;">
                    Continue Learning
                </a>
                <% } else { %>
                <button id="enrollBtn" class="btn btn-primary" style="padding: 14px 40px; font-size: 16px; border-radius: 12px;">
                    Enroll Now
                </button>
                <button id="wishlistBtn" class="btn btn-secondary" style="padding: 14px 24px; font-size: 16px; border-radius: 12px; margin-left: 12px;">
                    Add to Wishlist
                </button>
                <% } %>
            </div>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 350px; gap: 48px; margin-top: 64px;">
            <div class="course-main-info">
                <% if (typeof watchedVideos !== 'undefined' && watchedVideos > 0) { %>
                <div class="progress-card" style="margin-bottom: 48px;">
                    <div class="progress-header">
                        <span class="progress-title">Continue Learning</span>
                        <span class="progress-stats"><%= watchedVideos %>/<%= totalVideos %> lectures completed</span>
                    </div>
                    <div class="progress-bar">
                        <div id="courseProgressFill" class="progress-fill" style="width: 0%;"></div>
                    </div>
                </div>
                <% } %>
                <h2 class="section-title">Course Content</h2>
                <div class="curriculum-accordion bg-white dark:bg-[#001E2B] dark:border-[#133A41]" style="border: 1px solid rgba(0,237,100,0.2); border-radius: 12px; overflow: hidden;">
                    <% if (typeof sections !== 'undefined' && sections.length > 0) { %>
                        <% sections.forEach((section, sIndex) => { %>
                            <div class="curriculum-section border-b border-gray-100 dark:border-[#133A41] last:border-0">
                                <div class="section-header cursor-pointer flex justify-between items-center transition-colors hover:bg-gray-50 dark:hover:bg-[#023430] bg-gray-50 dark:bg-[#001E2B] dark:text-[#F9FBFA]" 
                                     onclick="toggleSection(this)"
                                     style="padding: 16px 24px; font-size: 15px;">
                                    <div class="flex items-center gap-3">
                                        <span class="toggle-icon transition-transform duration-200 dark:text-[#00ED64]">▶</span>
                                        <strong class="dark:text-[#F9FBFA] text-[#1d1d1f]">Section <%= sIndex + 1 %>: <%= section.title %></strong>
                                    </div>
                                    <span class="text-xs opacity-60 dark:text-[#9FB1AD] text-[#6e6e73]"><%= section.lectures.length %> Lectures</span>
                                </div>
                                <div class="section-lectures" style="display:none;">
                                    <% section.lectures.forEach((lecture, lIndex) => { %>
                                        <div class="lecture-row hover:bg-gray-50 dark:hover:bg-[#023430]/30 transition-colors dark:border-[#133A41]" 
                                             style="padding: 12px 24px 12px 48px; border-bottom: 1px solid rgba(0,237,100,0.1); display: flex; justify-content: space-between; align-items: center;">
                                            <div style="display: flex; align-items: center; gap: 12px;">
                                                <span class="text-lg opacity-70 dark:text-[#00ED64]"><%= lecture.type === 'video' ? '📺' : '📄' %></span>
                                                <a href="/course/<%= courseName %>/video/<%= lecture.contentId %>" 
                                                   class="lecture-link text-sm font-medium hover:text-[#00ED64] dark:text-[#F9FBFA]" 
                                                   data-content-id="<%= lecture.contentId %>" 
                                                   style="color: inherit; text-decoration: none;">
                                                    <%= lIndex + 1 %>. <%= lecture.title %>
                                                </a>
                                            </div>
                                            <span class="text-[11px] opacity-50 font-mono dark:text-[#9FB1AD]"><%= Math.floor((lecture.duration || 0) / 60) %>:00</span>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div style="padding: 24px; text-align: center; color: #6e6e73;">
                            <p>Curriculum is being updated. Individual videos are available below.</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <aside class="course-sidebar">
                <div id="sidebar-enrollment-card" class="card bg-white dark:bg-[#023430] dark:border-[#133A41]" style="position: sticky; top: 24px; border: 1px solid rgba(0,0,0,0.05); border-radius: 12px; overflow: hidden; <%= (typeof isEnrolled !== 'undefined' && isEnrolled) ? 'display:none;' : '' %>">
                    <div style="width: 100%; aspect-ratio: 16/9; background: #001E2B; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 48px;">
                        📽️
                    </div>
                    <div class="card-body" style="padding: 24px;">
                        <div style="font-size: 32px; font-weight: 800; margin-bottom: 16px;" class="dark:text-[#E7EEEB]">Free <span style="font-size: 16px; text-decoration: line-through; opacity: 0.5;">$94.99</span></div>
                        <button id="enrollBtnSidebar" onclick="enroll()" class="btn btn-primary" style="margin-bottom: 12px; height: 48px; width: 100%; justify-content: center;">Enroll Now</button>
                        <button id="wishlistBtnSidebar" onclick="addToWishlist()" class="btn border border-gray-200 dark:border-[#133A41] dark:text-[#E7EEEB]" style="height: 48px; width: 100%; justify-content: center;">Add to Wishlist</button>
                        
                        <div style="margin-top: 24px;">
                            <h4 style="font-size: 14px; margin-bottom: 12px;" class="dark:text-[#E7EEEB]">This course includes:</h4>
                            <ul style="list-style: none; padding: 0; font-size: 13px; display: flex; flex-direction: column; gap: 8px; opacity: 0.8;" class="dark:text-[#9FB1AD]">
                                <li>🎥 <%= (typeof totalVideos !== 'undefined' ? totalVideos : 0) %> On-demand videos</li>
                                <li>📄 Downloadable resources</li>
                                <li>📱 Access on mobile and TV</li>
                                <li>🏆 Certificate of completion</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>
    <!-- Data for JS -->
    <input type="hidden" id="course_id_data" value="<%= typeof courseId !== 'undefined' ? courseId : '' %>">
    <input type="hidden" id="watched_percent_data" value="<%= typeof watchedPercent !== 'undefined' ? watchedPercent : 0 %>">
    <input type="hidden" id="is_admin_data" value="<%= typeof isAdmin !== 'undefined' ? isAdmin : 'false' %>">
    <input type="hidden" id="course_name_data" value="<%= courseName %>">

    <script>
        // Theme management
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        
        function toggleTheme() {
            const isDark = document.documentElement.classList.contains('dark');
            const newTheme = isDark ? 'light' : 'dark';
            document.documentElement.classList.toggle('dark', newTheme === 'dark');
            localStorage.setItem('theme', newTheme);
        }
        
        initTheme();

        let isEnrolled = false;
        let isAdmin = false;

        document.addEventListener('DOMContentLoaded', () => {
            const savedUser = localStorage.getItem('user');
            if (savedUser) {
                const user = JSON.parse(savedUser);
                isAdmin = user.email === 'engineerfelex@gmail.com' || user.isAdmin;
            }
            
            checkEnrollmentStatus();
            
            // Open first section by default
            const firstSection = document.querySelector('.section-header');
            if (firstSection) toggleSection(firstSection);
        });

        function toggleSection(header) {
            const lectures = header.nextElementSibling;
            if (!lectures) return;
            const icon = header.querySelector('.toggle-icon');
            const isHidden = lectures.style.display === 'none' || lectures.style.display === '';
            
            if (isHidden) {
                lectures.style.display = 'block';
                if (icon) icon.style.transform = 'rotate(90deg)';
                header.style.background = 'rgba(0,237,100,0.05)';
            } else {
                lectures.style.display = 'none';
                if (icon) icon.style.transform = 'rotate(0deg)';
                header.style.background = '';
            }
        }

        async function checkEnrollmentStatus() {
            try {
                const token = localStorage.getItem('accessToken');
                const courseName = '<%= courseName %>';
                
                const response = await fetch(`/api/enrollments/check/${encodeURIComponent(courseName)}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                const data = await response.json();
                if (data.success && data.data.enrolled) {
                    isEnrolled = true;
                    // Hide the entire enrollment sidebar card
                    const card = document.getElementById('sidebar-enrollment-card');
                    if (card) card.style.display = 'none';
                    // Also hide the inline CTA buttons
                    if (document.getElementById('enrollBtn')) document.getElementById('enrollBtn').style.display = 'none';
                    if (document.getElementById('wishlistBtn')) document.getElementById('wishlistBtn').style.display = 'none';
                }
                
                applyDynamicStates();
            } catch (error) {
                console.error('Error checking enrollment:', error);
                applyDynamicStates();
            }
        }

        function applyDynamicStates() {
            const watchedPercent = parseInt(document.getElementById('watched_percent_data').value || '0');
            const progressFill = document.getElementById('courseProgressFill');
            if (progressFill) progressFill.style.width = watchedPercent + '%';

            const lectureLinks = document.querySelectorAll('.lecture-link');
            lectureLinks.forEach(link => {
                if (!isAdmin && !isEnrolled) {
                    link.style.pointerEvents = 'none';
                    link.style.opacity = '0.6';
                    link.parentElement.style.cursor = 'not-allowed';
                } else {
                    link.style.pointerEvents = 'auto';
                    link.style.opacity = '1';
                    link.style.color = '#00ED64';
                    link.parentElement.style.cursor = 'pointer';
                }
            });
        }

        async function enroll() {
            if (isEnrolled) return;
            const token = localStorage.getItem('accessToken');
            const courseIdVal = document.getElementById('course_id_data').value;
            const courseNameVal = document.getElementById('course_name_data').value;
            const targetId = courseIdVal || courseNameVal;
            
            if (!token) {
                window.location.href = '/login';
                return;
            }

            try {
                const response = await fetch('/api/enrollments', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ courseId: targetId })
                });
                
                const data = await response.json();
                if (data.success) {
                    isEnrolled = true;
                    location.reload();
                } else {
                    alert('Failed to enroll: ' + (data.error || 'Check authentication'));
                }
            } catch (error) {
                alert('Error enrolling: ' + error.message);
            }
        }

        async function addToWishlist() {
            const token = localStorage.getItem('accessToken');
            const courseIdVal = document.getElementById('course_id_data').value;
            const courseNameVal = document.getElementById('course_name_data').value;
            const targetId = courseIdVal || courseNameVal;
            
            if (!token) {
                alert('Please login to add to wishlist');
                return;
            }

            try {
                const response = await fetch('/api/wishlist/add', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ courseId: targetId })
                });
                
                const data = await response.json();
                if (data.success) {
                    const btn = document.getElementById('wishlistBtn');
                    if (btn) {
                        btn.textContent = 'Wishlisted ✓';
                        btn.style.color = '#00ED64';
                        btn.disabled = true;
                    }
                } else {
                    alert('Wishlist failed: ' + (data.error || 'Already in wishlist?'));
                }
            } catch (error) {
                alert('Wishlist error: ' + error.message);
            }
        }

        if (document.getElementById('enrollBtn')) document.getElementById('enrollBtn').addEventListener('click', enroll);
        if (document.getElementById('enrollBtnSidebar')) document.getElementById('enrollBtnSidebar').addEventListener('click', enroll);
        if (document.getElementById('wishlistBtn')) document.getElementById('wishlistBtn').addEventListener('click', addToWishlist);
    </script>
</body>
</html>