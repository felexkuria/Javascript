<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (typeof course !== 'undefined' && course.title) ? course.title : 'Course Details' %> - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mongo-green': '#00ED64',
              'mongo-slate': '#001E2B',
              'mongo-forest': '#00684A'
            }
          }
        }
      }
    </script>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] font-sans antialiased transition-colors duration-200" style="background: var(--color-bg);">
    <!-- Dark Mode Toggle -->
    <button id="themeToggle" class="fixed top-6 right-6 p-3 glass rounded-xl shadow-2xl hover:scale-110 active:scale-95 transition-all duration-300 z-[100]">
        <span id="themeIcon" class="text-xl">🌙</span>
    </button>

    <!-- Header -->
    <header class="bg-white/70 dark:bg-[#001E2B]/70 border-b border-gray-200 dark:border-[#133A41] transition-all duration-300 sticky top-0 z-50 backdrop-blur-2xl">
        <div class="max-w-7xl mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <a href="/dashboard" class="flex items-center space-x-4 group">
                    <div class="w-10 h-10 bg-gradient-to-br from-[#00ED64] to-[#00684A] rounded-xl flex items-center justify-center shadow-lg group-hover:rotate-6 transition-transform">
                        <span class="text-[#001E2B] text-xl font-black">M</span>
                    </div>
                    <span class="text-xl font-black tracking-tighter dark:text-white">Multitouch <span class="font-light text-gray-400 dark:text-[#9FB1AD]">Academy</span></span>
                </a>
                <button id="logoutBtn" class="text-xs font-black tracking-widest text-gray-500 hover:text-red-500 transition-colors uppercase">Logout</button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-12">
        <!-- Hero Section -->
        <div class="relative mb-16 rounded-[2.5rem] overflow-hidden shadow-2xl bg-[#001E2B]">
            <div class="absolute inset-0 bg-[var(--atlas-gradient)] opacity-90"></div>
            <div class="relative p-12 md:p-20 flex flex-col md:flex-row items-center gap-12">
                <div class="flex-1">
                    <div class="inline-flex items-center gap-2 px-4 py-2 glass rounded-full mb-8">
                        <span class="w-2 h-2 rounded-full bg-[#00ED64] animate-pulse"></span>
                        <span class="text-[10px] font-bold text-[#00ED64] uppercase tracking-widest">Premium Learning Track</span>
                    </div>
                    <h1 class="text-5xl md:text-7xl font-black text-white mb-6 tracking-tighter leading-none">
                        <%= (typeof course !== 'undefined' && course.title) ? course.title : (typeof courseName !== 'undefined' ? courseName : 'Untitled Course') %>
                    </h1>
                    <p class="text-xl text-gray-400 dark:text-[#9FB1AD] max-w-2xl font-medium leading-relaxed mb-10">
                        <%= (typeof course !== 'undefined' && course.description) ? course.description : 'Master high-performance engineering with our professional-grade curriculum components.' %>
                    </p>
                    <div class="flex items-center gap-6 text-sm font-bold text-white/60">
                        <div class="flex items-center gap-2">
                             <span class="opacity-50">Instructor:</span>
                             <span class="text-[#00ED64]"><%= (typeof course !== 'undefined' && course.instructor) ? course.instructor : 'Engineer Felex' %></span>
                        </div>
                        <div class="flex items-center gap-2">
                             <span class="opacity-50">Modules:</span>
                             <span class="text-white"><%= totalVideos %> Specialized Units</span>
                        </div>
                    </div>
                </div>
                
                <!-- CTA Sidebar in Hero -->
                <div class="w-full md:w-80">
                    <div class="glass p-8 rounded-[2rem] border-white/10 shadow-3xl text-center">
                        <% if (typeof isEnrolled !== 'undefined' && isEnrolled) { %>
                            <div class="mb-6">
                                <div class="text-[10px] font-black text-[#00ED64] uppercase tracking-widest mb-2">Learning Velocity</div>
                                <div class="text-4xl font-black text-white mb-4"><%- (totalVideos > 0 ? Math.round((watchedVideos/totalVideos)*100) : 0) %>%</div>
                                <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                                    <div class="h-full bg-[#00ED64] shadow-[0_0_10px_#00ED64]" style="width: <%- (totalVideos > 0 ? (watchedVideos/totalVideos)*100 : 0) %>%"></div>
                                </div>
                            </div>
                            <button onclick="window.location.href='/course/<%= typeof courseName !== 'undefined' ? encodeURIComponent(courseName) : (typeof course !== 'undefined' ? encodeURIComponent(course.name) : '') %>/video/'" class="w-full py-4 bg-[#00ED64] text-[#001E2B] font-black rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-[#00ED64]/20">
                                RESUME MODULE
                            </button>
                        <% } else { %>
                            <div class="text-4xl font-black text-white mb-2">$99.00</div>
                            <div class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-8">One-time Professional Access</div>
                            <button id="enrollBtn" class="w-full py-4 bg-[#00ED64] text-[#001E2B] font-black rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-[#00ED64]/20 mb-4">
                                PROVISION NOW
                            </button>
                            <button id="wishlistBtn" class="w-full py-4 glass text-white font-black rounded-2xl hover:bg-white/10 transition-all border-white/5">
                                ADD TO STACK
                            </button>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <!-- Main Content -->
            <div class="lg:col-span-2 space-y-12">
                <section>
                    <div class="flex items-center gap-4 mb-10">
                        <div class="h-10 w-1.5 bg-[#00ED64] rounded-full"></div>
                        <h2 class="text-3xl font-black tracking-tight dark:text-white">Curriculum <span class="premium-title">Blueprint</span></h2>
                    </div>

                    <div class="space-y-4">
                        <% if (typeof course !== 'undefined' && course.sections && course.sections.length > 0) { %>
                            <% course.sections.forEach((section, sIndex) => { %>
                                <div class="atlas-card glass group">
                                    <div class="p-6 flex items-center justify-between cursor-pointer" onclick="toggleSection('<%= sIndex %>')">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center font-bold text-[#00ED64]">
                                                0<%= sIndex + 1 %>
                                            </div>
                                            <div>
                                                <h3 class="font-bold text-gray-900 dark:text-white"><%= section.title %></h3>
                                                <p class="text-[10px] text-gray-400 uppercase font-black tracking-widest"><%= section.lectures ? section.lectures.length : 0 %> Components</p>
                                            </div>
                                        </div>
                                        <div id="icon-<%= sIndex %>" class="text-gray-400 transition-transform duration-300">
                                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                        </div>
                                    </div>
                                    <div id="section-<%= sIndex %>" class="hidden border-t border-white/5">
                                        <% if (section.lectures && section.lectures.length > 0) { %>
                                            <% section.lectures.forEach((lecture, lIndex) => { %>
                                                <div class="p-6 hover:bg-white/5 transition-colors flex items-center gap-4 group/item">
                                                    <div class="text-xs font-black text-gray-500 opacity-30">0<%= sIndex + 1 %>.<%= lIndex + 1 %></div>
                                                    <div class="w-2 h-2 rounded-full bg-[#00ED64]/30 group-hover/item:bg-[#00ED64]"></div>
                                                    <div class="flex-1">
                                                        <span class="text-sm font-bold text-gray-700 dark:text-[#9FB1AD] group-hover/item:text-white transition-colors">
                                                            <%= lecture.title %>
                                                        </span>
                                                        <% if (lecture.type === 'pdf') { %>
                                                            <span class="ml-2 py-0.5 px-1.5 bg-blue-500/10 text-blue-400 text-[8px] font-black uppercase tracking-widest rounded border border-blue-500/20">DOCUMENT</span>
                                                        <% } %>
                                                    </div>
                                                    <% if (typeof isEnrolled !== 'undefined' && isEnrolled) { %>
                                                        <a href="/video/<%= typeof courseName !== 'undefined' ? encodeURIComponent(courseName) : encodeURIComponent(course.name) %>?lecture=<%= lecture.id %>" class="text-[10px] font-black text-[#00ED64] opacity-0 group-hover/item:opacity-100 uppercase tracking-widest">Load Asset</a>
                                                    <% } %>
                                                </div>
                                            <% }) %>
                                        <% } %>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else if (typeof course !== 'undefined' && course.videos) { %>
                            <!-- Flat version if no sections (legacy support) -->
                            <% (course.videos || []).forEach((video, vIndex) => { %>
                                <div class="atlas-card glass p-6 flex items-center justify-between group">
                                    <div class="flex items-center gap-6">
                                        <div class="text-xs font-black text-gray-500 opacity-30">0<%= vIndex + 1 %></div>
                                        <h3 class="font-bold text-gray-900 dark:text-white"><%= video.title %></h3>
                                    </div>
                                    <% if (typeof isEnrolled !== 'undefined' && isEnrolled) { %>
                                        <a href="/video/<%= typeof courseName !== 'undefined' ? encodeURIComponent(courseName) : encodeURIComponent(course.name) %>?v=<%= vIndex %>" class="text-[10px] font-black text-[#00ED64] opacity-0 group-hover:opacity-100 transition-all uppercase tracking-widest">Execute</a>
                                    <% } %>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                </section>
            </div>

            <!-- Sidebar -->
            <div class="space-y-8">
                <div class="atlas-card glass p-8">
                    <h4 class="text-xs font-black tracking-widest uppercase mb-6 text-[#9FB1AD]">Learning Stack</h4>
                    <ul class="space-y-6">
                        <li class="flex items-center gap-4">
                            <div class="w-8 h-8 rounded-lg bg-[#00ED64]/10 flex items-center justify-center text-[#00ED64]">
                                <i class="fas fa-video text-sm"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-700 dark:text-white"><%= totalVideos %> Specialized Modules</span>
                        </li>
                        <li class="flex items-center gap-4">
                            <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400">
                                <i class="fas fa-infinity text-sm"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-700 dark:text-white">LIFETIME INFRASTRUCTURE ACCESS</span>
                        </li>
                        <li class="flex items-center gap-4">
                            <div class="w-8 h-8 rounded-lg bg-orange-500/10 flex items-center justify-center text-orange-400">
                                <i class="fas fa-certificate text-sm"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-700 dark:text-white">VERIFIED SECTOR CERTIFICATE</span>
                        </li>
                    </ul>
                </div>

                <div class="atlas-card glass p-8 bg-gradient-to-br from-[#00ED64]/5 to-transparent">
                    <h4 class="text-xs font-black tracking-widest uppercase mb-4 text-[#00ED64]">Course Governance</h4>
                    <p class="text-xs text-gray-500 dark:text-[#9FB1AD] font-medium leading-relaxed mb-6">
                        This content is provisioned by the Multitouch Academy Engineering Council. All labs are periodically synced with industry benchmarks.
                    </p>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-[#001E2B] border border-white/10 flex items-center justify-center text-[#00ED64] font-black text-xs">M</div>
                        <div>
                             <p class="text-[10px] font-black dark:text-white">COUNCIL VERIFIED</p>
                             <p class="text-[8px] font-bold text-[#9FB1AD] uppercase">ID: MTA-992-PX</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        function toggleSection(id) {
            const section = document.getElementById(`section-${id}`);
            const icon = document.getElementById(`icon-${id}`);
            if (section) section.classList.toggle('hidden');
            if (icon) icon.classList.toggle('rotate-180');
        }

        async function enroll() {
            const courseName = '<%= typeof courseName !== 'undefined' ? courseName : (typeof course !== 'undefined' ? course.name : '') %>';
            const btn = document.getElementById('enrollBtn');
            try {
                const token = localStorage.getItem('accessToken');
                if (!token) { window.location.href = '/login'; return; }
                
                if (btn) {
                    btn.disabled = true;
                    btn.textContent = 'PROVISIONING...';
                }
                
                const response = await fetch('/api/enrollments', {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ courseName })
                });
                const data = await response.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    alert('Provisioning failed: ' + (data.error || 'Unknown error'));
                    if (btn) {
                        btn.disabled = false;
                        btn.textContent = 'PROVISION NOW';
                    }
                }
            } catch (err) {
                console.error(err);
                alert('An error occurred during provisioning.');
                if (btn) {
                    btn.disabled = false;
                    btn.textContent = 'PROVISION NOW';
                }
            }
        }

        async function addToWishlist() {
            const courseName = '<%= typeof courseName !== 'undefined' ? courseName : (typeof course !== 'undefined' ? course.name : '') %>';
            const btn = document.getElementById('wishlistBtn');
            try {
                const token = localStorage.getItem('accessToken');
                if (!token) { window.location.href = '/login'; return; }
                
                const response = await fetch('/api/wishlist', {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ courseName })
                });
                const data = await response.json();
                if (data.success) {
                    if (btn) {
                        btn.textContent = 'ADDED TO STACK ✓';
                        btn.classList.add('text-[#00ED64]');
                        setTimeout(() => {
                            btn.textContent = 'ADD TO STACK';
                            btn.classList.remove('text-[#00ED64]');
                        }, 3000);
                    } else {
                        alert('Added to stack!');
                    }
                } else {
                    alert('Stack update failed: ' + (data.error || 'Already in stack?'));
                }
            } catch (error) {
                alert('Stack update error: ' + error.message);
            }
        }

        function initTheme() {
            const theme = localStorage.getItem("theme") || "light";
            document.documentElement.classList.toggle("dark", theme === "dark");
            const themeIcon = document.getElementById('themeIcon');
            if (themeIcon) themeIcon.textContent = theme === "dark" ? '☀️' : '🌙';
        }
        
        function toggleTheme() {
            const newTheme = document.documentElement.classList.contains("dark") ? "light" : "dark";
            document.documentElement.classList.toggle("dark", newTheme === "dark");
            localStorage.setItem("theme", newTheme);
            const themeIcon = document.getElementById('themeIcon');
            if (themeIcon) themeIcon.textContent = newTheme === "dark" ? '☀️' : '🌙';
        }

        const themeToggle = document.getElementById('themeToggle');
        if (themeToggle) themeToggle.onclick = toggleTheme;
        
        const enrollBtn = document.getElementById('enrollBtn');
        if (enrollBtn) enrollBtn.onclick = enroll;
        
        const wishlistBtn = document.getElementById('wishlistBtn');
        if (wishlistBtn) wishlistBtn.onclick = addToWishlist;
        
        const logoutBtn = document.getElementById('logoutBtn');
        if (logoutBtn) logoutBtn.onclick = () => {
            localStorage.clear();
            window.location.href = '/login';
        };

        initTheme();
    </script>
</body>
</html>