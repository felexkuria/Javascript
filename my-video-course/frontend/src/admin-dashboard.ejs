<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .instructor-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            min-height: 100vh;
            background: var(--color-bg);
        }

        .instructor-main {
            padding: var(--space-8);
            background: var(--color-bg);
            overflow-y: auto;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-6);
            margin-bottom: var(--space-10);
        }

        .stat-card {
            background: var(--color-surface);
            padding: var(--space-8);
            border-radius: var(--radius-2xl);
            border: 1px solid var(--color-border);
            box-shadow: var(--shadow-sm);
            text-align: center;
        }

        .stat-value {
            font-size: 40px;
            font-weight: 800;
            color: var(--mdb-green);
            margin-bottom: 4px;
        }

        .stat-label {
            font-size: 14px;
            font-weight: 600;
            color: var(--color-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .action-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: var(--space-6);
            margin-bottom: var(--space-10);
        }

        .action-card {
            background: var(--mdb-midnight);
            color: #fff;
            padding: var(--space-8);
            border-radius: var(--radius-xl);
            text-decoration: none;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            gap: 12px;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .action-card:hover {
            transform: translateY(-4px);
            border-color: var(--mdb-green);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .action-icon {
            font-size: 28px;
            color: var(--mdb-green);
        }

        .recent-section {
            background: var(--color-surface);
            border-radius: var(--radius-2xl);
            border: 1px solid var(--color-border);
            padding: var(--space-8);
        }
        
        .course-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid var(--color-border);
        }
        .course-row:last-child { border-bottom: none; }
    </style>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
    <div class="instructor-layout">
        <%- include('partials/instructor-sidebar', { activePage: 'dashboard' }) %>

        <main class="instructor-main">
            <header style="margin-bottom: var(--space-10);">
                <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--mdb-green); letter-spacing: 0.15em;">Administrative Command</span>
                <h1 style="font-size: 40px; font-weight: 800; letter-spacing: -0.04em; margin-top: 4px;">Platform Overview</h1>
            </header>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-value"><%= stats.totalCourses %></div>
                    <div class="stat-label">Courses Deployed</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= stats.totalVideos %></div>
                    <div class="stat-label">Total Assets</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= stats.totalStudents %></div>
                    <div class="stat-label">Active Learners</div>
                </div>
            </div>

            <div class="action-grid">
                <a href="/admin/course-manager" class="action-card">
                    <div class="action-icon"><i class="fas fa-layer-group"></i></div>
                    <div style="font-size: 18px; font-weight: 700;">Curriculum Manager</div>
                    <p style="font-size: 13px; opacity: 0.6;">Deploy new courses and manage existing content hierarchy.</p>
                </a>
                <a href="/admin/teacher-requests" class="action-card">
                    <div class="action-icon"><i class="fas fa-user-check"></i></div>
                    <div style="font-size: 18px; font-weight: 700;">Teacher Requests</div>
                    <p style="font-size: 13px; opacity: 0.6;">Review and approve new instructor applications.</p>
                </a>
                <a href="/teacher/upload-center" class="action-card">
                    <div class="action-icon"><i class="fas fa-satellite-dish"></i></div>
                    <div style="font-size: 18px; font-weight: 700;">Global Upload Center</div>
                    <p style="font-size: 13px; opacity: 0.6;">Access CLI tools and web uploader for bulk asset ingest.</p>
                </a>
            </div>

            <div class="recent-section">
                <h3 style="font-size: 20px; font-weight: 700; margin-bottom: 24px;">Recent Deployments</h3>
                <% if (courses && courses.length > 0) { %>
                    <% courses.slice(0, 5).forEach(course => { %>
                        <div class="course-row">
                            <div>
                                <div style="font-weight: 700; font-size: 15px;"><%= course.title || course.name %></div>
                                <div style="font-size: 13px; color: var(--color-text-muted);"><%= course.category || 'Engineering' %> • <%= course.videos ? course.videos.length : 0 %> Lessons</div>
                            </div>
                            <a href="/course/<%= encodeURIComponent(course.name) %>" class="btn btn-secondary" style="font-size: 12px; padding: 8px 16px;">View Site</a>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="color: var(--color-text-muted); text-align: center; padding: 40px;">No recent courses found.</p>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        initTheme();
    </script>
</body>
</html>