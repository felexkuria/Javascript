<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Platform Governance - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mongo-green': '#00ED64',
              'mongo-slate': '#001E2B',
              'mongo-forest': '#00684A'
            }
          }
        }
      }
    </script>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] font-sans antialiased transition-colors duration-200" style="background: var(--color-bg);">
    <div class="flex min-h-screen">
        <%- include('partials/instructor-sidebar', { activePage: 'dashboard' }) %>

        <main class="flex-1 p-8 md:p-12 overflow-y-auto">
            <!-- Header -->
            <header class="flex flex-col md:flex-row md:items-center justify-between gap-8 mb-16">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <span class="w-2 h-2 rounded-full bg-[#00ED64] animate-pulse"></span>
                        <span class="text-[10px] font-black text-[#00ED64] uppercase tracking-widest leading-none">Administrative Node: Active</span>
                    </div>
                    <h1 class="text-4xl md:text-5xl font-black tracking-tighter dark:text-white leading-none">Platform <span class="premium-title">Orchestration</span></h1>
                </div>
                <!-- Theme Toggle -->
                <button id="themeToggle" class="p-3 glass rounded-xl shadow-2xl hover:scale-110 active:scale-95 transition-all duration-300">
                    <span id="themeIcon" class="text-xl">🌙</span>
                </button>
            </header>

            <!-- Stats Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
                <div class="atlas-card glass p-8 group">
                    <div class="flex items-center justify-between mb-6">
                        <p class="text-[10px] font-black text-gray-500 dark:text-[#9FB1AD] uppercase tracking-widest">Deployed Clusters</p>
                        <i class="fas fa-layer-group text-[#00ED64] opacity-30 group-hover:opacity-100 transition-opacity"></i>
                    </div>
                    <div class="text-5xl font-black text-gray-900 dark:text-white group-hover:scale-105 transition-transform origin-left">
                        <%= stats.totalCourses %>
                    </div>
                    <div class="mt-4 flex items-center gap-2 text-[10px] font-bold text-gray-400">
                        <span class="text-[#00ED64]">+2 this week</span>
                        <span>• Stability: 99.9%</span>
                    </div>
                </div>
                
                <div class="atlas-card glass p-8 group">
                    <div class="flex items-center justify-between mb-6">
                        <p class="text-[10px] font-black text-gray-500 dark:text-[#9FB1AD] uppercase tracking-widest">Asset Registry</p>
                        <i class="fas fa-database text-[#00ED64] opacity-30 group-hover:opacity-100 transition-opacity"></i>
                    </div>
                    <div class="text-5xl font-black text-gray-900 dark:text-white group-hover:scale-105 transition-transform origin-left">
                        <%= stats.totalVideos %>
                    </div>
                    <div class="mt-4 flex items-center gap-2 text-[10px] font-bold text-gray-400">
                        <span class="text-[#00ED64]"><%= Math.round(stats.totalVideos/stats.totalCourses) %> avg/repo</span>
                        <span>• Verified: All</span>
                    </div>
                </div>

                <div class="atlas-card glass p-8 group">
                    <div class="flex items-center justify-between mb-6">
                        <p class="text-[10px] font-black text-gray-500 dark:text-[#9FB1AD] uppercase tracking-widest">Active Engineers</p>
                        <i class="fas fa-users text-[#00ED64] opacity-30 group-hover:opacity-100 transition-opacity"></i>
                    </div>
                    <div class="text-5xl font-black text-gray-900 dark:text-white group-hover:scale-105 transition-transform origin-left">
                        <%= stats.totalStudents %>
                    </div>
                    <div class="mt-4 flex items-center gap-2 text-[10px] font-bold text-gray-400">
                        <span class="text-blue-400">+12% growth</span>
                        <span>• Global Rank: Tier 1</span>
                    </div>
                </div>
            </div>

            <!-- Action Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
                <a href="/admin/course-manager" class="atlas-card glass p-8 group hover:-translate-y-2 transition-all border-white/5 active:scale-95">
                    <div class="w-14 h-14 bg-gradient-to-br from-[#00ED64]/20 to-[#00684A]/20 rounded-2xl flex items-center justify-center mb-8 border border-[#00ED64]/10">
                        <i class="fas fa-terminal text-[#00ED64] text-xl"></i>
                    </div>
                    <h3 class="text-xl font-black mb-3 dark:text-white group-hover:text-[#00ED64] transition-colors">Curriculum Architect</h3>
                    <p class="text-sm text-gray-500 dark:text-[#9FB1AD] font-medium leading-relaxed">
                        Design course hierarchies, provision new repositories, and manage asset distribution scale.
                    </p>
                </a>
                
                <a href="/admin/teacher-requests" class="atlas-card glass p-8 group hover:-translate-y-2 transition-all border-white/5 active:scale-95">
                    <div class="w-14 h-14 bg-gradient-to-br from-blue-500/20 to-blue-900/20 rounded-2xl flex items-center justify-center mb-8 border border-blue-500/10">
                        <i class="fas fa-fingerprint text-blue-400 text-xl"></i>
                    </div>
                    <h3 class="text-xl font-black mb-3 dark:text-white group-hover:text-blue-400 transition-colors">Governance Queue</h3>
                    <p class="text-sm text-gray-500 dark:text-[#9FB1AD] font-medium leading-relaxed">
                        Authorize instructor credentials, verify engineering requests, and audit platform access logs.
                    </p>
                </a>

                <a href="/teacher/upload-center" class="atlas-card glass p-8 group hover:-translate-y-2 transition-all border-white/5 active:scale-95">
                    <div class="w-14 h-14 bg-gradient-to-br from-purple-500/20 to-purple-900/20 rounded-2xl flex items-center justify-center mb-8 border border-purple-500/10">
                        <i class="fas fa-satellite-dish text-purple-400 text-xl"></i>
                    </div>
                    <h3 class="text-xl font-black mb-3 dark:text-white group-hover:text-purple-400 transition-colors">Ingest Center</h3>
                    <p class="text-sm text-gray-500 dark:text-[#9FB1AD] font-medium leading-relaxed">
                        High-bandwidth asset synchronization, CLI-driven uploads, and real-time processing analytics.
                    </p>
                </a>
            </div>

            <!-- Recent Deployments -->
            <section class="atlas-card glass p-10">
                <div class="flex items-center justify-between mb-10">
                    <div class="flex items-center gap-4">
                        <div class="h-8 w-1.5 bg-[#00ED64] rounded-full"></div>
                        <h2 class="text-2xl font-black tracking-tight dark:text-white">Audit: <span class="premium-title">Recent Deployments</span></h2>
                    </div>
                    <button class="px-6 py-2 glass text-[10px] font-black tracking-widest uppercase hover:bg-white/10 transition-all border-white/5">View Full Log</button>
                </div>

                <div class="space-y-4">
                    <% if (courses && courses.length > 0) { %>
                        <% courses.slice(0, 5).forEach(course => { %>
                            <div class="flex items-center justify-between p-6 rounded-2xl hover:bg-white/5 transition-all group border border-transparent hover:border-white/5">
                                <div class="flex items-center gap-6">
                                    <div class="w-12 h-12 rounded-xl bg-[#001E2B] border border-white/10 flex items-center justify-center text-[#00ED64] font-black group-hover:rotate-6 transition-transform">
                                        <%= (course.title || course.name || 'C').charAt(0) %>
                                    </div>
                                    <div>
                                        <div class="font-bold text-gray-900 dark:text-white text-lg"><%= course.title || course.name %></div>
                                        <div class="text-[10px] font-black text-gray-400 dark:text-[#9FB1AD] uppercase tracking-widest mt-1">
                                            <%= course.category || 'Core Engineering' %> • <%= course.videos ? course.videos.length : 0 %> Active Components
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-6">
                                    <span class="hidden md:block px-3 py-1 bg-[#00ED64]/10 text-[#00ED64] text-[8px] font-black uppercase tracking-widest rounded-lg border border-[#00ED64]/20">STABLE</span>
                                    <a href="/course/<%= encodeURIComponent(course.name) %>" class="px-6 py-2.5 glass text-[10px] font-black tracking-widest text-[#00ED64] uppercase border-[#00ED64]/20 hover:bg-[#00ED64] hover:text-[#001E2B] transition-all">
                                        DEBUG SITE
                                    </a>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="py-20 text-center opacity-30 italic font-medium">No recent deployment vectors detected.</div>
                    <% } %>
                </div>
            </section>
        </main>
    </div>

    <script>
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
            const icon = document.getElementById('themeIcon');
            if (icon) icon.textContent = theme === 'dark' ? '☀️' : '🌙';
        }
        
        function toggleTheme() {
            const currentTheme = document.documentElement.classList.contains('dark') ? 'light' : 'dark';
            document.documentElement.classList.toggle('dark', currentTheme === 'dark');
            localStorage.setItem('theme', currentTheme);
            const icon = document.getElementById('themeIcon');
            if (icon) icon.textContent = currentTheme === 'dark' ? '☀️' : '🌙';
        }

        const themeToggle = document.getElementById('themeToggle');
        if (themeToggle) themeToggle.addEventListener('click', toggleTheme);
        
        initTheme();
    </script>
</body>
</html>