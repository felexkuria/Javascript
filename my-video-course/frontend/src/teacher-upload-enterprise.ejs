<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enterprise Orchestration Center - Multitouch Academy</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mdb-green': '#00ED64',
              'mdb-forest': '#00684A',
              'mdb-midnight': '#001E2B',
              'mdb-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        :root {
            --mdb-green: #00ED64;
            --mdb-midnight: #001E2B;
            --glass-bg: rgba(2, 52, 48, 0.4);
            --glass-border: rgba(0, 237, 100, 0.1);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--mdb-midnight);
            color: #E7EEEB;
            -webkit-font-smoothing: antialiased;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
        }

        .enterprise-card-atlas {
            border-radius: 40px;
            transition: all 0.4s cubic-bezier(0.2, 0, 0, 1);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .enterprise-card-atlas:hover {
            transform: translateY(-10px);
            border-color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.03);
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.4);
        }

        .tab-atlas {
            padding: 12px 24px;
            border-radius: 14px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
            color: #9FB1AD;
            border: 1px solid transparent;
        }

        .tab-atlas.active {
            background: rgba(0, 237, 100, 0.1);
            color: var(--mdb-green);
            border-color: rgba(0, 237, 100, 0.2);
        }

        .code-vault {
            background: #000F15;
            border-radius: 20px;
            padding: 30px;
            font-family: 'JetBrains Mono', 'Fira Code', monospace;
            font-size: 13px;
            color: #00ED64;
            border: 1px solid rgba(255, 255, 255, 0.05);
            position: relative;
            overflow-x: auto;
        }

        .btn-atlas-primary {
            background: #00ED64;
            color: #001E2B;
            font-weight: 900;
            border-radius: 16px;
            transition: all 0.3s;
            box-shadow: 0 0 20px rgba(0, 237, 100, 0.2);
        }

        .btn-atlas-primary:hover {
            box-shadow: 0 0 40px rgba(0, 237, 100, 0.4);
            transform: scale(1.05);
        }

        .metric-ring-atlas {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            border: 6px solid rgba(0, 237, 100, 0.1);
            border-top-color: var(--mdb-green);
            animation: ringOrbit 2s linear infinite;
        }

        @keyframes ringOrbit {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="dark overflow-x-hidden">
    <div class="flex">
        <!-- Sidebar -->
        <%- include('partials/instructor-sidebar', { activePage: 'upload' }) %>

        <main class="flex-grow p-10 lg:p-16">
            <header class="flex flex-col md:flex-row justify-between items-end gap-10 mb-24 md:max-w-6xl">
                <div>
                    <div class="flex items-center gap-4 mb-4">
                        <span class="px-4 py-1.5 bg-[#00ED64]/10 text-[#00ED64] text-[10px] font-black uppercase tracking-[0.3em] rounded-full border border-[#00ED64]/20">Enterprise Grade</span>
                        <div class="h-px w-16 bg-white/5"></div>
                    </div>
                    <h1 class="text-7xl font-black tracking-tighter text-white">Advanced <span class="text-[#00ED64]">Orchestration</span></h1>
                    <p class="text-gray-400 text-xl font-medium mt-2">Professional-grade curriculum ingestion and logic synchronization.</p>
                </div>
            </header>

            <!-- Intelligence Overview -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-20 md:max-w-6xl">
                <div class="premium-glass p-8 rounded-[32px] border border-white/5 flex flex-col items-center text-center">
                    <div class="w-16 h-16 rounded-full bg-green-500/10 flex items-center justify-center text-[#00ED64] mb-6">
                        <i class="fas fa-microchip text-2xl"></i>
                    </div>
                    <div class="text-3xl font-black text-white mb-1">99.8%</div>
                    <div class="text-[9px] font-black uppercase tracking-widest text-gray-500">Sync Velocity</div>
                </div>
                <!-- ... other metrics ... -->
            </div>

            <div class="space-y-16 md:max-w-6xl">
                <!-- Method Selection -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                    <div class="enterprise-card-atlas premium-glass p-12">
                        <div class="text-4xl mb-8">⚡</div>
                        <h3 class="text-2xl font-black text-white mb-4 tracking-tighter">Bulk Scripts</h3>
                        <p class="text-gray-400 text-sm leading-relaxed mb-10">Generate custom CLI scripts for high-volume asset ingestion with automated logic mapping.</p>
                        <button class="btn-atlas-primary w-full py-4 text-[10px] uppercase tracking-widest">Generate Protocol</button>
                    </div>
                    <div class="enterprise-card-atlas premium-glass p-12">
                        <div class="text-4xl mb-8">☁️</div>
                        <h3 class="text-2xl font-black text-white mb-4 tracking-tighter">Cloud Direct</h3>
                        <p class="text-gray-400 text-sm leading-relaxed mb-10">Native S3 tunnel for direct-to-cloud transfers with real-time health monitoring.</p>
                        <button class="btn-atlas-primary w-full py-4 text-[10px] uppercase tracking-widest bg-gray-600/20 text-gray-400 pointer-events-none">Coming Soon</button>
                    </div>
                    <div class="enterprise-card-atlas premium-glass p-12">
                        <div class="text-4xl mb-8">🔄</div>
                        <h3 class="text-2xl font-black text-white mb-4 tracking-tighter">Sync Link</h3>
                        <p class="text-gray-400 text-sm leading-relaxed mb-10">External API integration for multi-source curriculum synchronization.</p>
                        <button class="btn-atlas-primary w-full py-4 text-[10px] uppercase tracking-widest bg-gray-600/20 text-gray-400 pointer-events-none">Coming Soon</button>
                    </div>
                </div>

                <!-- Script Infrastructure -->
                <section class="premium-glass p-12 md:p-16 rounded-[48px]">
                    <div class="flex flex-col md:flex-row justify-between items-center gap-10 mb-12">
                        <div class="flex gap-4">
                            <button class="tab-atlas active">Windows (PS)</button>
                            <button class="tab-atlas">macOS (Bash)</button>
                            <button class="tab-atlas">Linux (Shell)</button>
                        </div>
                        <div class="flex gap-4">
                            <button class="px-6 py-3 bg-[#00ED64]/10 text-[#00ED64] rounded-xl text-[10px] font-black uppercase tracking-widest border border-[#00ED64]/20 hover:bg-[#00ED64] hover:text-[#001E2B] transition-all">
                                Copy Pipeline
                            </button>
                        </div>
                    </div>

                    <div class="code-vault">
<pre>
# Enterprise Ingestion Script v2.1
# Initializing S3 Tunnels...

aws s3 sync ./local-assets s3://multitouch-academy-curriculum/ \
    --exclude "*" \
    --include "*.mp4" \
    --storage-class INTELLIGENT_TIERING \
    --metadata "course-id=dev-ops-bootcamp-2026"
</pre>
                    </div>

                    <div class="mt-12 p-10 bg-white/2 rounded-[32px] border border-white/5">
                        <h4 class="text-xs font-black text-[#00ED64] uppercase tracking-[0.2em] mb-4">Ingestion Instructions</h4>
                        <ol class="space-y-4 text-sm text-gray-400 font-medium">
                            <li class="flex gap-4"><span class="text-[#00ED64]">01.</span> Install AWS CLI infrastructure on your local node.</li>
                            <li class="flex gap-4"><span class="text-[#00ED64]">02.</span> Configure IAM orchestration keys via `aws configure`.</li>
                            <li class="flex gap-4"><span class="text-[#00ED64]">03.</span> Pulse the script within your media root directory.</li>
                        </ol>
                    </div>
                </section>
            </div>
        </main>
    </div>
</body>
</html>