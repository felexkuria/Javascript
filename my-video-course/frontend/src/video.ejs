<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= video ? video.title : 'Video' %> - <%= courseName %></title>
    <link rel="stylesheet" href="/css/video-performance.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%- include('partials/interactive-styles') %>
    <%- include('partials/video-styles') %>
    <%- include('partials/chatbot-styles') %>

</head>
<body class="dark bg-[#001E2B] font-sans antialiased text-[#E7EEEB] min-h-screen">
    <%- include('partials/header', { title: (video ? video.title : 'Lecture') + ' - ' + courseName, activePage: 'video' }) %>

    <div class="command-center">
        <!-- Main Learning Canvas -->
        <main class="learning-canvas scroll-premium">
            <div class="max-w-[1200px] mx-auto">
                <!-- Cinematic Breadcrumbs -->
                <div class="breadcrumb-atlas">
                    <a href="/dashboard" class="breadcrumb-node hover:opacity-100 transition-all">ACADEMY</a>
                    <span class="breadcrumb-sep">/</span>
                    <a href="/course/<%= encodeURIComponent(courseName) %>" class="breadcrumb-node hover:opacity-100 transition-all truncate max-w-[200px]"><%= courseName %></a>
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-node active truncate max-w-[300px]"><%= video ? video.title : 'TERMINAL' %></span>
                </div>

                <!-- Achievement HUD Atlas Style -->
                <div class="flex items-center gap-6 mb-12">
                    <div class="atlas-card glass px-8 py-4 flex items-center gap-5">
                        <div class="w-10 h-10 rounded-xl bg-[#00ED64]/10 flex items-center justify-center text-[#00ED64] border border-[#00ED64]/20 shadow-inner">
                            <i class="fas fa-bolt text-xs"></i>
                        </div>
                        <div>
                            <p class="technical-label">Velocity (XP)</p>
                            <p id="userPoints" class="text-lg font-black text-white leading-none">0</p>
                        </div>
                    </div>
                    <div class="atlas-card glass px-8 py-4 flex items-center gap-5">
                        <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-500 border border-amber-500/20 shadow-inner">
                            <i class="fas fa-fire text-xs"></i>
                        </div>
                        <div>
                            <p class="technical-label">Path Mastery</p>
                            <p id="userStreak" class="text-lg font-black text-white leading-none">0 DAYS</p>
                        </div>
                    </div>
                    <div class="ml-auto flex items-center gap-2">
                        <span class="atlas-badge">Premium Node</span>
                        <div class="flex gap-1">
                            <div class="w-1 h-1 rounded-full bg-white/20"></div>
                            <div class="w-1 h-1 rounded-full bg-white/20"></div>
                            <div class="w-1 h-1 rounded-full bg-[#00ED64] shadow-[0_0_8px_#00ED64]"></div>
                        </div>
                    </div>
                </div>

                <div class="video-hero group">
                <!-- System Status HUD Overlay -->
                <div class="absolute top-6 left-6 z-20 flex items-center gap-4 pointer-events-none opacity-0 group-hover:opacity-100 transition-all duration-500">
                    <div class="bg-[#001E2B]/80 backdrop-blur-xl border border-[#00ED64]/50 px-4 py-2 rounded-xl flex items-center gap-3">
                        <div class="w-2 h-2 bg-[#00ED64] rounded-full animate-pulse shadow-[0_0_10px_#00ED64]"></div>
                        <span class="text-[9px] font-black uppercase tracking-[0.2em] text-[#00ED64]">Protocol: Active</span>
                    </div>
                </div>
                    <div class="video-container relative h-full">
                        <% if (video && (video.isYouTube || video.url && video.url.includes('youtube.com'))) { %>
                            <% 
                                let embedUrl = video.url;
                                if (embedUrl.includes('watch?v=')) embedUrl = embedUrl.replace('watch?v=', 'embed/');
                                if (!embedUrl.includes('?')) embedUrl += '?rel=0&showinfo=0&modestbranding=1';
                            %>
                            <iframe src="<%= embedUrl %>" allowfullscreen></iframe>
                        <% } else if (video && (video.type === 'pdf' || (video.url && /\.pdf(\?|$)/i.test(video.url)))) { %>
                            <div class="pdf-viewer-premium h-full w-full bg-[#001E2B] flex flex-col pt-12">
                                <div class="px-8 pb-4 flex items-center justify-between">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center text-red-500 border border-red-500/20">
                                            <i class="fas fa-file-pdf"></i>
                                        </div>
                                        <div>
                                            <p class="text-[9px] font-black uppercase tracking-widest text-red-500/60">Documentation Node</p>
                                            <h3 class="text-sm font-black text-white truncate max-w-[400px]"><%= video.title %></h3>
                                        </div>
                                    </div>
                                    <a href="<%= video.url %>" target="_blank" class="btn-atlas btn-atlas-primary text-[10px] py-2 px-6">
                                        <i class="fas fa-expand mr-2"></i> FULLSCREEN
                                    </a>
                                </div>
                                <div class="flex-1 overflow-hidden relative border-t border-white/5">
                                    <iframe src="<%= video.url %>#toolbar=0" class="w-full h-full border-none filter grayscale-[0.2] invert-[0.1] contrast-[1.1]"></iframe>
                                </div>
                            </div>
                        <% } else if (video && video.url) { %>
                            <video id="videoPlayer" class="w-full h-full" controls crossorigin="anonymous" playsinline <%= video.thumbnail ? `poster="${video.thumbnail}"` : '' %>>
                                <source src="<%= video.url %>" type="video/mp4">
                            </video>
                        <% } %>
                    </div>
                </div>

                <div class="flex items-center justify-between mt-8 p-6 glass rounded-2xl">
                    <div class="flex items-center gap-6">
                        <button id="markWatchedButton" class="btn-atlas btn-atlas-primary px-8">
                            <i class="fas fa-check"></i> MARK COMPLETE
                        </button>
                        <div class="flex gap-2">
                            <button id="prevButton" class="w-10 h-10 glass rounded-xl flex items-center justify-center hover:bg-white/10 transition-all">
                                <i class="fas fa-chevron-left text-[10px]"></i>
                            </button>
                            <button id="nextButton" class="w-10 h-10 glass rounded-xl flex items-center justify-center hover:bg-white/10 transition-all">
                                <i class="fas fa-chevron-right text-[10px]"></i>
                            </button>
                        </div>
                    </div>
                    <div class="hidden md:flex items-center gap-4 text-[#9FB1AD]">
                        <span class="text-[9px] font-black uppercase tracking-widest opacity-40">Command Console</span>
                        <div class="flex gap-1.5">
                            <kbd class="px-2 py-1 bg-white/5 border border-white/10 rounded text-[9px] font-mono">F</kbd>
                            <kbd class="px-2 py-1 bg-white/5 border border-white/10 rounded text-[9px] font-mono">SPACE</kbd>
                        </div>
                    </div>
                </div>

                <div class="premium-meta-bay">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <p class="text-[10px] font-black text-[#00ED64] uppercase tracking-[0.3em] mb-2"><%= courseName %></p>
                            <h1 class="text-4xl font-black tracking-tight"><%= video ? video.title : 'Lecture Module' %></h1>
                        </div>
                        <div class="text-right">
                            <p class="text-[9px] font-black text-[#9FB1AD] uppercase tracking-widest mb-1 opacity-50">Technical Lead</p>
                            <div class="flex items-center gap-3">
                                <span class="text-sm font-black text-white">Engineer Felex</span>
                                <div class="w-2 h-2 rounded-full bg-[#00ED64] animate-pulse"></div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="prose prose-invert max-w-none text-[#9FB1AD] text-sm leading-relaxed mb-12">
                        <%= video ? video.description : 'Detailed architectural deep dive into this technical module.' %>
                    </div>

                    <!-- AI Learning Lab Integrated -->
                    <div class="pt-12 border-t border-white/5">
                        <div class="flex items-center justify-between mb-8">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[#00ED64] to-[#00684A] flex items-center justify-center text-[#001E2B] shadow-lg shadow-[#00ED64]/10">
                                    <i class="fas fa-dna text-xs"></i>
                                </div>
                                <h3 class="text-xl font-black tracking-tight uppercase">AI Learning <span class="premium-text">Lab</span></h3>
                            </div>
                            <button id="refreshTodos" class="btn-atlas btn-atlas-secondary text-[10px] py-3 px-6">
                                <i class="fas fa-sync-alt mr-2"></i> SYNC INSIGHTS
                            </button>
                        </div>

                        <div id="ai-todo-container" class="grid grid-cols-1 md:grid-cols-2 gap-6 p-2">
                            <!-- Populated by video-scripts.ejs -->
                            <div class="col-span-2 py-12 text-center opacity-40 italic text-[11px] font-bold uppercase tracking-widest">
                                <i class="fas fa-circle-notch fa-spin mb-4 block text-lg"></i>
                                Calibrating AI Learning Nodes...
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Multimedia Fallout Protection -->
                <script>
                    window.addEventListener('load', () => {
                        const container = document.querySelector('.video-container');
                        if (container && !container.innerHTML.trim()) {
                            container.innerHTML = `
                                <div class="h-full w-full flex flex-col items-center justify-center bg-[#001E2B] border border-[#00ED64]/10 rounded-3xl">
                                    <div class="w-20 h-20 rounded-full bg-[#00ED64]/5 flex items-center justify-center text-[#00ED64] mb-6 animate-pulse">
                                        <i class="fas fa-microchip text-3xl"></i>
                                    </div>
                                    <h3 class="text-xl font-black text-white uppercase tracking-tighter mb-2">Protocol: No Signal</h3>
                                    <p class="text-[10px] font-bold text-[#9FB1AD] uppercase tracking-[0.2em] opacity-50">Calibrating Multimedia Stream...</p>
                                </div>
                            `;
                        }
                    });
                </script>
            </div>
        </main>

        <!-- Side Lab (Integrated Sidebar) -->
        <aside class="side-lab">
            <div class="lab-tabs">
                <button onclick="switchLabTab('curriculum')" id="tab-curriculum" class="lab-tab-btn active">
                    <i class="fas fa-list-ul"></i> Path
                </button>
                <button onclick="switchLabTab('advisor')" id="tab-advisor" class="lab-tab-btn">
                    <i class="fas fa-brain"></i> AI Advisor
                </button>
                <button onclick="switchLabTab('notes')" id="tab-notes" class="lab-tab-btn">
                    <i class="fas fa-pen-nib"></i> Notes
                </button>
            </div>

            <div class="lab-content scroll-premium">
                <!-- Curriculum Tab -->
                <div id="content-curriculum" class="lab-pane active space-y-6">
                    <% if (typeof sections !== 'undefined' && sections.length > 0) { %>
                        <% sections.forEach((section, sIdx) => { %>
                            <div class="section-group mb-6">
                                <div class="flex items-center gap-3 mb-4 px-2">
                                    <div class="w-1.5 h-1.5 rounded-full bg-[#00ED64]"></div>
                                    <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-[#9FB1AD]"><%= section.title %></h3>
                                </div>
                                <div class="space-y-1">
                                    <% section.lectures.forEach((lec, lIdx) => { 
                                        const lecId = lec.videoId || lec._id || lec.contentId || 'missing';
                                        const isActive = video && (video.videoId === lecId || video._id === lecId || video.id === lecId);
                                    %>
                                        <a href="/course/<%= encodeURIComponent(courseName) %>/video/<%= encodeURIComponent(lecId) %>" 
                                           class="lecture-node flex items-center gap-4 p-4 rounded-xl transition-all duration-300 border border-transparent <%= isActive ? 'bg-[#00ED64]/10 border-[#00ED64]/30 active-glow shadow-lg shadow-[#00ED64]/5 ring-1 ring-[#00ED64]/20' : 'hover:bg-white/5 active:scale-[0.98]' %>">
                                            <div class="w-8 h-8 rounded-lg <%= isActive ? 'bg-[#00ED64] text-[#001E2B] shadow-[0_0_15px_rgba(0,237,100,0.4)]' : 'bg-white/5 text-[#9FB1AD]' %> flex items-center justify-center shrink-0 shadow-lg">
                                                <i class="fas <%= lec.type === 'pdf' ? 'fa-file-pdf' : (isActive ? 'fa-play' : 'fa-lock-open') %> text-[10px]"></i>
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <p class="text-[12px] font-bold truncate <%= isActive ? 'text-[#00ED64]' : 'text-[#E7EEEB]' %>"><%= lec.title %></p>
                                                <p class="text-[9px] font-medium text-[#9FB1AD] mt-1 uppercase tracking-wider opacity-60">Node <%= sIdx + 1 %>.<%= lIdx + 1 %></p>
                                            </div>
                                            <% if (lec.watched) { %>
                                                <div class="text-[#00ED64] text-[10px] animate-pulse">
                                                    <i class="fas fa-check-circle"></i>
                                                </div>
                                            <% } %>
                                        </a>
                                    <% }) %>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="py-20 text-center px-6">
                            <div class="w-16 h-16 rounded-3xl bg-white/5 flex items-center justify-center text-[#9FB1AD] mx-auto mb-6 opacity-20 border border-white/10">
                                <i class="fas fa-map text-2xl"></i>
                            </div>
                            <h4 class="text-xs font-black text-white uppercase tracking-widest mb-2 opacity-50">Chartless Territory</h4>
                            <p class="text-[10px] font-bold text-[#9FB1AD] leading-relaxed opacity-40">No technical modules have been deployed to this curriculum yet.</p>
                            <a href="/course-management" class="btn-atlas btn-atlas-primary w-full mt-8 py-3 text-[10px]">CONFIGURE NODES</a>
                        </div>
                    <% } %>
                </div>

                <!-- AI Advisor Tab -->
                <div id="content-advisor" class="lab-pane h-full flex flex-col">
                    <div id="floating-chat-messages" class="flex-1 space-y-6 pb-24 scroll-premium">
                        <!-- Messages go here -->
                        <div class="flex flex-col items-start animate-message-in">
                            <div class="max-w-[90%] bg-white/5 border border-white/10 text-[#E7EEEB] p-5 rounded-2xl rounded-tl-none text-[13px] leading-relaxed">
                                Hello! I'm your integrated **Nova AI** technical advisor. I have full context of this lesson's transcript and related PDF materials. How can I assist your learning protocol?
                            </div>
                            <div class="text-[9px] font-black text-[#00ED64] uppercase tracking-widest mt-2 flex items-center gap-2">
                                <i class="fas fa-bolt text-[8px] animate-pulse"></i> Nova AI • ACTIVE
                            </div>
                        </div>
                    </div>
                    
                    <div class="absolute bottom-6 left-6 right-6">
                        <div class="relative">
                            <input type="text" id="floating-chat-input" placeholder="Query Nova AI..." 
                                   class="w-full bg-[#001E2B] border border-white/10 rounded-2xl py-4 pl-6 pr-14 text-sm font-bold text-white focus:border-[#00ED64]/50 focus:outline-none transition-all shadow-2xl">
                            <button onclick="sendFloatingChatMessage()" class="absolute right-2 top-2 w-10 h-10 bg-[#00ED64] text-[#001E2B] rounded-xl flex items-center justify-center hover:scale-105 active:scale-95 transition-all">
                                <i class="fas fa-paper-plane text-xs"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Notes Tab -->
                <div id="content-notes" class="lab-pane">
                    <textarea id="studentNotes" class="w-full h-[400px] bg-white/5 border border-white/10 rounded-2xl p-6 text-sm font-medium text-[#9FB1AD] focus:border-[#00ED64]/50 focus:outline-none transition-all placeholder:opacity-30" 
                              placeholder="Record your architectural insights here..."></textarea>
                    <button id="saveNotesBtn" onclick="saveStudentNotes()" class="btn-atlas btn-atlas-primary w-full mt-6 py-4 flex items-center justify-center gap-2">
                        <i class="fas fa-save" id="saveIcon"></i> 
                        <span id="saveText">PERSIST NOTES</span>
                    </button>
                    <div id="saveFeedback" class="hidden mt-3 text-[10px] font-black text-[#00ED64] uppercase tracking-widest text-center animate-pulse">
                        <i class="fas fa-check-double mr-2"></i> Synced to Cloud Vault
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <!-- Senior Floating Nova AI Widget [RESTORED] -->
    <div id="floating-chatbot" class="fixed bottom-24 right-32 w-[380px] h-[550px] bg-[#001E2B]/95 backdrop-blur-3xl border border-white/10 rounded-3xl shadow-[0_40px_100px_rgba(0,0,0,0.8)] z-[200] hidden flex-col overflow-hidden animate-message-in">
        <div class="p-6 border-b border-white/5 bg-[#00ED64]/5 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-[#00ED64] flex items-center justify-center text-[#001E2B] shadow-lg shadow-[#00ED64]/20 animate-pulse">
                    <i class="fas fa-bolt text-xs"></i>
                </div>
                <div>
                    <h4 class="text-xs font-black text-white uppercase tracking-widest">Nova AI Assistant</h4>
                    <p class="text-[9px] font-bold text-[#00ED64] uppercase opacity-70">Protocol Layer 0.1</p>
                </div>
            </div>
            <button onclick="toggleFloatingChatbot()" class="text-[#9FB1AD] hover:text-white transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div id="floating-chat-messages-widget" class="flex-1 overflow-y-auto p-6 space-y-4 scroll-premium">
            <!-- Syncs with sidebar but provides floating experience -->
        </div>
        <div class="p-4 border-t border-white/5 bg-[#001E2B]">
            <div class="relative">
                <input type="text" id="floating-chat-input-widget" placeholder="Query Nova Lite..." 
                       class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-6 pr-14 text-sm font-bold text-white focus:border-[#00ED64]/30 focus:outline-none transition-all">
                <button onclick="sendFloatingChatMessageWidget()" class="absolute right-2 top-2 w-10 h-10 bg-[#00ED64] text-[#001E2B] rounded-xl flex items-center justify-center hover:scale-105 active:scale-95 transition-all">
                    <i class="fas fa-paper-plane text-xs"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Floating Trigger Bubble -->
    <div id="floating-trigger" onclick="toggleFloatingChatbot()" class="fixed bottom-6 right-32 w-14 h-14 bg-[#00ED64] text-[#001E2B] rounded-full flex items-center justify-center shadow-[0_10px_30px_rgba(0,237,100,0.3)] cursor-pointer z-[190] hover:scale-110 active:scale-95 transition-all group">
        <i class="fas fa-comment-dots text-xl"></i>
        <div class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full border-2 border-[#001E2B] animate-bounce"></div>
    </div>

    <!-- Achievement Popup (Universal) -->
    <div id="achievement-popup">
        <div id="achievement-icon" class="text-4xl">🏆</div>
        <div>
            <p id="achievement-title" class="text-[10px] font-black text-[#00ED64] uppercase tracking-[0.3em] mb-1">Architecture Milestone</p>
            <h4 id="achievement-name" class="text-xl font-black text-white">Cloud Explorer</h4>
            <p class="text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest mt-1">+ <span id="achievement-points">500</span> CREDITS AWARDED</p>
        </div>
    </div>

    <!-- Key Hints -->
    <div id="keyHint" class="fixed bottom-12 left-1/2 -translate-x-1/2 bg-white text-[#001E2B] px-6 py-3 rounded-2xl font-black text-xs uppercase tracking-widest pointer-events-none opacity-0 transition-all z-[1000]">
        COMMAND EXECUTED
    </div>

    <!-- Gamification Data Context -->
    <input type="hidden" id="isLastVideo" value="<%= typeof isLastVideo !== 'undefined' ? isLastVideo : false %>">
    <input type="hidden" id="isLastInChapter" value="<%= typeof isLastInChapter !== 'undefined' ? isLastInChapter : false %>">

    <%- include('partials/video-scripts', { video, courseName, isLastVideo, isLastInChapter }) %>

    <script>
        function switchLabTab(tabId) {
            document.querySelectorAll('.lab-tab-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById('tab-' + tabId).classList.add('active');
            
            document.querySelectorAll('.lab-pane').forEach(pane => pane.classList.remove('active'));
            document.getElementById('content-' + tabId).classList.add('active');
            
            if (tabId === 'advisor') {
                setTimeout(() => {
                    const messages = document.getElementById('floating-chat-messages');
                    if (messages) messages.scrollTop = messages.scrollHeight;
                    document.getElementById('floating-chat-input')?.focus();
                }, 100);
            }
        }

        // --- Persistent Notes Protocol ---
        const notesArea = document.querySelector('#content-notes textarea');
        const persistBtn = document.querySelector('#content-notes button');
        const notesKey = `notes_${courseName}_${videoId}`;

        if (notesArea) {
            notesArea.value = localStorage.getItem(notesKey) || '';
            
            persistBtn?.addEventListener('click', () => {
                localStorage.setItem(notesKey, notesArea.value);
                window.showAtlasHint?.('ARCHITECTURAL INSIGHTS PERSISTED');
                persistBtn.innerHTML = '<i class="fas fa-check"></i> INSIGHTS PERSISTED';
                setTimeout(() => { persistBtn.innerHTML = '<i class="fas fa-save"></i> PERSIST NOTES'; }, 3000);
            });
        }

        // Global key shortcut hint for redesigned page
        window.showAtlasHint = function(text) {
            const hint = document.getElementById('keyHint');
            if (hint) {
                hint.textContent = text;
                hint.style.opacity = '1';
                hint.style.transform = 'translateX(-50%) translateY(-20px)';
                setTimeout(() => {
                    hint.style.opacity = '0';
                    hint.style.transform = 'translateX(-50%) translateY(0)';
                }, 1500);
            }
        };
    </script>
</body>
</html>