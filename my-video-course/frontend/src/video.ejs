<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= video ? video.title : 'Video' %> - <%= courseName %></title>
    <link rel="stylesheet" href="/css/video-performance.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%- include('partials/interactive-styles') %>
    <%- include('partials/video-styles') %>
    <%- include('partials/chatbot-styles') %>
    <!-- Markdown & Code Formatting -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/styles/atom-one-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/highlight.min.js"></script>
</head>
<body class="dark bg-[#001E2B] font-sans antialiased text-[#E7EEEB] min-h-screen">
    <%- include('partials/header', { title: (video ? video.title : 'Lecture') + ' - ' + courseName, activePage: 'video' }) %>
    <div id="sidebar-overlay" onclick="toggleSidebar()"></div>

    <div class="command-center">
        <!-- Main Learning Canvas -->
        <main class="learning-canvas scroll-premium">
            <div class="max-w-[1200px] mx-auto">
                <!-- Cinematic Breadcrumbs and Toolbar -->
                <div class="flex items-center justify-between mb-8">
                    <div class="breadcrumb-atlas mb-0 border-b-0 pb-0 w-fit">
                        <a href="/dashboard" class="breadcrumb-node hover:opacity-100 transition-all">ACADEMY</a>
                        <span class="breadcrumb-sep">/</span>
                        <a href="/course/<%= encodeURIComponent(courseName) %>" class="breadcrumb-node hover:opacity-100 transition-all truncate max-w-[200px]"><%= courseName %></a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-node active truncate max-w-[300px]"><%= video ? video.title : 'TERMINAL' %></span>
                    </div>
                    <button onclick="toggleSideLab()" id="toggleSideLabBtn" class="flex items-center gap-2 text-[10px] uppercase font-black tracking-widest text-[#9FB1AD] hover:text-[#00ED64] transition-all bg-white/5 hover:bg-white/10 px-4 py-2 rounded-lg border border-white/5 shadow-lg">
                        <span id="sideLabBtnText">Collapse Lab</span>
                        <i id="sideLabBtnIcon" class="fas fa-arrow-right"></i>
                    </button>
                </div>

                <!-- Achievement HUD Atlas Style -->

                <div class="flex items-center gap-6 mb-12">
                    <div class="atlas-card glass px-8 py-4 flex items-center gap-5">
                        <div class="w-10 h-10 rounded-xl bg-[#00ED64]/10 flex items-center justify-center text-[#00ED64] border border-[#00ED64]/20 shadow-inner">
                            <i class="fas fa-bolt text-xs"></i>
                        </div>
                        <div>
                            <p class="technical-label">Velocity (XP)</p>
                            <p id="userPoints" class="text-lg font-black text-white leading-none">0</p>
                        </div>
                    </div>
                    <div class="atlas-card glass px-8 py-4 flex items-center gap-5">
                        <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-500 border border-amber-500/20 shadow-inner">
                            <i class="fas fa-fire text-xs"></i>
                        </div>
                        <div>
                            <p class="technical-label">Path Mastery</p>
                            <p id="userStreak" class="text-lg font-black text-white leading-none">0 DAYS</p>
                        </div>
                    </div>
                    <div class="ml-auto flex items-center gap-2">
                        <span class="atlas-badge">Premium Node</span>
                        <div class="flex gap-1">
                            <div class="w-1 h-1 rounded-full bg-white/20"></div>
                            <div class="w-1 h-1 rounded-full bg-white/20"></div>
                            <div class="w-1 h-1 rounded-full bg-[#00ED64] shadow-[0_0_8px_#00ED64]"></div>
                        </div>
                    </div>
                </div>

                <div class="video-hero group">
                <!-- System Status HUD Overlay -->
                <div class="absolute top-6 left-6 z-20 flex items-center gap-4 pointer-events-none opacity-0 group-hover:opacity-100 transition-all duration-500">
                    <div class="bg-[#001E2B]/80 backdrop-blur-xl border border-[#00ED64]/50 px-4 py-2 rounded-xl flex items-center gap-3">
                        <div class="w-2 h-2 bg-[#00ED64] rounded-full animate-pulse shadow-[0_0_10px_#00ED64]"></div>
                        <span class="text-[9px] font-black uppercase tracking-[0.2em] text-[#00ED64]">Protocol: Active</span>
                    </div>
                </div>
                    <div class="video-container relative h-full">
                        <%- include('partials/video-player', { video, courseName, isYouTube }) %>
                    </div>
                </div>


                <div class="flex items-center justify-between mt-8 p-6 glass rounded-2xl">
                    <div class="flex items-center gap-6">
                        <button id="markWatchedButton" class="btn-atlas btn-atlas-primary px-8">
                            <i class="fas fa-check"></i> MARK COMPLETE
                        </button>
                        <div class="flex gap-2">
                            <button id="prevButton" class="w-10 h-10 glass rounded-xl flex items-center justify-center hover:bg-white/10 transition-all">
                                <i class="fas fa-chevron-left text-[10px]"></i>
                            </button>
                            <button id="nextButton" class="w-10 h-10 glass rounded-xl flex items-center justify-center hover:bg-white/10 transition-all">
                                <i class="fas fa-chevron-right text-[10px]"></i>
                            </button>
                        </div>
                    </div>
                    <div class="hidden md:flex items-center gap-4 text-[#9FB1AD]">
                        <span class="text-[9px] font-black uppercase tracking-widest opacity-40">Command Console</span>
                        <div class="flex gap-1.5">
                            <kbd class="px-2 py-1 bg-white/5 border border-white/10 rounded text-[9px] font-mono">F</kbd>
                            <kbd class="px-2 py-1 bg-white/5 border border-white/10 rounded text-[9px] font-mono">SPACE</kbd>
                        </div>
                    </div>
                </div>

                <div class="premium-meta-bay glass">
                    <div class="mb-10">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="atlas-badge"><%= courseName %></span>
                            <div class="w-px h-3 bg-white/10"></div>
                            <span class="technical-label text-[#00ED64]">Node 01: Architecture</span>
                        </div>
                        <h1 class="text-5xl font-black tracking-tight mb-6 bg-clip-text text-transparent bg-gradient-to-r from-white to-white/60">
                            <%= video ? video.title : 'Lecture Module' %>
                        </h1>
                        <div class="flex items-center gap-6">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
                                    <i class="fas fa-user-astronaut text-[10px] text-[#9FB1AD]"></i>
                                </div>
                                <span class="text-[11px] font-bold text-[#E7EEEB] uppercase tracking-widest">Engineer Felex</span>
                            </div>
                            <div class="w-1 h-1 rounded-full bg-white/20"></div>
                            <div class="flex items-center gap-2">
                                <i class="fas fa-clock text-[9px] text-[#9FB1AD]"></i>
                                <span class="text-[11px] font-bold text-[#9FB1AD] uppercase tracking-widest"><%= video && video.duration ? video.duration : '24:00' %></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="prose prose-invert max-w-none text-[#9FB1AD] text-sm leading-relaxed mb-12 border-l-2 border-[#00ED64]/20 pl-8 py-2">
                        <%= video ? video.description : 'Detailed architectural deep dive into this technical module.' %>
                    </div>

                    <!-- AI Learning Lab Integrated -->
                    <div class="pt-12 border-t border-white/5">
                        <div class="flex items-center justify-between mb-8">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[#00ED64] to-[#00684A] flex items-center justify-center text-[#001E2B] shadow-lg shadow-[#00ED64]/10">
                                    <i class="fas fa-dna text-xs"></i>
                                </div>
                                <h3 class="text-xl font-black tracking-tight uppercase">AI Learning <span class="text-[#00ED64]">Insights</span></h3>
                            </div>
                            <button id="refreshTodos" class="flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] text-[#00ED64] bg-[#00ED64]/10 border border-[#00ED64]/20 px-6 py-3 rounded-xl hover:bg-[#00ED64]/20 transition-all">
                                <i class="fas fa-sync-alt"></i> SYNC ENGINE
                            </button>
                        </div>

                        <div id="ai-todo-container" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Populated by video-scripts.ejs -->
                            <div class="col-span-2 py-12 text-center opacity-40 italic text-[11px] font-bold uppercase tracking-widest">
                                <i class="fas fa-circle-notch fa-spin mb-4 block text-lg"></i>
                                Calibrating AI Learning Nodes...
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Multimedia Fallout Protection -->
                <script>
                    window.addEventListener('load', () => {
                        const container = document.querySelector('.video-container');
                        if (container && !container.innerHTML.trim()) {
                            container.innerHTML = `
                                <div class="h-full w-full flex flex-col items-center justify-center bg-[#001E2B] border border-[#00ED64]/10 rounded-3xl">
                                    <div class="w-20 h-20 rounded-full bg-[#00ED64]/5 flex items-center justify-center text-[#00ED64] mb-6 animate-pulse">
                                        <i class="fas fa-microchip text-3xl"></i>
                                    </div>
                                    <h3 class="text-xl font-black text-white uppercase tracking-tighter mb-2">Protocol: No Signal</h3>
                                    <p class="text-[10px] font-bold text-[#9FB1AD] uppercase tracking-[0.2em] opacity-50">Calibrating Multimedia Stream...</p>
                                </div>
                            `;
                        }
                    });
                </script>
            </div>
        </main>

        <!-- Side Lab (Integrated Sidebar) -->
        <aside class="side-lab">
            <div class="lab-tabs">
                <button onclick="switchLabTab('curriculum')" id="tab-curriculum" class="lab-tab-btn active" title="Curriculum Path">
                    <i class="fas fa-map-signs"></i>
                </button>
                <button onclick="switchLabTab('quiz')" id="tab-quiz" class="lab-tab-btn" title="Technical Assessment">
                    <i class="fas fa-microchip"></i>
                </button>
                <button onclick="switchLabTab('lab')" id="tab-lab" class="lab-tab-btn" title="Hands-on Lab">
                    <i class="fas fa-flask"></i>
                </button>
                <button onclick="switchLabTab('notes')" id="tab-notes" class="lab-tab-btn" title="Architect Notes">
                    <i class="fas fa-pen-nib"></i>
                </button>
                <button onclick="switchLabTab('advisor')" id="tab-advisor" class="lab-tab-btn" title="Nova AI Advisor">
                    <i class="fas fa-brain"></i>
                </button>
            </div>

            <div class="lab-content flex-1 overflow-hidden relative">
                <!-- Curriculum Tab -->
                <div id="content-curriculum" class="lab-pane active h-full overflow-y-auto px-6 py-10 scroll-premium space-y-4">
                    <!-- Achievement Banner (Hidden until 100%) -->
                    <div id="claimCertificateBanner" class="hidden animate-in slide-in-from-top duration-700 mb-8 p-6 rounded-[24px] bg-gradient-to-br from-[#00ED64] to-[#00A345] text-[#001E2B] shadow-[0_10px_40px_rgba(0,237,100,0.3)]">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center text-xl">
                                <i class="fas fa-medal"></i>
                            </div>
                            <div>
                                <h3 class="text-lg font-black leading-tight uppercase tracking-tight">Protocol Mastered</h3>
                                <p class="text-xs font-bold opacity-80 uppercase tracking-widest">Architect Certification Ready</p>
                            </div>
                        </div>
                        <button onclick="generateArchitectCertificate()" id="claimCertBtn" class="w-full py-4 bg-[#001E2B] text-[#00ED64] rounded-xl text-[11px] font-black tracking-[0.2em] uppercase hover:bg-[#001E2B]/90 transition-all flex items-center justify-center gap-2 group">
                            <span>GENERATE CERTIFICATE</span>
                            <i class="fas fa-rocket group-hover:-translate-y-1 transition-transform"></i>
                        </button>
                    </div>

                    <% if (typeof sections !== 'undefined' && sections.length > 0) { %>
                        <% 
                           // Calculate global course completion for banner toggle
                           let totalLectures = 0;
                           let watchedLectures = 0;
                           sections.forEach(s => {
                               totalLectures += s.lectures.length;
                               watchedLectures += s.lectures.filter(l => l.watched).length;
                           });
                           const courseComplete = totalLectures > 0 && watchedLectures === totalLectures;
                        %>
                        <script>
                            document.addEventListener('DOMContentLoaded', () => {
                                if (<%= courseComplete %>) {
                                    document.getElementById('claimCertificateBanner')?.classList.remove('hidden');
                                }
                            });
                        </script>
                        <% sections.forEach((section, sIdx) => { %>
                            <% 
                                const sectionWatched = section.lectures.filter(l => l.watched).length;
                                const sectionTotal = section.lectures.length;
                                const sectionPercent = Math.round((sectionWatched / sectionTotal) * 100);
                                let hasActiveVideo = false;
                                if (video) {
                                    hasActiveVideo = section.lectures.some((lec) => {
                                        const lecId = lec.videoId || lec._id || lec.contentId;
                                        return video.videoId === lecId || video._id === lecId || video.id === lecId;
                                    });
                                }
                            %>
                            <div class="section-group mb-8 <%= hasActiveVideo || sections.length === 1 ? 'expanded' : '' %>">
                                <div class="px-2 mb-4 flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <div class="w-1.5 h-1.5 rounded-full <%= hasActiveVideo ? 'bg-[#00ED64] shadow-[0_0_8px_#00ED64]' : 'bg-white/20' %>"></div>
                                        <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-[#9FB1AD]"><%= section.title %></h3>
                                    </div>
                                    <span class="text-[9px] font-bold text-[#00ED64]"><%= sectionPercent %>% Complete</span>
                                </div>
                                
                                <div class="space-y-3">
                                    <% section.lectures.forEach((lec, lIdx) => { 
                                        const lecId = lec.videoId || lec._id || lec.contentId || 'missing';
                                        const isActive = video && (video.videoId === lecId || video._id === lecId || video.id === lecId);
                                    %>
                                        <a href="/course/<%= encodeURIComponent(courseName) %>/video/<%= encodeURIComponent(lecId) %>" 
                                           class="curriculum-node <%= isActive ? 'active' : '' %>">
                                            <div class="w-8 h-8 rounded-lg <%= isActive ? 'bg-[#00ED64] text-[#001E2B]' : 'bg-white/5 text-[#9FB1AD]' %> flex items-center justify-center shrink-0">
                                                <i class="fas <%= lec.type === 'pdf' ? 'fa-file-pdf' : (isActive ? 'fa-play' : (lec.watched ? 'fa-check' : 'fa-play opacity-40')) %> text-[10px]"></i>
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <p class="text-[12px] font-bold truncate leading-none <%= isActive ? 'text-white' : 'text-[#E7EEEB]/80' %>"><%= lec.title %></p>
                                                <div class="curriculum-progress-rail">
                                                    <div class="curriculum-progress-fill" style="width: <%= lec.watched ? '100' : (isActive ? '45' : '0') %>%"></div>
                                                </div>
                                            </div>
                                        </a>
                                    <% }) %>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="py-20 text-center px-6">
                            <div class="w-16 h-16 rounded-3xl bg-white/5 flex items-center justify-center text-[#9FB1AD] mx-auto mb-6 opacity-20 border border-white/10">
                                <i class="fas fa-map text-2xl"></i>
                            </div>
                            <h4 class="text-xs font-black text-white uppercase tracking-widest mb-2 opacity-50">Chartless Territory</h4>
                            <p class="text-[10px] font-bold text-[#9FB1AD] leading-relaxed opacity-40">No technical modules have been deployed to this curriculum yet.</p>
                            <a href="/course-management" class="btn-atlas btn-atlas-primary w-full mt-8 py-3 text-[10px]">CONFIGURE NODES</a>
                        </div>
                    <% } %>
                </div>

                <!-- Technical Assessment Tab -->
                <div id="content-quiz" class="lab-pane h-full overflow-y-auto px-6 py-10 scroll-premium">
                    <div id="quiz-container" class="space-y-8 animate-in fade-in duration-500">
                        <div class="text-center py-20 opacity-40">
                            <i class="fas fa-microchip fa-spin text-3xl mb-4 text-[#00ED64]"></i>
                            <p class="text-[10px] font-black uppercase tracking-[0.3em]">Initializing Assessment Core...</p>
                        </div>
                    </div>
                </div>

                <!-- Hands-on Lab Tab -->
                <div id="content-lab" class="lab-pane h-full overflow-y-auto px-6 py-10 scroll-premium">
                    <div id="lab-container" class="space-y-10 animate-in slide-in-from-right-10 duration-500">
                        <div class="text-center py-20 opacity-40">
                            <i class="fas fa-flask fa-spin text-3xl mb-4 text-[#00ED64]"></i>
                            <p class="text-[10px] font-black uppercase tracking-[0.3em]">Provisioning Lab Environment...</p>
                        </div>
                    </div>
                </div>

                <!-- AI Advisor Tab -->
                <div id="content-advisor" class="lab-pane h-full flex flex-col relative px-6">
                    <div id="floating-chat-messages" class="flex-1 overflow-y-auto space-y-6 pt-6 pb-24 scroll-premium">
                        <!-- Messages go here -->
                        <div class="flex flex-col items-start animate-message-in">
                            <div class="max-w-[90%] bg-white/5 border border-white/10 text-[#E7EEEB] p-5 rounded-2xl rounded-tl-none text-[13px] leading-relaxed">
                                Hello! I'm your integrated **Nova AI** technical advisor. I have full context of this lesson's transcript and related PDF materials. How can I assist your learning protocol?
                            </div>
                            <div class="text-[9px] font-black text-[#00ED64] uppercase tracking-widest mt-2 flex items-center gap-2">
                                <i class="fas fa-bolt text-[8px] animate-pulse"></i> Nova AI • ACTIVE
                            </div>
                        </div>
                    </div>
                    
                    <div class="absolute bottom-6 left-6 right-6">
                        <div class="relative">
                            <input type="text" id="floating-chat-input" placeholder="Query Nova AI..." 
                                   class="w-full bg-[#001E2B] border border-white/10 rounded-2xl py-4 pl-6 pr-14 text-sm font-bold text-white focus:border-[#00ED64]/50 focus:outline-none transition-all shadow-2xl">
                            <button onclick="sendFloatingChatMessage()" class="absolute right-2 top-2 w-10 h-10 bg-[#00ED64] text-[#001E2B] rounded-xl flex items-center justify-center hover:scale-105 active:scale-95 transition-all">
                                <i class="fas fa-paper-plane text-xs"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Notes Tab -->
                <div id="content-notes" class="lab-pane h-full overflow-y-auto px-6 py-6 scroll-premium">
                    <textarea id="studentNotes" class="w-full h-[calc(100%-80px)] bg-white/5 border border-white/10 rounded-2xl p-6 text-sm font-medium text-[#9FB1AD] focus:border-[#00ED64]/50 focus:outline-none transition-all placeholder:opacity-30" 
                              placeholder="Record your architectural insights here..."></textarea>
                    <button id="saveNotesBtn" onclick="saveStudentNotes()" class="btn-atlas btn-atlas-primary w-full mt-6 py-4 flex items-center justify-center gap-2">
                        <i class="fas fa-save" id="saveIcon"></i> 
                        <span id="saveText">PERSIST NOTES</span>
                    </button>
                    <div id="saveFeedback" class="hidden mt-3 text-[10px] font-black text-[#00ED64] uppercase tracking-widest text-center animate-pulse">
                        <i class="fas fa-check-double mr-2"></i> Synced to Cloud Vault
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <!-- Floating AI Assistant Widget (Atlas Look) -->
    <div id="floating-chatbot" class="floating-chatbot glass">
        <div class="chatbot-header">
            <div class="chatbot-title">
                <i class="fas fa-brain chatbot-icon"></i>
                <span>AI Assistant</span>
                <span class="ai-model-badge">Nova Lite</span>
            </div>
            <button class="chatbot-toggle" onclick="toggleFloatingChatbot()">
                <i class="fas fa-minus"></i>
            </button>
        </div>
        
        <div class="chatbot-body flex flex-col h-[calc(100%-80px)]">
            <div class="chat-messages scroll-premium" id="floating-chat-messages-widget">
                <!-- Syncs with sidebar but provides floating experience -->
            </div>
            
            <div class="chat-input-container">
                <input type="text" id="floating-chat-input-widget" placeholder="Query Nova Lite..." maxlength="500">
                <button onclick="sendFloatingChatMessage()" class="btn-send">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Floating Trigger Bubble -->
    <button id="floating-trigger" class="chatbot-trigger" onclick="toggleFloatingChatbot()">
        <i class="fas fa-comment-dots"></i>
        <span class="notification-dot" style="display: none;"></span>
    </button>

    <!-- Achievement Popup (Universal) -->
    <div id="achievement-popup">
        <div id="achievement-icon" class="text-4xl">🏆</div>
        <div>
            <p id="achievement-title" class="text-[10px] font-black text-[#00ED64] uppercase tracking-[0.3em] mb-1">Architecture Milestone</p>
            <h4 id="achievement-name" class="text-xl font-black text-white">Cloud Explorer</h4>
            <p class="text-[10px] font-black text-[#9FB1AD] uppercase tracking-widest mt-1">+ <span id="achievement-points">500</span> CREDITS AWARDED</p>
        </div>
    </div>

    <!-- Key Hints -->
    <div id="keyHint" class="fixed bottom-12 left-1/2 -translate-x-1/2 bg-white text-[#001E2B] px-6 py-3 rounded-2xl font-black text-xs uppercase tracking-widest pointer-events-none opacity-0 transition-all z-[1000]">
        COMMAND EXECUTED
    </div>

    <!-- Gamification Data Context -->
    <input type="hidden" id="isLastVideo" value="<%= typeof isLastVideo !== 'undefined' ? isLastVideo : false %>">
    <input type="hidden" id="isLastInChapter" value="<%= typeof isLastInChapter !== 'undefined' ? isLastInChapter : false %>">

    <%- include('partials/video-scripts', { video, courseName, isLastVideo, isLastInChapter }) %>

    <script>
        function switchLabTab(tabId) {
            document.querySelectorAll('.lab-tab-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById('tab-' + tabId).classList.add('active');
            
            document.querySelectorAll('.lab-pane').forEach(pane => pane.classList.remove('active'));
            document.getElementById('content-' + tabId).classList.add('active');
            
            if (tabId === 'advisor') {
                setTimeout(() => {
                    const messages = document.getElementById('floating-chat-messages');
                    if (messages) messages.scrollTop = messages.scrollHeight;
                    document.getElementById('floating-chat-input')?.focus();
                }, 100);
            }
        }

        function toggleSidebar() {
            const sidebar = document.querySelector('.side-lab');
            const overlay = document.getElementById('sidebar-overlay');
            if (sidebar && overlay) {
                sidebar.classList.toggle('mobile-open');
                overlay.classList.toggle('active');
                
                // Prevent body scroll when menu is open
                document.body.style.overflow = sidebar.classList.contains('mobile-open') ? 'hidden' : '';
            }
        }

        // Global export for header onclick
        window.toggleSidebar = toggleSidebar;

        // --- Persistent Notes Protocol ---
        const notesArea = document.querySelector('#content-notes textarea');
        const persistBtn = document.querySelector('#content-notes button');
        const notesKey = `notes_${courseName}_${videoId}`;

        if (notesArea) {
            notesArea.value = localStorage.getItem(notesKey) || '';
            
            persistBtn?.addEventListener('click', () => {
                localStorage.setItem(notesKey, notesArea.value);
                window.showAtlasHint?.('ARCHITECTURAL INSIGHTS PERSISTED');
                persistBtn.innerHTML = '<i class="fas fa-check"></i> INSIGHTS PERSISTED';
                setTimeout(() => { persistBtn.innerHTML = '<i class="fas fa-save"></i> PERSIST NOTES'; }, 3000);
            });
        }

        // Global key shortcut hint for redesigned page
        window.showAtlasHint = function(text) {
            const hint = document.getElementById('keyHint');
            if (hint) {
                hint.textContent = text;
                hint.style.opacity = '1';
                hint.style.transform = 'translateX(-50%) translateY(-20px)';
                setTimeout(() => {
                    hint.style.opacity = '0';
                    hint.style.transform = 'translateX(-50%) translateY(0)';
                }, 1500);
            }
        };

        // --- Auto-scroll to active node ---
        window.addEventListener('load', () => {
            const activeNode = document.querySelector('.lecture-node.active-glow');
            if (activeNode) {
                activeNode.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    </script>
</body>
</html>