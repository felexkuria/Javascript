<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= video ? video.title : 'Video' %> - <%= courseName %></title>
    <link rel="stylesheet" href="/css/video-performance.css">
    <%- include('partials/interactive-styles') %>
    <%- include('partials/video-styles') %>
    <%- include('partials/chatbot-styles') %>
    <style>
        .main-content {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 40px;
            align-items: start;
        }
        
        .corner-badges {
            position: fixed;
            top: 80px;
            left: 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 1000;
        }
        
        .corner-badge {
            background: var(--color-surface);
            backdrop-filter: blur(20px);
            border-radius: 12px;
            padding: 10px;
            box-shadow: var(--shadow-md);
            border: 0.5px solid var(--color-border);
            min-width: 180px;
            transition: all 0.2s ease;
        }
        
        .dark .corner-badge {
            background: rgba(2, 52, 48, 0.9);
            border: 0.5px solid rgba(0, 237, 100, 0.2);
        }
        
        .corner-badge:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        }
        
        .badge-icon {
            font-size: 20px;
            color: #00ED64;
        }
        
        .stat-row .stat-label {
            font-size: 11px;
            color: #86868b;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .stat-row .stat-value {
            font-size: 14px;
            font-weight: 700;
            color: #1d1d1f;
        }
        
        .dark .stat-row .stat-value {
            color: #00ED64;
        }
        
        .dark #keyTopics h4 {
            color: #00ED64;
        }
        
        .dark .sidebar-card {
            background: rgba(2, 52, 48, 0.6);
            border: 0.5px solid rgba(0, 237, 100, 0.1);
            border-radius: 16px;
        }
        
        .dark #refreshTodos {
            background: #001E2B;
            color: #00ED64;
            border: 0.5px solid rgba(0, 237, 100, 0.2);
        }
        
        .dark #refreshTodos:hover {
            background: #3a3a3c;
        }
        
        .dark .loading-skeleton .skeleton-line {
            background: linear-gradient(90deg, #2c2c2e 25%, #3a3a3c 50%, #2c2c2e 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }
        
        .dark .loading-spinner {
            border-color: #001E2B !important;
            border-top-color: #00ED64 !important;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
        
        .typing-indicator {
            display: flex;
            gap: 4px;
            align-items: center;
        }
        
        .typing-indicator span {
            width: 6px;
            height: 6px;
            background: #86868b;
            border-radius: 50%;
            animation: typing 1.4s infinite ease-in-out;
        }
        
        .typing-indicator span:nth-child(1) { animation-delay: 0s; }
        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
        
        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
            30% { transform: translateY(-10px); opacity: 1; }
        }
        
        .shortcuts-mini {
            flex: 1;
        }
        
        .shortcut-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 4px;
            font-size: 11px;
        }
        
        .shortcut-row:last-child {
            margin-bottom: 0;
        }
        
        .shortcut-row span {
            background: var(--color-bg);
            color: var(--color-text);
            padding: 2px 6px;
            border-radius: 4px;
            font-family: 'SF Mono', Monaco, monospace;
            font-weight: 500;
            min-width: 16px;
            text-align: center;
            border: 1px solid var(--color-border);
        }
        
        .dark .shortcut-row span {
            background: #001E2B;
            color: #00ED64;
            border: 0.5px solid rgba(0, 237, 100, 0.2);
        }
        
        .chapters-sidebar {
            max-height: calc(100vh - 120px);
            overflow-y: auto;
        }
        
        @media (max-width: 1024px) {
            .main-content {
                grid-template-columns: 1fr;
                gap: 24px;
            }
            
            .corner-badges {
                position: relative;
                top: auto;
                left: auto;
                flex-direction: row;
                justify-content: center;
                margin: 20px 0;
            }
            
            .corner-badge {
                min-width: auto;
                flex: 1;
            }
        }
    </style>

    <script src="/js/video-quiz-functions.js"></script>
    <link rel="preload" as="image" href="/thumbnails/<%= video ? video._id : '' %>.jpg">
</head>
<body class="dark bg-[#001E2B] font-sans antialiased text-[#E7EEEB] min-h-screen">
    <%- include('partials/header', { title: (video ? video.title : 'Lecture') + ' - ' + courseName, activePage: 'video' }) %>

    <!-- Corner Stats (Atlas Style) -->
    <div class="fixed top-24 left-8 flex flex-col gap-4 z-[100] hidden md:flex">
        <div class="atlas-card glass p-4 flex items-center gap-4 group">
            <div class="w-8 h-8 rounded-lg bg-[#00ED64]/10 flex items-center justify-center text-[#00ED64] border border-[#00ED64]/20 group-hover:scale-110 transition-transform">
                <i class="fas fa-bolt text-[10px]"></i>
            </div>
            <div>
                <p class="text-[8px] font-black uppercase tracking-widest text-[#9FB1AD]">Current Velocity</p>
                <p id="userPoints" class="text-sm font-black text-white">0 XP</p>
            </div>
        </div>
        <div class="atlas-card glass p-4 flex items-center gap-4 group">
            <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-500 border border-amber-500/20 group-hover:scale-110 transition-transform">
                <i class="fas fa-fire text-[10px]"></i>
            </div>
            <div>
                <p class="text-[8px] font-black uppercase tracking-widest text-[#9FB1AD]">Learning Streak</p>
                <p id="userStreak" class="text-sm font-black text-white">0 DAYS</p>
            </div>
        </div>
    </div>

    <main class="max-w-[1600px] mx-auto px-6 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
            
            <!-- Player Section -->
            <div class="lg:col-span-2 space-y-8">
                <div class="video-section atlas-card group">
                    <div class="video-container relative">
                        <% if (video && (video.isYouTube || video.url && video.url.includes('youtube.com'))) { %>
                            <% 
                                let embedUrl = video.url;
                                if (embedUrl.includes('watch?v=')) {
                                    embedUrl = embedUrl.replace('watch?v=', 'embed/');
                                }
                                if (!embedUrl.includes('?')) embedUrl += '?rel=0&showinfo=0&modestbranding=1';
                            %>
                            <iframe src="<%= embedUrl %>" allowfullscreen></iframe>
                        <% } else if (video && video.type === 'pdf') { %>
                            <div class="pdf-container h-full">
                                <i class="fas fa-file-pdf pdf-icon-hero"></i>
                                <div class="text-center">
                                    <h3 class="text-2xl font-black mb-2 uppercase tracking-tight">Technical Documentation</h3>
                                    <p class="text-sm text-[#9FB1AD] font-bold uppercase tracking-widest opacity-60"><%= video.title %></p>
                                </div>
                                <a href="<%= video.url %>" target="_blank" class="btn-atlas btn-atlas-primary">
                                    <i class="fas fa-external-link-alt"></i> LAUNCH READER
                                </a>
                            </div>
                        <% } else if (video && video.url) { %>
                            <video id="videoPlayer" controls crossorigin="anonymous" playsinline <%= video.thumbnail ? `poster="${video.thumbnail}"` : '' %>>
                                <source src="<%= video.url %>" type="video/mp4">
                                Your browser does not support the video tag.
                            </video>
                        <% } else { %>
                            <div class="flex items-center justify-center h-full bg-[#001E2B]">
                                <p class="text-[10px] font-black uppercase tracking-[0.4em] opacity-30 italic">Provisioning Lesson...</p>
                            </div>
                        <% } %>
                    </div>

                    <div class="video-controls-bar">
                        <div class="flex items-center gap-6">
                            <button id="markWatchedButton" class="btn-atlas btn-atlas-primary <%= video && video.watched ? 'opacity-50' : '' %>">
                                <i class="fas <%= video && video.watched ? 'fa-check-double' : 'fa-check' %>"></i>
                                <%= video && video.watched ? 'MARK AS DONE' : 'MARK AS DONE' %>
                            </button>
                            <span class="h-8 w-px bg-white/5"></span>
                            <div class="flex items-center gap-4">
                                <button id="prevButton" class="w-12 h-12 glass rounded-2xl flex items-center justify-center hover:bg-white/10 transition-all">
                                    <i class="fas fa-chevron-left text-xs"></i>
                                </button>
                                <button id="nextButton" class="w-12 h-12 glass rounded-2xl flex items-center justify-center hover:bg-white/10 transition-all">
                                    <i class="fas fa-chevron-right text-xs"></i>
                                </button>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="text-[10px] font-mono text-[#9FB1AD] uppercase tracking-widest opacity-40">Command Console</span>
                            <div class="flex gap-2">
                                <span class="px-2 py-1 glass rounded text-[9px] font-mono opacity-50">F</span>
                                <span class="px-2 py-1 glass rounded text-[9px] font-mono opacity-50">J</span>
                                <span class="px-2 py-1 glass rounded text-[9px] font-mono opacity-50">K</span>
                                <span class="px-2 py-1 glass rounded text-[9px] font-mono opacity-50">L</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="atlas-card glass p-10">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h2 class="text-3xl font-black tracking-tight mb-2"><%= video ? video.title : 'Lecture Module' %></h2>
                            <p class="text-xs font-bold text-[#00ED64] uppercase tracking-[0.2em]"><%= courseName %></p>
                        </div>
                        <div class="text-right">
                            <p class="text-[9px] font-black text-[#9FB1AD] uppercase tracking-widest mb-1 opacity-50">Technical Lead</p>
                            <p class="text-sm font-black text-white">Engineer Felex</p>
                        </div>
                    </div>
                    <div class="prose prose-invert max-w-none text-[#9FB1AD] text-sm font-medium leading-relaxed">
                        <%= video ? video.description : 'Welcome to this module. In this lecture, we explore core engineering principles and architecture patterns defined by the Multitouch Academy standard.' %>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="sidebar space-y-8">
                <div class="atlas-card glass p-8">
                    <h3 class="text-[10px] font-black text-white uppercase tracking-[0.3em] mb-8 flex items-center gap-3">
                        <i class="fas fa-bars-staggered text-[#00ED64]"></i> Curriculum Sections
                    </h3>
                    <div class="curriculum-list">
                        <% if (typeof sections !== 'undefined' && sections.length > 0) { %>
                            <% sections.forEach((section, sIndex) => { %>
                                <div class="mb-4">
                                    <div class="px-4 py-2 text-[9px] font-black text-[#9FB1AD] uppercase tracking-widest opacity-40 mb-2">
                                        Section <%= sIndex + 1 %>: <%= section.title %>
                                    </div>
                                    <div class="space-y-1">
                                        <% if (section.lectures) { %>
                                            <% section.lectures.forEach(lec => { %>
                                                <% 
                                                    const lecId = lec._id || lec.contentId;
                                                    const currentVideoId = video && (video.id || video._id);
                                                    const isActive = (currentVideoId && lecId) ? currentVideoId.toString() === lecId.toString() : false; 
                                                %>
                                                <a href="/course/<%= encodeURIComponent(courseName) %>/video/<%= encodeURIComponent(lec._id || lec.contentId) %>" 
                                                   class="lecture-item <%= isActive ? 'active' : '' %>">
                                                    <div class="lecture-icon">
                                                        <i class="fas <%= lec.type === 'pdf' ? 'fa-file-pdf' : 'fa-play' %>"></i>
                                                    </div>
                                                    <div class="flex-1 overflow-hidden">
                                                        <p class="lecture-title"><%= lec.title %></p>
                                                        <p class="lecture-meta"><%= lec.duration || '0:00' %></p>
                                                    </div>
                                                    <% if (lec.watched) { %>
                                                        <i class="fas fa-check-circle text-[#00ED64] text-[10px]"></i>
                                                    <% } %>
                                                </a>
                                            <% }); %>
                                        <% } %>
                                    </div>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/video-scripts', { video, courseName, isLastVideo, isLastInChapter }) %>
    <script>
        // Atlas Interactive Logic
        document.addEventListener('DOMContentLoaded', function() {
            const player = document.getElementById('videoPlayer');
            const markBtn = document.getElementById('markWatchedButton');
            
            // Sync initial state
            if (markBtn && '<%= video && video.watched ? "true" : "false" %>' === 'true') {
                markBtn.classList.add('opacity-50');
            }

            // Keyboard Shortcuts Sync
            document.addEventListener('keydown', (e) => {
                const key = e.key.toLowerCase();
                const hint = document.getElementById('keyHint');
                if (!hint) return;
                
                const showHint = (text) => {
                    hint.textContent = text;
                    hint.classList.add('visible');
                    setTimeout(() => hint.classList.remove('visible'), 1200);
                };

                if (player) {
                    if (key === 'f') {
                        if (document.fullscreenElement) document.exitFullscreen();
                        else player.requestFullscreen();
                        showHint('FULLSCREEN MODE');
                    }
                    if (key === 'k' || key === ' ') {
                        e.preventDefault();
                        if (player.paused) player.play(); else player.pause();
                        showHint(player.paused ? 'PAUSED' : 'PLAYING');
                    }
                }
            });

            // Tab Management
            window.switchAtlasTab = function(tabId) {
                document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
                document.getElementById(tabId)?.classList.remove('hidden');
            };
        });
    </script>
</body>
</html>