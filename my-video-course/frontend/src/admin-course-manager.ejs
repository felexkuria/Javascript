<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Course Manager - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .instructor-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            min-height: 100vh;
            background: var(--color-bg);
        }

        .instructor-sidebar {
            background: var(--mdb-midnight);
            color: #fff;
            padding: var(--space-6);
            display: flex;
            flex-direction: column;
            gap: var(--space-4);
            position: sticky;
            top: 0;
            height: 100vh;
            border-right: 1px solid rgba(255,255,255,0.05);
        }

        .sidebar-brand {
            font-size: 20px;
            font-weight: 800;
            color: var(--mdb-green);
            margin-bottom: var(--space-8);
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item {
            padding: var(--space-3) var(--space-4);
            border-radius: var(--radius-md);
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            font-weight: 500;
            transition: all var(--transition);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item:hover, .nav-item.active {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }

        .nav-item.active {
            color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.08);
        }

        .instructor-main {
            padding: var(--space-8);
            background: var(--color-bg);
            overflow-y: auto;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: var(--space-6);
            margin-bottom: var(--space-8);
        }

        .stat-card {
            background: var(--color-surface);
            padding: var(--space-6);
            border-radius: var(--radius-lg);
            border: 1px solid var(--color-border);
            box-shadow: var(--shadow-sm);
        }

        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--color-text);
            margin-bottom: 4px;
        }

        .stat-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--color-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .course-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: var(--space-6);
        }

        .course-card {
            background: var(--color-surface);
            border-radius: var(--radius-xl);
            border: 1px solid var(--color-border);
            padding: var(--space-6);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .course-card:hover {
            transform: translateY(-4px);
            border-color: var(--mdb-green);
            box-shadow: var(--shadow-xl);
        }

        .category-badge {
            display: inline-block;
            padding: 4px 10px;
            background: rgba(0, 237, 100, 0.1);
            color: var(--mdb-green);
            font-size: 11px;
            font-weight: 700;
            border-radius: 6px;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .nav-leaf { font-size: 20px; }

        /* Modal Styles */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 30, 43, 0.8);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .modal-content {
            background: var(--color-surface);
            width: 100%;
            max-width: 500px;
            border-radius: var(--radius-2xl);
            padding: var(--space-8);
            box-shadow: var(--shadow-2xl);
            transform: scale(0.9);
            transition: transform 0.3s ease;
        }

        .modal-overlay.active .modal-content {
            transform: scale(1);
        }

        .form-group {
            margin-bottom: var(--space-5);
        }

        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--color-text);
        }

        .form-input {
            width: 100%;
            padding: 12px 16px;
            border-radius: var(--radius-md);
            border: 1px solid var(--color-border);
            background: var(--color-bg);
            color: var(--color-text);
            outline: none;
            transition: border-color 0.2s;
        }

        .form-input:focus {
            border-color: var(--mdb-green);
        }
    </style>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
    <div class="instructor-layout">
        <%- include('partials/instructor-sidebar', { activePage: 'courses' }) %>
        <main class="instructor-main">
            <header style="margin-bottom: var(--space-10); display: flex; justify-content: space-between; align-items: flex-end;">
                <div>
                    <h1 style="font-size: 36px; font-weight: 800; letter-spacing: -0.03em;">Course Management</h1>
                    <p style="color: var(--color-text-muted); font-size: 17px;">Deploy and manage elite engineering curricula.</p>
                </div>
                <button class="btn btn-primary" onclick="showCreateModal()" style="height: 48px; padding: 0 24px; border-radius: 12px; font-weight: 700;">
                    + Create New Course
                </button>
            </header>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-value"><%= courses.length %></div>
                    <div class="stat-label">Total Courses</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= courses.reduce((acc, c) => acc + (c.videos ? c.videos.length : 0), 0) %></div>
                    <div class="stat-label">Total Lessons</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">Elite</div>
                    <div class="stat-label">Quality Status</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">March'26</div>
                    <div class="stat-label">Last Deploy</div>
                </div>
            </div>

            <div class="course-grid" id="courseList">
                <% if (courses && courses.length > 0) { %>
                    <% courses.forEach(course => { %>
                        <div class="course-card group">
                            <span class="category-badge"><%= course.category || 'Engineering' %></span>
                            <h3 style="font-size: 20px; font-weight: 700; margin-bottom: 8px;"><%= course.title || course.name %></h3>
                            <p style="color: var(--color-text-muted); font-size: 14px; margin-bottom: 24px; line-height: 1.5;" class="line-clamp-2">
                                <%= course.description || 'Professional curriculum for software engineers and architects.' %>
                            </p>
                            <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--color-border); padding-top: 16px;">
                                <div style="font-size: 12px; font-weight: 600; color: var(--color-text-muted);">
                                    <i class="fas fa-play-circle" style="color: var(--mdb-green);"></i> <%= course.videos ? course.videos.length : 0 %> Lessons
                                </div>
                                <div style="display: flex; gap: 8px;">
                                    <a href="/teacher/course-editor/<%= course._id || course.name %>" class="btn btn-secondary" style="font-size: 12px; padding: 6px 12px; border-radius: 8px;">Edit curriculum</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div style="grid-column: 1 / -1; text-align: center; padding: 80px 0; background: var(--color-surface); border: 2px dashed var(--color-border); border-radius: 24px;">
                        <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 8px;">Ready to teach?</h2>
                        <p style="color: var(--color-text-muted); margin-bottom: 32px;">Start your journey by deploying your first engineering course.</p>
                        <button class="btn btn-primary" onclick="showCreateModal()" style="width: auto; padding: 0 32px;">Deploy First Course</button>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <!-- Create Course Modal -->
    <div id="createModal" class="modal-overlay">
        <div class="modal-content">
            <h2 style="font-size: 24px; font-weight: 800; margin-bottom: var(--space-2);">Deploy New Course</h2>
            <p style="color: var(--color-text-muted); font-size: 14px; margin-bottom: var(--space-6);">Configure the basic metadata for your new curriculum.</p>
            
            <div class="form-group">
                <label class="form-label">Course Title</label>
                <input type="text" id="courseTitle" class="form-input" placeholder="e.g. Advanced System Design">
            </div>
            
            <div class="form-group">
                <label class="form-label">Category</label>
                <select id="courseCategory" class="form-input">
                    <option value="Cloud Computing">Cloud Computing</option>
                    <option value="DevOps">DevOps</option>
                    <option value="Architecture">Architecture</option>
                    <option value="Programming">Programming</option>
                    <option value="Security">Security</option>
                </select>
            </div>
            
            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea id="courseDescription" class="form-input" rows="3" placeholder="Briefly describe the learning outcomes..."></textarea>
            </div>
            
            <div style="display: flex; gap: 12px; margin-top: 32px;">
                <button class="btn btn-secondary" onclick="hideCreateModal()" style="flex: 1;">Cancel</button>
                <button class="btn btn-primary" id="submitCreateBtn" onclick="submitCreateCourse()" style="flex: 2;">Deploy Course</button>
            </div>
        </div>
    </div>

    <script>
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        initTheme();

        function showCreateModal() {
            document.getElementById('createModal').classList.add('active');
        }

        function hideCreateModal() {
            document.getElementById('createModal').classList.remove('active');
        }

        async function submitCreateCourse() {
            const title = document.getElementById('courseTitle').value.trim();
            const category = document.getElementById('courseCategory').value;
            const description = document.getElementById('courseDescription').value.trim();
            
            if (!title) return alert('Course title is required');

            const btn = document.getElementById('submitCreateBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deploying...';

            try {
                const response = await fetch('/api/courses', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        title, 
                        name: title, // Backend logic uses name as key often
                        category, 
                        description 
                    })
                });
                
                const data = await response.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Deployment failed: ' + data.message);
                }
            } catch (error) {
                alert('Connection error: ' + error.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Deploy Course';
            }
        }

        // Close modal on escape
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') hideCreateModal();
        });
    </script>
</body>
</html>