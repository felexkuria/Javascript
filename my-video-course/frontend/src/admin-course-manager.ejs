<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Course Governance - Multitouch Academy</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mdb-green': '#00ED64',
              'mdb-forest': '#00684A',
              'mdb-midnight': '#001E2B',
              'mdb-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        :root {
            --mdb-green: #00ED64;
            --mdb-midnight: #001E2B;
            --glass-bg: rgba(2, 52, 48, 0.4);
            --glass-border: rgba(0, 237, 100, 0.1);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--mdb-midnight);
            color: #E7EEEB;
            -webkit-font-smoothing: antialiased;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
        }

        .course-row-atlas {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .course-row-atlas:hover {
            background: rgba(0, 237, 100, 0.03);
            border-color: var(--mdb-green);
            transform: translateX(4px);
        }

        .btn-atlas-action {
            background: #00ED64;
            color: #001E2B;
            font-weight: 800;
            border-radius: 12px;
            transition: all 0.3s;
        }

        .btn-atlas-action:hover {
            box-shadow: 0 0 20px rgba(0, 237, 100, 0.3);
            transform: scale(1.05);
        }

        .btn-atlas-ghost {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            transition: all 0.3s;
        }

        .btn-atlas-ghost:hover {
            border-color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.05);
        }

        .status-badge {
            padding: 4px 12px;
            border-radius: 99px;
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .modal-blur {
            background: rgba(0, 30, 43, 0.8);
            backdrop-filter: blur(12px);
        }

        .atlas-input {
            background: rgba(0, 30, 43, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 14px 20px;
            color: white;
            outline: none;
            transition: all 0.3s;
        }

        .atlas-input:focus {
            border-color: var(--mdb-green);
            background: rgba(0, 30, 43, 0.8);
            box-shadow: 0 0 0 4px rgba(0, 237, 100, 0.1);
        }
    </style>
</head>
<body class="dark overflow-x-hidden">
    <div class="flex">
        <!-- Sidebar -->
        <%- include('partials/instructor-sidebar', { activePage: 'courses' }) %>

        <!-- Main Content -->
        <main class="flex-grow p-10 lg:p-16">
            <!-- Hero Section / Sticky Command Bar -->
            <header class="sticky top-16 z-30 bg-[#001E2B]/90 backdrop-blur-xl -mx-4 px-4 lg:-mx-12 lg:px-12 py-8 mb-12 border-b border-white/5 flex flex-col md:flex-row justify-between items-center gap-8 transition-all">
                <div>
                    <div class="flex items-center gap-4 mb-3">
                        <span class="px-4 py-1 bg-[#00ED64]/10 text-[#00ED64] text-[9px] font-black uppercase tracking-[0.3em] rounded-full border border-[#00ED64]/20">Global Governance</span>
                        <div class="h-px w-12 bg-white/5"></div>
                    </div>
                    <h1 class="text-4xl font-black tracking-tighter text-white">Course <span class="text-[#00ED64]">Orchestrator</span></h1>
                </div>
                <button onclick="showCreateModal()" class="btn-atlas-action px-8 py-4 uppercase tracking-widest text-[10px] flex items-center gap-2">
                    <i class="fas fa-plus"></i> Initialize New Track
                </button>
            </header>


            <!-- Stats Ribbon -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-16">
                <div class="premium-glass p-8 rounded-[32px]">
                    <div class="text-[10px] font-black uppercase tracking-widest text-[#00ED64] mb-2">Total Managed</div>
                    <div class="text-4xl font-black text-white"><%= courses.length %></div>
                </div>
                <div class="premium-glass p-8 rounded-[32px]">
                    <div class="text-[10px] font-black uppercase tracking-widest text-blue-400 mb-2">Total Lessons</div>
                    <div class="text-4xl font-black text-white"><%= courses.reduce((acc, c) => acc + (c.videos ? c.videos.length : 0), 0) %></div>
                </div>
                <div class="premium-glass p-8 rounded-[32px]">
                    <div class="text-[10px] font-black uppercase tracking-widest text-purple-400 mb-2">Active Students</div>
                    <div class="text-4xl font-black text-white"><%= courses.reduce((acc, c) => acc + (c.enrollments || 0), 0) %></div>
                </div>
                <div class="premium-glass p-8 rounded-[32px]">
                    <div class="text-[10px] font-black uppercase tracking-widest text-amber-400 mb-2">System Health</div>
                    <div class="text-4xl font-black text-white">99.9%</div>
                </div>
            </div>

            <!-- Management Console -->
            <div class="premium-glass rounded-[40px] overflow-hidden shadow-2xl">
                <div class="grid grid-cols-12 gap-6 p-8 bg-white/5 border-b border-white/5 text-[10px] font-black uppercase tracking-[0.2em] text-gray-500">
                    <div class="col-span-1">ID</div>
                    <div class="col-span-5">Curriculum Architecture</div>
                    <div class="col-span-2">Cluster</div>
                    <div class="col-span-2">Deployment Status</div>
                    <div class="col-span-2 text-right">Actions</div>
                </div>

                <div class="divide-y divide-white/5">
                    <% if (courses && courses.length > 0) { %>
                        <% courses.forEach((course, index) => { %>
                            <div class="grid grid-cols-12 gap-6 p-10 items-center course-row-atlas">
                                <div class="col-span-1 font-black text-white/20 text-sm">#<%= index + 1 %></div>
                                <div class="col-span-5 flex items-center gap-6">
                                    <div class="w-14 h-14 bg-gradient-to-br from-[#00ED64] to-[#00684A] rounded-2xl flex items-center justify-center text-[#001E2B] font-black text-xl shadow-lg">
                                        <%= (course.title || course.name || 'C').charAt(0).toUpperCase() %>
                                    </div>
                                    <div>
                                        <div class="text-xl font-black text-white mb-1 tracking-tight"><%= course.title || course.name %></div>
                                        <div class="text-[10px] font-bold text-gray-500 uppercase tracking-widest flex items-center gap-2">
                                            <i class="fas fa-layer-group text-[#00ED64]"></i>
                                            <%= course.videos ? course.videos.length : 0 %> Lessons Verified
                                        </div>
                                    </div>
                                </div>
                                <div class="col-span-2">
                                    <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[9px] font-black text-gray-400 uppercase tracking-widest">
                                        <%= course.category || 'CLOUD-ENG' %>
                                    </span>
                                </div>
                                <div class="col-span-2">
                                    <div class="flex items-center gap-3">
                                        <span class="w-2 h-2 rounded-full <%= course.isPublished !== false ? 'bg-[#00ED64] animate-pulse' : 'bg-amber-500' %>"></span>
                                        <span class="text-[10px] font-black uppercase tracking-widest <%= course.isPublished !== false ? 'text-[#00ED64]' : 'text-amber-500' %>">
                                            <%= course.isPublished !== false ? 'Production' : 'Sandbox' %>
                                        </span>
                                    </div>
                                </div>
                                <div class="col-span-2 flex justify-end gap-3">
                                    <a href="/teacher/course-editor/<%= encodeURIComponent(course._id || course.name) %>" class="btn-atlas-ghost w-12 h-12 rounded-xl flex items-center justify-center">
                                        <i class="fas fa-terminal text-xs"></i>
                                    </a>
                                    <button onclick="deleteCourse('<%= encodeURIComponent(course._id || course.name) %>')" class="btn-atlas-ghost w-12 h-12 rounded-xl flex items-center justify-center text-red-400 hover:bg-red-500/10 hover:border-red-500/20">
                                        <i class="fas fa-trash-alt text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="p-24 text-center">
                            <div class="w-24 h-24 bg-[#00ED64]/5 rounded-full flex items-center justify-center mx-auto mb-8 border border-[#00ED64]/10">
                                <i class="fas fa-satellite text-[#00ED64] text-4xl"></i>
                            </div>
                            <h2 class="text-3xl font-black text-white mb-4">No Curriculum Detected</h2>
                            <p class="text-gray-400 max-w-sm mx-auto mb-10 font-medium">Provision your first engineering module from the orchestrator header.</p>
                            <button onclick="showCreateModal()" class="btn-atlas-action px-10 py-4">Deploy First Section</button>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <!-- Modal Portal -->
    <div id="createModal" class="fixed inset-0 modal-blur hidden flex items-center justify-center z-[100] p-6">
        <div class="premium-glass w-full max-w-[540px] rounded-[40px] p-12 shadow-3xl animate-in zoom-in-95 duration-300">
            <div class="flex justify-between items-start mb-10">
                <div>
                    <h2 class="text-3xl font-black tracking-tighter text-white mb-2">New Architecture</h2>
                    <p class="text-gray-400 font-medium text-sm">Initialize a production-grade curriculum section.</p>
                </div>
                <button onclick="hideCreateModal()" class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center hover:bg-white/10 transition-colors">
                    <i class="fas fa-times text-gray-500"></i>
                </button>
            </div>

            <div class="space-y-8">
                <div>
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em] mb-3 ml-1">Title (Manifest ID)</label>
                    <input type="text" id="courseTitle" class="atlas-input w-full" placeholder="e.g. Distributed Consensus Algorithms">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em] mb-3 ml-1">Category Cluster</label>
                    <select id="courseCategory" class="atlas-input w-full appearance-none">
                        <option value="Cloud Computing">Cloud Computing</option>
                        <option value="DevOps">DevOps</option>
                        <option value="Architecture">Architecture</option>
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em] mb-3 ml-1">Technical Intent</label>
                    <textarea id="courseDescription" class="atlas-input w-full h-32 resize-none" placeholder="Primary learning objectives and infrastructure outcomes..."></textarea>
                </div>

                <div class="flex gap-4 pt-4">
                    <button onclick="hideCreateModal()" class="flex-1 py-4 font-black uppercase text-[10px] text-gray-500 tracking-widest hover:text-white transition-colors">Abort</button>
                    <button onclick="submitCreateCourse()" id="submitBtn" class="flex-[2] btn-atlas-action py-4 uppercase tracking-[0.2em] text-[10px]">Execute Deployment</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showCreateModal() {
            document.getElementById('createModal').classList.remove('hidden');
        }

        function hideCreateModal() {
            document.getElementById('createModal').classList.add('hidden');
        }

        async function submitCreateCourse() {
            const title = document.getElementById('courseTitle').value.trim();
            const category = document.getElementById('courseCategory').value;
            const description = document.getElementById('courseDescription').value.trim();
            
            if (!title) return;
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Deploying...';

            try {
                const response = await fetch('/api/courses', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title, name: title, category, description })
                });
                const data = await response.json();
                if (data.success) location.assign('/admin/course-manager');
                else alert('DEPLOYMENT ERROR: ' + data.message);
            } catch (error) { console.error(error); }
            finally { btn.disabled = false; btn.innerText = 'Execute Deployment'; }
        }

        async function deleteCourse(courseId) {
            if (!confirm('DECOMMISSION NODE? All synchronized data will be purged.')) return;
            try {
                const response = await fetch(`/api/teacher/courses/${courseId}`, { method: 'DELETE' });
                const data = await response.json();
                if (data.success) location.reload();
            } catch (error) { console.error(error); }
        }
    </script>
</body>
</html>