<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In — Multitouch Academy</title>
    <meta name="description" content="Sign in to your Multitouch Academy account to access your courses.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        body {
            min-height: 100vh;
            display: grid;
            place-items: center;
            background: var(--mdb-midnight);
            padding: 24px;
        }

        /* Subtle animated background */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 60% 50% at 20% 30%, rgba(0,237,100,.07) 0%, transparent 70%),
                radial-gradient(ellipse 50% 40% at 80% 70%, rgba(1,107,248,.06) 0%, transparent 70%);
            pointer-events: none;
        }

        .auth-card {
            width: 100%;
            max-width: 440px;
            background: #0D1B24;
            border: 1px solid rgba(0,237,100,.15);
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,.5), 0 0 0 1px rgba(0,237,100,.08);
            position: relative;
            z-index: 1;
        }

        /* Top brand strip */
        .auth-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 32px;
        }
        .auth-leaf {
            width: 32px; height: 32px;
            background: var(--mdb-green);
            border-radius: 50% 50% 50% 0 / 60% 60% 40% 40%;
            flex-shrink: 0;
            position: relative;
        }
        .auth-leaf::after {
            content: '';
            position: absolute;
            width: 2px; height: 16px;
            background: var(--mdb-midnight);
            bottom: 4px; left: 50%;
            transform: translateX(-50%);
            border-radius: 1px;
        }
        .auth-brand-name {
            font-size: 18px; font-weight: 700;
            color: #fff; letter-spacing: -.01em;
        }
        .auth-brand-name span { color: var(--mdb-green); }

        .auth-heading {
            font-size: 22px; font-weight: 600;
            color: #E8EDEB;
            margin-bottom: 4px;
        }
        .auth-sub {
            font-size: 13px;
            color: #5C6B74;
            margin-bottom: 28px;
        }

        /* Input group */
        .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
        .field label { font-size: 13px; font-weight: 500; color: #89989E; }
        .field input {
            padding: 10px 14px;
            background: #0F2336;
            border: 1px solid #1C3A52;
            border-radius: 6px;
            font-size: 14px;
            color: #E8EDEB;
            outline: none;
            transition: border-color .15s, box-shadow .15s;
        }
        .field input:focus {
            border-color: var(--mdb-green);
            box-shadow: 0 0 0 3px rgba(0,237,100,.18);
        }
        .field input::placeholder { color: #3D4F58; }

        /* CTA */
        .auth-submit {
            width: 100%;
            padding: 11px;
            margin-top: 4px;
            background: var(--mdb-green);
            color: var(--mdb-midnight);
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: background .15s, box-shadow .15s;
        }
        .auth-submit:hover { background: var(--mdb-green-dark); box-shadow: 0 2px 8px rgba(0,237,100,.3); }
        .auth-submit:disabled { opacity: .5; cursor: not-allowed; }

        /* Divider */
        .auth-divider {
            display: flex; align-items: center; gap: 12px;
            margin: 20px 0;
            color: #3D4F58; font-size: 12px;
        }
        .auth-divider::before, .auth-divider::after {
            content: ''; flex: 1; height: 1px; background: #1C3A52;
        }

        .auth-footer {
            text-align: center;
            font-size: 13px;
            color: #5C6B74;
            margin-top: 20px;
        }
        .auth-footer a { color: var(--mdb-green); font-weight: 500; }
        .auth-footer a:hover { text-decoration: underline; }

        /* Alert */
        .auth-alert {
            display: flex; align-items: flex-start; gap: 8px;
            padding: 10px 14px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 16px;
            border-left: 3px solid;
        }
        .auth-alert-error   { background: rgba(193,42,42,.12); color: #F56262; border-color: #C12A2A; }
        .auth-alert-success { background: rgba(0,237,100,.1);  color: var(--mdb-green); border-color: var(--mdb-green); }
        .auth-alert.hidden  { display: none; }

        /* Admin hint */
        .admin-hint {
            background: rgba(245,166,35,.07);
            border: 1px solid rgba(245,166,35,.2);
            border-radius: 6px;
            padding: 10px 14px;
            font-size: 12px;
            color: #B8860B;
            margin-bottom: 20px;
            text-align: center;
        }

        /* Forgot link */
        .forgot-link {
            font-size: 12px;
            color: var(--mdb-blue);
            float: right;
        }
        .forgot-link:hover { text-decoration: underline; }

        /* Spinner */
        .spinner {
            display: inline-block; width: 14px; height: 14px;
            border: 2px solid var(--mdb-midnight);
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin .8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="auth-card" role="main">
        <div class="auth-brand">
            <div class="auth-leaf" aria-hidden="true"></div>
            <div class="auth-brand-name">Learn<span>DB</span></div>
        </div>

        <h1 class="auth-heading">Welcome back</h1>
        <p class="auth-sub">Sign in to continue to your courses</p>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth-alert auth-alert-error" role="alert">⚠ <%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
        <div class="auth-alert auth-alert-success" role="alert">✓ <%= success %></div>
        <% } %>

        <div id="jsAlert" class="auth-alert hidden" role="alert" aria-live="assertive"></div>

        <form id="loginForm" novalidate>
            <div class="field">
                <label for="email">
                    Email address
                    <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                </label>
                <input type="email" id="email" name="email" autocomplete="email" required placeholder="you@example.com">
            </div>

            <div class="field">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" autocomplete="current-password" required placeholder="••••••••">
            </div>

            <button type="submit" id="loginBtn" class="auth-submit">
                Sign In
            </button>
        </form>

        <div class="auth-divider">or</div>

        <div class="admin-hint">
            🔑 <strong>Super Admin:</strong> engineerfelex@gmail.com
        </div>

        <div class="auth-footer">
            Don't have an account? <a href="/signup">Create one free</a>
        </div>
    </div>

    <script>
        // Dark mode init (always dark on auth pages — matches MongoDB Atlas)
        document.getElementById('html-root').classList.add('dark');

        async function handleLogin(e) {
            e.preventDefault();
            const email    = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const btn      = document.getElementById('loginBtn');
            const alert    = document.getElementById('jsAlert');

            // Reset alert
            alert.className = 'auth-alert hidden';
            alert.textContent = '';

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span> Signing in…';

            try {
                const res  = await fetch('/api/auth/signin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });
                const data = await res.json();

                if (data.success) {
                    localStorage.setItem('accessToken',  data.accessToken);
                    localStorage.setItem('refreshToken', data.refreshToken);
                    localStorage.setItem('idToken',      data.idToken);
                    localStorage.setItem('user',         JSON.stringify(data.user));
                    btn.innerHTML = '✓ Redirecting…';
                    btn.style.background = '#00A854';
                    setTimeout(() => window.location.href = data.redirect, 900);
                } else {
                    throw new Error(data.error || 'Invalid credentials');
                }
            } catch (err) {
                alert.className = 'auth-alert auth-alert-error';
                alert.textContent = '⚠ ' + err.message;
                btn.disabled = false;
                btn.textContent = 'Sign In';
            }
        }

        document.getElementById('loginForm').addEventListener('submit', handleLogin);
    </script>
</body>
</html>