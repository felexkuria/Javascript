<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mission Control - Platform Governance</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;400;700;900&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --atlas-green: #00ED64;
            --atlas-forest: #00684A;
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(0, 30, 43, 0.1);
        }

        .dark {
            --glass-bg: rgba(2, 52, 48, 0.3);
            --glass-border: rgba(0, 237, 100, 0.15);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: #F9FBFA;
            color: #001E2B;
            transition: all 0.3s ease;
        }

        .dark body {
            background-color: #001E2B;
            color: white;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
        }

        .tool-card-premium {
            border-radius: 32px;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            position: relative;
            overflow: hidden;
        }

        .tool-card-premium:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 30, 43, 0.1);
            border-color: var(--atlas-green);
        }

        .input-premium {
            width: 100%;
            padding: 14px 20px;
            border-radius: 16px;
            border: 1px solid var(--glass-border);
            background: rgba(255, 255, 255, 0.5);
            font-weight: 600;
            outline: none;
            transition: all 0.2s;
        }

        .dark .input-premium {
            background: rgba(0, 30, 43, 0.4);
            color: white;
        }

        .input-premium:focus {
            border-color: var(--atlas-green);
            box-shadow: 0 0 0 4px rgba(0, 237, 100, 0.1);
        }

        .btn-atlas {
            background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
            color: #001E2B;
            font-weight: 900;
            padding: 14px 32px;
            border-radius: 16px;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 12px;
        }

        .btn-atlas:hover {
            transform: scale(1.02);
            box-shadow: 0 8px 25px rgba(0, 237, 100, 0.3);
        }

        .status-pill {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .mono { font-family: 'JetBrains Mono', monospace; }
    </style>
</head>
<body class="dark">
    <!-- Navbar -->
    <nav class="fixed top-0 left-0 right-0 z-50 px-10 py-6 flex justify-between items-center premium-glass border-b border-white/5">
        <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-[#00ED64] rounded-xl flex items-center justify-center text-[#001E2B] shadow-lg shadow-[#00ED64]/20">
                <i class="fas fa-tower-broadcast"></i>
            </div>
            <span class="text-xl font-black tracking-tighter uppercase">Mission Control</span>
        </div>
        <div class="flex items-center gap-6">
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-[#00ED64] rounded-full animate-pulse"></span>
                <span class="text-[10px] font-black uppercase tracking-widest opacity-60">System Synchronized</span>
            </div>
            <button id="themeToggle" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 transition-all">🌙</button>
        </div>
    </nav>

    <main class="pt-32 pb-20 px-10">
        <div class="max-w-7xl mx-auto">
            <!-- Hero -->
            <div class="mb-16">
                <div class="flex items-center gap-3 mb-4">
                    <span class="px-3 py-1 bg-[#00ED64]/10 text-[#00ED64] text-[10px] font-black uppercase tracking-widest rounded-full border border-[#00ED64]/20">Infrastructure Orchestration</span>
                    <div class="h-px w-12 bg-white/10"></div>
                </div>
                <h1 class="text-6xl font-black tracking-tighter mb-4">Platform <span class="text-[#00ED64]">Governance</span></h1>
                <p class="text-gray-400 text-xl font-medium max-w-2xl leading-relaxed">Execute critical infrastructure migrations, ingest multi-source assets, and synthesize pedagogical resources.</p>
            </div>

            <!-- Dashboard Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- YouTube Ingest -->
                <div class="tool-card-premium premium-glass p-10 flex flex-col justify-between">
                    <div>
                        <div class="w-14 h-14 bg-red-500/10 rounded-2xl flex items-center justify-center text-red-500 mb-8 border border-red-500/20">
                            <i class="fab fa-youtube text-2xl"></i>
                        </div>
                        <h2 class="text-2xl font-black tracking-tight mb-4 text-white">Stream Ingestion</h2>
                        <p class="text-gray-400 text-sm font-medium mb-8 leading-relaxed">Provision entire YouTube manifests into the platform hierarchy. Orchestrate metadata synchronization at scale.</p>
                        
                        <div class="space-y-4 mb-8">
                            <input type="text" id="playlistId" placeholder="Manifest ID (Playlist)" class="input-premium">
                            <input type="text" id="courseName" placeholder="Resource Destination (Course)" class="input-premium">
                        </div>
                    </div>
                    <button id="importPlaylist" class="btn-atlas w-full">Synchronize Manifest</button>
                    <div id="importStatus" class="mt-4 hidden p-4 rounded-xl text-xs font-bold bg-white/5 border border-white/10"></div>
                </div>

                <!-- Exam Synthesis -->
                <div class="tool-card-premium premium-glass p-10 flex flex-col justify-between">
                    <div>
                        <div class="w-14 h-14 bg-purple-500/10 rounded-2xl flex items-center justify-center text-purple-400 mb-8 border border-purple-500/20">
                            <i class="fas fa-brain text-2xl"></i>
                        </div>
                        <h2 class="text-2xl font-black tracking-tight mb-4 text-white">Curriculum Synthesis</h2>
                        <p class="text-gray-400 text-sm font-medium mb-8 leading-relaxed">Synthesize high-fidelity practice assessments using generative neural networks. 65 questions per iteration.</p>
                        
                        <div class="space-y-4 mb-8">
                            <select id="examCourse" class="input-premium">
                                <option value="">Select Resource Node</option>
                            </select>
                        </div>
                    </div>
                    <button id="generateExam" class="btn-atlas w-full bg-none !bg-purple-600 !text-white hover:!bg-purple-500">Synthesize 65 Units</button>
                    <div id="examStatus" class="mt-4 hidden p-4 rounded-xl text-xs font-bold bg-white/5 border border-white/10"></div>
                </div>

                <!-- AWS Transcribe -->
                <div class="tool-card-premium premium-glass p-10 flex flex-col justify-between">
                    <div>
                        <div class="w-14 h-14 bg-orange-500/10 rounded-2xl flex items-center justify-center text-orange-400 mb-8 border border-orange-500/20">
                            <i class="fas fa-closed-captioning text-2xl"></i>
                        </div>
                        <h2 class="text-2xl font-black tracking-tight mb-4 text-white">Neural Transcription</h2>
                        <p class="text-gray-400 text-sm font-medium mb-8 leading-relaxed">Execute AWS Transcribe protocols for high-bandwidth video assets. Precision linguistic capture.</p>
                        
                        <div class="space-y-4 mb-8">
                            <div class="relative group cursor-pointer">
                                <input type="file" id="largeVideo" accept="video/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                <div class="px-6 py-4 rounded-2xl border-2 border-dashed border-white/10 group-hover:border-[#00ED64] transition-all text-center">
                                    <span id="fileNameDisplay" class="text-xs font-black text-gray-500 uppercase tracking-widest">Load Source Asset</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <button id="transcribeVideo" class="btn-atlas w-full bg-none !bg-orange-600 !text-white hover:!bg-orange-500">Initiate Capture</button>
                    <div id="transcribeStatus" class="mt-4 hidden p-4 rounded-xl text-xs font-bold bg-white/5 border border-white/10"></div>
                </div>

                <!-- DynamoDB Migration -->
                <div class="tool-card-premium premium-glass p-10 lg:col-span-3">
                    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-12">
                        <div class="max-w-xl">
                            <div class="w-14 h-14 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-400 mb-8 border border-blue-500/20">
                                <i class="fas fa-database text-2xl"></i>
                            </div>
                            <h2 class="text-2xl font-black tracking-tight mb-4 text-white">Data Architecture Migration</h2>
                            <p class="text-gray-400 text-sm font-medium leading-relaxed">Transition legacy course manifests into high-availability DynamoDB clusters. Execute atomic synchronization protocols across global availability zones.</p>
                        </div>
                        <div class="flex flex-col sm:flex-row gap-4 flex-shrink-0">
                            <button id="migrateToDynamo" class="btn-atlas !bg-blue-600 !text-white hover:!bg-blue-500 px-10 py-5">Initiate Migration</button>
                            <button id="syncDynamo" class="px-10 py-5 rounded-2xl border-2 border-[#00ED64] text-[#00ED64] font-black text-xs tracking-widest hover:bg-[#00ED64] hover:text-[#001E2B] transition-all">DATA SYNC</button>
                        </div>
                    </div>
                    <div id="migrationStatus" class="mt-8 hidden p-6 rounded-2xl text-xs font-black mono text-[#00ED64] bg-[#001E2B] border border-white/5"></div>
                </div>
            </div>
        </div>
    </main>

    <script>
        // UI Logic
        const themeToggle = document.getElementById('themeToggle');
        themeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark');
            themeToggle.textContent = document.body.classList.contains('dark') ? '☀️' : '🌙';
        });

        document.getElementById('largeVideo').addEventListener('change', (e) => {
            const fileName = e.target.files[0]?.name || 'Load Source Asset';
            document.getElementById('fileNameDisplay').textContent = fileName;
        });

        function showStatus(elementId, message, type) {
            const element = document.getElementById(elementId);
            element.textContent = `> ${message.toUpperCase()}`;
            element.classList.remove('hidden');
            element.style.color = type === 'success' ? '#00ED64' : (type === 'error' ? '#ff3b30' : '#E7EEEB');
        }

        // Functional Integration
        document.addEventListener('DOMContentLoaded', () => {
            fetch('/api/videos/localStorage')
                .then(r => r.json())
                .then(data => {
                    const select = document.getElementById('examCourse');
                    Object.keys(data).forEach(course => {
                        const opt = document.createElement('option');
                        opt.value = course;
                        opt.textContent = course.toUpperCase();
                        select.appendChild(opt);
                    });
                });

            document.getElementById('importPlaylist').addEventListener('click', async function() {
                const playlistId = document.getElementById('playlistId').value.trim();
                const courseName = document.getElementById('courseName').value.trim();
                if (!playlistId || !courseName) return showStatus('importStatus', 'Incomplete parameters', 'error');
                
                this.classList.add('opacity-50', 'cursor-not-allowed');
                showStatus('importStatus', 'Executing manifest ingest...', 'info');
                
                try {
                    const r = await fetch('/api/youtube/playlist', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ playlistId, courseName })
                    });
                    const d = await r.json();
                    if (d.success) showStatus('importStatus', `Success: ${d.videos.length} units ingested`, 'success');
                    else throw new Error(d.error);
                } catch (e) { showStatus('importStatus', `Failure: ${e.message}`, 'error'); }
                finally { this.classList.remove('opacity-50', 'cursor-not-allowed'); }
            });

            document.getElementById('generateExam').addEventListener('click', async function() {
                const courseName = document.getElementById('examCourse').value;
                if (!courseName) return showStatus('examStatus', 'Target not specified', 'error');
                
                this.classList.add('opacity-50', 'cursor-not-allowed');
                showStatus('examStatus', 'Initiating neural synthesis...', 'info');
                
                try {
                    const r = await fetch('/api/practice-exam/generate', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ courseName })
                    });
                    const d = await r.json();
                    if (d.questions) {
                        showStatus('examStatus', `Manifest generated: ${d.totalQuestions} items`, 'success');
                        const blob = new Blob([JSON.stringify(d.questions, null, 2)], { type: 'application/json' });
                        const url = URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.href = url;
                        a.download = `${courseName}-assessment.json`;
                        a.click();
                    } else throw new Error(d.error);
                } catch (e) { showStatus('examStatus', `Failure: ${e.message}`, 'error'); }
                finally { this.classList.remove('opacity-50', 'cursor-not-allowed'); }
            });

            document.getElementById('transcribeVideo').addEventListener('click', async function() {
                const file = document.getElementById('largeVideo').files[0];
                if (!file) return showStatus('transcribeStatus', 'Source asset missing', 'error');
                
                this.classList.add('opacity-50', 'cursor-not-allowed');
                showStatus('transcribeStatus', 'Orchestrating AWS Transcribe...', 'info');
                
                try {
                    const fd = new FormData();
                    fd.append('video', file);
                    fd.append('videoTitle', file.name.replace(/\.[^/.]+$/, ''));
                    const r = await fetch('/api/transcribe/large-video', { method: 'POST', body: fd });
                    const d = await r.json();
                    if (d.success) showStatus('transcribeStatus', 'Transcription manifest saved', 'success');
                    else throw new Error(d.error);
                } catch (e) { showStatus('transcribeStatus', `Protocols failed: ${e.message}`, 'error'); }
                finally { this.classList.remove('opacity-50', 'cursor-not-allowed'); }
            });

            document.getElementById('migrateToDynamo').addEventListener('click', async function() {
                this.classList.add('opacity-50', 'cursor-not-allowed');
                showStatus('migrationStatus', 'Cluster migration initiated...', 'info');
                try {
                    const r = await fetch('/api/migrate/dynamodb', { method: 'POST' });
                    const d = await r.json();
                    if (d.success) showStatus('migrationStatus', 'Migration complete. Cluster synchronized.', 'success');
                    else throw new Error(d.error);
                } catch (e) { showStatus('migrationStatus', `Critical failure: ${e.message}`, 'error'); }
                finally { this.classList.remove('opacity-50', 'cursor-not-allowed'); }
            });

            document.getElementById('syncDynamo').addEventListener('click', async function() {
                this.classList.add('opacity-50', 'cursor-not-allowed');
                showStatus('migrationStatus', 'Atomic data sync starting...', 'info');
                try {
                    const r = await fetch('/api/sync/dynamodb', { method: 'POST' });
                    const d = await r.json();
                    if (d.success) showStatus('migrationStatus', 'Manifests synchronized with global cluster.', 'success');
                    else throw new Error(d.error);
                } catch (e) { showStatus('migrationStatus', `Sync interrupted: ${e.message}`, 'error'); }
                finally { this.classList.remove('opacity-50', 'cursor-not-allowed'); }
            });
        });
    </script>
</body>
</html>