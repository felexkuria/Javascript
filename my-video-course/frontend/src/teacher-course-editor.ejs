<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Curriculum Architect - <%= course.title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <style>
        :root {
            --atlas-green: #00ED64;
            --atlas-forest: #00684A;
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(0, 30, 43, 0.1);
        }

        .dark {
            --glass-bg: rgba(2, 52, 48, 0.3);
            --glass-border: rgba(0, 237, 100, 0.15);
        }

        body {
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            box-shadow: 0 8px 32px rgba(0, 30, 43, 0.05);
        }

        /* ── Section & Lecture Cards ── */
        .curriculum-feed {
            max-width: 1000px;
            margin: 0 auto;
            position: relative;
        }

        .curriculum-feed::before {
            content: '';
            position: absolute;
            left: 36px;
            top: 100px;
            bottom: 50px;
            width: 2px;
            background: linear-gradient(to bottom, var(--atlas-green) 0%, transparent 100%);
            opacity: 0.2;
            z-index: 0;
        }

        .section-node {
            position: relative;
            z-index: 1;
            margin-bottom: 40px;
        }

        .section-header-premium {
            padding: 24px 32px;
            border-radius: 24px;
            cursor: move;
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        .section-header-premium:hover {
            border-color: var(--atlas-green);
            background: rgba(0, 237, 100, 0.05);
        }

        .lecture-card {
            margin-left: 60px;
            margin-top: 12px;
            padding: 16px 24px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.2s;
        }

        .lecture-card:hover {
            border-color: var(--atlas-green);
            transform: translateX(8px);
            background: rgba(0, 237, 100, 0.03);
        }

        /* ── Special Buttons ── */
        .btn-ghost-alt {
            border: 1px dashed var(--atlas-green);
            color: var(--atlas-green);
            padding: 8px 16px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 700;
            transition: all 0.2s;
        }

        .btn-ghost-alt:hover {
            background: rgba(0, 237, 100, 0.1);
            transform: scale(1.02);
        }

        .btn-add-section {
            width: 100%;
            padding: 24px;
            border-radius: 24px;
            border: 2px dashed var(--glass-border);
            color: var(--color-text-muted);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.3s;
        }

        .btn-add-section:hover {
            border-color: var(--atlas-green);
            color: var(--atlas-green);
            background: rgba(0, 237, 100, 0.02);
            box-shadow: 0 0 20px rgba(0, 237, 100, 0.1);
        }

        .publish-glow {
            position: relative;
            background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
            color: #001E2B;
            font-weight: 900;
            padding: 14px 32px;
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(0, 237, 100, 0.3);
            transition: all 0.3s;
        }

        .publish-glow:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 12px 32px rgba(0, 237, 100, 0.5);
        }

        .publish-glow:disabled {
            opacity: 0.5;
            filter: grayscale(1);
            cursor: default;
        }

        /* ── Progress & Status ── */
        .progress-micro {
            width: 100%;
            height: 4px;
            background: rgba(0, 30, 43, 0.05);
            border-radius: 2px;
            margin-top: 8px;
            overflow: hidden;
            display: none;
        }

        .dark .progress-micro { background: rgba(255, 255, 255, 0.05); }

        .progress-fill-neon {
            height: 100%;
            background: var(--atlas-green);
            box-shadow: 0 0 10px var(--atlas-green);
            transition: width 0.3s ease;
        }

        .status-badge {
            font-size: 10px;
            font-weight: 900;
            padding: 4px 10px;
            border-radius: 6px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .status-synced {
            background: rgba(0, 237, 100, 0.15);
            color: #00A35C;
        }

        .status-alert {
            background: rgba(255, 59, 48, 0.1);
            color: #ff3b30;
        }
    </style>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
    <div class="instructor-layout">
        <%- include('partials/instructor-sidebar', { activePage: 'curriculum' }) %>
        <main class="instructor-main flex-grow p-10 overflow-auto">
            <div class="curriculum-feed">
                <header class="flex justify-between items-end mb-16">
                    <div>
                        <div class="flex items-center gap-3 mb-4">
                            <span class="px-3 py-1 bg-[#00ED64]/10 text-[#00684A] dark:text-[#00ED64] text-[10px] font-black uppercase tracking-widest rounded-full border border-[#00ED64]/20">Architect Mode</span>
                            <div class="h-px w-12 bg-gray-200 dark:bg-white/10"></div>
                        </div>
                        <h1 id="course-title-display" class="text-5xl font-black tracking-tighter text-[#001E2B] dark:text-white mb-2 flex items-center gap-4">
                            <%= course.title %>
                            <button onclick="renameCourse()" class="text-gray-300 hover:text-[#00ED64] transition-colors">
                                <i class="fas fa-fingerprint text-xl"></i>
                            </button>
                        </h1>
                        <p class="text-gray-500 dark:text-gray-400 font-medium text-lg">Engineer the modular structure of your technical curriculum.</p>
                    </div>
                    <button class="publish-glow group" onclick="publishCourse()" <%= course.isPublished ? 'disabled' : '' %>>
                        <i class="fas fa-rocket mr-2 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"></i>
                        <%= course.isPublished ? 'Live in Production' : 'Deploy to Production' %>
                    </button>
                </header>

                <div id="sections-container">
                    <% if (course.sections && course.sections.length > 0) { %>
                        <% course.sections.forEach((section, sIdx) => { %>
                            <div class="section-node" data-section-id="<%= section._id %>" data-title="<%= section.title %>">
                                <div class="section-header-premium premium-glass flex justify-between items-center group">
                                    <div class="flex items-center gap-6">
                                        <div class="w-10 h-10 rounded-full border-2 border-[#00ED64]/30 flex items-center justify-center font-black text-[#00ED64] text-sm">
                                            <%= sIdx + 1 %>
                                        </div>
                                        <div>
                                            <h3 class="text-xl font-bold text-[#001E2B] dark:text-white leading-tight"><%= section.title %></h3>
                                            <p class="text-[11px] font-black uppercase tracking-widest text-[#00ED64]/50">Strategic Module</p>
                                        </div>
                                    </div>
                                    <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button class="w-10 h-10 rounded-xl hover:bg-[#00ED64]/10 text-gray-400 hover:text-[#00ED64] transition-all" onclick="editSection('<%= section._id %>', this.closest('.section-node').dataset.title)">
                                            <i class="fas fa-terminal"></i>
                                        </button>
                                        <button class="w-10 h-10 rounded-xl hover:bg-red-500/10 text-gray-400 hover:text-red-500 transition-all" onclick="deleteSection('<%= section._id %>')">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="lecture-feed mt-2">
                                    <% section.lectures.forEach((lecture, lIdx) => { %>
                                        <div class="lecture-card premium-glass" data-lecture-id="<%= lecture._id %>" data-title="<%= lecture.title %>">
                                            <i class="fas <%= lecture.s3Key && lecture.s3Key.endsWith('.pdf') ? 'fa-file-pdf text-[#ff3b30]' : 'fa-play-circle text-[#00ED64]' %> text-lg"></i>
                                            <div class="flex-grow">
                                                <div class="flex items-center gap-3">
                                                    <span class="text-sm font-bold text-[#001E2B] dark:text-white"><%= lecture.title %></span>
                                                    <button onclick="editLecture('<%= section._id %>', '<%= lecture._id %>', this.closest('.lecture-card').dataset.title)" class="text-gray-300 hover:text-[#00ED64] transition-colors">
                                                        <i class="fas fa-pen text-[10px]"></i>
                                                    </button>
                                                </div>
                                                <div class="progress-micro" id="progress-<%= lecture._id %>">
                                                    <div class="progress-fill-neon" style="width: 0%"></div>
                                                </div>
                                            </div>
                                            <div class="flex items-center gap-4">
                                                <% if (lecture.s3Key) { %>
                                                    <span class="status-badge status-synced border border-[#00ED64]/20">
                                                        <i class="fas fa-satellite-dish mr-1"></i> Synced
                                                    </span>
                                                <% } else { %>
                                                    <button class="btn-ghost-alt" onclick="triggerUpload('<%= section._id %>', '<%= lecture._id %>')">
                                                        <i class="fas fa-cloud-upload-alt mr-2"></i> Deploy Data
                                                    </button>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                    
                                    <!-- Action Row -->
                                    <div class="ml-[60px] mt-4 flex gap-4">
                                        <button class="btn-ghost-alt border-[#00ED64]/30" onclick="addLecture('<%= section._id %>')">
                                            <i class="fas fa-plus-circle mr-2"></i> Append Lecture
                                        </button>
                                        <button class="btn-ghost-alt border-[#00ED64]/30" onclick="triggerResourceUpload('<%= section._id %>')">
                                            <i class="fas fa-file-invoice mr-2"></i> Append Resource (PDF)
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="py-32 text-center premium-glass rounded-[40px] mb-12">
                            <div class="text-5xl mb-6">🛰️</div>
                            <h3 class="text-2xl font-black text-[#001E2B] dark:text-white mb-2">Awaiting Architecture</h3>
                            <p class="text-gray-500 dark:text-gray-400 max-w-sm mx-auto mb-8 font-medium">Start building your technical curriculum by initializing the first strategic module.</p>
                            <button class="btn-add-section max-w-xs" onclick="addSection()">Initialize Module</button>
                        </div>
                    <% } %>
                </div>

                <button class="btn-add-section mt-8 mb-20" onclick="addSection()">
                    <i class="fas fa-cubes mr-3"></i> Initialize Strategic Module
                </button>
            </div>
        </main>
    </div>

    <script>
        const courseId = '<%= encodeURIComponent(course._id) %>';

        async function publishCourse() {
            if (!confirm('Deploy this curriculum to production?')) return;
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/publish`, { method: 'PATCH' });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Deployment failed: ' + data.message);
                }
            } catch (e) { console.error(e); }
        }

        async function renameCourse() {
            const newTitle = prompt("Enter new curriculum designation:", "<%= course.title %>");
            if (!newTitle || newTitle === "<%= course.title %>") return;

            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/metadata`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title: newTitle })
                });
                const data = await res.json();
                if (data.success) location.reload();
            } catch (e) { console.error(e); }
        }

        async function addSection() {
            const title = prompt("Strategic Module Title:");
            if (!title) return;

            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                const data = await res.json();
                if (data.success) location.reload();
            } catch (e) { console.error(e); }
        }

        async function editSection(sectionId, currentTitle) {
            const title = prompt("Update Module Title:", currentTitle);
            if (!title) return;

            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${sectionId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                const data = await res.json();
                if (data.success) location.reload();
            } catch (e) { console.error(e); }
        }

        async function deleteSection(sectionId) {
            if (!confirm('Decommission this module and all associated sections?')) return;
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${sectionId}`, {
                    method: 'DELETE'
                });
                const data = await res.json();
                if (data.success) location.reload();
            } catch (e) { console.error(e); }
        }

        async function addLecture(sectionId) {
            const title = prompt("Lesson Title:");
            if (!title) return;

            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${sectionId}/lectures`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                const data = await res.json();
                if (data.success) location.reload();
            } catch (e) { console.error(e); }
        }

        async function editLecture(sectionId, lectureId, currentTitle) {
            const title = prompt("Update Lesson Title:", currentTitle);
            if (!title) return;

            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${sectionId}/lectures/${lectureId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                const data = await res.json();
                if (data.success) location.reload();
            } catch (e) { console.error(e); }
        }

        function triggerUpload(sectionId, lectureId) {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'video/*';
            input.onchange = async (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const formData = new FormData();
                const safeName = file.name.replace(/\s+/g, '_').replace(/[^a-zA-Z0-9._\-]/g, '');
                const sanitizedFile = new File([file], safeName, { type: file.type });
                
                formData.append('video', sanitizedFile);
                formData.append('sectionId', sectionId);

                performUpload(`/api/teacher/courses/${courseId}/lectures/${encodeURIComponent(lectureId)}/upload`, formData, lectureId);
            };
            input.click();
        }

        function triggerResourceUpload(sectionId) {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.pdf';
            input.onchange = async (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const formData = new FormData();
                const safeName = file.name.replace(/\s+/g, '_').replace(/[^a-zA-Z0-9._\-]/g, '');
                const sanitizedFile = new File([file], safeName, { type: file.type });
                
                formData.append('video', sanitizedFile);
                formData.append('sectionId', sectionId);
                formData.append('type', 'resource');

                performUpload(`/api/teacher/courses/${courseId}/upload`, formData, sectionId);
            };
            input.click();
        }

        function performUpload(url, formData, progressId) {
            const xhr = new XMLHttpRequest();
            const progressContainer = document.getElementById(`progress-${progressId}`);
            const progressBar = progressContainer?.querySelector('.progress-fill-neon');
            
            if (progressContainer) progressContainer.style.display = 'block';

            xhr.upload.onprogress = (e) => {
                if (e.lengthComputable) {
                    const percent = (e.loaded / e.total) * 100;
                    if (progressBar) progressBar.style.width = percent + '%';
                }
            };

            xhr.onload = function() {
                if (xhr.status >= 200 && xhr.status < 300) {
                    location.reload();
                } else {
                    const data = JSON.parse(xhr.responseText || '{"message":"Internal error"}');
                    alert('Sync error: ' + data.message);
                }
            };

            xhr.open('POST', url, true);
            xhr.send(formData);
        }

        function initSortable() {
            const container = document.getElementById('sections-container');
            if (!container) return;

            Sortable.create(container, {
                animation: 150,
                handle: '.section-header-premium',
                onEnd: async function(evt) {
                    const sectionIds = Array.from(container.querySelectorAll('.section-node'))
                                           .map(card => card.dataset.sectionId);
                    
                    try {
                        const res = await fetch(`/api/teacher/courses/${courseId}/reorder`, {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ sectionIds })
                        });
                        const data = await res.json();
                        if (!data.success) console.error('Failed to persist order');
                    } catch (e) { console.error(e); }
                }
            });
        }
        initSortable();
    </script>
</body>
</html>
