<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Curriculum - <%= course.title %> - Multitouch Academy</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .instructor-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            min-height: 100vh;
            background: var(--color-bg);
            font-family: 'Euclid Circular A', 'Inter', system-ui, sans-serif;
        }

        .instructor-sidebar {
            background: var(--mdb-midnight);
            color: #fff;
            padding: var(--space-6);
            display: flex;
            flex-direction: column;
            gap: var(--space-4);
            position: sticky;
            top: 0;
            height: 100vh;
            border-right: 1px solid rgba(255,255,255,0.05);
        }

        .sidebar-brand {
            font-size: 20px;
            font-weight: 800;
            color: var(--mdb-green);
            margin-bottom: var(--space-8);
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item {
            padding: var(--space-3) var(--space-4);
            border-radius: var(--radius-md);
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            font-weight: 500;
            transition: all var(--transition);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item:hover, .nav-item.active {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }

        .nav-item.active {
            color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.08);
        }

        .instructor-main {
            padding: var(--space-8);
            background: var(--color-bg);
            overflow-y: auto;
        }

        /* ── Curriculum Builder Styles ────────────────────────── */
        .curriculum-container {
            max-width: 900px;
            margin: 0 auto;
        }

        .section-card {
            background: var(--color-surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--color-border);
            margin-bottom: var(--space-6);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: all 0.2s ease;
        }

        .section-header {
            padding: var(--space-4) var(--space-6);
            background: var(--mdb-cloud-light);
            border-bottom: 1px solid var(--color-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: move;
        }

        .dark .section-header {
            background: rgba(255,255,255,0.03);
        }

        .lecture-list {
            padding: var(--space-4);
        }

        .lecture-item {
            display: flex;
            align-items: center;
            padding: var(--space-3) var(--space-4);
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            margin-bottom: var(--space-2);
            gap: var(--space-4);
        }

        .lecture-item:hover {
            border-color: var(--mdb-green);
        }

        .btn-upload {
            background: transparent;
            border: 1px dashed var(--mdb-green);
            color: var(--mdb-green);
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-upload:hover {
            background: rgba(0, 237, 100, 0.05);
        }

        .nav-leaf { font-size: 20px; }

        .btn-add {
            width: 100%;
            padding: var(--space-4);
            border: 2px dashed var(--color-border);
            background: transparent;
            color: var(--color-text-muted);
            font-weight: 600;
            border-radius: var(--radius-lg);
            cursor: pointer;
            transition: all 0.2s ease;
            margin-top: var(--space-4);
        }

        .btn-add:hover {
            border-color: var(--mdb-green);
            color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.02);
        }
    </style>
</head>
<body class="bg-[#F9FBFA] dark:bg-[#001E2B] transition-colors duration-200">
    <div class="instructor-layout">
        <%- include('partials/instructor-sidebar', { activePage: 'curriculum' }) %>
        <main class="instructor-main">
            <div class="curriculum-container">
                <header style="margin-bottom: var(--space-8); display: flex; justify-content: space-between; align-items: flex-end;">
                    <div>
                        <h1 style="font-size: 32px; font-weight: 700;">Curriculum Builder</h1>
                        <p style="color: var(--color-text-muted);">Build your course structure with sections and lectures.</p>
                    </div>
                    <div>
                        <button class="btn btn-primary" onclick="publishCourse()" <%= course.isPublished ? 'disabled' : '' %>>
                            <%= course.isPublished ? 'Published' : 'Publish Course' %>
                        </button>
                    </div>
                </header>

                <div id="sections-container">
                    <% if (course.sections && course.sections.length > 0) { %>
                        <% course.sections.forEach((section, sIdx) => { %>
                            <div class="section-card" data-section-id="<%= section._id %>">
                                <div class="section-header">
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <i class="fas fa-bars text-muted"></i>
                                        <strong style="font-size: 15px;">Section <%= sIdx + 1 %>: <%= section.title %></strong>
                                    </div>
                                    <div style="display: flex; gap: 12px;">
                                        <button class="btn-icon" onclick="deleteSection('<%= section._id %>')"><i class="fas fa-trash"></i></button>
                                    </div>
                                </div>
                                <div class="lecture-list">
                                    <% section.lectures.forEach((lecture, lIdx) => { %>
                                        <div class="lecture-item">
                                            <i class="fas fa-play-circle text-muted"></i>
                                            <div style="flex: 1;">
                                                <div style="font-weight: 600; font-size: 14px;"><%= lecture.title %></div>
                                            </div>
                                            <% if (!lecture.s3Key) { %>
                                                <button class="btn-upload" onclick="triggerUpload('<%= section._id %>', '<%= lecture._id %>')">
                                                    <i class="fas fa-upload"></i> Upload Video
                                                </button>
                                            <% } else { %>
                                                <span class="status-pill status-published" style="padding: 2px 8px;">Uploaded</span>
                                            <% } %>
                                        </div>
                                    <% }) %>
                                    <button class="btn-add" style="padding: 8px; border-style: dotted; margin-top: 8px;" onclick="addLecture('<%= section._id %>')">
                                        + Add Lecture
                                    </button>
                                    <button class="btn-add" style="padding: 8px; border-style: dotted; margin-top: 8px; border-color: #00684A; color: #00684A;" onclick="triggerResourceUpload('<%= section._id %>')">
                                        <i class="fas fa-file-pdf"></i> + Add Resource (PDF)
                                    </button>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div style="text-align: center; padding: var(--space-10); background: var(--color-surface); border: 2px dashed var(--color-border); border-radius: var(--radius-lg);">
                            <div style="font-size: 48px; margin-bottom: 16px; opacity: 0.3;">🗂️</div>
                            <h3>No Sections Yet</h3>
                            <p class="text-muted">Start by adding your first section to the course.</p>
                        </div>
                    <% } %>
                </div>

                <button class="btn-add" onclick="addSection()">
                    + Add New Section
                </button>
            </div>
        </main>
    </div>

    <script>
        const courseId = '<%= course._id %>';

        // Theme management
        function initTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        initTheme();

        async function addSection() {
            const title = prompt("Enter section title:");
            if (!title) return;

            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                const data = await res.json();
                if (data.success) window.location.reload();
            } catch (e) { alert(e.message); }
        }

        async function addLecture(sectionId) {
            const title = prompt("Enter lecture title:");
            if (!title) return;

            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${sectionId}/lectures`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                const data = await res.json();
                if (data.success) window.location.reload();
            } catch (e) { alert(e.message); }
        }

        async function triggerUpload(sectionId, lectureId) {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'video/*';
            input.onchange = async (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const formData = new FormData();
                // Sanitize file name for S3
                const safeName = file.name.replace(/\s+/g, '_').replace(/[^a-zA-Z0-9._\-]/g, '');
                const sanitizedFile = new File([file], safeName, { type: file.type });
                
                formData.append('video', sanitizedFile);
                formData.append('sectionId', sectionId);

                const btn = e.target.closest('.lecture-item')?.querySelector('.btn-upload');
                if (btn) {
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Uploading...';
                }

                try {
                    const res = await fetch(`/api/teacher/courses/${courseId}/lectures/${lectureId}/upload`, {
                        method: 'POST',
                        body: formData
                    });
                    const data = await res.json();
                    if (data.success) {
                        alert('Video uploaded successfully!');
                        window.location.reload();
                    } else {
                        alert('Upload failed: ' + data.message);
                    }
                } catch (err) {
                    alert('Upload error: ' + err.message);
                } finally {
                    if (btn) {
                        btn.disabled = false;
                        btn.innerHTML = '<i class="fas fa-upload"></i> Upload Video';
                    }
                }
            };
            input.click();
        }

        async function triggerResourceUpload(sectionId) {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.pdf';
            input.onchange = async (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const formData = new FormData();
                const safeName = file.name.replace(/\s+/g, '_').replace(/[^a-zA-Z0-9._\-]/g, '');
                const sanitizedFile = new File([file], safeName, { type: file.type });
                
                formData.append('video', sanitizedFile); // Backend expects 'video' field for now, but filter allows PDF
                formData.append('sectionId', sectionId);
                formData.append('type', 'resource');

                try {
                    const res = await fetch(`/api/teacher/courses/${courseId}/upload`, {
                        method: 'POST',
                        body: formData
                    });
                    const data = await res.json();
                    if (data.success) {
                        alert('Resource uploaded successfully!');
                        window.location.reload();
                    } else {
                        alert('Upload failed: ' + data.message);
                    }
                } catch (err) {
                    alert('Upload error: ' + err.message);
                }
            };
            input.click();
        }

        async function deleteSection(sectionId) {
            if (!confirm('Are you sure you want to delete this section and all its lectures?')) return;
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${sectionId}`, {
                    method: 'DELETE'
                });
                const data = await res.json();
                if (data.success) window.location.reload();
            } catch (e) { alert(e.message); }
        }
    </script>
</body>
</html>
