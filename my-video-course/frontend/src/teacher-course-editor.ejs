<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Curriculum Architect - <%= course.title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              'mdb-green': '#00ED64',
              'mdb-forest': '#00684A',
              'mdb-midnight': '#001E2B',
              'mdb-slate': '#023430',
            }
          }
        }
      }
    </script>
    <style>
        :root {
            --mdb-green: #00ED64;
            --mdb-midnight: #001E2B;
            --glass-bg: rgba(2, 52, 48, 0.4);
            --glass-border: rgba(0, 237, 100, 0.1);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--mdb-midnight);
            color: #E7EEEB;
            -webkit-font-smoothing: antialiased;
        }

        .premium-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
        }

        .curriculum-timeline::before {
            content: '';
            position: absolute;
            left: 36px;
            top: 20px;
            bottom: 20px;
            width: 2px;
            background: linear-gradient(to bottom, var(--mdb-green) 0%, transparent 100%);
            opacity: 0.15;
        }

        .section-box {
            position: relative;
            transition: all 0.4s cubic-bezier(0.2, 0, 0, 1);
        }

        .section-header-atlas {
            padding: 24px 32px;
            border-radius: 28px;
            cursor: move;
            transition: all 0.3s ease;
        }

        .section-header-atlas:hover {
            border-color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.05);
        }

        .lesson-card-atlas {
            margin-left: 64px;
            padding: 16px 24px;
            border-radius: 20px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .lesson-card-atlas:hover {
            border-color: var(--mdb-green);
            background: rgba(0, 237, 100, 0.03);
            transform: translateX(8px);
        }

        .btn-atlas-glow {
            background: linear-gradient(135deg, #00ED64 0%, #00684A 100%);
            color: #001E2B;
            font-weight: 800;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0, 237, 100, 0.2);
            transition: all 0.3s;
        }

        .btn-atlas-glow:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 12px 40px rgba(0, 237, 100, 0.4);
        }

        .btn-add-ghost {
            border: 1px dashed rgba(0, 237, 100, 0.3);
            color: #00ED64;
            padding: 12px 20px;
            border-radius: 14px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: all 0.3s;
        }

        .btn-add-ghost:hover {
            background: rgba(0, 237, 100, 0.1);
            border-style: solid;
        }

        .progress-micro-line {
            height: 3px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 99px;
            overflow: hidden;
            display: none;
        }

        .progress-flow-neon {
            height: 100%;
            background: #00ED64;
            box-shadow: 0 0 10px #00ED64;
        }
    </style>
</head>
<body class="dark overflow-x-hidden">
    <div class="flex">
        <!-- Sidebar -->
        <%- include('partials/instructor-sidebar', { activePage: 'curriculum' }) %>

        <main class="flex-grow p-10 lg:p-16">
            <div class="max-w-5xl mx-auto">
                <header class="flex flex-col md:flex-row justify-between items-end gap-12 mb-20">
                    <div>
                        <div class="flex items-center gap-4 mb-6">
                            <span class="px-4 py-1.5 bg-[#00ED64]/10 text-[#00ED64] text-[10px] font-black uppercase tracking-[0.3em] rounded-full border border-[#00ED64]/20">Architect Console</span>
                            <div class="h-px w-16 bg-white/5"></div>
                        </div>
                        <h1 class="text-6xl font-black tracking-tighter text-white mb-2 flex items-center gap-6">
                            <%= course.title %>
                            <button onclick="renameCourse()" class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center hover:bg-[#00ED64]/10 hover:text-[#00ED64] transition-all">
                                <i class="fas fa-edit text-xs"></i>
                            </button>
                        </h1>
                        <p class="text-gray-400 text-lg font-medium opacity-80">Design the strategic progression of your engineering curriculum.</p>
                    </div>
                    <button class="btn-atlas-glow px-10 py-5 uppercase tracking-[0.2em] text-xs flex items-center gap-3" 
                            onclick="publishCourse()" <%= course.isPublished ? 'disabled' : '' %>>
                        <i class="fas <%= course.isPublished ? 'fa-check-circle' : 'fa-rocket' %>"></i>
                        <%= course.isPublished ? 'Deployed to Production' : 'Deploy Curriculum' %>
                    </button>
                </header>

                <!-- Curriculum Construction Bay -->
                <div class="relative curriculum-timeline" id="sections-container">
                    <% if (course.sections && course.sections.length > 0) { %>
                        <% course.sections.forEach((section, sIdx) => { 
                            const secId = section._id || section.id || section.sectionId || ('sec-' + sIdx);
                        %>
                            <div class="section-box mb-12" data-section-id="<%= secId %>" data-title="<%= section.title %>">
                                <!-- Section Header -->
                                <div class="section-header-atlas premium-glass flex justify-between items-center group">
                                    <div class="flex items-center gap-8">
                                        <div class="w-12 h-12 rounded-2xl bg-[#001E2B] border border-[#00ED64]/30 flex items-center justify-center font-black text-[#00ED64] text-lg shadow-inner">
                                            <%= sIdx + 1 %>
                                        </div>
                                        <div>
                                            <h3 class="text-2xl font-black text-white tracking-tight"><%= section.title %></h3>
                                            <div class="text-[10px] font-black uppercase tracking-[0.2em] text-[#00ED64]/60 mt-1">Strategic Section Node</div>
                                        </div>
                                    </div>
                                    <div class="flex gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button onclick="editSection('<%= secId %>', '<%= section.title %>')" class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center hover:bg-[#00ED64]/10 hover:text-[#00ED64] transition-all">
                                            <i class="fas fa-terminal text-xs"></i>
                                        </button>
                                        <button onclick="deleteSection('<%= secId %>')" class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center hover:bg-red-500/10 hover:text-red-400 transition-all">
                                            <i class="fas fa-trash-alt text-xs"></i>
                                        </button>
                                    </div>
                                </div>

                                <!-- Lessons Feed -->
                                <div class="mt-6 space-y-4">
                                    <% section.lectures.forEach((lecture, lIdx) => { 
                                        const lecId = lecture._id || lecture.videoId || lecture.id || '';
                                    %>
                                        <div class="lesson-card-atlas premium-glass flex items-center gap-6 group" data-lecture-id="<%= lecId %>" data-title="<%= lecture.title %>">
                                            <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-[#00ED64]/60 group-hover:text-[#00ED64] transition-colors">
                                                <i class="fas <%= lecture.type === 'pdf' ? 'fa-file-pdf' : 'fa-play-circle' %>"></i>
                                            </div>
                                            <div class="flex-grow">
                                                <div class="flex items-center gap-4 mb-2">
                                                    <span class="text-base font-bold text-white/90 group-hover:text-white"><%= lecture.title %></span>
                                                    <button onclick="editLecture('<%= secId %>', '<%= lecId %>', '<%= lecture.title %>')" class="opacity-0 group-hover:opacity-100 transition-opacity text-gray-500 hover:text-[#00ED64]">
                                                        <i class="fas fa-pen text-[10px]"></i>
                                                    </button>
                                                </div>
                                                <div class="progress-micro-line" id="progress-<%= lecId %>">
                                                    <div class="progress-flow-neon w-0 h-full"></div>
                                                </div>
                                            </div>
                                            <div class="flex items-center gap-4" id="status-container-<%= lecId %>">
                                                <% if (lecture.s3Key || lecture.videoUrl) { %>
                                                    <div class="px-3 py-1.5 bg-[#00ED64]/10 border border-[#00ED64]/20 rounded-lg text-[9px] font-black text-[#00ED64] uppercase tracking-widest">
                                                        <i class="fas fa-check-circle mr-2"></i> Synced
                                                    </div>
                                                <% } else { %>
                                                    <button class="btn-add-ghost py-2 !text-[9px]" onclick="triggerUpload('<%= secId %>', '<%= lecId %>')">
                                                        <i class="fas fa-cloud-upload-alt mr-2"></i> Deploy Media
                                                    </button>
                                                <% } %>

                                            </div>
                                        </div>

                                    <% }) %>

                                    <!-- Action Interface -->
                                    <div class="ml-16 pt-4 flex gap-4">
                                        <button onclick="addLecture('<%= secId %>')" class="btn-add-ghost">
                                            <i class="fas fa-plus mr-2"></i> Append Lesson
                                        </button>
                                        <button onclick="triggerResourceUpload('<%= secId %>')" class="btn-add-ghost !border-blue-500/30 !text-blue-400 hover:!bg-blue-500/10">
                                            <i class="fas fa-file-pdf mr-2"></i> Append Resource
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="py-40 premium-glass rounded-[60px] border-dashed border-white/10 flex flex-col items-center justify-center text-center">
                            <div class="w-24 h-24 bg-[#00ED64]/5 rounded-full flex items-center justify-center mb-10 border border-[#00ED64]/10">
                                <i class="fas fa-project-diagram text-[#00ED64] text-4xl"></i>
                            </div>
                            <h2 class="text-4xl font-black text-white mb-6">Manifest Empty</h2>
                            <p class="text-gray-400 text-lg font-medium max-w-sm mx-auto mb-12">Initialize your first strategic curriculum section to begin the orchestration process.</p>
                            <button onclick="addSection()" class="btn-atlas-glow px-12 py-5 uppercase tracking-widest text-xs">Initialize First Section</button>
                        </div>
                    <% } %>
                </div>

                <div class="mt-16 mb-40 flex justify-center">
                    <button onclick="addSection()" class="w-full py-10 rounded-[40px] border-2 border-dashed border-white/5 hover:border-[#00ED64]/30 hover:bg-[#00ED64]/5 transition-all group">
                        <div class="flex flex-col items-center gap-4">
                            <div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center text-gray-600 group-hover:text-[#00ED64] group-hover:scale-110 transition-all">
                                <i class="fas fa-plus text-xl"></i>
                            </div>
                            <span class="text-xs font-black uppercase tracking-[0.4em] text-gray-500 group-hover:text-white">Initialize New Curriculum Section</span>
                        </div>
                    </button>
                </div>
            </div>
        </main>
    </div>

    <script>
        const courseId = '<%= encodeURIComponent(course.courseName || course.name || course.title) %>';

        // Core Orchestration Logic
        async function publishCourse() {
            if (!confirm('COMMIT ARCHITECTURE TO PRODUCTION?')) return;
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/publish`, { method: 'PATCH' });
                const data = await res.json();
                if (data.success) location.reload();
                else alert('DEPLOYMENT ERROR: ' + data.message);
            } catch (e) { console.error(e); }
        }

        async function renameCourse() {
            const title = prompt("New Designation:", "<%= course.title %>");
            if (!title || title === "<%= course.title %>") return;
            updateMetadata({ title });
        }

        async function addSection() {
            const title = prompt("Section Designation:");
            if (!title) return;
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                if ((await res.json()).success) location.reload();
            } catch (e) { console.error(e); }
        }

        async function editSection(id, old) {
            const title = prompt("Update Designation:", old);
            if (!title || title === old) return;
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                if ((await res.json()).success) location.reload();
            } catch (e) { console.error(e); }
        }

        async function deleteSection(id) {
            if (!confirm('DECOMMISSION SECTION? All lessons will be purged.')) return;
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${id}`, { method: 'DELETE' });
                if ((await res.json()).success) location.reload();
            } catch (e) { console.error(e); }
        }

        async function addLecture(sid) {
            const title = prompt("Lesson Designation:");
            if (!title) return;
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${sid}/lectures`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                if ((await res.json()).success) location.reload();
            } catch (e) { console.error(e); }
        }

        async function editLecture(sid, lid, old) {
            const title = prompt("Update Lesson Designation:", old);
            if (!title || title === old) return;
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/sections/${sid}/lectures/${lid}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });
                if ((await res.json()).success) location.reload();
            } catch (e) { console.error(e); }
        }

        function triggerUpload(sid, lid) {
            const card = document.querySelector(`.lesson-card-atlas[data-lecture-id="${lid}"]`);
            const title = card ? card.dataset.title : 'Legacy Lesson';
            
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'video/*,application/pdf';
            input.onchange = (e) => {
                const file = e.target.files[0];
                if (!file) return;
                performModernUpload(file, sid, lid, title);
            };
            input.click();
        }

        async function performModernUpload(file, sid, lid, title) {
            const progress = document.getElementById(`progress-${lid}`);
            const statusContainer = document.getElementById(`status-container-${lid}`);
            
            try {
                if (progress) progress.style.display = 'block';
                if (statusContainer) statusContainer.innerHTML = '<span class="text-[9px] font-black uppercase tracking-widest text-mdb-green animate-pulse">Syncing...</span>';

                // 1. Request Presigned URL (POST Protocol)
                const preRes = await fetch('/api/upload/request-presigned-url', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        courseName: decodeURIComponent(courseId),
                        videoTitle: title,
                        contentType: file.type || 'video/mp4'
                    })
                });

                if (!preRes.ok) throw new Error(`Signing Failed: HTTP ${preRes.status}`);
                const { url, key } = await preRes.json();
                if (!url) throw new Error('No secure upload link returned from server');

                // 2. Direct S3 Upload
                const xhr = new XMLHttpRequest();
                await new Promise((resolve, reject) => {
                    xhr.upload.onprogress = (e) => {
                        if (e.lengthComputable) {
                            const pct = (e.loaded / e.total) * 100;
                            if (progress) progress.querySelector('div').style.width = pct + '%';
                        }
                    };
                    xhr.onload = () => (xhr.status >= 200 && xhr.status < 300) ? resolve() : reject(new Error('Cloud Stream Interrupted'));
                    xhr.onerror = () => reject(new Error('Network Interruption'));
                    xhr.open('PUT', url, true);
                    xhr.setRequestHeader('Content-Type', file.type);
                    xhr.send(file);
                });

                // 3. Atomic Ingestion Sync
                const compRes = await fetch('/api/upload/complete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        courseName: decodeURIComponent(courseId),
                        videoTitle: title,
                        description: '',
                        s3Key: key,
                        sectionId: sid,
                        lectureId: lid
                    })
                });

                if (compRes.ok) {
                    if (statusContainer) {
                        statusContainer.innerHTML = `
                            <div class="px-3 py-1.5 bg-[#00ED64]/10 border border-[#00ED64]/20 rounded-lg text-[9px] font-black text-[#00ED64] uppercase tracking-widest">
                                <i class="fas fa-check-circle mr-2"></i> Synced
                            </div>`;
                    }
                    if (progress) progress.style.display = 'none';
                } else {
                    throw new Error('Curriculum sync failed');
                }

            } catch (err) {
                console.error('Upload Failure:', err);
                alert('INGESTION ERROR: ' + err.message);
                if (statusContainer) {
                    statusContainer.innerHTML = `
                        <button class="btn-add-ghost py-2 !text-[9px]" onclick="triggerUpload('${sid}', '${lid}', '${title.replace(/'/g, "\\'")}')">
                            <i class="fas fa-cloud-upload-alt mr-2"></i> Retry Deployment
                        </button>`;
                }
                if (progress) progress.style.display = 'none';
            }
        }

        function triggerResourceUpload(sid) {
            // Simplified: Add a placeholder lecture first, then trigger upload
            const title = prompt("Resource Title (PDF):");
            if (!title) return;
            
            fetch(`/api/teacher/courses/${courseId}/sections/${sid}/lectures`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title, type: 'pdf' })
            }).then(res => res.json()).then(data => {
                if (data.success) {
                    // Start upload immediately for the new slot
                    const lid = data.lecture._id;
                    location.reload(); // Quick reload to show the slot, then user can upload
                }
            });
        }


        async function updateMetadata(data) {
            try {
                const res = await fetch(`/api/teacher/courses/${courseId}/metadata`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if ((await res.json()).success) location.reload();
            } catch (e) { console.error(e); }
        }

        // Initialize UI Systems
        (function() {
            const container = document.getElementById('sections-container');
            if (container) {
                Sortable.create(container, {
                    animation: 150,
                    handle: '.section-header-atlas',
                    onEnd: async (evt) => {
                        const sids = Array.from(container.children).map(c => c.dataset.sectionId).filter(id => id);
                        await fetch(`/api/teacher/courses/${courseId}/reorder`, {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ sectionIds: sids })
                        });
                    }
                });
            }
        })();
    </script>
</body>
</html>
