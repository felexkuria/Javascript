<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Video Course Platform' %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            'inter': ['Inter', 'sans-serif'],
            'brand': ['Source Serif 4', 'serif']
          }
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/quiz-system.css">
  <script src="/js/theme-manager.js"></script>
  <% if (typeof extraStyles !== 'undefined') { %>
    <%- extraStyles %>
  <% } %>
</head>
<body class="bg-gray-50 dark:bg-[#001E2B] font-inter min-h-screen transition-colors text-gray-900 dark:text-[#E7EEEB]">
  <nav class="bg-white dark:bg-[#001E2B]/95 backdrop-blur-md border-b border-gray-200 dark:border-[#133A41] px-4 py-3 sticky top-0 z-50 transition-colors">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <div class="flex items-center gap-6">
        <a href="/" class="flex items-center gap-2 text-xl font-bold tracking-tight text-gray-900 dark:text-white transition-colors brand-font">
          <span class="text-[#00ED64]">🍃</span> MongoDB <span class="font-normal text-gray-400 dark:text-gray-500">Academy</span>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/" class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-[#00ED64] transition-colors border-b-2 border-transparent hover:border-[#00ED64] py-1">Dashboard</a>
          <a href="/profile" class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-[#00ED64] transition-colors border-b-2 border-transparent hover:border-[#00ED64] py-1">My Career Path</a>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <button id="theme-toggle" class="p-2 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors" title="Toggle theme">
          <i class="fas fa-moon"></i>
        </button>
        <div class="hidden sm:flex items-center gap-3 bg-gray-50 dark:bg-[#023430] rounded-full border border-transparent dark:border-[#00ED64]/20 px-4 py-1.5 transition-colors">
          <div class="w-6 h-6 bg-[#00ED64] rounded-full flex items-center justify-center text-[#001E2B] text-[10px] font-black user-level shadow-sm">1</div>
          <span class="text-sm font-semibold text-gray-900 dark:text-[#E7EEEB] user-points">0</span>
          <span class="text-sm">⚡</span>
          <span class="text-sm font-semibold text-gray-900 dark:text-[#E7EEEB] user-streak">0</span>
        </div>
        <button class="md:hidden p-2 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors">
          <i class="fas fa-bars"></i>
        </button>
      </div>
    </div>
  </nav>
  <div class="flex-1">